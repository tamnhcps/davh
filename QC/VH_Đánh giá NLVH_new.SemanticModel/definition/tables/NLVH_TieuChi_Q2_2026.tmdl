table NLVH_TieuChi_Q2_2026
	lineageTag: fb30d3ff-f195-4c7f-9025-e4b96bae893d

	measure 'NLVH Target' = ```
			
			VAR _key = SELECTEDVALUE(NLVH_TieuChi_Q2_2026[Key])
			VAR _shop = SELECTEDVALUE('DIM_Danh mục_Phòng ban'[Cửa hàng])
			VAR _zone = SELECTEDVALUE('adhoc_shop_zone_mappings'[zone])
			VAR _region = SELECTEDVALUE('DIM_Danh mục_Miền'[Miền])
			VAR _size = SELECTEDVALUE('DIM_Danh mục_Phòng ban'[Size])
			VAR _targetNghiViec =
			    SWITCH(
			        TRUE(),
			        _region = "Miền Nam" && _size = "S", 2.0,
			        _region = "Miền Nam" && _size IN { "A", "B" }, 1.5,
			        _region = "Miền Nam" && _size IN { "C", "D" }, 1.0,
			        _region = "Miền Bắc" && _size IN { "S", "A" }, 2.0,
			        _region = "Miền Bắc" && _size = "B", 1.5,
			        _region = "Miền Bắc" && _size IN { "C", "D" }, 1.0,
			        BLANK()
			    )
			VAR _targetLogistics =
			    SWITCH(
			        TRUE(),
			        _zone = "Zone 1", "2h ≤  15% | TT ≤ 15%",
			        _zone = "Zone 2", "2h ≤  15% | TT ≤ 20%",
			        _zone = "Zone 3", "TT ≤  20%",
			        "2h ≤ 15% | TT ≤  15%"
			    )
			RETURN
			SWITCH(
			    TRUE(),
			    _key = "ONLINE", "≥ 65%",
			    _key = "LOGISTICS", _targetLogistics,
			    _key = "AIOV2", "≥ 70%",
			    _key = "TKKD", "≥ 90%",
			    _key = "TAI_APP", IF(CONTAINSSTRING(_shop, "HCM") || CONTAINSSTRING(_shop, "HNO"), "≥ 50%", "≥ 55%"),
			    _key = "CODE", "Không vượt hạn mức",
			    _key = "NGHI_VIEC", "≤ " & FORMAT(_targetNghiViec, "0.0") & " nhân sự/quý",
			    _key = "NPS", "≥ 94%",
			    BLANK()
			)
			
			```
		lineageTag: 87698d02-e2ff-4d1b-a058-1eb823d18f3f

	measure 'Thực đạt' = ```
			
			VAR _key = SELECTEDVALUE(NLVH_TieuChi_Q2_2026[Key])
			VAR _actual2h = [% Thực đạt Trễ hạn_DH Giao 2 giờ]
			VAR _actualTT = [% Thực đạt Trễ hạn_DH Giao thông thường]
			VAR _codeVuot = [Số code vượt hạn mức (3 code)] VAR zone = SELECTEDVALUE(adhoc_shop_zone_mappings[zone])
			RETURN
			SWITCH(
			    TRUE(),
			    _key = "ONLINE" && NOT ISBLANK([% Thực đạt Online ra SP]), FORMAT([% Thực đạt Online ra SP], "0.00%"),
			    _key = "LOGISTICS",
			        VAR _text2h =
			        IF(
			            ISBLANK(_actual2h) && zone IN {"Zone 1", "Zone 2"},
			            "2h: 0%",
			            "2h: " & FORMAT(_actual2h, "0.00%")
			    )
			        VAR _textTT = IF(ISBLANK(_actualTT), BLANK(), "TT: " & FORMAT(_actualTT, "0.00%"))
			        RETURN
			            SWITCH(
			                TRUE(),
			                NOT ISBLANK(_text2h) && NOT ISBLANK(_textTT), _text2h & " | " & _textTT,
			                NOT ISBLANK(_text2h), _text2h,
			                NOT ISBLANK(_textTT), _textTT,
			                BLANK()
			            ),
			    _key = "AIOV2" && NOT ISBLANK([% Thực đạt Sử dụng AioV2]), FORMAT([% Thực đạt Sử dụng AioV2], "0.00%"),
			    _key = "TKKD" && NOT ISBLANK([NLVH Actual TKKD]), FORMAT([NLVH Actual TKKD], "0.00%"),
			    _key = "TAI_APP" && NOT ISBLANK([% Thực đạt Tải app]), FORMAT([% Thực đạt Tải app], "0.00%"),
			    _key = "CODE" && NOT ISBLANK(_codeVuot), "Vượt " & FORMAT(_codeVuot, "0") & "/3 code",
			    _key = "NGHI_VIEC" && NOT ISBLANK(SELECTEDVALUE('gsheet_chi_so_nghi_viec'[Thực đạt Chỉ số nghỉ việc])),
			        FORMAT(SELECTEDVALUE('gsheet_chi_so_nghi_viec'[Thực đạt Chỉ số nghỉ việc]), "0.00"),
			    _key = "NPS" && NOT ISBLANK([% Thực đạt NPS]), FORMAT([% Thực đạt NPS], "0.00%"),
			    BLANK()
			)
			
			```
		lineageTag: 242b4fe6-8c80-46ee-ad39-349869383403

	measure 'NLVH % Hoàn thành Logistics' = ```
			
			VAR _score2h = [% Hoàn thành Trễ DH_2h]
			VAR _scoreTT = [% Hoàn thành Trễ DH_TT]
			VAR _has2h = NOT ISBLANK(_score2h)
			VAR _hasTT = NOT ISBLANK(_scoreTT)
			RETURN
			SWITCH(
			    TRUE(),
			    _has2h && _hasTT, DIVIDE(_score2h + _scoreTT, 2),
			    _has2h, _score2h,
			    _hasTT, _scoreTT,
			    BLANK()
			)
			
			```
		lineageTag: a947f230-69aa-41f2-92fe-00a3a8a117b6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Hoàn thành' = ```
			
			VAR _key = SELECTEDVALUE(NLVH_TieuChi_Q2_2026[Key])
			RETURN
			SWITCH(
			    TRUE(),
			    _key = "ONLINE", [% Hoàn thành Online ra SP],
			    _key = "LOGISTICS", [NLVH % Hoàn thành Logistics],
			    _key = "AIOV2", [% Hoàn thành Sử dụng AIOv2],
			    _key = "TKKD", [% Hoàn thành TKKD],
			    _key = "TAI_APP", [% Hoàn thành Tải app],
			    _key = "CODE", [% Target hiệu quả sử dụng code (3 code)],
			    _key = "NGHI_VIEC", [% Hoàn thành Chỉ số nghỉ việc],
			    _key = "NPS", [% Hoàn Thành NPS],
			    BLANK()
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c00ea468-ad36-49b3-8e13-b5ba55f864d7

	measure 'Điểm trọng số' = ```
			
			VAR _score = [% Hoàn thành]
			VAR _weight = SELECTEDVALUE(NLVH_TieuChi_Q2_2026[Trọng số])
			RETURN
			IF(
			    ISBLANK(_score) || ISBLANK(_weight),
			    BLANK(),
			    _score * _weight
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: a889729b-7dda-46a2-876e-64d323e3a790

