	measure 'Tổng hệ số AM/SMKN' = ```
			
			SUMX(
			    FILTER(
			        VALUES('AM_SM_Current_Month'[SHOP]),
			        VAR _shop = 'AM_SM_Current_Month'[SHOP]
			        RETURN
			            CALCULATE(
			                [Dso],
			                TREATAS(
			                    { _shop },
			                    'DIM_Danh mục_Phòng ban'[Cửa hàng]
			                )
			            ) > 0
			    ),
			    VAR _shop = 'AM_SM_Current_Month'[SHOP]
			    RETURN
			        CALCULATE(
			            [Hệ số size Shop],
			            TREATAS(
			                { _shop },
			                'DIM_Danh mục_Phòng ban'[Cửa hàng]
			            )
			        )
			)
			
			```
		displayFolder: QLVH
		lineageTag: bcb2bb31-ce9f-4511-8129-3c6976a1bf71

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Trọng số đạt theo hệ số AM/SMKN' = ```
			
			SUMX(
			    FILTER(
			        VALUES('AM_SM_Current_Month'[SHOP]),
			        VAR _shop = 'AM_SM_Current_Month'[SHOP]
			        RETURN
			            CALCULATE(
			                [Dso],
			                TREATAS(
			                    { _shop },
			                    'DIM_Danh mục_Phòng ban'[Cửa hàng]
			                )
			            ) > 0
			    ),
			    VAR _shop = 'AM_SM_Current_Month'[SHOP]
			    VAR _score =
			        CALCULATE(
			            [% Đạt tỷ trọng tổng Shop],
			            TREATAS(
			                { _shop },
			                'DIM_Danh mục_Phòng ban'[Cửa hàng]
			            )
			        )
			    VAR _heSo =
			        CALCULATE(
			            [Hệ số size Shop],
			            TREATAS(
			                { _shop },
			                'DIM_Danh mục_Phòng ban'[Cửa hàng]
			            )
			        )
			    RETURN
			        _score * _heSo
			)
			
			```
		displayFolder: QLVH
		lineageTag: 6bb6fbb3-5c02-42ee-aed8-2a7e7bb634df

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Final Score AM/SMKN' = ```
			
			
			    DIVIDE(
			        [% Trọng số đạt theo hệ số AM/SMKN],
			        [Tổng hệ số AM/SMKN]
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: QLVH
		lineageTag: e97a1d4a-d80a-48b1-b4c6-12e1de40a6cd

	measure 'TB Tiêu chí đạt AM/SMKN' = ```
			
			round(DIVIDE(
			    SUMX(
			        FILTER(
			            VALUES('AM_SM_Current_Month'[SHOP]),
			            VAR _shop = 'AM_SM_Current_Month'[SHOP]
			            RETURN
			                CALCULATE(
			                    [Dso],
			                    TREATAS(
			                        { _shop },
			                        'DIM_Danh mục_Phòng ban'[Cửa hàng]
			                    )
			                ) > 0
			        ),
			        VAR _shop = 'AM_SM_Current_Month'[SHOP]
			        VAR _tieuChiDat =
			            CALCULATE(
			                [Tổng KPI Đạt Shop],
			                TREATAS(
			                    { _shop },
			                    'DIM_Danh mục_Phòng ban'[Cửa hàng]
			                )
			            )
			        VAR _heSo =
			            CALCULATE(
			                [Hệ số size Shop],
			                TREATAS(
			                    { _shop },
			                    'DIM_Danh mục_Phòng ban'[Cửa hàng]
			                )
			            )
			        RETURN
			            _tieuChiDat * _heSo
			    ),
			    [Số cửa hàng AM/SMKN]
			),0)
			
			```
		displayFolder: QLVH
		lineageTag: 2293719b-8b3f-46f8-ae80-75ada8129e32

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Đánh giá AM/SMKN' = ```
			
			VAR _score = [% Final Score AM/SMKN]
			VAR _tieuChi = [TB Tiêu chí đạt AM/SMKN]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(_score) || ISBLANK(_tieuChi), BLANK(),
			
			    _score >= 1 && _tieuChi >= 7, "Xuất sắc tuyệt đối",
			    _score >= 0.8 && _tieuChi >= 5, "Tốt",
			    _score >= 0.7 && _tieuChi >= 3, "Khá",
			    _score >= 0.5 && _tieuChi >= 2, "Kém",
			
			    "Cảnh báo"
			)
			
			```
		displayFolder: QLVH
		lineageTag: 9049a533-a4fb-4d74-9522-cae47f78ab8a

	measure 'Số shop theo từng đánh giá' =
			
			VAR _label = SELECTEDVALUE('DIM_Ghi chú_Đánh giá'[Xếp loại])
			RETURN
			CALCULATE(
			    DISTINCTCOUNT('DIM_Danh mục_Phòng ban'[Cửa hàng]),
			    FILTER(
			        ALL('DIM_Danh mục_Phòng ban'),
			        [Đánh giá SHOP] = _label
			    )
			)
		formatString: 0
		lineageTag: e84f2aed-ece8-4002-a801-2818b1a04b98

	measure so_shop_theo_danh_gia =
			
			SUMX(
			    VALUES('DIM_Danh mục_Phòng ban'[Cửa hàng]),
			    VAR _rating = [Đánh giá SHOP]
			    RETURN
			        IF(
			            _rating IN VALUES(Dim_DanhGia[Label]),
			            1,
			            0
			        )
			)
		lineageTag: 9a6d2d87-4143-4532-9746-47aaea907253

	column 'AM Fixed' = ```
			
			VAR _Shop = 'AM_SM_Current_Month'[SHOP]
			VAR _StartDate = 'AM_SM_Current_Month'[StartDate]
			RETURN
			CALCULATE(
			    SELECTEDVALUE('DIM_Danh mục_Shop_AM'[AM]),
			    REMOVEFILTERS('AM_SM_Current_Month'),
			    REMOVEFILTERS('FACT_Đánh giá Shop'),
			    REMOVEFILTERS('Kết quả đánh giá Shop'),
			    FILTER(
			        ALL('DIM_Danh mục_Shop_AM'),
			        'DIM_Danh mục_Shop_AM'[SHOP] = _Shop
			            && 'DIM_Danh mục_Shop_AM'[StartDate] = _StartDate
			    )
			)
			
			```
		lineageTag: e5fdb1f4-90d4-4dbc-b022-987d0abda543
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column MNV_SM = ```
			
			VAR _sm =
			    CALCULATE(
			        FIRSTNONBLANK('FACT_Đánh giá SM'[Ma_TenSM], 1),
			        FILTER(
			            'FACT_Đánh giá SM',
			            'FACT_Đánh giá SM'[SHOP] = EARLIER(AM_SM_Current_Month[SHOP])
			                && 'FACT_Đánh giá SM'[StartDate] = EARLIER(AM_SM_Current_Month[StartDate])
			                && 'FACT_Đánh giá SM'[SM/SUP] = EARLIER(AM_SM_Current_Month[SM/SUP])
			        )
			    )
			RETURN
			    IF(
			        ISBLANK(_sm),
			        AM_SM_Current_Month[SM/SUP],
			        _sm
			    )
			
			```
		lineageTag: b14898c5-c3bc-4b48-aff9-35c7bd5e5301
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

		annotation __PBI_SemanticLinks = [{"LinkTarget":{"TableName":"AM_SM_Current_Month","TableItemName":"MNV_SM (groups)","ObjectType":4},"LinkType":"UsedInGroup"}]

	column 'MNV_SM (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('AM_SM_Current_Month'[MNV_SM]),
				"(Blank)",
				'AM_SM_Current_Month'[MNV_SM] IN {"ĐOÀN MỸ DUYÊN",
