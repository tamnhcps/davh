	measure 'QLVH Đánh giá AM/SM/SUP' = ```
			
			VAR _score = [QLVH Score TB AM/SM/SUP]
			VAR _criteria = [QLVH Tiêu chí đạt TB AM/SM/SUP]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(_score), BLANK(),
			        _score >= 1 && _criteria >= 7, "Xuất sắc tuyệt đối",
			        _score >= 0.8 && _criteria >= 5, "Tốt",
			        _score >= 0.7 && _criteria >= 3, "Khá",
			        _score >= 0.5 && _criteria >= 2, "Kém",
			        "Cảnh cáo"
			    )
			
			```
		displayFolder: QLVH
		lineageTag: bdf8cbb2-a8aa-477a-8203-0c4aff778878

	measure 'Số cửa hàng AM/SMKN' = ```
			
			COUNTROWS(
			    FILTER(
			        VALUES('AM_SM_Current_Month'[SHOP]),
			        VAR _shop = 'AM_SM_Current_Month'[SHOP]
			        RETURN
			            CALCULATE(
			                [Dso],
			                TREATAS(
			                    { _shop },
			                    'DIM_Danh mục_Phòng ban'[Cửa hàng]
			                )
			            ) > 0
			    )
			)
			
			```
		formatString: 0
		displayFolder: QLVH
		lineageTag: 25c68b02-3579-4d74-a91b-023f1e832370

	measure '% Đạt tỷ trọng tổng Shop' = ```
			
			    0.20 * [% Hoàn thành Online ra SP]
