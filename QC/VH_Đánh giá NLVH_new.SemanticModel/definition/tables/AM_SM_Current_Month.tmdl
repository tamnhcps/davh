table AM_SM_Current_Month
	lineageTag: 039e78fe-fb38-48fe-87eb-c3d0ffb2caf3

	/// các chỉ tiêu VH
	measure '% Đạt tỷ trọng tổng' = ```
			
			SUMX(
			    ALL(NLVH_TieuChi_Q2_2026),
			    CALCULATE([Điểm trọng số])
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: QLVH
		lineageTag: 30aea503-e3d5-4fbc-88b3-d9166f1c5dbc

	measure 'Greater KPI Count' =
			
			VAR t =
			    {
			        [% Hoàn Thành NPS],
			        [% Hoàn thành Online ra SP],
			        [% Hoàn thành Sử dụng AIOv2], [% Hoàn thành TKKD], [% Hoàn thành Tải app]
			    }
			RETURN
			COUNTX(
			    t,
			    IF([Value] > 1, 1)
			)
		formatString: 0
		lineageTag: 1a78bd3b-8ae4-40b4-9bd9-923540107022

	measure 'KPI_Nghỉ việc' =
			
			VAR t =
			    {
			        [% Hoàn thành Chỉ số nghỉ việc]
			    }
			RETURN
			COUNTX(
			    t,
			    IF([Value] > 0, 1)
			)
		formatString: 0
		lineageTag: c2834e72-e127-492e-b551-929920e924b4

	measure 'Tổng KPI Đạt' = ```
			
			COUNTX(
			    FILTER(
			        ALL(NLVH_TieuChi_Q2_2026),
			        CALCULATE([% Hoàn thành]) >= 1
			    ),
			    NLVH_TieuChi_Q2_2026[Key]
			)
			
			```
		formatString: 0
		lineageTag: 8a6c5d4d-45dd-4bc8-9eaa-7232ab9c78f4

	measure 'Đánh giá SHOP' = ```
			
			VAR _score = [% Đạt tỷ trọng tổng]
			VAR _kpi = [Tổng KPI Đạt Shop]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(_score) || ISBLANK(_kpi), BLANK(),
			    _score >= 1 && _kpi >= 7, "Xuất sắc tuyệt đối",
			    _score >= 0.8 && _kpi >= 5, "Tốt",
			    _score >= 0.7 && _kpi >= 3, "Khá",
			    _score >= 0.5 && _kpi >= 2, "Kém",
			    "Cảnh báo"
			)
			
			```
		lineageTag: f3515555-f7de-4d5d-89da-7770fe9e9c38

	measure 'Hệ số size Shop' =
			
			VAR size =
			    UPPER(SELECTEDVALUE('DIM_Danh mục_Phòng ban'[Size]))
			RETURN
			SWITCH(
			    TRUE(),
			    size = "S", 1.5,
			    size = "A", 1.2,
			    size = "B", 1,
			    size IN {"C","D"}, 0.8,
			    BLANK()
			)
		lineageTag: f16a4838-84f4-4e96-a220-a9b8ba6fcb18

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// các chỉ tiêu VH
	measure '% Đạt tỷ trọng theo hệ số tổng' = [% Đạt tỷ trọng tổng] * [Hệ số size Shop]
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: QLVH
		lineageTag: e6876701-7dfd-4bde-8652-33b7e2318f06

	measure 'QLVH Số cửa hàng AM/SM/SUP' =
			
			DISTINCTCOUNT(AM_SM_Current_Month[SHOP])
		formatString: 0
		lineageTag: 64975935-8fd3-4d17-a703-7b42d3a396ed

	measure 'QLVH Score Shop' = ```
			
			VAR _score =
			    0.20 * [% Hoàn thành Online ra SP]
			    + 0.075 * [% Hoàn thành Trễ DH_2h]
			    + 0.075 * [% Hoàn thành Trễ DH_TT]
			    + 0.10 * [% Hoàn thành Sử dụng AIOv2]
			    + 0.10 * [% Hoàn thành TKKD]
			    + 0.15 * [% Hoàn thành Tải app]
			    + 0.10 * [% Target hiệu quả sử dụng code (3 code)]
			    + 0.10 * [% Hoàn thành Chỉ số nghỉ việc]
			    + 0.10 * [% Hoàn Thành NPS]
			RETURN
			_score
			
			```
		displayFolder: QLVH
		lineageTag: f9831881-8bf3-4355-93d6-59aa93d1f13c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'QLVH Tiêu chí đạt Shop' = ```
			
			VAR _online = IF([% Hoàn thành Online ra SP] >= 1, 1, 0)
			VAR _tre2h = IF([% Hoàn thành Trễ DH_2h] >= 1, 1, 0)
			VAR _trett = IF([% Hoàn thành Trễ DH_TT] >= 1, 1, 0)
			VAR _aio = IF([% Hoàn thành Sử dụng AIOv2] >= 1, 1, 0)
			VAR _tkkd = IF([% Hoàn thành TKKD] >= 1, 1, 0)
			VAR _app = IF([% Hoàn thành Tải app] >= 1, 1, 0)
			VAR _budget = IF([% Target hiệu quả sử dụng code (3 code)] >= 1, 1, 0)
			VAR _nghiviec = IF([%  Hoàn thành Chỉ số nghỉ việc_d] >= 1, 1, 0)
			VAR _nps = IF([% Hoàn Thành NPS] >= 1, 1, 0)
			RETURN
			_online + _tre2h + _trett + _aio + _tkkd + _app + _budget + _nghiviec + _nps
			
			```
		formatString: 0
		displayFolder: QLVH
		lineageTag: cea1b877-cb9f-4855-87d8-6c67d17c6eca

	measure 'QLVH Tiêu chí đạt TB AM/SM/SUP' =
			
			AVERAGEX(
			    VALUES(AM_SM_Current_Month[SHOP]),
			    VAR _shop = AM_SM_Current_Month[SHOP]
			    RETURN
			        CALCULATE(
			            [QLVH Tiêu chí đạt Shop],
			            TREATAS({_shop}, 'DIM_Danh mục_Phòng ban'[Cửa hàng])
			        )
			)
		displayFolder: QLVH
		lineageTag: cca1e808-2872-4493-abea-47df334dde71

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'QLVH Score TB AM/SM/SUP' = ```
			
			AVERAGEX(
			    VALUES(AM_SM_Current_Month[SHOP]),
			    VAR _shop = AM_SM_Current_Month[SHOP]
			    RETURN
			        CALCULATE(
			            [QLVH Score Shop],
			            TREATAS({_shop}, 'DIM_Danh mục_Phòng ban'[Cửa hàng])
