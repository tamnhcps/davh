	column SHOP
		lineageTag: 4459fa94-1973-4e84-8299-5cadbbb2fe35
		summarizeBy: none
		isNameInferred
		sourceColumn: FACT_Đánh giá SM[SHOP]

		annotation SummarizationSetBy = Automatic

	column StartDate
		formatString: General Date
		lineageTag: aa30581c-0aac-4fac-89e6-c49d2949ee1e
		summarizeBy: none
		isNameInferred
		sourceColumn: FACT_Đánh giá SM[StartDate]

		variation Variation
			isDefault
			relationship: ee73c359-1aec-4c75-a09c-af4b53bad508
			defaultHierarchy: LocalDateTable_8d608702-9c4e-42ae-90a6-4c661ad23256.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	partition AM_SM_Current_Month = calculated
		mode: import
		source =
				
				var _start = CALCULATE (
				    MAX ( 'DIM_Danh mục_Ngày'[Đầu tháng] ),
				    FILTER (
				        'DIM_Danh mục_Ngày',
				        'DIM_Danh mục_Ngày'[Ngày_IsActive] = 1
				    )
				)
				var SM =
				SUMMARIZE(FILTER('FACT_Đánh giá SM', 'FACT_Đánh giá SM'[MNV] <> BLANK() && NOT 'FACT_Đánh giá SM'[SHOP] IN {"CPS-HNO-DDA-B2B"} && 'FACT_Đánh giá SM'[StartDate] = _start), 'FACT_Đánh giá SM'[SM/SUP], 'FACT_Đánh giá SM'[SHOP], 'FACT_Đánh giá SM'[StartDate])
				var SMKN =
				SUMMARIZE(FILTER('DIM_Danh mục_Shop_SMKN', 'DIM_Danh mục_Shop_SMKN'[SMKN] <> BLANK() && 'DIM_Danh mục_Shop_SMKN'[StartDate] = MAX('DIM_Danh mục_Shop_SMKN'[StartDate])), 'DIM_Danh mục_Shop_SMKN'[SMKN], 'DIM_Danh mục_Shop_SMKN'[SHOP], 'DIM_Danh mục_Shop_SMKN'[StartDate])
				RETURN UNION(SM, SMKN)

	annotation PBI_Id = 09d4af87e57c44cd95801020055b52a8

