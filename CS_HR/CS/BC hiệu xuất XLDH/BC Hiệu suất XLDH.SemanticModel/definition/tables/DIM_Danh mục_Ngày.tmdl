	column Ngày_IsActive = ```
			
			    IF (
			        'DIM_Danh mục_Ngày'[Ngày]>= MIN ( 'FACT_Đơn hàng'[CreatedDate])
			            && 'DIM_Danh mục_Ngày'[Ngày] <= MAX ( 'FACT_Đơn hàng'[CreatedDate]),
			        1,
			        BLANK ()
			    )
			```
		formatString: 0
		lineageTag: ac253c6a-66e2-44ba-b8b6-ac6e2d4cffa1
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition 'DIM_Danh mục_Ngày' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform"]}[Data], "-- Source: cellphones-data-platform.cps_DA_General_Transform.dim_date#(lf)#(lf)SELECT#(lf)  d AS `Ngày`,#(lf)#(lf)  -- Năm / Quý / Tháng#(lf)  EXTRACT(YEAR FROM d) AS `Năm`,#(lf)  EXTRACT(QUARTER FROM d) AS `Quý`,#(lf)  FORMAT('Q%d/%d', EXTRACT(QUARTER FROM d), EXTRACT(YEAR FROM d)) AS `Nhãn_Quý_Năm`,#(lf)#(lf)  EXTRACT(MONTH FROM d) AS `Tháng`,#(lf)  FORMAT_DATE('%b', d) AS `Tên_Tháng_Ngắn`,#(lf)  FORMAT_DATE('%B', d) AS `Tên_Tháng_Dài`,#(lf)#(lf)  FORMAT_DATE('%Y-%m', d) AS `NămTháng`,#(lf)  EXTRACT(YEAR FROM d) * 100 + EXTRACT(MONTH FROM d) AS `NămTháng_Số`,#(lf)  FORMAT('T%d/%d', EXTRACT(MONTH FROM d), EXTRACT(YEAR FROM d)) AS `Nhãn_Tháng_Năm`,#(lf)#(lf)  DATE_TRUNC(d, MONTH) AS `Đầu_Tháng`,#(lf)  LAST_DAY(d, MONTH) AS `Cuối_Tháng`,#(lf)#(lf)  -- Ngày#(lf)  EXTRACT(DAY FROM d) AS `Ngày_Trong_Tháng`,#(lf)  EXTRACT(DAYOFYEAR FROM d) AS `Ngày_Trong_Năm`,#(lf)#(lf)  -- Thứ#(lf)  FORMAT_DATE('%a', d) AS `Tên_Thứ_Ngắn`,#(lf)  FORMAT_DATE('%A', d) AS `Tên_Thứ_Dài`,#(lf)#(lf)  MOD(EXTRACT(DAYOFWEEK FROM d) + 5, 7) + 1 AS `Thứ_Trong_Tuần`,#(lf)#(lf)  CASE EXTRACT(DAYOFWEEK FROM d)#(lf)    WHEN 1 THEN 'Chủ nhật'#(lf)    WHEN 2 THEN 'Thứ 2'#(lf)    WHEN 3 THEN 'Thứ 3'#(lf)    WHEN 4 THEN 'Thứ 4'#(lf)    WHEN 5 THEN 'Thứ 5'#(lf)    WHEN 6 THEN 'Thứ 6'#(lf)    WHEN 7 THEN 'Thứ 7'#(lf)  END AS `Tên_Thứ`,#(lf)#(lf)  EXTRACT(DAYOFWEEK FROM d) IN (1, 7) AS `Là_Cuối_Tuần`,#(lf)#(lf)  -- Tuần#(lf)  DATE_TRUNC(d, WEEK(MONDAY)) AS `Ngày_Đầu_Tuần`,#(lf)  DATE_ADD(DATE_TRUNC(d, WEEK(MONDAY)), INTERVAL 6 DAY) AS `Ngày_Cuối_Tuần`,#(lf)  EXTRACT(WEEK(MONDAY) FROM d) AS `Tuần_Trong_Năm`,#(lf)  FORMAT_DATE('%Y-%W', d) AS `Năm_Tuần`,#(lf)#(lf)  -- ISO week#(lf)  EXTRACT(ISOYEAR FROM d) AS `Năm_ISO`,#(lf)  EXTRACT(ISOWEEK FROM d) AS `Tuần_ISO`,#(lf)  FORMAT_DATE('%G-%V', d) AS `Năm_Tuần_ISO`,#(lf)#(lf)  -- Tuần trong tháng#(lf)  DIV(EXTRACT(DAY FROM d) - 1, 7) + 1 AS `Tuần_Trong_Tháng`,#(lf)#(lf)  -- Cờ thời gian động#(lf)  d = CURRENT_DATE('Asia/Ho_Chi_Minh') AS `Ngày_Hiện_Tại`,#(lf)  d < CURRENT_DATE('Asia/Ho_Chi_Minh') AS `Ngày_Quá_Khứ`,#(lf)  d > CURRENT_DATE('Asia/Ho_Chi_Minh') AS `Ngày_Tương_Lai`,#(lf)  DATE_TRUNC(d, MONTH) = DATE_TRUNC(CURRENT_DATE('Asia/Ho_Chi_Minh'), MONTH) AS `Tháng_Hiện_Tại`,#(lf)  DATE_TRUNC(d, YEAR) = DATE_TRUNC(CURRENT_DATE('Asia/Ho_Chi_Minh'), YEAR) AS `Năm_Hiện_Tại`,#(lf)#(lf)  -- Index tháng#(lf)  DENSE_RANK() OVER (#(lf)    ORDER BY EXTRACT(YEAR FROM d) * 100 + EXTRACT(MONTH FROM d)#(lf)  ) AS `Index_NămTháng`#(lf)#(lf)FROM (#(lf)  SELECT DATE(`date`) AS d#(lf)  FROM `cellphones-data-platform.cps_DA_General_Transform.dim_date`#(lf))#(lf)ORDER BY `Ngày`", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

