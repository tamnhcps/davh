	partition FACT_XLDH_CDR = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform."]}[Data], "---""dataset_id=a917b480-5ef3-491e-98f5-45fa8594b4e5""#(lf)#(lf)WITH line_cdr AS (#(lf)  SELECT 'VÕ KIM LIÊN' AS ten_nhan_vien, '1111' AS line UNION ALL#(lf)  SELECT 'VÕ THỊ CẨM NHUNG', '1113' UNION ALL#(lf)  SELECT 'NGUYỄN HOÀNG BÍCH TÂM', '1711' UNION ALL#(lf)  SELECT 'CHẠC HÁN CHẦU', '1115' UNION ALL#(lf)  SELECT 'DANH THỊ CHANH THI', '1220'#(lf)),#(lf)#(lf)cdr AS (#(lf)  SELECT#(lf)    DATE(date) AS `Date`,#(lf)    TIME(date) AS Time,#(lf)    time AS Duration,#(lf)    CAST(SOURCE AS STRING) AS SOURCE,#(lf)    CAST(destination AS STRING) AS Destination,#(lf)    status AS Status,#(lf)    DATETIME(date) AS Call_Date,#(lf)    EXTRACT(HOUR FROM date) AS Hour,#(lf)    EXTRACT(DAY FROM date) AS Day,#(lf)    '' AS Src_Channel,#(lf)    '' AS Dst_Channel,#(lf)    type AS TypeS,#(lf)    EXTRACT(MONTH FROM date) AS Month#(lf)  FROM#(lf)    `cellphones-data-platform.cps_cloudteam_dwh.cloud_team_cdr_report`#(lf)  WHERE#(lf)    DATE(date) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 3 MONTH), MONTH)#(lf))#(lf)#(lf)SELECT#(lf)  cdr.Date,#(lf)  cdr.Time,#(lf)  cdr.Duration,#(lf)  cdr.SOURCE,#(lf)  cdr.Destination,#(lf)  cdr.Status,#(lf)  cdr.Call_Date,#(lf)  cdr.Hour,#(lf)  cdr.Day,#(lf)#(lf)  COALESCE(src.ten_nhan_vien, dst.ten_nhan_vien) AS `Tên nhân viên`,#(lf)  COALESCE(src.line, dst.line) AS `Line`,#(lf)#(lf)  cdr.TypeS,#(lf)  cdr.Month#(lf)#(lf)FROM cdr#(lf)#(lf)LEFT JOIN line_cdr src#(lf)  ON cdr.SOURCE = src.line#(lf)#(lf)LEFT JOIN line_cdr dst#(lf)  ON cdr.Destination = dst.line#(lf)#(lf)WHERE#(lf)  src.line IS NOT NULL#(lf)  OR dst.line IS NOT NULL#(lf)#(lf)ORDER BY#(lf)  cdr.Date DESC,#(lf)  cdr.Time DESC", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

