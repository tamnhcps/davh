role 'Vận hành_Cửa hàng'
	modelPermission: read

	tablePermission 'DIM_Phân quyền_Vận hành' = ```
			IF( 
			LOOKUPVALUE('DIM_Phân quyền_User'[Title],'DIM_Phân quyền_User'[Mail] ,USERPRINCIPALNAME()) = "SHOP", 
			[Bộ phận] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('DIM_Phân quyền_Vận hành','DIM_Phân quyền_Vận hành'[Bộ phận] = LOOKUPVALUE('DIM_Phân quyền_User'[Tên],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())),'DIM_Phân quyền_User'),
			                        "Path leader", PATHCONTAINS('DIM_Phân quyền_User'[Path],'DIM_Phân quyền_Vận hành'[Bộ phận])),[Path leader]),"Cửa hàng",'DIM_Phân quyền_User'[Tên]))
			,True)
			```

	annotation PBI_Id = d988acf153454e8288a01648a184874b

