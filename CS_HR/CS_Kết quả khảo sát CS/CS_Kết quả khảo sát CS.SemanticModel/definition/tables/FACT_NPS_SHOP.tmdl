	column 'Số phiếu Hài lòng_HaveTicket' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Cửa hàng] = EARLIER(FACT_NPS_SHOP[Văn phòng])
			        && FACT_TFEX_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_SHOP[Năm/Tháng])        
			        && FACT_TFEX_TICKET[Kết luận] IN {"Hài lòng", "Khen ngợi"}
			    )
			)
			```
		lineageTag: 300a0c95-ecbb-4c7f-a1ee-f8cb0678ee38
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Hài lòng' = FACT_NPS_SHOP[Số phiếu Hài lòng_NoTicket] + FACT_NPS_SHOP[Số phiếu Hài lòng_HaveTicket]
