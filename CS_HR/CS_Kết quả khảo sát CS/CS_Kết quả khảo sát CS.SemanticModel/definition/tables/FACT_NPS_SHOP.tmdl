	column '%Hài lòng' = DIVIDE(FACT_NPS_SHOP[Số phiếu Hài lòng],FACT_NPS_SHOP[Tổng khảo sát],BLANK())
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d9170919-2fee-4db3-81e6-c479aced7314
		summarizeBy: sum

