	partition FACT_NPS_SHOP = calculated
		mode: import
		source = ```
				
				CALCULATETABLE(
				        SUMMARIZE(
				            'FACT_Công_ChiTiet',
				            'FACT_Công_ChiTiet'[Văn phòng],
				            'FACT_Công_ChiTiet'[Năm/Tháng],
				            'FACT_Công_ChiTiet'[StartDate]
				        ),
				        FILTER(
				            'FACT_Công_ChiTiet',
				            NOT 'FACT_Công_ChiTiet'[Văn phòng] IN {"CPS-HNO-DDA-B2B", "CPS-HCM-SHOPONLINE", "CPS-HNO-DDA-ON98TH"} 
				            && ('FACT_Công_ChiTiet'[Chức danh] = "Trưởng cửa hàng"
				                || 'FACT_Công_ChiTiet'[Chức danh] = "Trợ lý cửa hàng")
				            && 'FACT_Công_ChiTiet'[Startshop] >15
				        ))
				```

	annotation PBI_Id = 14591b6abf9941f5891a36620a758202

