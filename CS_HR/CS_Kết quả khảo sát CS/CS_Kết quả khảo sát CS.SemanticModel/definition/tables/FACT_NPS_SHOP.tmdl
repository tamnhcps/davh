	column 'Tổng khảo sát' = FACT_NPS_SHOP[Số phiếu Hài lòng]+FACT_NPS_SHOP[Số phiếu Bình thường]+FACT_NPS_SHOP[Số phiếu Không hài lòng]+FACT_NPS_SHOP[Số phiếu Vi phạm_HaveTicket]+FACT_NPS_SHOP[Số phiếu Nhắc nhở_HaveTicket]
