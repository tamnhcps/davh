	column 'Số phiếu Hài lòng_NoTicket' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_SHOP[Cửa hàng])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_SHOP[Năm/Tháng])
			        && FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"}
			            && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			)
			```
		formatString: 0
		lineageTag: cb9eedb4-2633-4ce1-94a2-559a98b6fc64
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Cửa hàng' = RELATED('DIM_Danh mục_Phòng ban'[HaraID])
