	column 'Mã-Tên nhân viên' = FACT_NPS_NV[Mã nhân viên]&"-"&FACT_NPS_NV[Tên nhân viên]
		lineageTag: 47f17dbc-c708-4c8b-a359-38017c8b456d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column HaraID_NV =
			
			RELATED( 'DIM_Danh mục_Nhân viên'[Mã nhân viên Harawork] )
		dataType: string
		lineageTag: 24425e08-bba3-4502-8ebd-e8c88545c382
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Hài lòng_NoTicket' = ```
			
			var NV = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && CONTAINSSTRING(FACT_NPS_TICKET[HaraID_NV], EARLIER(FACT_NPS_NV[HaraID_NV]))
			        && FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"}
			            && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			)
			var AM = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"}
			            && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			)
			RETURN IF(FACT_NPS_NV[isSMKN] = 1,AM,NV)
			```
		formatString: 0
		lineageTag: 7e0da851-672b-46fc-bbaa-9cf641917ffa
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column HaraID_Shop = LOOKUPVALUE('DIM_Danh mục_Phòng ban'[HaraID],'DIM_Danh mục_Phòng ban'[Bộ phận],FACT_NPS_NV[Cửa hàng])
		lineageTag: ee761768-00ed-439e-adbb-7bb26a531f02
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Miền = LOOKUPVALUE('DIM_Danh mục_Phòng ban'[Miền],'DIM_Danh mục_Phòng ban'[Bộ phận],FACT_NPS_NV[Cửa hàng])
		lineageTag: 7d35cd39-ffbe-46ed-ac3e-ee21e0594d29
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Hài lòng_HaveTicket' = ```
			
			VAR NV = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[Cửa hàng])
			        && FACT_TFEX_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && CONTAINSSTRING(FACT_TFEX_TICKET[Nhân viên liên quan khảo sát], EARLIER(FACT_NPS_NV[HaraID_NV]))
			        && FACT_TFEX_TICKET[Kết luận] IN {"Hài lòng", "Khen ngợi"}
			    )
			)
			var AM = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[Cửa hàng])
			        && FACT_TFEX_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_TFEX_TICKET[Kết luận] IN {"Hài lòng", "Khen ngợi"}
			    )
			)
			RETURN IF(FACT_NPS_NV[isSMKN] = 1,AM,NV)
			```
		formatString: 0
		lineageTag: 3928ef51-beed-40d6-bd32-7c7d0a111eb1
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Hài lòng' = IF(FIND("tiếp đón",LOWER(FACT_NPS_NV[Chức danh]),1,Blank())= BLANK(), FACT_NPS_NV[Số phiếu Hài lòng_NoTicket] + FACT_NPS_NV[Số phiếu Hài lòng_HaveTicket],FACT_NPS_NV[Số phiếu Hài lòng_Tiếp đón])
		formatString: #,0
		lineageTag: 29f63b35-a7a1-469f-a3b2-819331ca6f23
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Bình thường' =
			
			VAR NV =
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && CONTAINSSTRING(FACT_NPS_TICKET[HaraID_NV], EARLIER(FACT_NPS_NV[HaraID_NV]))
			        && FACT_NPS_TICKET[Kết quả khảo sát] = "Bình thường"
			            && (FACT_NPS_TICKET[NV_Câu 5] = BLANK()
			            || FACT_NPS_TICKET[NV_Câu 5] = "None")
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			)
			VAR AM =
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_NPS_TICKET[Kết quả khảo sát] = "Bình thường"
			            && (FACT_NPS_TICKET[NV_Câu 5] = BLANK()
			            || FACT_NPS_TICKET[NV_Câu 5] = "None")
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			)
			RETURN
			 IF(FACT_NPS_NV[isSMKN] = 1,AM,
			    IF(FIND("tiếp đón",LOWER(FACT_NPS_NV[Chức danh]),1,BLANK())= BLANK(), NV,FACT_NPS_NV[Số phiếu Bình thường_Tiếp đón]))
		formatString: #,0
		lineageTag: 03949238-b4d8-47d5-a34f-d628e7679c0d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Không hài lòng' =
			
			VAR NV =
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && CONTAINSSTRING(FACT_NPS_TICKET[HaraID_NV], EARLIER(FACT_NPS_NV[HaraID_NV]))
			        && FACT_NPS_TICKET[Kết quả khảo sát] = "Không hài lòng"
			            && (FACT_NPS_TICKET[NV_Câu 5] = BLANK()
			            || FACT_NPS_TICKET[NV_Câu 5] = "None")
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			        && FACT_NPS_TICKET[Có liên hệ được] = TRUE()
			    )
			)
			VAR AM =
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_NPS_TICKET[Kết quả khảo sát] = "Không hài lòng"
			            && (FACT_NPS_TICKET[NV_Câu 5] = BLANK()
			            || FACT_NPS_TICKET[NV_Câu 5] = "None")
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			        && FACT_NPS_TICKET[Có liên hệ được] = TRUE()
			    )
			)
			RETURN
			 IF(FACT_NPS_NV[isSMKN] = 1,AM,
			    IF(FIND("tiếp đón",LOWER(FACT_NPS_NV[Chức danh]),1,BLANK())= BLANK(), NV,FACT_NPS_NV[Số phiếu Không hài lòng_Tiếp đón]))
		formatString: 0
		lineageTag: ee8c1625-a51b-46a3-823e-c1122c48713f
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Vi phạm_HaveTicket' = ```
			
			VAR NV = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[Cửa hàng])
			        && FACT_TFEX_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && CONTAINSSTRING(FACT_TFEX_TICKET[Nhân viên liên quan], EARLIER(FACT_NPS_NV[Mã-Tên nhân viên]))
			        && FACT_TFEX_TICKET[Kết luận] = "Có vi phạm"
			    )
			)
			VAR AM = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[Cửa hàng])
			        && FACT_TFEX_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_TFEX_TICKET[Kết luận] = "Có vi phạm"
			    )
			)
			RETURN
			 IF(FACT_NPS_NV[isSMKN] = 1,AM,NV)
			```
		formatString: 0
		lineageTag: 09c0bdce-c0a4-44b6-9f21-e1670b5489e2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Nhắc nhở_HaveTicket' = ```
			
			VAR NV = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[Cửa hàng])
			        && FACT_TFEX_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && CONTAINSSTRING(FACT_TFEX_TICKET[Nhân viên liên quan], EARLIER(FACT_NPS_NV[Mã-Tên nhân viên]))
			        && FACT_TFEX_TICKET[Kết luận] = "Nhắc nhở"
			        && FACT_TFEX_TICKET[Nguồn] <> "Khảo sát"
			    )
			)
			VAR AM = 
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[Cửa hàng])
			        && FACT_TFEX_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_TFEX_TICKET[Kết luận] = "Nhắc nhở"
			        && FACT_TFEX_TICKET[Nguồn] <> "Khảo sát"
			    )
			)
			RETURN
			 IF(FACT_NPS_NV[isSMKN] = 1,AM,NV)
			```
		formatString: 0
		lineageTag: dc5735b1-158a-4986-a0cc-de455c740251
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Tổng khảo sát' =
			FACT_NPS_NV[Số phiếu Hài lòng] + FACT_NPS_NV[Số phiếu Bình thường] + FACT_NPS_NV[Số phiếu Không hài lòng] + FACT_NPS_NV[Số phiếu Vi phạm_HaveTicket] + FACT_NPS_NV[Số phiếu Nhắc nhở_HaveTicket]
			// IF(
			//     FIND(
			//         "tiếp đón",
			//         LOWER( FACT_NPS_NV[Chức danh] ),
			//         1,
			//         BLANK()
			//     )
			//         = BLANK(),
			//     FACT_NPS_NV[Số phiếu Hài lòng] + FACT_NPS_NV[Số phiếu Bình thường] + FACT_NPS_NV[Số phiếu Không hài lòng] + FACT_NPS_NV[Số phiếu Lỗi đúng_HaveTicket] + FACT_NPS_NV[Số phiếu Nhắc nhở_HaveTicket],
			//     FACT_NPS_NV[Số phiếu Hài lòng] + FACT_NPS_NV[Số phiếu Lỗi đúng_HaveTicket] + FACT_NPS_NV[Số phiếu Nhắc nhở_HaveTicket]
			// )
		formatString: #,0
		lineageTag: 7266e388-e27d-465f-af1a-081e0b5d2858
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column NPS =
			
			DIVIDE(
			    FACT_NPS_NV[Số phiếu Hài lòng] - FACT_NPS_NV[Số phiếu Vi phạm_HaveTicket],
			    FACT_NPS_NV[Tổng khảo sát],
			    BLANK()
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 4a679287-5aad-4bc2-8c1d-f4ba2756483c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Hài lòng_Tiếp đón' = ```
			
			 SWITCH(TRUE(),
			 FACT_NPS_NV[Chức danh] = "Tiếp đón" || FACT_NPS_NV[Chức danh] = "Tiếp đón Miền Bắc",     
			 CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"}
			            && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			),
			 FACT_NPS_NV[Chức danh] = "Tiếp đón sáng",     
			 CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_NPS_TICKET[Ca tiếp đón] = "Sáng"
			        && FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"}
			            && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			),
			 FACT_NPS_NV[Chức danh] = "Tiếp đón chiều" || FACT_NPS_NV[Chức danh] = "Tiếp Đón Parttime" , 
			  CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Cửa hàng] = EARLIER(FACT_NPS_NV[HaraID_Shop])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_NPS_NV[Năm/Tháng])
			        && FACT_NPS_TICKET[Ca tiếp đón] = "Chiều"
			        && FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"}
			            && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			            && FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			    )
			),
			 BLANK())
			```
		formatString: 0
		lineageTag: 10b7735a-9f81-4f7b-9b81-80186b507e3b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Số phiếu Khen thưởng' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Năm/Tháng] = EARLIER('FACT_NPS_NV'[Năm/Tháng])
			        && CONTAINSSTRING(FACT_TFEX_TICKET[Nhân viên liên quan], EARLIER('FACT_NPS_NV'[Mã-Tên nhân viên]))
			        && CONTAINSSTRING(FACT_TFEX_TICKET[Cửa hàng], EARLIER('FACT_NPS_NV'[Cửa hàng]))
			        && CONTAINSSTRING(FACT_TFEX_TICKET[Nhãn], "Khen thưởng")
			    )
