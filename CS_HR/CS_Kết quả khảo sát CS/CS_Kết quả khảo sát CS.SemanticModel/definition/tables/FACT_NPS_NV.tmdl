	column 'Số phiếu Lỗi phạt_Liên đới' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Năm/Tháng] = EARLIER('FACT_NPS_NV'[Năm/Tháng])
