				            'FACT_Công_ChiTiet'[Tên nhân viên],
				            'FACT_Công_ChiTiet'[Chức danh],
				            'FACT_Công_ChiTiet'[StartDate]
				        ),
				        FILTER(
				            'FACT_Công_ChiTiet',
				            LEFT('FACT_Công_ChiTiet'[Cửa hàng],3) = "CPS"
				            && NOT 'FACT_Công_ChiTiet'[Cửa hàng] = "CPS-HNO-DDA-B2B"
				        ))

