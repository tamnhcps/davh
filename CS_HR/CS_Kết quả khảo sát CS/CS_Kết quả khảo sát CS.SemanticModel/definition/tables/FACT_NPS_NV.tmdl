	partition FACT_NPS_NV = calculated
		mode: import
		source =
				
				CALCULATETABLE(
				        SUMMARIZE(
				            'FACT_Công_ChiTiet',
				            --'FACT_Công_ChiTiet'[Văn phòng],
				            'FACT_Công_ChiTiet'[Cửa hàng],
				            'FACT_Công_ChiTiet'[Năm/Tháng],
