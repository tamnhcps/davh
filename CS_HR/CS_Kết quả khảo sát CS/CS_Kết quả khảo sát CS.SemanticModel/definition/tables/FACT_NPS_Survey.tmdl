	column IsWarning = ```
			
			var som = [StartDate]
			var shop = RELATED('DIM_Danh mục_Phòng ban'[Bộ phận])
			var check = CALCULATE( COUNTROWS(DIM_Shop_Warning), FILTER(DIM_Shop_Warning, DIM_Shop_Warning[CỬA HÀNG] = shop && DIM_Shop_Warning[THÁNG] = som))
			RETURN IF(check > 0, "⚠️", "📞") 
			```
		lineageTag: 0ec97b1c-fe27-4575-af43-31f1721cb515
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition FACT_NPS_Survey = calculated
		mode: import
		source =
				
				CALCULATETABLE(
				        SUMMARIZE(
				            FACT_NPS_TICKET,
				            FACT_NPS_TICKET[Mã phiếu],
				            FACT_NPS_TICKET[Ngày tạo phiếu],
				            FACT_NPS_TICKET[Ngày tạo],
				            FACT_NPS_TICKET[Trạng thái],
				            FACT_NPS_TICKET[Cửa hàng],
				            // FACT_NPS_TICKET[Mã phiếu SEP],
				            FACT_NPS_TICKET[Mã hóa đơn],
				            FACT_NPS_TICKET[Ngày mua],
				            FACT_NPS_TICKET[Nguồn],
				            // FACT_NPS_TICKET[Tên khách hàng],
				            FACT_NPS_TICKET[SĐT],
				            FACT_NPS_TICKET[Thời gian thực hiện khảo sát],
				            // FACT_NPS_TICKET[Mã sản phẩm],
				            // FACT_NPS_TICKET[Tên sản phẩm],
				            FACT_NPS_TICKET[Tên hàng],
				            FACT_NPS_TICKET[Loại hàng],
				            FACT_NPS_TICKET[Phương thức],
				            FACT_NPS_TICKET[Liên hệ khảo sát],
				            FACT_NPS_TICKET[Lý do không liên hệ được],
				            FACT_NPS_TICKET[IsSurveyed]
				        ),
				        FILTER(
				            FACT_NPS_TICKET,
				            FACT_NPS_TICKET[Phương thức] IN {"Bán lẻ", "Đơn đến cửa hàng", "Đơn giao hàng"}
				        ))

	annotation PBI_Id = b6c9f78bc09b4d458b97c1747f773115

