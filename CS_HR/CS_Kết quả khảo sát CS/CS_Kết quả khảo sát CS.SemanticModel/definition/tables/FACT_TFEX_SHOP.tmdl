	column Column = IF(FACT_TFEX_SHOP[Group_Type] = FACT_TFEX_SHOP[Nhóm_Đánh_Giá],1,0)
		lineageTag: 47bc4485-60a9-4a97-9cf0-69e299fa5ad2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Group_Type = ```
			
			SWITCH(
			    TRUE(),
			    -- BHMR
			    FACT_TFEX_SHOP[Type] = "Cảm nhận khách hàng" && FACT_TFEX_SHOP[Loại ghi nhận] = "BHMR", "BHMR",
			    FACT_TFEX_SHOP[Type] = "Có sự việc cụ thể" && FACT_TFEX_SHOP[Loại ghi nhận] = "BHMR", "BHMR",
			    FACT_TFEX_SHOP[Type] = "Lỗi tư vấn", "BHMR",    
			    -- Thái độ
			    FACT_TFEX_SHOP[Type] = "Cảm nhận khách hàng" , "Thái độ",
			    FACT_TFEX_SHOP[Type] = "Có sự việc cụ thể", "Thái độ",
			    -- Nghiệp vụ
			    "Nghiệp vụ"
			)
			
			```
		lineageTag: a5b003fe-e25f-48f5-9cab-f8acc0aa1a38
		summarizeBy: none
		sortByColumn: Index

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column Nhóm_Đánh_Giá =
			SWITCH(
				TRUE,
				ISBLANK('FACT_TFEX_SHOP'[Type]),
				"(Blank)",
				'FACT_TFEX_SHOP'[Type] IN {"Lỗi tư vấn"},
				"BHMR",
				'FACT_TFEX_SHOP'[Type] IN {"Bám sàn",
					"Bảo hành",
					"Chase Khách",
					"Hóa đơn đỏ",
					"Không Đúng Hẹn",
					"Kiến thức",
					"Kỹ năng",
					"Lỗi nghiệp vụ điều chuyển",
					"Thanh toán",
					"Tiếp đón",
					"Trước - Sau tư vấn",
					"Xử lý đơn hàng"},
				"Nghiệp vụ",
				'FACT_TFEX_SHOP'[Type] IN {"Cảm nhận khách hàng",
					"Có sự việc cụ thể"},
				"Thái độ",
				'FACT_TFEX_SHOP'[Type]
			)
