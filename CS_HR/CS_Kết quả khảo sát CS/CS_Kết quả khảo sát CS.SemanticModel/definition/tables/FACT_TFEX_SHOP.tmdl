			        && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			        && FACT_NPS_TICKET[Shop] = EARLIER(FACT_TFEX_SHOP[Cửa hàng])
			        && FACT_NPS_TICKET[Năm/Tháng] = EARLIER(FACT_TFEX_SHOP[Năm/Tháng])
			    )
			)
			
			
			var loidung_HaveTicket = 
			    CALCULATE(
