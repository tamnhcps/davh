	column 'Phương thức mới' = ```
			
			LOOKUPVALUE(
			    'FACT_NPS_TICKET'[Phương thức], 
			    'FACT_NPS_TICKET'[Mã phiếu], 
			    'NPS_Detail_Evaluation'[Mã phiếu khảo sát]
			)
			```
		lineageTag: 1133c65e-986b-4028-86dd-82dae813ab43
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Mã NV' =
			
			PATHITEM(SUBSTITUTE('NPS_Detail_Evaluation'[Nhân viên liên quan], "-", "|"), 1)
		lineageTag: 5cd1b814-8e90-4bf7-8d69-f188cfa740e7
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Trạng thái NV mới' = ```
			
			VAR v_MaNV = 'NPS_Detail_Evaluation'[Mã NV]
			VAR v_Ngay = 'NPS_Detail_Evaluation'[Ngày tạo] 
			RETURN
			CALCULATE(
			    MAX('FACT_Công_ChiTiet'[Trạng thái làm việc]),
			    'FACT_Công_ChiTiet'[Mã nhân viên] = v_MaNV,
			    'FACT_Công_ChiTiet'[Date] = v_Ngay
			)
			```
		lineageTag: f838ffb3-4aa7-4551-b8da-27c7b714f638
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition NPS_Detail_Evaluation = calculated
		mode: import
		source = ```
				
				
				    UNION(
				        CALCULATETABLE(
				            SUMMARIZE(
				                FACT_TFEX_TICKET,
				                FACT_TFEX_TICKET[Mã phiếu khảo sát],
				                FACT_TFEX_TICKET[Mã ticket],
				                FACT_TFEX_TICKET[Ngày tạo],
				                FACT_TFEX_TICKET[Nguồn],
				                FACT_TFEX_TICKET[Trạng thái ticket],
				                FACT_TFEX_TICKET[Evaluation_NPS],
				                FACT_TFEX_TICKET[Nhãn],
				                FACT_TFEX_TICKET[Cửa hàng],
				                FACT_TFEX_TICKET[Đối tượng liên quan],
				                FACT_TFEX_TICKET[Nội dung khách phản ánh],
				                FACT_TFEX_TICKET[Nhân viên liên quan],
				                FACT_TFEX_TICKET[Quản lý liên đới],
				                FACT_TFEX_TICKET[Loại ghi nhận],
				                "Link khảo sát", BLANK(),
				                "Link ticket", MAX(FACT_TFEX_TICKET[Link ticket])
				            ),
				            FILTER(
				                FACT_TFEX_TICKET,
				                FACT_TFEX_TICKET[Loại yêu cầu] IN {"Khiếu nại dịch vụ", "Đánh giá"} &&
				                FACT_TFEX_TICKET[Evaluation_NPS] <> BLANK()
				            )
				        ),
				        CALCULATETABLE(
				            SUMMARIZE(
				                FACT_NPS_TICKET,
				                FACT_NPS_TICKET[Mã phiếu],
				                FACT_NPS_TICKET[TicketCode],
				                FACT_NPS_TICKET[Ngày tạo],
				                FACT_NPS_TICKET[Nguồn],
				                FACT_NPS_TICKET[Trạng thái],
				                FACT_NPS_TICKET[Evaluation_NPS],
				                FACT_NPS_TICKET[Nhãn],
				                FACT_NPS_TICKET[Shop],
				                FACT_NPS_TICKET[NV_Câu 4],
				                "Nội dung khách phản ánh", BLANK(),
				                "Nhân viên liên quan", BLANK(),
				                "Quản lý liên đới", BLANK(),
				                "Loại ghi nhận", BLANK(),
				                "Link khảo sát",
				                    MAXX(
				                        FILTER(
				                            FACT_NPS_TICKET,
				                            FACT_NPS_TICKET[TicketCode] = BLANK()
				                        ),
				                        FACT_NPS_TICKET[Link khảo sát]
				                    ),
				                "Link ticket", MAX(FACT_NPS_TICKET[Link ticket])
				            ),
				            FILTER(
				                FACT_NPS_TICKET,
				                FACT_NPS_TICKET[Trạng thái] IN {"Mới", "Hoàn tất"} &&
				                FACT_NPS_TICKET[Evaluation_NPS] <> BLANK()
				            )
				        )
				    )
				    
				    
				
				
				```

	annotation PBI_Id = 93c36eeb0b214ff7a695d76cdbc36af3

