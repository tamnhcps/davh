			defaultHierarchy: LocalDateTable_ca86cbdf-bf8d-4117-ad7b-af4edf643090.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'Nguồn khảo sát' =
			
			IF(
			    FACT_NPS_SURVEY_SStudent[Trạng thái] = "Hoàn tất"
			        && ISBLANK(FACT_NPS_SURVEY_SStudent[Nguồn]),
			    "HappyCall",
			    IF(
			        FACT_NPS_SURVEY_SStudent[Trạng thái] IN {"Mới", "Hoàn tất"}
			            && FACT_NPS_SURVEY_SStudent[Nguồn] = "SMS",
			        "SMS",
			        BLANK()
			    )
			)
		lineageTag: b6e62b79-9fa9-4069-97cc-f5a4fc8c0754
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Năm/Tháng = FORMAT(FACT_NPS_SURVEY_SStudent[Ngày mua],"YYYY/MM")
		lineageTag: aece5f14-06f4-4519-8c2e-82a6880e18a5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Năm/Tháng_KS = FORMAT(FACT_NPS_SURVEY_SStudent[Ngày tạo],"YYYY/MM")
		lineageTag: b30bd8e5-ef12-42d9-bd0e-aa80255ad769
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column is_tiep_nhan =
			
			CALCULATE(
			    COUNTROWS(FACT_SALES_TICKET),
			    FILTER(FACT_SALES_TICKET, FACT_SALES_TICKET[AutoCode] = FACT_NPS_SURVEY_SStudent[Mã hóa đơn]))
		formatString: 0
		lineageTag: f178f6ee-d7b9-43f5-9102-0d2521cc9141
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition FACT_NPS_SURVEY_SStudent = calculated
		mode: import
		source = ```
				
				    CALCULATETABLE(
				        SELECTCOLUMNS(
				            FACT_NPS_TICKET,
				            "Mã phiếu", FACT_NPS_TICKET[Mã phiếu],
				            "Ngày tạo phiếu", FACT_NPS_TICKET[Ngày tạo phiếu],
				            "Ngày tạo", FACT_NPS_TICKET[Ngày tạo],
				            "Trạng thái", FACT_NPS_TICKET[Trạng thái],
				            "Cửa hàng", FACT_NPS_TICKET[Cửa hàng],
				            "Mã hóa đơn", FACT_NPS_TICKET[Mã hóa đơn],
				            "Ngày mua", FACT_NPS_TICKET[Ngày mua],
				            "Nguồn", FACT_NPS_TICKET[Nguồn],
				            "SĐT", FACT_NPS_TICKET[SĐT],
				            "Thời gian thực hiện khảo sát", FACT_NPS_TICKET[Thời gian thực hiện khảo sát],
				            "Tên hàng", FACT_NPS_TICKET[Tên hàng],
				            "Loại hàng", FACT_NPS_TICKET[Loại hàng],
				            "Phương thức", FACT_NPS_TICKET[Phương thức],
				            "Nhân viên bán", FACT_NPS_TICKET[Nhân viên bán],
				            "Liên hệ khảo sát", FACT_NPS_TICKET[Liên hệ khảo sát],
				            "Lý do không liên hệ được", FACT_NPS_TICKET[Lý do không liên hệ được],
				            "Kết quả khảo sát_SStudent", FACT_NPS_TICKET[Kết quả khảo sát_SStudent]
				        ),
				      FACT_NPS_TICKET[Ngày tạo phiếu] >= DATE(2026, 1, 1),
				      FACT_NPS_TICKET[Phương thức] IN { "Bán lẻ", "Đơn đến cửa hàng", "Đơn giao hàng" },
				      FACT_NPS_TICKET[IsSurveyed_SStudent] = 1
				    )
				```

