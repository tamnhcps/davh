	measure 'Tỷ lệ có tư vấn_LD g%' =
			
			VAR tv_ld_g =
			    DIVIDE (
			        [Tỷ lệ có tư vấn],
			        [Tỷ lệ có tư vấn_LD],
			        BLANK ()
			    ) - 1
			RETURN
			    IF (
			        [Tỷ lệ có tư vấn_LD] <> 0
			            && [Tỷ lệ có tư vấn] <> 0,
			        tv_ld_g,
			        0
			    )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 71c0862b-3b09-408c-bfe0-6d0656a0dad0

	measure 'Tỷ lệ có tư vấn_LD' =
			
			CALCULATE (
			    [Tỷ lệ có tư vấn],
			    PREVIOUSDAY ( DIM_Date[Date] )
			)
		lineageTag: a378bfe2-6800-4319-9786-a97a7eca3435

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Target NPS' =
			
			CALCULATE(
			    AVERAGE(FACT_GSheet_Target_NPS[Target]),
			    FILTER(
			        FACT_GSheet_Target_NPS,
			        FACT_GSheet_Target_NPS[Đối tượng] = "NPS"
