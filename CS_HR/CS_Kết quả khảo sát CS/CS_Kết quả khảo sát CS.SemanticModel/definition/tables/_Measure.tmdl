			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 1a4ca499-d442-478a-be14-37193cb1ba09

	measure '%Target NPS' = ROUND(DIVIDE([NPS_Shop], [Target NPS]),4)
		formatString: 0.00%;-0.00%;0.00%
