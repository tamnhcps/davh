	measure 'Color_Lỗi phạt NV' = SUM(FACT_NPS_NV[Lỗi phạt])
		formatString: 0
		lineageTag: 3c99e17b-f8b0-430e-ab91-b8d84311275c

	measure Shop_NPS_notachieve =
			
			var zT0 = CALCULATETABLE( VALUES('DIM_Danh mục_Phòng ban'[Bộ phận]), 'DIM_Danh mục_Phòng ban'[AM] <> BLANK())
			var zT1 = ADDCOLUMNS( zT0, "zDanhGia", IF(ISBLANK([%Target NPS]), BLANK(), IF([%Target NPS] >= 1, "Đạt", "Không đạt")))
			return COUNTX( FILTER( zT1, [zDanhGia] = "Không đạt"), 'DIM_Danh mục_Phòng ban'[Bộ phận] )
		formatString: 0
		lineageTag: 856dc634-d0dd-4ca5-8a38-f4eb35a2b9e4

	measure Shop_NPS_achieve =
			
			var zT0 = CALCULATETABLE( VALUES('DIM_Danh mục_Phòng ban'[Bộ phận]), 'DIM_Danh mục_Phòng ban'[AM] <> BLANK())
			var zT1 = ADDCOLUMNS( zT0, "zDanhGia", IF(ISBLANK([%Target NPS]), BLANK(), IF([%Target NPS] >= 1, "Đạt", "Không đạt")))
			return COUNTX( FILTER( zT1, [zDanhGia] = "Đạt"), 'DIM_Danh mục_Phòng ban'[Bộ phận] )
		formatString: 0
		lineageTag: b52f708b-1859-4c51-8f1b-e72cee5f3b47

	measure %Shop_achieve = DIVIDE([Shop_NPS_achieve], ([Shop_NPS_achieve] + [Shop_NPS_notachieve]))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c114c0b1-cef9-4360-b0a2-5d1060fdef34

	measure %Shop_notachieve = DIVIDE([Shop_NPS_notachieve], ([Shop_NPS_achieve] + [Shop_NPS_notachieve]))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6e4700bb-f5de-4cc2-8441-b016c41ac91c

	measure 'Shop_Slg cửa hàng' = COUNTROWS(CALCULATETABLE(VALUES(FACT_NPS_SHOP[Cửa hàng]), FACT_NPS_SHOP[Tổng khảo sát] > 0))
		formatString: 0
		lineageTag: 71e9b8ce-026a-48ca-b4f4-8ea7dae03770

	measure 'Chi tiết Vi phạm' = ```
			
			VAR NghiepVu = CALCULATE(
			    [Số phiếu Vi phạm_HaveTicket], 
			    FILTER(FACT_TFEX_TICKET, FACT_TFEX_TICKET[Loại ghi nhận] = "Nghiệp vụ")
			)
			VAR Khac = CALCULATE(
			    [Số phiếu Vi phạm_HaveTicket], 
			    FILTER(FACT_TFEX_TICKET, FACT_TFEX_TICKET[Loại ghi nhận] = BLANK() || FACT_TFEX_TICKET[Loại ghi nhận] = "Các vấn đề khác")
			)
			VAR ThaiDo = CALCULATE(
			    [Số phiếu Vi phạm_HaveTicket], 
			    FILTER(FACT_TFEX_TICKET, FACT_TFEX_TICKET[Loại ghi nhận] = "Thái độ phục vụ")
			)
			VAR ChatLuong = CALCULATE(
			    [Số phiếu Vi phạm_HaveTicket], 
			    FILTER(FACT_TFEX_TICKET, FACT_TFEX_TICKET[Loại ghi nhận] = "Chất lượng sữa chửa")
			)
			
			VAR ErrorDetails = 
			    UNION(
			        ROW("Category", "Thái độ", "Value", ThaiDo),
			        ROW("Category", "Nghiệp vụ", "Value", NghiepVu),
			        ROW("Category", "Chất lượng sữa chửa", "Value", ChatLuong),
			        ROW("Category", "Khác", "Value", Khac)
			    )
			
			RETURN
			IF(
			    ThaiDo + NghiepVu + ChatLuong + Khac > 0,
			    CONCATENATEX(
			        FILTER(ErrorDetails, [Value] > 0),
			        [Category] & " " & [Value],
			        " | "
			    ),
			    BLANK()
			)
			```
		lineageTag: f39b3130-6106-4c85-bdcc-6583c773e290

