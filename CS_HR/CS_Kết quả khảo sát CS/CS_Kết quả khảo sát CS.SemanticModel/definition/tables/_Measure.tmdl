	measure 'Phạt tư vấn_NV' = ```
			
			VAR sl = [Số lượng phiếu không tư vấn]
			VAR _day = SELECTEDVALUE(FACT_NPS_Survey_SMember[Năm/Tháng])
			VAR _z07 =  
			SWITCH(
			    TRUE(),
			    sl < 5,0,
			    (sl-4)*100000)
			
			VAR _z08 =  
			SWITCH(
			    TRUE(),
			    sl < 6,0,
			    (sl-5)*100000)   
			RETURN
			IF(_day = "2025/07",_z07,_z08)
			```
		formatString: #,0
		lineageTag: 5880619e-e0e2-42e9-a618-6e55eb6a6719

	measure NPS_NV = ```
			
			var _is_smkn =
			sign(
			    countrows(
			        filter(
			            FACT_NPS_NV,
			            FACT_NPS_NV[isSMKN] = 1
			        )
			    )
			)
			
			var _nps_smkn = 
			    average( FACT_NPS_NV[NPS] )
			
			var _sp_hai_long = sum(FACT_NPS_NV[Số phiếu Hài lòng])
			var _sp_vi_pham = sum(FACT_NPS_NV[Số phiếu Vi phạm_HaveTicket])
			var _sp_tong_khao_sat = sum(FACT_NPS_NV[Tổng khảo sát])
			
			var _nps_nv =
			divide(
			    _sp_hai_long - _sp_vi_pham,
			    _sp_tong_khao_sat,
			    blank()
			)
			
			return
			    if( _is_smkn = 1, _nps_smkn, _nps_nv )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: f20a4ce6-0fd7-46d1-9b9e-9a2ed901cbaa

