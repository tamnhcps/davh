	measure StartDate =
			
			VAR Mindate_D =
			    CALCULATE(
			        MIN( 'DIM_Date'[Date] ),
			        FILTER(
			            'Dim_Date',
			            'Dim_Date'[IsActive] = 1
			        )
			    )
			RETURN
			    CALCULATE(
			        STARTOFMONTH( 'DIM_Date'[Date] ),
			        'Dim_Date'[Date] = Mindate_D
			    )
		formatString: m/d/yyyy
		lineageTag: e7161af1-9656-4f5b-845b-b1eb9ea917e0

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

