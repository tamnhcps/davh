	measure 'Số cửa hàng đạt %Vi phạm' =
			
			CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_SHOP[Văn phòng]),
			    FILTER( FACT_NPS_SHOP, FACT_NPS_SHOP[%Vi phạm] < FACT_NPS_SHOP[%Vi phạm toàn miền] )
			)
		formatString: 0
		lineageTag: 0bfe585a-3473-4ae9-ac7d-bc087a6d6d75

	measure 'Số cửa hàng ko đạt %Vi phạm' =
			
			CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_SHOP[Văn phòng]),
			    FILTER( FACT_NPS_SHOP, FACT_NPS_SHOP[%Vi phạm] > FACT_NPS_SHOP[%Vi phạm toàn miền] )
			)
		formatString: 0
		lineageTag: 35cf5a57-966d-49c2-b848-82c78a1e8d6f

