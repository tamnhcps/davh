	measure 'SLg Shop' = CALCULATE(DISTINCTCOUNT('DIM_Danh mục_Phòng ban'[Cửa hàng gộp]), FILTER('DIM_Danh mục_Phòng ban', [NPS_Shop] > 0))
		formatString: 0
