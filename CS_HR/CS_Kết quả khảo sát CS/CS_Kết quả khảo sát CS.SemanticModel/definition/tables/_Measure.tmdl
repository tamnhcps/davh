	measure 'SLg Quản lý' = CALCULATE(DISTINCTCOUNT(FACT_NPS_NV[Mã nhân viên]),FILTER(FACT_NPS_NV,FACT_NPS_NV[Chức danh] IN {"Trưởng cửa hàng", "Trợ lý cửa hàng"}))
		formatString: 0
