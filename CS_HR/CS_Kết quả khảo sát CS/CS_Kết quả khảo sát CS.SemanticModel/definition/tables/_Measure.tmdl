			 CALCULATE(DISTINCTCOUNT(FACT_NPS_Survey[Mã hóa đơn]), FILTER(FACT_NPS_Survey, FACT_NPS_Survey[IsSurveyed] = 1 && FACT_NPS_Survey[Nguồn] = "Tại Cửa Hàng"))
