table _Measure
	lineageTag: 24aa7ac1-f2f2-4608-a5fa-3857639e89e5

	measure 'Số phiếu Hài lòng_HaveTicket' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Kết luận] IN {"Hài lòng", "Khen ngợi"}
			    )
			)
			```
		formatString: 0
		lineageTag: 67aa5632-8720-4d76-bba4-a41d3a737494

	measure 'Số phiếu Hài lòng_NoTicket' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			        && FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"}
			            && FACT_NPS_TICKET[HaveTFEX] = BLANK()
			    )
			)
			```
		formatString: 0
		lineageTag: 54b0a0bb-266c-4b83-95e0-acff7bc54bf8

	measure 'Số phiếu Hài lòng' = [Số phiếu Hài lòng_NoTicket] + [Số phiếu Hài lòng_HaveTicket]
		formatString: #,0
		lineageTag: 35a07c4f-151d-44e2-8aee-f919f862fbe1

	measure 'Số phiếu Bình thường' =
			
			CALCULATE(
			    DISTINCTCOUNT( FACT_NPS_TICKET[Mã phiếu] ),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			            && FACT_NPS_TICKET[Kết quả khảo sát] = "Bình thường"
			            && FACT_NPS_TICKET[Liên hệ khảo sát] <> "Không liên hệ được"
			            && (
			                FACT_NPS_TICKET[NV_Câu 5] = BLANK()
			                    || FACT_NPS_TICKET[NV_Câu 5] = "None"
			            )
			    )
			)
		formatString: 0
		lineageTag: 77ca9813-190e-4d0e-b849-080b05a3f46e

	measure 'Số phiếu Không hài lòng' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_NPS_TICKET[Mã phiếu]),
			    FILTER(
			        FACT_NPS_TICKET,
			        FACT_NPS_TICKET[Trạng thái] <> "Đang xử lý"
			        && FACT_NPS_TICKET[Kết quả khảo sát] = "Không hài lòng"
			            && (FACT_NPS_TICKET[NV_Câu 5] = BLANK()
			            || FACT_NPS_TICKET[NV_Câu 5] = "None")
			        && FACT_NPS_TICKET[Có liên hệ được] = TRUE()
			        
			    )
			)
			```
		formatString: #,0
		lineageTag: fcee3a98-c951-4068-8b88-2d772e279ea6

	measure 'Số phiếu Vi phạm_HaveTicket' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Kết luận] = "Có vi phạm"
			    )
			)
			```
		formatString: #,0
		lineageTag: a68ab2c9-57c7-4592-b7f2-18b198c5f71b

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Số phiếu Nhắc nhở_HaveTicket' = ```
			
			    CALCULATE(
			    DISTINCTCOUNT(FACT_TFEX_TICKET[Mã ticket]),
			    FILTER(
			        FACT_TFEX_TICKET,
			        FACT_TFEX_TICKET[Kết luận] = "Nhắc nhở"
			        && FACT_TFEX_TICKET[Nguồn] <> "Khảo sát"
			    )
			)
			```
		formatString: 0
		lineageTag: c4939aa0-878c-4025-abb0-482bbe6a7f51

	measure 'Tổng khảo sát' = [Số phiếu Hài lòng]+[Số phiếu Bình thường]+[Số phiếu Không hài lòng]+[Số phiếu Vi phạm_HaveTicket]+[Số phiếu Nhắc nhở_HaveTicket]
		formatString: #,0
		lineageTag: 6accdc74-faee-48a2-a883-e40188b610c5

	measure NPS_Shop = DIVIDE([Số phiếu Hài lòng]-[Số phiếu Vi phạm_HaveTicket],[Tổng khảo sát],BLANK())
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 42e29637-98bb-4963-8f8e-13b23f7b6c7d

	measure '%Hài lòng_Shop' =
			
			AVERAGEX(
			    VALUES('DIM_Danh mục_Miền'[Miền]),
			    DIVIDE([Số phiếu Hài lòng],[Tổng khảo sát],BLANK()))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: f1265249-65b6-40c7-bcb2-cf6aac05ecbc

	measure '%Vi phạm_Shop' = DIVIDE([Số phiếu Vi phạm_HaveTicket],[Tổng khảo sát],BLANK())
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 970ee5b2-6bbf-4b5f-8f02-6250c60d9c77

	measure 'Xếp hạng_Shop' = RANKX(ALL('DIM_Danh mục_Phòng ban'[Bộ phận]),[NPS_Shop],[NPS_Shop])
		formatString: 0
		lineageTag: a1917a7a-53f9-4b92-9e28-2bcbaa352108

	measure 'Ngày cập nhật' =
			--MAX(FACT_NPS_TICKET[Ngày khảo sát gần nhất])
