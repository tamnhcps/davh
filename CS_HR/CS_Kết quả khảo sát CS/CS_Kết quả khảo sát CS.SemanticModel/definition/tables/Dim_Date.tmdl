	column IsActive =
			
			VAR mindate =
			    MIN(FACT_NPS_TICKET[Ngày khảo sát gần nhất])
			VAR maxdate =
			    MAX ( FACT_NPS_TICKET[Ngày khảo sát gần nhất] )
			RETURN
			    IF (
			        'Dim_Date'[Date] >= mindate
			            && 'Dim_Date'[Date] <= maxdate,
			        1,
			        BLANK ()
			    )
		formatString: 0
		lineageTag: 6c76e440-44d8-418a-888a-724cec0e3f67
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column IsCurrentMonth = ```
			
			IF(
			    YEAR('Dim_Date'[date]) = YEAR(TODAY()) && MONTH('Dim_Date'[date]) = MONTH(TODAY()), 
			    1, 
			    0
			)
			```
		formatString: 0
		lineageTag: 48ea19e1-8f69-4412-bfb5-1a340f6316ee
		summarizeBy: sum

