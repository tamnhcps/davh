	column 'Trạng thái đánh giá' = ```
			
			VAR KetLuan = 'FACT_TFEX_TICKET'[Kết luận]
			
			VAR TrangThai = MAXX(RELATEDTABLE('FACT_TFEX_FEEDBACK'), 'FACT_TFEX_FEEDBACK'[Trạng thái])
			
			RETURN
			IF (
			    ISBLANK(KetLuan) || KetLuan = "", 
			    "Chưa đánh giá",
			    IF (
			        KetLuan = "Cần thêm thông tin",
			        TrangThai, 
			        KetLuan 
			    )
			)
			```
		lineageTag: dda4de15-0689-4eb0-9527-ca3dc4a176db
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition FACT_TFEX_TICKET = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=846a68ee-cfb9-40fd-940b-7f8fd45fb141""#(lf)WITH activities AS #(lf)  (SELECT * #(lf)  FROM `cellphones-data-platform.cps_data_hrw_dwh.hrw_tfex_ticket_activities` #(lf)  WHERE #(lf)    field_key_had_updated = 'Assessment_Responsible_Departments'#(lf)    and gia_tri_moi like 'CPS-%')#(lf)#(lf)SELECT #(lf)  f.* except (`Cửa hàng`), #(lf)  REGEXP_REPLACE(COALESCE(a.gia_tri_moi, f.`Cửa hàng`), r'^PG_', '') as `Cửa hàng` #(lf)FROM `cellphones-data-platform.cps_data_hrw_dwh.fact_tfex_ticket` f#(lf)LEFT JOIN activities a on f.`Mã ticket` = a.ticket_code#(lf)WHERE DATE(`Tạo lúc`) >= DATE_ADD(DATE_TRUNC(CURRENT_DATE(), MONTH), INTERVAL -5 MONTH)#(lf)AND REGEXP_CONTAINS(`Nhãn`, r'Liên quan Shop|XLKN|Cần QLCH gọi|Khen thưởng')", null, [EnableFolding=true]),
				    #"Replaced Value" = Table.ReplaceValue(Source,"CPS-HNO-DDA-384XD","CPS-HNO-DDA-360XD",Replacer.ReplaceText,{"Cửa hàng"}),
				    #"Replaced Value1" = Table.ReplaceValue(#"Replaced Value","CPS-QNI-HL-126KL","CPS-QNI-HGA-19THD",Replacer.ReplaceText,{"Cửa hàng"})
				in
				    #"Replaced Value1"

