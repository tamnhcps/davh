	column Group_Nguồn =
			SWITCH(
				TRUE,
				ISBLANK('FACT_TFEX_TICKET'[Nguồn]),
				"(Blank)",
				'FACT_TFEX_TICKET'[Nguồn] IN {"Chat",
					"Chat web",
					"Chat Facebook",
					"Cửa hàng",
					"Email",
					"Khảo sát",
					"Nội bộ",
					"QC",
					"Tổng đài"},
				"Khảo sát",
				'FACT_TFEX_TICKET'[Nguồn] IN {"Mạng xã hội",
					"Social_Facebook_Cá nhân",
					"Social_Facebook_Review Page",
					"Social_Google Rating",
					"Social_Website Công ty"},
				"Social",
				'FACT_TFEX_TICKET'[Nguồn]
			)
		lineageTag: 12fc3a9d-4101-4701-8934-47953c9068d1
		summarizeBy: none

