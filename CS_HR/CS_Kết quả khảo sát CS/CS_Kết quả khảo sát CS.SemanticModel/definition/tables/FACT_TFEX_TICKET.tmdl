	column Evaluation_NPS =
			
			SWITCH(TRUE(),
			FACT_TFEX_TICKET[Kết luận] IN {"Hài lòng", "Khen ngợi"}, "Hài lòng_HaveTicket",
			FACT_TFEX_TICKET[Kết luận] = "Nhắc nhở" && FACT_TFEX_TICKET[Nguồn] <> "Khảo sát", "Nhắc nhở",
			FACT_TFEX_TICKET[Kết luận] = "Có vi phạm", "Vi phạm",
			BLANK())
