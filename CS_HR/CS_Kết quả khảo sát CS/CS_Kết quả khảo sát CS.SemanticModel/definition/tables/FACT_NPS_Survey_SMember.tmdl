	column is_tiep_nhan =
			
			CALCULATE(
			    COUNTROWS(FACT_SALES_TICKET),
			    FILTER(FACT_SALES_TICKET, FACT_SALES_TICKET[AutoCode] = FACT_NPS_Survey_SMember[Mã hóa đơn]))
		formatString: 0
		lineageTag: 2e2120f8-3929-4146-945c-bb751e46a0d9
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition FACT_NPS_Survey_SMember = calculated
		mode: import
		source = ```
				
				UNION(
				    CALCULATETABLE(
				        SELECTCOLUMNS(
				            FACT_NPS_TICKET,
				            "Mã phiếu", FACT_NPS_TICKET[Mã phiếu],
				            "Ngày tạo phiếu", FACT_NPS_TICKET[Ngày tạo phiếu],
				            "Ngày tạo", FACT_NPS_TICKET[Ngày tạo],
				            "Trạng thái", FACT_NPS_TICKET[Trạng thái],
				            "Cửa hàng", FACT_NPS_TICKET[Cửa hàng],
				            // "Mã phiếu SEP", FACT_NPS_TICKET[Mã phiếu SEP],
				            "Mã hóa đơn", FACT_NPS_TICKET[Mã hóa đơn],
				            "Ngày mua", FACT_NPS_TICKET[Ngày mua],
				            "Nguồn", FACT_NPS_TICKET[Nguồn],
				            // "Tên khách hàng", FACT_NPS_TICKET[Tên khách hàng],
				            "SĐT", FACT_NPS_TICKET[SĐT],
				            "Thời gian thực hiện khảo sát", FACT_NPS_TICKET[Thời gian thực hiện khảo sát],
				            // "Mã sản phẩm", FACT_NPS_TICKET[Mã sản phẩm],
				            // "Tên sản phẩm", FACT_NPS_TICKET[Tên sản phẩm],
				            "Tên hàng", FACT_NPS_TICKET[Tên hàng],
				            "Loại hàng", FACT_NPS_TICKET[Loại hàng],
				            "Phương thức", FACT_NPS_TICKET[Phương thức],
				            "Nhân viên bán", FACT_NPS_TICKET[Nhân viên bán],
				            "Liên hệ khảo sát", FACT_NPS_TICKET[Liên hệ khảo sát],
				            "Lý do không liên hệ được", FACT_NPS_TICKET[Lý do không liên hệ được],
				            "Kết quả khảo sát_SMember", FACT_NPS_TICKET[Kết quả khảo sát_SMember]
				        ),
				        FACT_NPS_TICKET[Phương thức] IN { "Bán lẻ", "Đơn đến cửa hàng", "Đơn giao hàng" }
				            && FACT_NPS_TICKET[Ngày tạo phiếu] >= DATE(2024, 5, 4)
				            && FACT_NPS_TICKET[IsSurveyed_SMember] = 1
				    ),
				    
				    SELECTCOLUMNS(
				        FACT_QC_AI,
				        "Mã phiếu", FACT_QC_AI[Mã phiếu],
				        "Ngày tạo phiếu", FACT_QC_AI[Ngày tạo phiếu],
				        "Ngày tạo", FACT_QC_AI[Ngày tạo],
				        "Trạng thái", BLANK(),
				        "Cửa hàng", FACT_QC_AI[HaraID],
				        // "Mã phiếu SEP", BLANK(),
				        "Mã hóa đơn", FACT_QC_AI[Mã hóa đơn],
				        "Ngày mua", FACT_QC_AI[Ngày mua],
				        "Nguồn", FACT_QC_AI[Nguồn],
				        // "Tên khách hàng", BLANK(),
				        "SĐT", FACT_QC_AI[SĐT],
				        "Thời gian thực hiện khảo sát", BLANK(),
				        // "Mã sản phẩm", BLANK(),
				        // "Tên sản phẩm", BLANK(),
				        "Tên hàng", BLANK(),
				        "Loại hàng", BLANK(),
				        "Phương thức", FACT_QC_AI[Phương thức],
				        "Nhân viên bán", FACT_QC_AI[Nhân viên bán],
				        "Liên hệ khảo sát", BLANK(),
				        "Lý do không liên hệ được", BLANK(),
				        "Kết quả khảo sát_SMember", FACT_QC_AI[Kết quả khảo sát_SMember]
				    )
				)
				
				```

	annotation PBI_Id = dcd86a0ea72a4875b080845ce50c52ad

