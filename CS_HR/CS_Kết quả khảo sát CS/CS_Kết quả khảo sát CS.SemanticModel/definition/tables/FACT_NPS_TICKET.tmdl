	column 'Kết quả khảo sát_SStudent' = IF(FACT_NPS_TICKET[NV_Câu 11] = BLANK() || FACT_NPS_TICKET[NV_Câu 11] = "None", FACT_NPS_TICKET[KH_Câu_11], FACT_NPS_TICKET[NV_Câu 11])
