	column 'Khách hàng thực hiện khảo sát'
		dataType: string
		lineageTag: 307117a6-dff0-40a0-88d7-c190cdd0eab3
		summarizeBy: none
		sourceColumn: Khách hàng thực hiện khảo sát

		annotation SummarizationSetBy = Automatic

	column Evaluation_NPS =
			
			SWITCH(TRUE(),
			FACT_NPS_TICKET[Trạng thái] = "Đang xử lý", BLANK(),
			FACT_NPS_TICKET[Kết quả khảo sát] IN {"Hài lòng", "Khen ngợi"} && FACT_NPS_TICKET[HaveTFEX] = BLANK(), "Hài lòng_NoTicket",
			FACT_NPS_TICKET[Kết quả khảo sát] = "Bình thường" && FACT_NPS_TICKET[Liên hệ khảo sát] <> "Không liên hệ được" && FACT_NPS_TICKET[NV_Câu 5] IN {"None", BLANK()}, "Bình thường",
			FACT_NPS_TICKET[Kết quả khảo sát] = "Không hài lòng" && FACT_NPS_TICKET[Liên hệ khảo sát] <> "Không liên hệ được"  && FACT_NPS_TICKET[NV_Câu 5] IN {"None", BLANK()} && FACT_NPS_TICKET[Có liên hệ được] = TRUE(), "Không hài lòng",
			BLANK())
		lineageTag: 8e0f5a40-6598-4228-897c-31576018dd42
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Shop = RELATED('DIM_Danh mục_Phòng ban'[Bộ phận])
		lineageTag: 97f0ab0c-92f2-42a7-93c0-f43e5a814694
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column TicketCode = IF(FACT_NPS_TICKET[HaveTFEX] = 1, CALCULATE(MIN(FACT_TFEX_TICKET[Mã ticket]),FILTER(FACT_TFEX_TICKET,FACT_TFEX_TICKET[Mã phiếu khảo sát]=EARLIER(FACT_NPS_TICKET[Mã phiếu]))), BLANK())
		lineageTag: bb6777ac-c351-4b1b-85a5-6a0789f81ff3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Link ticket' = ```
			
			        CALCULATE(
			            FIRSTNONBLANK(FACT_TFEX_TICKET[Link ticket], 1),
			                FILTER(
			                    FACT_TFEX_TICKET,FACT_TFEX_TICKET[Mã phiếu khảo sát]
			                        = EARLIER(FACT_NPS_TICKET[Mã phiếu])
			                )
			            )
			```
		lineageTag: dc6a5c77-48b8-4847-8a62-fb5179bc1637
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column AM = RELATED('DIM_Danh mục_Phòng ban'[AM])
		lineageTag: 4e1b1340-e080-425b-a607-f7adf1b1c930
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Miền = RELATED('DIM_Danh mục_Miền'[Miền])
