	partition FACT_NPS_TICKET = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=846a68ee-cfb9-40fd-940b-7f8fd45fb141""#(lf)SELECT #(lf)  co_lien_he_duoc as `Có liên hệ được`,#(lf)  replace(cua_hang,'7199','25887') as `Cửa hàng`,#(lf)  kh_cau_1 as `KH_Câu 1`,#(lf)  kh_cau_10 as `KH_Câu 10`,#(lf)  kh_cau_2 as `KH_Câu 2`,#(lf)  kh_cau_11 as `KH_Câu_11`,#(lf)  khach_hang_thuc_hien_khao_sat as `Khách hàng thực hiện khảo sát`,#(lf)  lien_he_khao_sat as `Liên hệ khảo sát`,#(lf)  REGEXP_EXTRACT(link_khao_sat, r'[^/]+$') AS ticket_id,#(lf)  --link_khao_sat as `Link khảo sát`,#(lf)  loai_hang as `Loại hàng`,#(lf)  loai_khao_sat as `Loại khảo sát`,#(lf)  ly_do_khong_lien_he_duoc as `Lý do không liên hệ được`,#(lf)  ma_hoa_don as `Mã hóa đơn`,#(lf)  --ma_khach_hang as `Mã khách hàng`,#(lf)  ma_nv_khao_sat_gan_nhat as `Mã NV khảo sát gần nhất`,#(lf)  ma_phieu as `Mã phiếu`,#(lf)  --ma_phieu_sep as `Mã phiếu SEP`,#(lf)  --ma_san_pham as `Mã sản phẩm`,#(lf)  --ma_tham_chieu as `Mã tham chiếu`,#(lf)  ngay_khao_sat_gan_nhat as `Ngày khảo sát gần nhất`,#(lf)  ngay_mua as `Ngày mua`,#(lf)  ngay_tao_phieu as `Ngày tạo phiếu`,#(lf)  nguon as `Nguồn`,#(lf)  nhan as `Nhãn`,#(lf)  nhan_vien_ban as `Nhân viên bán`,#(lf)  nhan_vien_cs as `Nhân viên CS`,#(lf)  nhan_vien_kho as`Nhân viên kho`,#(lf)  nhan_vien_ky_thuat as `Nhân viên kỹ thuật`,#(lf)  nhan_vien_quan_ly as `Nhân viên quản lý`,#(lf)  nv_khao_sat_gan_nhat as `NV khảo sát gần nhất`,#(lf)  nv_cau_1 as `NV_Câu 1`,#(lf)  nv_cau_10 as `NV_Câu 10`,#(lf)  nv_cau_11 as `NV_Câu 11`,#(lf)  nv_cau_2 as `NV_Câu 2`,#(lf)  nv_cau_3 as `NV_Câu 3`,#(lf)  nv_cau_4 as `NV_Câu 4`,#(lf)  nv_cau_5 as `NV_Câu 5`, #(lf)  phuong_thuc as `Phương thức`,#(lf)  --quan_huyen as `Quận huyện`,#(lf)  sdt_khach as `SĐT khách`,#(lf)  ten_hang as `Tên hàng`,#(lf)  --ten_khach_hang as `Tên khách hàng`,#(lf)  --ten_san_pham as `Tên sản phẩm`,#(lf)  tfexTicketIds,#(lf)  thoi_gian_thuc_hien_khao_sat as `Thời gian thực hiện khảo sát`,#(lf)  thu_ngan as `Thu ngân`,#(lf)  --tinh_thanh as `Tỉnh thành`,#(lf)  tong_so_luong as `Tổng số lượng`,#(lf)  tong_tien as `Tổng tiền`,#(lf)  trang_thai as `Trạng thái`#(lf)FROM `cellphones-data-platform.cps_organization_datamart.fact_nps_ticket`#(lf)WHERE DATE(`ngay_tao_phieu`) >= DATE_ADD(DATE_TRUNC(CURRENT_DATE(), MONTH), INTERVAL -7 MONTH)#(lf)AND (NOT `nguon` IN ('Tại Cửa Hàng') OR `nguon` IS NULL)", null, [EnableFolding=true])
				in
