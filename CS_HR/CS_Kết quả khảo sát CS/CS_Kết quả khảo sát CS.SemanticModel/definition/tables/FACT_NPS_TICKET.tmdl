	column 'Ngày tạo' = FACT_NPS_TICKET[Ngày khảo sát gần nhất].[Date]
		formatString: Short Date
		lineageTag: 69bc6f90-7df1-49a0-b401-73f0b827ebce
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column HaveTFEX = SIGN(CALCULATE(COUNT(FACT_TFEX_TICKET[Mã phiếu khảo sát]),FILTER(FACT_TFEX_TICKET,FACT_TFEX_TICKET[Mã phiếu khảo sát]=FACT_NPS_TICKET[Mã phiếu])))
		formatString: 0
		lineageTag: ae8f8692-60c1-42a3-a17f-738339210bac
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Năm/Tháng = FORMAT(FACT_NPS_TICKET[Ngày khảo sát gần nhất],"YYYY/MM")
		lineageTag: 07dc445a-2d00-42e5-820a-8dc48f4145ed
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column HaraID_NV = FACT_NPS_TICKET[Thu Ngân]&";"&FACT_NPS_TICKET[Nhân viên bán]&";"&FACT_NPS_TICKET[Nhân viên quản lý]&";"&FACT_NPS_TICKET[Nhân viên kho]&";"&FACT_NPS_TICKET[Nhân viên kỹ thuật]&";"&FACT_NPS_TICKET[Nhân viên CS]
		lineageTag: 787b2a38-8ada-45c5-8adb-8d37e33b4fbb
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Ca tiếp đón' = IF(TIMEVALUE(FORMAT(FACT_NPS_TICKET[Ngày mua], "HH:mm:ss"))>TIME(17,0,0),"Chiều","Sáng")
		dataType: string
		lineageTag: 1e372fce-8460-4874-b3a0-8cf725635ca9
		summarizeBy: none

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	column IsSurveyed = ```
			
			IF( 
			    FACT_NPS_TICKET[Phương thức] IN {"Bán lẻ", "Đơn đến cửa hàng", "Đơn giao hàng"} 
			        && (FACT_NPS_TICKET[Thời gian thực hiện khảo sát] <> BLANK() 
			        || FACT_NPS_TICKET[Liên hệ khảo sát] = "Liên hệ được"),
			        // || FACT_NPS_TICKET[Nguồn] = "Tại Cửa Hàng"), 
			            1, 
			            0
			)
			```
		formatString: 0
		lineageTag: 41469811-c54b-46c1-9289-4ad7fb65e5f2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Kết quả khảo sát' =
			
			VAR kq_ticket = CALCULATE(VALUES(FACT_TFEX_TICKET[Kết luận]),FILTER(FACT_TFEX_TICKET,FACT_TFEX_TICKET[Mã ticket]=EARLIER(FACT_NPS_TICKET[TicketCode])))
			RETURN IF(kq_ticket IN {"Không vi phạm", "Có vi phạm"}, BLANK(), IF(FACT_NPS_TICKET[NV_Câu 2] = BLANK(), FACT_NPS_TICKET[KH_Câu 2], FACT_NPS_TICKET[NV_Câu 2]))
		lineageTag: 6b6b9535-5078-4112-a7a3-6ecacfbbe073
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'KH_Câu 10'
		dataType: string
		lineageTag: c1ac755e-4469-451d-9540-5177d27a1132
		summarizeBy: none
		sourceColumn: KH_Câu 10

		annotation SummarizationSetBy = Automatic

	column 'NV_Câu 10'
		dataType: string
		lineageTag: 40e062fd-a956-49ee-b1d3-6847168cd661
		summarizeBy: none
		sourceColumn: NV_Câu 10

		annotation SummarizationSetBy = Automatic

	column SĐT = IF(LEN(FACT_NPS_TICKET[SĐT khách]) > 4, SUBSTITUTE(FACT_NPS_TICKET[SĐT khách], LEFT(FACT_NPS_TICKET[SĐT khách], LEN(FACT_NPS_TICKET[SĐT khách])-4), REPT("*", LEN(FACT_NPS_TICKET[SĐT khách])-4)), BLANK())
		lineageTag: a596e9e6-09b7-4c85-bfa5-41be3af515ef
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column IsSurveyed_SMember = IF( OR(AND(FACT_NPS_TICKET[Nguồn] = "SMS", FACT_NPS_TICKET[Trạng thái] IN {"Mới", "Hoàn tất"}), AND(ISBLANK(FACT_NPS_TICKET[Nguồn]), FACT_NPS_TICKET[Trạng thái] = "Hoàn tất"))  && (FACT_NPS_TICKET[KH_Câu 10] IN {"Có", "Không"} || FACT_NPS_TICKET[NV_Câu 10] IN {"Có", "Không"}), 1, 0)
		formatString: 0
		lineageTag: a21be382-1452-4b54-a7f9-b5e7273e8251
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Kết quả khảo sát_SMember' = IF(FACT_NPS_TICKET[NV_Câu 10] = BLANK() || FACT_NPS_TICKET[NV_Câu 10] = "None", FACT_NPS_TICKET[KH_Câu 10], FACT_NPS_TICKET[NV_Câu 10])
		lineageTag: 47b162c0-8a9e-496b-a938-ce2c3cdbb4f4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Date = FACT_NPS_TICKET[Ngày tạo phiếu].[Date]
		formatString: Short Date
		lineageTag: 2ef8611b-ae56-445b-98db-66f38f96f410
