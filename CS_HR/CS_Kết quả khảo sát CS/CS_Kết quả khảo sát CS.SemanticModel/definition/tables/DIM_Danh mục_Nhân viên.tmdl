	partition 'DIM_Danh mục_Nhân viên' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=846a68ee-cfb9-40fd-940b-7f8fd45fb141""#(lf)SELECT#(lf)  sp.id AS ID,#(lf)  UPPER(sp.code) AS `Mã nhân viên`,#(lf)  sp.HaraId AS `Mã nhân viên Harawork`,#(lf)  UPPER(sp.fullname) AS `Tên nhân viên`,#(lf)  UPPER(sp.FirstName) AS `Tên rút gọn`,#(lf)  sp.inactive AS Inactive,#(lf)  COALESCE(DATE(hr.birthday),DATE(ee.DateOfBirth)) AS `Ngày sinh`,#(lf)  sp.gender AS `Giới tính`,#(lf)  COALESCE(DATE(ee.DateJoin), DATE(ee.LastEdit),DATE(hr.start_date)) AS `Ngày nhận việc`,#(lf)  COALESCE(DATE(ee.DayLeave), DATE(hr.end_date)) AS `Ngày kết thúc`,#(lf)  et.name AS `Vị trí`,#(lf)  sd.name AS DepartmentName,#(lf)  es.name AS BranchName,#(lf)  ee.WorkingPhone,#(lf)  ee.Telephone#(lf)FROM#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` sp#(lf)LEFT JOIN#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Employee` ee#(lf)ON#(lf)  ee.id = sp.id#(lf)LEFT JOIN#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Department` sd#(lf)ON#(lf)  sd.id = ee.DepartmentId#(lf)LEFT JOIN#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_SubBranch` es#(lf)ON#(lf)  es.id = sp.BranchId#(lf)LEFT JOIN#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_EmployeeTitle` et#(lf)ON#(lf)  et.id = ee.TitleId#(lf)JOIN#(lf)`cellphones-data-platform.cps_unified_postgres_dwh.hrw_hr_profile` hr#(lf)ON#(lf) hr.hara_id = sp.HaraId AND sp.HaraId IS NOT NULL", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_ResultType = Table

