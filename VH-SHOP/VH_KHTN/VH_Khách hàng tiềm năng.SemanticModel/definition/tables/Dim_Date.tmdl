	column Ngay_isActive =
			
			VAR zMin =
			    CALCULATE(
			        MIN( FACT_PotentialCustomers[Date] ),
			        FILTER( FACT_PotentialCustomers, FACT_PotentialCustomers[Phone] <> BLANK() )
			    )
			VAR zMax =
			    CALCULATE(
			        MAX( FACT_PotentialCustomers[Date] ),
			        FILTER( FACT_PotentialCustomers, FACT_PotentialCustomers[Phone] <> BLANK() )
			    )
			RETURN
			    IF(
			        Dim_Date[Date] >= zMin
			            && Dim_Date[Date] <= zMax,
			        1,
			        0
			    )
		formatString: 0
		lineageTag: f36d0857-8d3d-4b9f-ba32-42c913c14fc6
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

