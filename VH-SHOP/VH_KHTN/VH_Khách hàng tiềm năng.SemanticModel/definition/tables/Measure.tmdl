	measure KHTN_Customer_Caring_IsOverDue = ```
			
			    CALCULATE(DISTINCTCOUNT(FACT_PotentialCustomers[AutoCode]), 
			        FACT_PotentialCustomers[StatusName] = "Đang chăm sóc"
			        && FACT_PotentialCustomers[IsOverDue] = 1)
			```
		formatString: 0
		lineageTag: a645b08d-ddb9-49bf-85c4-0accb78cf1a4

	/// Số lượng khách hàng đang chăm sóc còn hạn
	/// 
	measure KHTN_Customer_Caring_NoOverDue = ```
			
			    CALCULATE(DISTINCTCOUNT(FACT_PotentialCustomers[AutoCode]), 
			        FACT_PotentialCustomers[StatusName] = "Đang chăm sóc"
			        && FACT_PotentialCustomers[IsOverDue] = 0)
			```
		formatString: 0
		lineageTag: 193baca2-335d-471a-a1c7-d8a9d0b999fe

	/// Tỷ lệ đang chăm sóc quá hạn
	measure %KHTN_Customer_Caring_IsOverDue = DIVIDE([KHTN_Customer_Caring_IsOverDue], [KHTN_Customer], BLANK())
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d3a0fb58-f13d-43d0-ae19-8571d68c0513

	/// Tỷ lệ đang chăm sóc còn hạn
	measure %KHTN_Customer_Caring_NoOverDue = DIVIDE([KHTN_Customer_Caring_NoOverDue], [KHTN_Customer], BLANK())
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 875610a8-6da0-420d-b5be-cf53a5d8ba6a

	measure 'Store_Sales transaction by phone' =
			
			SUM ( FACT_Palexy_Store[transaction_by_phone] )
		lineageTag: af3ef910-74b8-41dc-8ad6-471337fc8194

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Store_Conversion by Opportunities_plx' = ```
			
			DIVIDE (
			    [Store_Sales transaction],
			    [Store_Total opportunities_plx],
			    BLANK ()
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
