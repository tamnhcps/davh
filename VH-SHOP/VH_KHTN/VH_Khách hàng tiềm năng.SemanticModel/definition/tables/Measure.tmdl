	measure 'Store_Target test' = [Store_Visit miss] * 0.31 *[Store_Total opportunities]
		lineageTag: b19a360f-5ae7-4ad0-8679-63c32014bf11

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Store_Visit miss_PLX' = ```
			
			VAR _cr_plx =
			    [Store_Conversion by Opportunities_plx]
			RETURN
			    IF(
			        ISBLANK(_cr_plx),
			        BLANK(),
			        MAX(0, 1 - _cr_plx)
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: PLX
		lineageTag: f0cda9cb-8240-41b0-a086-a5e3faba1a78

	measure 'Store_Total miss_PLX' = ```
			
			ROUND(
			    [Store_Total opportunities_plx] * [Store_Visit miss_PLX],
			    0
			)
			
			```
		displayFolder: PLX
		lineageTag: f51555d2-c633-405d-87b4-3612fd0b4f87

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure %KHTN_Customer_miss_PLX = ```
			
			DIVIDE(
			    [KHTN_Customer],
			    [Store_Total miss_PLX],
			    BLANK()
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: PLX
		lineageTag: b45dfdb3-727e-4052-acd0-e6ead5889810

	measure KHTN_TA_Rate_PLX = ```
			
			DIVIDE(
			    [%KHTN_Customer_miss_PLX],
			    0.31,
			    BLANK()
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: PLX
		lineageTag: 6f5ee85c-eece-4379-a0e0-47acf95f82a9

	measure 'Store_Target test_PLX' = ```
			
			[Store_Visit miss_PLX] * 0.31 * [Store_Total opportunities_plx]
			
			```
		displayFolder: PLX
		lineageTag: b28441d9-9585-4867-b9dd-3b7a869c5a6b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure KHTN_Evaluation_PLX = ```
			
			VAR _target =
			    [Store_Target test_PLX]
			VAR _ta =
			    [KHTN_TA_Rate_PLX]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(_target), BLANK(),
			        _target = 0 && ISBLANK(_ta), "Hoàn thành",
			        _ta >= 1, "Đạt",
			        _target > 0 && COALESCE(_ta, 0) < 1, "Không đạt",
			        BLANK()
			    )
			
			```
		displayFolder: PLX
		lineageTag: d82175c2-ebdd-40b2-be85-8538ed19cd2d

	measure KHTN_Evaluation_notachieve_PLX = ```
			
			VAR zT0 =
			    CALCULATETABLE(
			        SUMMARIZE(
			            DIM_BQ_Department,
			            DIM_BQ_Department[Shop+Size]
			        )
			    )
			VAR zT1 =
			    ADDCOLUMNS(
			        zT0,
			        "zDanhGia", [KHTN_Evaluation_PLX]
			    )
			RETURN
			    COUNTX(
			        FILTER(zT1, [zDanhGia] = "Không đạt"),
			        DIM_BQ_Department[Shop+Size]
			    )
			
			```
		formatString: 0
		displayFolder: PLX
		lineageTag: d59aa186-0c9e-48a4-9d25-af570c0d7156

	measure 'Total Opps_PLX' = ```
			
