	partition FACT_CR_byMaxDate = calculated
		mode: import
		source = ```
				
				VAR _MaxActiveDate =
				    CALCULATE (
				        MAX ( 'DIM_Danh mục_Ngày'[Date] ),
				        FILTER ( 'DIM_Danh mục_Ngày', 'DIM_Danh mục_Ngày'[Ngày_isActive] = 1 )
				    )
				RETURN
				ADDCOLUMNS (
				    SUMMARIZE (
				        FILTER ( 'DIM_Danh mục_Phòng ban', 'DIM_Danh mục_Phòng ban'[AM] <> BLANK() ),
				        'DIM_Danh mục_Phòng ban'[Bộ phận]
				    ),
				    "Date", _MaxActiveDate,
				    "CR", CALCULATE ( [Store_Conversion by Opportunities], 'DIM_Danh mục_Ngày'[Date] = _MaxActiveDate ),
				    "Target CR", CALCULATE ( [Store_Target_CR], 'DIM_Danh mục_Ngày'[Date] = _MaxActiveDate ),
				    "%Target CR", CALCULATE ( DIVIDE([Store_Conversion by Opportunities],[Store_Target_CR],BLANK()), 'DIM_Danh mục_Ngày'[Date] = _MaxActiveDate )
				)
				
				```

	annotation PBI_Id = 65e35450eaeb4de090569bbe37236020

