	column Ngày_isActive_Sale =
			
			VAR zMinDate =  MIN ( 'FACT_Palexy_Store'[day] )
			
			VAR zMaxDate = MAX ( 'FACT_Palexy_Store'[day] )
			
			RETURN
			    IF (
			        'DIM_Danh mục_Ngày'[Date] >= zMinDate
			            && 'DIM_Danh mục_Ngày'[Date] <= zMaxDate,
			        1,
			        0
			    )
		formatString: 0
		lineageTag: 6c611adf-9c09-4347-97cf-9e4f7fbcca96
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Tháng_IsActive =
			
			var monthx = calculate(sum('DIM_Danh mục_Ngày'[Ngày_isActive_Sale]),filter('DIM_Danh mục_Ngày','DIM_Danh mục_Ngày'[yearMonth] = earlier('DIM_Danh mục_Ngày'[yearMonth])))
			return if(monthx > 0,1,BLANK())
		formatString: 0
		lineageTag: 40fdcec8-af25-43b6-b439-388f5c1264a0
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column quy_nam
		dataType: string
		lineageTag: e93c94d7-6b45-48a6-bcec-1f88438fc293
		summarizeBy: none
		sourceColumn: quy_nam

		annotation SummarizationSetBy = Automatic

	column Ngày_isActive =
			
			VAR zMinDate =  MIN ( 'FACT_Palexy_Store'[day] )
			
			VAR zMaxDate = MAX ( 'FACT_Palexy_Store'[day] )
			
			RETURN
			    IF (
			        'DIM_Danh mục_Ngày'[Date] >= zMinDate
			            && 'DIM_Danh mục_Ngày'[Date] <= zMaxDate,
			        1,
			        0
			    )
		formatString: 0
		lineageTag: eaf9f61a-6dd6-4c86-ad21-99317877b408
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

