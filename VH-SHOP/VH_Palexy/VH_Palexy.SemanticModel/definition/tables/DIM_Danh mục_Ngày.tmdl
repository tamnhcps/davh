	partition 'DIM_Danh mục_Ngày-cffe03fa-f266-4b47-ba2b-bf033a515eb6' = m
		mode: import
		queryGroup: DIM\Ngày
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=42baee31-9dab-48af-b317-d89f4f8011db""#(lf)SELECT *,#(lf)       CURRENT_DATE('Asia/Ho_Chi_Minh') AS refresh_time#(lf)FROM cellphones-data-platform.cps_DA_General_Transform.dim_date#(lf)where 1=1#(lf)  and date >= date_sub(date_trunc(current_date('Asia/Ho_Chi_Minh'), year), interval 1 year) #(lf)  and date <= date_add(date_trunc(current_date('Asia/Ho_Chi_Minh'), year), interval 1 year)", null, [EnableFolding=true]),
				    #"Renamed Columns" = Table.RenameColumns(Source,{{"date", "Date"}}),
				    #"Sorted Rows" = Table.Sort(#"Renamed Columns",{{"Date", Order.Ascending}}),
				    #"Added Index" = Table.AddIndexColumn(#"Sorted Rows", "Index", 4, 1, Int64.Type)
				in
				    #"Added Index"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

