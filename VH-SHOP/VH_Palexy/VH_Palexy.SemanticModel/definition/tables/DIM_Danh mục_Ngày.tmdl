table 'DIM_Danh mục_Ngày'
	lineageTag: 463512df-d34c-4525-bab8-ba6b7498e80a

	column 'Giai đoạn' =
			
			VAR nam_max =
			    CALCULATE (
			        MAX ( 'DIM_Danh mục_Ngày'[year] ),
			        FILTER (
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Tháng_IsActive] = 1
			        )
			    )
			VAR thang_max =
			    CALCULATE (
			        MAX ( 'DIM_Danh mục_Ngày'[month] ),
			        FILTER (
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Tháng_IsActive] = 1
			                && 'DIM_Danh mục_Ngày'[year] = nam_max
			        )
			    )
			VAR thang_group =
			    SWITCH (
			        TRUE (),
			        'DIM_Danh mục_Ngày'[month] < thang_max,
			            "01 - "
			                & FORMAT (
			                    thang_max - 1,
			                    "0#"
			                ) & "/"
			                & FORMAT (
			                    nam_max,
			                    "#"
			                ),
			        'DIM_Danh mục_Ngày'[month] = thang_max, "Tháng hiện tại",
			        FORMAT (
			            thang_max + 1,
			            "0#"
			        ) & " - 12/"
			            & FORMAT (
			                nam_max,
			                "#"
			            )
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        'DIM_Danh mục_Ngày'[year] = nam_max , thang_group,
			        FORMAT (
			            'DIM_Danh mục_Ngày'[year],
			            "#"
			        )
			    )
		lineageTag: 65586410-44f6-4ed1-8d99-3695a84c3005
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

