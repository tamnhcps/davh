	column phone
		lineageTag: ed0cd5a7-df49-4d28-bb07-94df12e49d3f
		summarizeBy: none
		isNameInferred
		sourceColumn: FACT_Sale_Doanh số bán[phone]

		annotation SummarizationSetBy = Automatic

	partition DIM_Phone = calculated
		mode: import
		source = ```
				
				SUMMARIZE(
				    UNION(
				        CALCULATETABLE(ALLSELECTED('FACT_Sale_Doanh số bán'[phone]), 'FACT_Sale_Doanh số bán'[phone] <> BLANK()),
				        CALCULATETABLE(ALLSELECTED('FACT_App_Cài đặt app'[customer_phone]), 'FACT_App_Cài đặt app'[customer_phone] <> BLANK())),
				        'FACT_Sale_Doanh số bán'[phone])
				        
				```

