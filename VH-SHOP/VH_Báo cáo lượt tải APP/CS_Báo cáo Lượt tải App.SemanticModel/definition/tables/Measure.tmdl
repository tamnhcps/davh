table Measure
	lineageTag: a55949cc-ddbc-4e3f-bc32-d19d25c951d5

	measure Update-Filtered = ```
			
			--Update
			VAR zFmt_HeaderStart = 
				"<a> <span style='color:#000000'> <b> "
			VAR zFmt_HeaderEnd = 
				": </b> </a>"
			VAR zUpdate_time =
			    [Last_Update]
			VAR zUpdate = 
				"<font_update> <span style='color:#000000'>
			        <u> Cập nhật đến </u>: " & zUpdate_time & 
			    "</font_update>" 
			
			--Thời gian
			VAR zFil_Ngay =
			    ISFILTERED( Dim_Date[Date])
			VAR zNgay =
			    zFmt_HeaderStart & "Ngày" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( Dim_Date[Date] ), Dim_Date[Date] , ", " ) & "."
			
			VAR zFil_NamThang =
			    ISFILTERED( DIM_Date[Năm/Tháng])
			VAR zNamThang =
			    zFmt_HeaderStart & "Năm/Tháng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES(  DIM_Date[Năm/Tháng] ),  DIM_Date[Năm/Tháng] , ", " ) & "."
			
			VAR zFil_ThoiGian = 
				zFil_NamThang + 0
			
			--Chủ thể
			VAR zFil_Mien =
			    ISFILTERED( 'DIM_BQ_Miền'[Miền] )
			VAR zMien =
			    zFmt_HeaderStart & "Miền" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'DIM_BQ_Miền'[Miền] ), 'DIM_BQ_Miền'[Miền], ", " ) & "."
			
			VAR zFil_AM =
			    ISFILTERED( DIM_BQ_Shop[AM] )
			VAR zAM =
			    zFmt_HeaderStart & "AM" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( DIM_BQ_Shop[AM] ), DIM_BQ_Shop[AM] , ", " ) & "."
			
			VAR zFil_CuaHang =
			    ISFILTERED( DIM_BQ_Shop[Shop+Size])
			VAR zCuaHang =
			    zFmt_HeaderStart & "Cửa hàng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( DIM_BQ_Shop[Shop+Size] ), DIM_BQ_Shop[Shop+Size], ", " ) & "."
			
			VAR zFil_ChuThe = 
			    zFil_Mien + zFil_AM + zFil_CuaHang + 0
				
			--Final
			VAR zFilter =
			    IF(
			        zFil_ThoiGian + 
			        zFil_ChuThe = 0,
			        BLANK(),
			        "<br> <u> <span style='color:#000000'> Bộ lọc áp dụng:</u> "
			            & IF( zFil_NamThang = TRUE, zNamThang, BLANK() )
			            & IF( zFil_Mien = TRUE, zMien, BLANK() )
			            & IF( zFil_AM = TRUE, zAM, BLANK() )
			            & IF( zFil_CuaHang = TRUE, zCuaHang, BLANK() )
			    )
			RETURN
			    "<font_all> <i> <span style='color:#000000'>" & zUpdate & zFilter & "</font_all>"
			```
		displayFolder: Other
		lineageTag: 7a1e1553-fa48-42ca-aa6f-98be2d2d5b51

