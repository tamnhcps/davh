	measure 'Số cửa hàng' = ```
			
			CALCULATE(
			    DISTINCTCOUNT('FACT_Sale_Doanh số bán'[store_code])
			    )
			
			```
		formatString: 0
		lineageTag: bc41db2c-76d2-4e76-ab94-a3223dec075c

	measure 'Số cửa hàng không đạt' = ```
			
			VAR num = 
			    CALCULATE(
			    DISTINCTCOUNT('FACT_Sale_Doanh số bán'[store_code]),
			    FILTER(
			        SUMMARIZE(
			            'DIM_BQ_Shop',
			            DIM_BQ_Shop[Cửa hàng],
			            "Target",[Target],
			            "Rate",[%Tải app],
			            "AvgRate",DIVIDE([%Tải app],[Target])
			        ),
			        [AvgRate] < 1
			    )
			)
			RETURN IF(ISBLANK(num),0,num)
			```
		formatString: 0
		lineageTag: 1fdcab33-4f91-4d6f-ae91-a83e58de7930

	measure 'Số cửa hàng đạt' = ```
			
			VAR num = 
			    CALCULATE(
			    DISTINCTCOUNT('FACT_Sale_Doanh số bán'[store_code]),
			    FILTER(
			        SUMMARIZE(
			            'DIM_BQ_Shop',
			            'DIM_BQ_Shop'[Cửa hàng],
			            "Target",[Target],
			            "Rate",[%Tải app],
			            "AvgRate",DIVIDE([%Tải app],[Target])
			        ),
			        [AvgRate] >= 1
			    )
			)
			RETURN IF(ISBLANK(num),0,num)
			```
		formatString: 0
		lineageTag: 540f267f-7719-4e60-9294-880e1e851c61

