	partition Dim_BQ_Dataset = m
		mode: import
		queryGroup: 'Danh mục'
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=9a5347f2-fcf5-467a-9b55-a7d142ac9534”#(lf)#(lf)select#(lf)  dts.Id as `Id dataset`,#(lf)  dts.name as `Tên dataset`,#(lf)  dts.description as `Mô tả`,#(lf)  if( enabled = true, 'Yes', 'No' ) as `Bật cập nhật`,#(lf)  string_agg(distinct(json_times), ', ') as `Thời gian cập nhật`,#(lf)  case#(lf)    when count(distinct(json_days)) = 7 then 'Everyday'#(lf)    else string_agg(distinct(json_days), ', ')#(lf)  end as `Tần suất cập nhật`,#(lf)  m.measureCaption as `Tên chỉ số`,#(lf)  m.description as `Mô tả chỉ số`,#(lf)  m.expression as `DAX`,#(lf)  m.measureIsVisible as `Hiển thị`,#(lf)  m.measureGroupName,#(lf)  m.cubeName#(lf)from#(lf)  `cellphones-data-platform.cps_powerbi_metadata_dwh.datasets` dts#(lf)  left join `cellphones-data-platform.cps_powerbi_metadata_dwh.measure_information` m#(lf)    on dts.id = m.datasetId#(lf)  left join `cellphones-data-platform.cps_powerbi_metadata_dwh.refresh_schedule` rs#(lf)    on dts.id = rs.datasetId#(lf)  ,unnest(times) as `json_times`#(lf)  ,unnest(days) as `json_days`#(lf)where#(lf)  dts.id = 'aebc6190-e841-431d-81c2-4c0094c42fb9'#(lf)--Để tạm, sau khi publish đổi ID của báo cáo#(lf)group by#(lf)  1,2,3,4,7,8,9,10,11,12", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

