role 'Vận hành_AM'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' = ```
			'DIM_Danh mục_Ngày'[Date]>=LOOKUPVALUE('DIM_Phân quyền_User'[Startdate],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())
			
			```

	tablePermission 'DIM_Phân quyền_Vận hành' = ```
			VAR zName = 
			    LOOKUPVALUE(
			        'DIM_Phân quyền_User'[Tên],
			        'DIM_Phân quyền_User'[Mail], 
			        USERPRINCIPALNAME()
			    )
			
			VAR zTable_AddColumns = 
			    ADDCOLUMNS(
			        'DIM_Danh mục_Phòng ban',
			        "zPath",
			        LOOKUPVALUE(
			            'DIM_Phân quyền_User'[Path],
			            'DIM_Phân quyền_User'[Tên], 
			            'DIM_Phân quyền_Vận hành'[Leader]
			        )
			    )
			
			VAR zFilteredTable = 
			    FILTER(
			        zTable_AddColumns,
			        PATHCONTAINS([zPath], zName)
			    )
			
			VAR zDistinctStores = 
			    DISTINCT(
			        SELECTCOLUMNS(
			            zFilteredTable,
			            "Cửa hàng", 'DIM_Danh mục_Phòng ban'[Cửa hàng]
			        )
			    )
			
			RETURN
			IF(
			    LOOKUPVALUE('DIM_Phân quyền_User'[Title], 'DIM_Phân quyền_User'[Mail], USERPRINCIPALNAME()) = "AM",
			    [Cửa hàng] IN zDistinctStores,
			    TRUE
			)
			```

	annotation PBI_Id = 8902a9db43824db2ba7edbe816f9e280

