	column Contactphone = LOOKUPVALUE('FACT_Sale_Doanh số bán'[ContactPhone],'FACT_Sale_Doanh số bán'[AutoCode], FACT_Code_DaSuDung[AutoCode])
		lineageTag: f44026a3-7314-4e32-8b80-5f7f8ad0f323
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'TakeValue thực' =
			
			VAR value_percent =
			    IF (
			        FACT_Code_DaSuDung[TakeMaxAmount]
			            = BLANK (),
			        DIVIDE (
			            'FACT_Code_DaSuDung'[Dso] * FACT_Code_DaSuDung[TakeValue],
			            100
			        ),
			        MIN (
			            DIVIDE (
			                'FACT_Code_DaSuDung'[Dso]  * FACT_Code_DaSuDung[TakeValue],
			                100
			            ),
			            FACT_Code_DaSuDung[TakeMaxAmount]
			        )
			    )
			RETURN
			    IF (
			        FACT_Code_DaSuDung[IsPercent]
			            =True,
			        value_percent,
			        FACT_Code_DaSuDung[TakeValue]
			    )
		formatString: #,0
		lineageTag: 86419be0-7bb0-4e5d-b107-b8e119760b8e
		summarizeBy: sum

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column Dso_SĐT =
			
			VAR minindex =
			    CALCULATE(
			        MIN( FACT_Code_DaSuDung[Index] ),
			        FILTER(
			            FACT_Code_DaSuDung,
			            FACT_Code_DaSuDung[Contactphone] = EARLIER( FACT_Code_DaSuDung[Contactphone] )
			                && FACT_Code_DaSuDung[Date_Used] = EARLIER( FACT_Code_DaSuDung[Date_Used] )
			        )
			    )
			RETURN
			    CALCULATE(
			        [Dso],
			        FILTER(
			            'FACT_Sale_Doanh số bán',
			            'FACT_Sale_Doanh số bán'[ContactPhone]
			                = EARLIER( FACT_Code_DaSuDung[Contactphone] )
			                && 'FACT_Sale_Doanh số bán'[Date] = EARLIER( FACT_Code_DaSuDung[Date_Used] )
			                && FACT_Code_DaSuDung[Index] = minindex
			        )
			    )
		lineageTag: 32fdd29d-d2a6-4c5a-9d27-4eb1a209975d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Code AM_SM' =
			
			SWITCH(
			    TRUE(),
			    SIGN(CALCULATE(COUNTROWS(DIM_PromotionCode),FILTER(DIM_PromotionCode, DIM_PromotionCode[PromotionCodeId]=EARLIER(FACT_Code_DaSuDung[Id]) && DIM_PromotionCode[SM] = 1))) = 1, "SM",
			    SIGN(CALCULATE(COUNTROWS(DIM_PromotionCode),FILTER(DIM_PromotionCode, DIM_PromotionCode[PromotionCodeId]=EARLIER(FACT_Code_DaSuDung[Id]) && DIM_PromotionCode[AM] = 1))) = 1, "AM",
			    BLANK()
			)
		lineageTag: 43ace223-f7d0-4881-9971-61307206a044
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

