	column Dso =
			
			VAR minindex =
			    CALCULATE (
			        MIN ( FACT_Code_DaSuDung[Index] ),
			        FILTER (
			            FACT_Code_DaSuDung,
			            FACT_Code_DaSuDung[AutoCode]
			                = EARLIER ( FACT_Code_DaSuDung[AutoCode] )
			        )
			    )
			VAR Dso_Not_BHMR=CALCULATE (
			                        [Dso],
			                        FILTER (
			                            'FACT_Sale_Doanh số bán',
			                            'FACT_Sale_Doanh số bán'[AutoCode]
			                                = EARLIER ( FACT_Code_DaSuDung[AutoCode] )
			                                && FACT_Code_DaSuDung[Index] = minindex
			                        )
			                    )
			VAR Dso_BHMR=CALCULATE (
			                        [Dso],
			                        FILTER (
			                            'FACT_Sale_Doanh số bán',
			                            'FACT_Sale_Doanh số bán'[AutoCode]
			                                = EARLIER ( FACT_Code_DaSuDung[AutoCode] )
			                                && FACT_Code_DaSuDung[Index] = minindex
			                                && 'FACT_Sale_Doanh số bán'[DMC3]="BH CŨ"
			                        )
			                    )
			RETURN SWITCH(TRUE(),'FACT_Code_DaSuDung'[ChuongTrinh]="Ban kem BHMR_SM"||'FACT_Code_DaSuDung'[ChuongTrinh]="Ban kem BHMR_AM",Dso_BHMR,Dso_Not_BHMR)
		formatString: #,0
		lineageTag: 318c3051-7a9f-4088-aff3-d5540a444aab
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

