	partition FACT_Code_DaSuDung-276cdaf6-8bb6-415e-aa55-9f13997596cf = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform"]}[Data], "with --BẢN FIX#(lf)_promotion_raw as --tạo bảng promotion_raw để phân loại phân bổ#(lf)(#(lf)  select#(lf)    code.id as `code_id`,#(lf)    code.name as `code_name`,#(lf)    case#(lf)      when sign(count(pro.ProductId)) = 1 then 'product_id'#(lf)      when sign(count(prg.ProductGroupId)) = 1 then 'product_group_id'#(lf)      else 'all'#(lf)    end as `allocate_type`,#(lf)    case#(lf)      when sign(count(pro.ProductId)) = 1 then 1#(lf)      when sign(count(prg.ProductGroupId)) = 1 then 2#(lf)      else 3#(lf)    end as `allocate_type_id`#(lf)  from#(lf)    `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_PromotionCode` as code#(lf)    left join `cellphones-data-platform.cps_sql_server_live_shared_data_dwh.SO_PromotionCodeProduct` as pro#(lf)      on pro.PromotionCodeId = code.Id#(lf)    left join `cellphones-data-platform.cps_sql_server_live_shared_data_dwh.SO_PromotionCodeProductGroup` as prg#(lf)      on prg.PromotionCodeId = code.Id and prg.Inactive is not true#(lf)  group by#(lf)    1,2#(lf)  qualify row_number() over(partition by code_id order by allocate_type_id asc) = 1#(lf)),#(lf)#(lf)_promotion as --lấy thông tin code đã sử dụng#(lf)(#(lf)  select#(lf)    raw.code_id,#(lf)    raw.code_name,#(lf)    raw.allocate_type,#(lf)    log.AutoCode,#(lf)    log.Code,#(lf)    log.TakeValue,#(lf)    date_diff(detail.UsingDate, detail.CreateDate, hour) as redeem_hour#(lf)  from#(lf)    `cellphones-data-platform.cps_cdc_sep_shared_data_dbo.SO_PromotionCodeLog` as log#(lf)    left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_PromotionCodeDetail` as detail#(lf)      on detail.Code = log.Code#(lf)    inner join _promotion_raw as raw#(lf)      on raw.code_id = log.PromotionCodeId#(lf)  where#(lf)    1 = 1#(lf)    and log.CancelDate is null#(lf)    and log.IsOrder = false --chỉ lấy các đơn SP, loại trừ các đơn DH#(lf)),#(lf)#(lf)_sale as --tạ