	column Len_Contact = len(FACT_Code_DaSuDung[Contactphone])
		formatString: 0
		lineageTag: b0a94a74-3f91-46a3-97dc-e96fdb53930c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Is_SĐT nv' =
			
			VAR is_nv =
			    CALCULATE (
			        COUNTROWS ( 'DIM_Danh mục_Nhân viên' ),
			        FILTER (
			            'DIM_Danh mục_Nhân viên',
			            'DIM_Danh mục_Nhân viên'[WorkingPhone]
			                = EARLIER ( FACT_Code_DaSuDung[ContactPhone] )
			        )
			    )
			VAR is_nv_2 =
			    CALCULATE (
			        COUNTROWS ( 'DIM_Danh mục_Nhân viên' ),
			        FILTER (
			            'DIM_Danh mục_Nhân viên',
			            'DIM_Danh mục_Nhân viên'[Telephone]
			                = EARLIER ( FACT_Code_DaSuDung[ContactPhone] )
			        )
			    )
			RETURN
			    IF (
			        FACT_Code_DaSuDung[Contactphone]
			            <> BLANK (),
			        IF (
			            is_nv > 0
			                || is_nv_2 > 0,
			            1,
			            BLANK ()
			        )
			    )
		formatString: 0
		lineageTag: 21cec31f-8b5d-48b2-9c7e-4a66fa58f94b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Imei = CALCULATE(FIRSTNONBLANK('FACT_Sale_Doanh số bán'[imei],0),filter('FACT_Sale_Doanh số bán','FACT_Sale_Doanh số bán'[AutoCode]=EARLIER( FACT_Code_DaSuDung[AutoCode])))
		lineageTag: af33a70e-d430-44c4-b1bb-48f1c6cc9bc9
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Ngày sử dụng code AM/SM gần nhất' =
			
			CALCULATE (
			    MIN ( FACT_Code_DaSuDung[UsingDate] ),
			    FILTER (
			        FACT_Code_DaSuDung,
			        FACT_Code_DaSuDung[Contactphone]
			            = EARLIER ( FACT_Code_DaSuDung[Contactphone] )
			            && ( FACT_Code_DaSuDung[Code AM_SM] = "AM"
			            || FACT_Code_DaSuDung[Code AM_SM] = "SM" )
			            && FACT_Code_DaSuDung[UsingDate]
			                > EARLIER ( FACT_Code_DaSuDung[UsingDate] )
			    )
			)
		formatString: General Date
		lineageTag: 3a0ff3a1-13b2-4ce9-ac5c-05700f2db67b
		summarizeBy: none

		variation Variation
			isDefault
			relationship: fcf38cc9-6962-4395-86d7-111aeda0c8bb
			defaultHierarchy: LocalDateTable_01fce7e2-511b-4d39-a573-cc6dd54bd51d.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'Kc.tg' = IF(FACT_Code_DaSuDung[Ngày sử dụng code AM/SM gần nhất]= BLANK(), BLANK(), FACT_Code_DaSuDung[Ngày sử dụng code AM/SM gần nhất]- FACT_Code_DaSuDung[UsingDate])
