	column Startdate_Cre = STARTOFMONTH(FACT_Code_DaSuDung[Date_Cre])
		formatString: Short Date
		lineageTag: 7e709178-f1fe-4865-8f17-cf554cea89f2
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 9cbc9176-274a-4934-a189-912a6888a993
