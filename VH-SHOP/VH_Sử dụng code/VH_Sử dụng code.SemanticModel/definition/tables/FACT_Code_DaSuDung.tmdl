	column 'Dso chưa ck' = ```
			
			VAR minindex =
			    CALCULATE (
			        MIN ( FACT_Code_DaSuDung[Index] ),
			        FILTER (
			            FACT_Code_DaSuDung,
			            FACT_Code_DaSuDung[AutoCode]
			                = EARLIER ( FACT_Code_DaSuDung[AutoCode] )
			        )
			    )
			var dso=
			    CALCULATE (
			        sum(FACT_Code_DaSuDung[Dso]),
			        FILTER (
			            FACT_Code_DaSuDung,
			            FACT_Code_DaSuDung[AutoCode]
			                = EARLIER ( FACT_Code_DaSuDung[AutoCode] )
			                && FACT_Code_DaSuDung[Index] = minindex
			        )
			    )
			var dis_smem=
			    CALCULATE (
			        sum(FACT_Code_DaSuDung[Smember_Discount]),
			            FACT_Code_DaSuDung,
			            FACT_Code_DaSuDung[AutoCode]
			                = EARLIER ( FACT_Code_DaSuDung[AutoCode] )
			                && FACT_Code_DaSuDung[Index] = minindex
			        )
			    
			return if(FACT_Code_DaSuDung[Index]=minindex, dso + dis_smem, BLANK())
			```
		lineageTag: 02eb8d60-2e4a-474c-ab53-5825b987084c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

