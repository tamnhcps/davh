	column 'Is.CampaignPeriod' =
			
			VAR ngaybatdau = date(2025,06,06)
			VAR ngayketthuc = date(2025,10,31)
			RETURN
			    IF (
			        'D_Ngày'[Date] >= ngaybatdau
			            && 'D_Ngày'[Date] <= ngayketthuc,
			        1,
			        0
			    )
		formatString: 0
		lineageTag: e8c88560-19b4-4c4a-9a76-752fb121480d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition D_Ngày = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=7abaff99-dd11-48ca-a4aa-2fc1ae086ba5”#(lf)SELECT *#(lf)FROM cellphones-data-platform.cps_DA_General_Transform.dim_date#(lf)where date between '2023-01-01' and '2025-12-31'", null, [EnableFolding=true])
				in
				    Source

