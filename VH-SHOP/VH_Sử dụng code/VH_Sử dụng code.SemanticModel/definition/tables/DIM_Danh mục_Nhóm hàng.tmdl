	column 'Phân nhóm' = ```
			
			VAR phannhom =
			    SWITCH (
			        TRUE (),
			        'DIM_Danh mục_Nhóm hàng'[Brand] = "NOKIA"
			            || 'DIM_Danh mục_Nhóm hàng'[Brand] = "OPPO"
			            || 'DIM_Danh mục_Nhóm hàng'[Brand] = "REALME"
			            || 'DIM_Danh mục_Nhóm hàng'[Brand] = "VIVO"
			            || 'DIM_Danh mục_Nhóm hàng'[Brand] = "HONOR","NHÓM 1",
			        'DIM_Danh mục_Nhóm hàng'[Brand] = "SAMSUNG"
			            || 'DIM_Danh mục_Nhóm hàng'[Brand] = "XIAOMI", "NHÓM 2",
			        "NHÓM 3"
			    )
			RETURN
			    IF (
			        'DIM_Danh mục_Nhóm hàng'[Nhóm hàng]  = "ANDROID",
			        phannhom,
			        'DIM_Danh mục_Nhóm hàng'[Nhóm hàng]  
			    )
			```
		lineageTag: 351f966a-ef5e-4adb-b4c2-7ca9c886abc1
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Nhóm Apple' = ```
			
			    SWITCH( 
			        TRUE(),
			        'DIM_Danh mục_Nhóm hàng'[Nhóm] = "APPLE" 
			        && 'DIM_Danh mục_Nhóm hàng'[Level2] = "CTM" 
			        && 'DIM_Danh mục_Nhóm hàng'[Level4] <> BLANK(), 
			        'DIM_Danh mục_Nhóm hàng'[SubBrand],
			        'DIM_Danh mục_Nhóm hàng'[Nhóm hàng] = "PHỤ KIỆN APPLE", "PK APPLE",
			        BLANK())
			```
		lineageTag: 9e9b9ab9-f11d-45b6-b2b6-559f75e82d91
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Nhóm =
			
			SWITCH (
			    TRUE (),
			    'DIM_Danh mục_Nhóm hàng'[Nhóm hàng cấp 2] = "ĐIỆN MÁY", "ĐIỆN MÁY",
			    'DIM_Danh mục_Nhóm hàng'[Nhóm hàng cấp 2] = "Gia Dụng", "GIA DỤNG",
			    'DIM_Danh mục_Nhóm hàng'[Brand] = "APPLE", "APPLE",
			    'DIM_Danh mục_Nhóm hàng'[Brand] = "DEMO", "DEMO",
			    'DIM_Danh mục_Nhóm hàng'[Brand] = "LAPTOP"
			        || 'DIM_Danh mục_Nhóm hàng'[Brand] = "PC"
			        || 'DIM_Danh mục_Nhóm hàng'[Brand] = "SURFACE", "LAPTOP/PC",
			    'DIM_Danh mục_Nhóm hàng'[Brand] <> BLANK() && NOT 'DIM_Danh mục_Nhóm hàng'[Nhóm hàng] IN {"TRANG TRÍ", "VẬT TƯ ĐIỆN TỬ"}, "ANDROID",
			    BLANK ()
			)
		lineageTag: 602e5e62-5f95-44c4-a23e-6b96276684f8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'DIM_Danh mục_Nhóm hàng' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=079001d0-99cb-48c3-86c4-0130e59b27d3""#(lf)Select #(lf)nhom_hang#(tab)`Nhóm hàng`,#(tab)#(tab)#(lf)nhom_hang_cap_1 `Nhóm hàng cấp 1`,#(tab)#(tab)#(tab)#(lf)case when nhom_hang in ('TIVI', 'Máy Ảnh') then 'ĐIỆN MÁY' else nhom_hang_cap_2 end as#(tab)`Nhóm hàng cấp 2`,#(tab)#(tab)#(lf)case when nhom_hang in ('DỊCH VỤ','Nhóm hàng Voucher','VC SAMSUNG','SAMSUNG BH') then 'DỊCH VỤ'#(lf)when nhom_hang in ('CÔNG CỤ DỤNG CỤ','HÀNG HÓA','Đồng phục - kho HC') then 'HÀNG HÓA'#(lf)when nhom_hang = 'CHUA SỬ DỤNG' then 'HÀNG HÓA ĐƠN'#(lf)when nhom_hang in ('LAPTOP CŨ','LAPTOP CTM','SURFACE CTM','LAPTOP BH','PC_SSD') then 'LAPTOP'#(lf)when nhom_hang in ('LINH KIỆN','PC_CASE','PC_CPU','PC_KHÁC','PC_MAIN','PC_NGUỒN','PC_Ổ CỨNG','PC_RAM','PC_TẢN NHIỆT','PC_VGA','PC_VỎ') then 'LINH KIỆN'#(lf)when nhom_hang in ('PHỤ KIỆN','PHỤ KIỆN SALE','PK - XẢ TỒN','PKDEMO') then 'PHỤ KIỆN'#(lf)when nhom_hang in ('APPLE WATCH CTM','APPLE WATCH CŨ','APPLE WATCH BH') then 'SMARTWATCH'#(lf)else nganh_hang end as `Ngành hàng`,#(tab)#(tab)#(tab)#(lf)thuoc_tinh `Thuộc tính`,#(tab)#(tab)#(tab)#(lf)level Level,#(tab)#(tab)#(tab)#(lf)level1 Level1,#(tab)#(tab)#(tab)#(lf)case when nhom_hang in ('TIVI', 'Máy Ảnh') then 'ĐIỆN MÁY' else level2 end as Level2,#(tab)#(tab)#(tab)#(lf)Level3 Level3,#(tab)#(tab)#(tab)#(lf)Level4 Level4,#(tab)#(tab)#(tab)#(lf)ban_kem#(tab)`Bán kèm`,#(tab)#(tab)#(lf)sub_brand SubBrand,#(lf)brand#(tab)Brand,#(tab)#(tab)#(lf)thi_dua_s_star `Thi đua S-Star`,#(tab)#(tab)#(tab)#(lf)nhom_s_star#(tab)`Nhóm S-Star`,#(tab)#(tab)#(lf)he_so_thi_dua_phu_kien `Hệ số thi đua phụ kiện`,#(tab)#(tab)#(tab)#(lf)nhom_s_star_index `Nhóm S-Star_Index`#(tab)#(tab)#(tab)#(lf)from `cellphones-data-platform.cps_DA_General_Transform.dim_product_group`#(lf)where not nhom_hang in ('DỊCH VỤ LAPTOP','KIỂM TRA NHÓM HÀNG  - ACITON SỬA','PHỤ KIỆN MACBOOK','DÁN MÀN HÌNH','DỊCH VỤ TIVI','LINH KIỆN LAPTOP','LAPTOP_MÀN HÌNH','LAPTOP_PIN LINH KIỆN','LAPTOP_BÀN PHÍM','LAPTOP_MAIN','LAPTOP_RAM','LAPTOP_Ổ CỨNG','LAPTOP_KHÁC','LAPTOP_LOA','LAPTOP_VỎ MÁY','DÁN VA ĐẬP','DÁN VA ĐẬP CAO CẤP','erp test nhóm hàng','IPHONECTM','LAPTOP_PIN CHÍNH HÃNG','MÀN HÌNH ANDROID','MÀN HÌNH APPLE','ỐP BAO DA', 'LAPTOP CŨ','HÀNG BẢO HÀNH', 'ĐIỆN TỬ', 'CŨ', 'DTH CŨ', 'CTM')", null, [EnableFolding=true]),
				    #"Appended Query" = Table.Combine({Source, NhomHang_LaptopCu})
				in
				    #"Appended Query"

