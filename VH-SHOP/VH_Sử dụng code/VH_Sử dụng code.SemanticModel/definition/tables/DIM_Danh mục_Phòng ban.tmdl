	column 'Khu vực' =
			
			IF(
			    LEFT('DIM_Danh mục_Phòng ban'[Cửa hàng], 4) = "CPS-"
			                    && 'DIM_Danh mục_Phòng ban'[AM] <> BLANK(),
			                        MID('DIM_Danh mục_Phòng ban'[Cửa hàng], 5, 3),
			                        BLANK()
			)
		lineageTag: af4feaa4-3e14-4562-8112-efdbe6a38c74
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

