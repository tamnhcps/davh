		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=54cfc7b0-4cd1-4ab1-87fd-85c6e135d1ac""#(lf)SELECT#(lf)  hara_id HaraID,#(lf)  ma_bo_phan `Mã Bộ phận`,#(lf)  bo_phan `Cửa hàng`,#(lf)  ma_kho `Mã kho`,#(lf)  level_2 lv2,#(lf)  level_3 lv3,#(lf)  level_4 lv4,#(lf)  level_5 lv5,#(lf)  level_6 lv6,#(lf)  level_7 lv7,#(lf)  Latitude || ',' || Longitude `Lat-Long`,#(lf)  branch_id BranchId,#(lf)  is_inactive IsInactive,#(lf)  hara_workplace_name HaraWorkPlaceName,#(lf)  cong_ty `Công ty`,#(lf)  short_name `Tên ngắn gọn`,#(lf)  van_phong_cua_hang `Cửa hàng_Văn phòng`,#(lf)  mien `Miền`,#(lf)  vung `Vùng`,#(lf)  khoi `Khối`,#(lf)  phong `Phòng`,#(lf)  tinh_thanh_pho `Tỉnh_Thành phố`,#(lf)  quan_huyen `Quận_Huyện`,#(lf)  khai_truong `Ngày khai trương`,#(lf)  dong_cua `Ngày bán cuối cùng`,#(lf)  ngang_m `Chiều ngang`,#(lf)  sau_m `Chiều rộng`,#(lf)  tong_m2 `Diện tích tổng`,#(lf)  dien_tich_ban_hang `Diện tích shop`,#(lf)  am AM,#(lf)  size SIZE,#(lf)  rsm RSM#(lf)FROM#(lf)  `cellphones-data-platform.cps_DA_General_Transform.dim_department`#(lf)WHERE cong_ty = 'CPS' AND van_phong_cua_hang = 'Cửa Hàng'", null, [EnableFolding=true])
