	measure 'Giá trị code_used_LM g%' =
			
			VAR slg_lm_g =
			    DIVIDE (
			        [Giá trị code_used],
			        [Giá trị code_used_LM],
			        BLANK ()
			    ) - 1
			RETURN
			    IF (
			        [Giá trị code_used] <> 0
			            && [Giá trị code_used_LM] <> 0,
			        slg_lm_g,
			        0
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Code\Giá trị sử dụng
		lineageTag: 018301e2-cf3e-4b72-a3d9-8a05d1b34830

