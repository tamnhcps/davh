	measure Dso_Target = ```
			
			VAR target =
			    CALCULATE (
			        SUM ( 'FACT_Sale_Target'[Target] ),
			        'FACT_Sale_Target'[Type] = "DSO TARGET"
			    )
			VAR dso_iP17 =
			    CALCULATE (
			        [Dso],
			        FILTER (
			            'DIM_Danh mục_Sản phẩm',
			            CONTAINSSTRING ( 'DIM_Danh mục_Sản phẩm'[Mã hàng], "APP-IP17" )
			            || CONTAINSSTRING ( 'DIM_Danh mục_Sản phẩm'[Mã hàng], "APP-IP-AIR" )
			        ),
			        FILTER (
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Date] >= DATE ( 2025, 9, 19 )
			            && 'DIM_Danh mục_Ngày'[Date] <= DATE ( 2025, 9, 30 )
			        )
			    )
			RETURN
			    target + dso_iP17
			
			```
		formatString: #,0
		displayFolder: 0. Datamodel\Doanh số
		lineageTag: 2787891a-5309-4f19-b040-ce80456f7d8f

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Dso_Target %' =
			
			var shop =
			DIVIDE (
			    [Dso],
			    [Dso_Target],
			    1
			)
			var nv =
			CALCULATE(
			    DIVIDE (
			    [Dso],
			    [Dso_Target]),
			    ALL ( 'DIM_Danh mục_Nhân viên' ))
			return IF(ISINSCOPE('DIM_Danh mục_Nhân viên'[Mã-tên]), nv, shop)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 0. Datamodel\Doanh số
		lineageTag: a46f9fd5-9f6b-4a06-8c54-44fe3c08558d

