	measure 'Tỷ lệ vượt ngân sách' = ```
			
			VAR StoreTableViPham = 
			    FILTER(
			        ADDCOLUMNS(
			            VALUES('DIM_Danh mục_Phòng ban'[Cửa hàng]),
			            "ThucTe", [Giá trị code_used],
			            "NganSach", [_target_su_dung_abs],
			            "PhanVuot", [Giá trị code_used] - [_target_su_dung_abs]
			        ),
			        [ThucTe] > [NganSach] 
			    )
			
			VAR TongTienVuot = SUMX(StoreTableViPham, [PhanVuot])
			VAR TongNganSachViPham = SUMX(StoreTableViPham, [NganSach])
			
			RETURN
			DIVIDE(
			    TongTienVuot, 
			    TongNganSachViPham, 
			    BLANK()
			)
