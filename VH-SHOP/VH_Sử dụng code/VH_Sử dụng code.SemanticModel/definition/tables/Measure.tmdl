	measure 'Số đơn code > 30%' =
			
			VAR _OrderTable =
			    ADDCOLUMNS (
			        SUMMARIZE (
			            FILTER (
			                FACT_Code_DaSuDung,
			                FACT_Code_DaSuDung[Is_Use] = 1
			                    && FACT_Code_DaSuDung[Id] IN { 3283, 3284, 3285, 3287, 2859, 3121 }
			            ),
			            FACT_Code_DaSuDung[AutoCode]
			        ),
			        "GiaTriCode", CALCULATE ( SUM ( FACT_Code_DaSuDung[TakeValue thực] ) ),
			        "GiaTriDonHang", CALCULATE ( MAX ( FACT_Code_DaSuDung[gia_tri_don_hang_ap_dung_code] ) )
			    )
			RETURN
			    COUNTROWS (
			        FILTER (
			            _OrderTable,
			            DIVIDE ( [GiaTriCode], [GiaTriDonHang], 0 ) > 0.3
			        )
			    )
		formatString: 0
		displayFolder: Code new
		lineageTag: 559f85d1-8334-4750-9873-09c5631ffd9e

	measure 'Giá trị code_used > 30%' =
			
			VAR _OrderTable =
			    ADDCOLUMNS (
			        SUMMARIZE (
			            FILTER (
			                FACT_Code_DaSuDung,
			                FACT_Code_DaSuDung[Is_Use] = 1
			                    && FACT_Code_DaSuDung[Id] IN { 3283, 3284, 3285, 3287, 2859, 3121 }
			            ),
			            FACT_Code_DaSuDung[AutoCode]
			        ),
			        "GiaTriCode", CALCULATE ( SUM ( FACT_Code_DaSuDung[TakeValue thực] ) ),
			        "GiaTriDonHang", CALCULATE ( MAX ( FACT_Code_DaSuDung[Dso] ) )
			    )
			RETURN
			    SUMX (
			        FILTER (
			            _OrderTable,
			            DIVIDE ( [GiaTriCode], [GiaTriDonHang], 0 ) > 0.3
			        ),
			        [GiaTriCode]
			    )
		displayFolder: Code new
		lineageTag: 9633220b-45ad-46f2-91e2-2530a7fbf8eb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Chênh lệch hạn mức code > 30%' =
			
			[_target_su_dung_abs] - [Giá trị code_used > 30%]
		displayFolder: Code new
		lineageTag: cea67baf-babf-4888-941c-b81ee6c73f93

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Tỷ lệ SD Code trên Ngân sách > 30%' =
			
			DIVIDE (
			    [Giá trị code_used > 30%],
			    [_target_su_dung_abs],
			    0
			)
		displayFolder: Code new
		lineageTag: 35d2b80b-f762-42e5-99f2-5d3f5dbdb788

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Số phiếu code > 30%' =
			
			VAR _BangDonCode =
			    ADDCOLUMNS (
			        SUMMARIZE (
			            FILTER (
			                FACT_Code_DaSuDung,
			                FACT_Code_DaSuDung[Is_Use] = 1
			                    && FACT_Code_DaSuDung[Id] IN { 3283, 3284, 3285, 3287, 2859, 3121 }
			            ),
			            FACT_Code_DaSuDung[AutoCode],
			            FACT_Code_DaSuDung[Code]
			        ),
			        "GiaTriCode",
			            CALCULATE (
			                SUM ( FACT_Code_DaSuDung[allocate_take_value] )
			            ),
			        "GiaTriDonHang",
			            CALCULATE (
			                MAX ( FACT_Code_DaSuDung[gia_tri_don_hang_ap_dung_code] )
			            )
			    )
			
			VAR _BangViPham =
			    FILTER (
			        _BangDonCode,
			        DIVIDE ( [GiaTriCode], [GiaTriDonHang], 0 ) > 0.3
			    )
			
			RETURN
			    COUNTROWS (
			        SUMMARIZE (
			            _BangViPham,
			            FACT_Code_DaSuDung[AutoCode]
			        )
			    )
		formatString: 0
		displayFolder: Code new
		lineageTag: 81c1f7aa-167a-4ada-892f-da19021a53d0

