	measure 'Dso_trong chtr' =
			
			calculate(
			    [Dso]
			    ,filter( 'FACT_Sale_Doanh số bán', 'FACT_Sale_Doanh số bán'[Is_useCode] = 1 )
			)
		displayFolder: Sale
		lineageTag: 5a4322ea-a0a6-47af-b58c-34ad15c8649f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Slg_trong chtr' = ```
			
			calculate(
			    [Slg]
			    ,filter(
			        addcolumns(
			            'FACT_Sale_Doanh số bán'
			            ,"is_code_kd"
			            ,var _nhom_hang = 
			                sign(
			                    countrows(
			                        filter( 
			                            F_Code_LoaiSuDung, 
			                            F_Code_LoaiSuDung[ngay_bat_dau] <= earlier([Date])
			                                && F_Code_LoaiSuDung[ngay_ket_thuc] >= earlier([Date])
			                                && F_Code_LoaiSuDung[loai_ap_dung] = "Nhóm hàng"
			                                && F_Code_LoaiSuDung[gia_tri] = earlier([DMC3])
			                        )
			                    )
			                )
			
			            var _ma_hang = 
			                sign(
			                    countrows(
			                        filter( 
			                            F_Code_LoaiSuDung, 
			                            F_Code_LoaiSuDung[ngay_bat_dau] <= earlier([Date])
			                                && F_Code_LoaiSuDung[ngay_ket_thuc] >= earlier([Date])
			                                && F_Code_LoaiSuDung[loai_ap_dung] = "Mã hàng"
			                                && F_Code_LoaiSuDung[gia_tri] = earlier([ProductCode])
			                        )
			                    )
			                )
			
			            var _x = if( _nhom_hang + _ma_hang >= 1, 1 , 0 )
			            return _x
			        )
			        ,[is_code_kd] = 1
			    )
			)
			```
		formatString: #,0
		displayFolder: Sale
		lineageTag: f208a0d8-1e4a-41aa-a4f4-22539ddafcfc

		annotation PBI_FormatHint = {"isDecimal":true}

