	measure Slg_Android = ```
			
			VAR Slg_nhom1 =
			    CALCULATE (
			        [Slg_Thi đua],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			            && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			                && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 1"
			        ),      
			        FILTER (
			            'DIM_Danh mục_Sản phẩm',
			            'DIM_Danh mục_Sản phẩm'[Android_exp] = BLANK () 
			        ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Date] < DATE(2024,9,1))
			    )
			VAR Slg_nhom1_moi =
			    CALCULATE (
			        [Slg_Thi đua],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			            && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			            && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 1"
			            && 'DIM_Danh mục_Nhóm hàng'[Nhóm hàng] <> "NOKIA CTM"
			        ),      
			        FILTER (
			            'DIM_Danh mục_Sản phẩm',
			            'DIM_Danh mục_Sản phẩm'[Android_exp] = BLANK () 
			        ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Date] >= DATE(2024,9,1))
			    )
			VAR Slg_nhom2 =
			    CALCULATE (
			        [Slg_Thi đua],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			                && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			                && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 2"
			        ),
			        FILTER (
			            'DIM_Sale_Giá bán',
			            'DIM_Sale_Giá bán'[IsTamTrung] = 1
			        ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Năm] <= 2023)
			    )
			VAR Slg_nhom2_moi =
			    CALCULATE (
			        [Slg_Thi đua],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			                && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			                && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 2"
			        ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Năm] >= 2024)
			
			    )
			VAR Slg_nhom3 =
			    CALCULATE (
			        [Slg_Thi đua],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			                && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			                && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 3"
			        ),
			        FILTER (
			            'DIM_Danh mục_Sản phẩm',
			            'DIM_Danh mục_Sản phẩm'[Android_exp] = BLANK () 
			        ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Date] < DATE(2024,9,1))
			    )
			VAR Slg_nhom3_moi =
			    CALCULATE (
			        [Slg_Thi đua],
			        FILTER (
			            'DIM_Danh mục_Nhóm hàng',
			            'DIM_Danh mục_Nhóm hàng'[Nhóm] = "ANDROID"
			            && 'DIM_Danh mục_Nhóm hàng'[Thuộc tính]= "MỚI"
			            && 'DIM_Danh mục_Nhóm hàng'[Phân nhóm] = "NHÓM 3"
			            && 'DIM_Danh mục_Nhóm hàng'[Nhóm hàng] <> "MASSTEL CTM"
			        ),      
			        FILTER (
			            'DIM_Danh mục_Sản phẩm',
			            'DIM_Danh mục_Sản phẩm'[Android_exp] = BLANK () 
			        ),
			        FILTER(
			            'DIM_Danh mục_Ngày',
			            'DIM_Danh mục_Ngày'[Date] >= DATE(2024,9,1))
			    )
			VAR Slg_android_tamtrung = Slg_nhom1 + Slg_nhom2 + Slg_nhom3 +  Slg_nhom1_moi +  Slg_nhom2_moi +  Slg_nhom3_moi
			RETURN
			    Slg_android_tamtrung
			```
		displayFolder: 0. Datamodel\Thi đua Android
		lineageTag: 7f5a1f05-d669-4292-bb60-73c44e9d0933

