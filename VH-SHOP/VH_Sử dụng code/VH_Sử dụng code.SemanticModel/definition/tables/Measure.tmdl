	measure '_target_su_dung_abs 1' = ```
			
			VAR _CurrentChartDate = MAX('DIM_Danh mục_Ngày'[Date]) 
			VAR _date = 
			    CALCULATE(
			        MAX(FACT_Code_TargetSuDung[Ngày bắt đầu]),
			        FACT_Code_TargetSuDung[Ngày bắt đầu] <= _CurrentChartDate
			    )
			VAR _target_per = 
			    CALCULATE(
			        MAX(FACT_Code_TargetSuDung[Tỷ trọng hạn mức]),
			        FACT_Code_TargetSuDung[Ngày bắt đầu] = _date
			    )
			VAR _BaseDso = 
			    SUMX(
			        DIM_PromotionCode,
			        SWITCH( TRUE(),
			            DIM_PromotionCode[PromotionCodeId] IN {3283,3284,3285,3287}, [Dso],
			            DIM_PromotionCode[PromotionCodeId] IN {2859,3121}, [Dso_BHMR],
			            DIM_PromotionCode[PromotionCodeId] IN {3742}, [Dso_IPHONE],
			            0
			        )
			    )
			RETURN 
			    _BaseDso * _target_per
			```
		displayFolder: 0. Datamodel
		lineageTag: b5100d3f-9d87-4d8a-9b10-cb7f18361e66

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Quỹ được phân bổ' = ```
			
			VAR __MonthContext =
			    VALUES ( 'DIM_Danh mục_Ngày'[Năm/Tháng] )
			RETURN
			    CALCULATE (
			        SUMX (
			            ADDCOLUMNS (
			                F_TargetCodeShop,
			                "__quy",
			                    IF (
			                        F_TargetCodeShop[loai_target] = "Quỹ sử dụng",
			                        F_TargetCodeShop[gia_tri_trb_ngay],
			                        F_TargetCodeShop[gia_tri_trb_ngay] * MAX ( [Dso_trong chtr], 0 )
			                    )
			            ),
			            [__quy]
			        ),
			        REMOVEFILTERS ( 'DIM_Danh mục_Ngày' ),
			        TREATAS ( __MonthContext, 'DIM_Danh mục_Ngày'[Năm/Tháng] )
			    )
			
			```
		formatString: #,0
		displayFolder: Code\Hạn mức sử dụng
		lineageTag: 9d885383-a7a5-422b-9017-0ca6b004df45

