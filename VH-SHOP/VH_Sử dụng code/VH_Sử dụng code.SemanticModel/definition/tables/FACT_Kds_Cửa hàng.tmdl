			defaultHierarchy: LocalDateTable_54a6f921-2c6b-4fbe-9462-1d75deafb335.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column _lastUpdate_calculate =
			
			var _lastupdate = max(LastUpdate[CreateDate])
			RETURN ROUNDDOWN(_lastupdate,0) + if( ( time(HOUR(_lastupdate), MINUTE(_lastupdate),0) ) <= TIME(22,30,0), -1, 0 )
		lineageTag: 8db6586e-16dd-447e-b14a-e07cd810472e
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column RunRate =
			
			var noday = DAY(EOMONTH('FACT_Kds_Cửa hàng'[Startdate],0))
			var _lastupdate = max(LastUpdate[CreateDate])
			var _lastUpdate_calculate = ROUNDDOWN(_lastupdate,0) + if( ( time(HOUR(_lastupdate), MINUTE(_lastupdate),0) ) <= TIME(22,30,0), -1, 0 )
			 --IF( 'FACT_Kds_Cửa hàng'[MaxDate] > 'FACT_Kds_Cửa hàng'[LastDate], 1, DIVIDE(noday, N_1))
			return
			SWITCH( true,
			'FACT_Kds_Cửa hàng'[Startdate] = DATE( 2024, 9, 1 ), IF( _lastUpdate_calculate > DATE( 2024, 9, 26), 1, DIVIDE( noday-4, day(_lastUpdate_calculate), BLANK() )),
			_lastUpdate_calculate >= EOMONTH('FACT_Kds_Cửa hàng'[Startdate],0), 1,
			DIVIDE( noday, day(_lastUpdate_calculate), BLANK() )
			)
		lineageTag: 74c561d4-1924-402f-9886-22cd2caef1a8
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Size =
			
