	partition F_TargetCodeShop = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=7abaff99-dd11-48ca-a4aa-2fc1ae086ba5”#(lf)select#(lf)  t.id_chuong_trinh#(lf)  ,t.ten_chuong_trinh#(lf)  ,t.shop#(lf)  ,date(t.ngay_bat_dau,'Asia/Ho_Chi_Minh') as `ngay_bat_dau`#(lf)  ,date(t.ngay_ket_thuc,'Asia/Ho_Chi_Minh') as `ngay_ket_thuc`#(lf)  ,d.date#(lf)  ,t.loai_target#(lf)  ,t.gia_tri#(lf)  ,case#(lf)    when t.loai_target = 'Quỹ sử dụng' then safe_divide(t.gia_tri, date_diff(date(t.ngay_ket_thuc),date(t.ngay_bat_dau),day)+1)#(lf)    when t.loai_target = 'Tỷ lệ doanh số' then t.gia_tri#(lf)    else t.gia_tri#(lf)  end as `gia_tri_trb_ngay`#(lf)from#(lf)  `cps_larkbase.code_kd_target_shop` as t#(lf)  left join `cps_DA_General_Transform.dim_date` as d#(lf)    on d.date >= date(t.ngay_bat_dau,'Asia/Ho_Chi_Minh') #(lf)    and d.date <= date(t.ngay_ket_thuc,'Asia/Ho_Chi_Minh')", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

