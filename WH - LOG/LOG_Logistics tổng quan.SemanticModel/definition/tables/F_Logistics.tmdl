	column 'Phân loại trễ hạn' = ```
			
			-- Trường hợp Ngày đơn hàng và Ngày tạo chuyến đi ngoài giờ làm việc (sau 9PM-8AM hôm sau) => Đúng hạn 
			-- Trường hợp Ngày đơn hàng ngoài giờ làm việc (sau 9PM-8AM hôm sau) và Ngày tạo chuyến đi sau 8AM hôm sau => Xét từ Ngày đơn hàng lúc 8AM hôm sau đến Ngày tạo chuyến đi có vượt 25 phút (giao 2 giờ) và 30 phút (giao 3 giờ và giao 4 giờ) hay không
			VAR zType = 'F_Logistics'[Loại giao hàng]
			VAR zStatus = 'F_Logistics'[Trạng thái phiếu]
			VAR zCreatedTimeDH = [Ngày đơn hàng]
			VAR zCreatedDateDH = [Ngày đơn hàng].[Date]
			VAR zAdjustedTimeDH =
			SWITCH(
			    TRUE(),
			    zCreatedTimeDH >= zCreatedDateDH + TIME(21,00,00), zCreatedDateDH + 1 + TIME(8,00,00),
			    zCreatedTimeDH < zCreatedDateDH + TIME(8,00,00), zCreatedDateDH + TIME(8,00,00),
			    zCreatedTimeDH
			)
			VAR zCreatedTimeRT = [Ngày tạo chuyến đi]
			VAR zCreatedDateRT = [Date]
			VAR zFinishedTimeRT = [Thời gian hoàn tất]
			VAR zCancelledTimeRT = [Thời gian hủy]
			VAR zShopX = DATEDIFF(zCreatedTimeDH, zCreatedTimeRT, MINUTE)
			VAR zShopY = DATEDIFF(zAdjustedTimeDH, zCreatedTimeRT, MINUTE)
			VAR zShipper = 
			COALESCE(
			    DATEDIFF(zCreatedTimeRT, zFinishedTimeRT, MINUTE), 
			    DATEDIFF(zCreatedTimeRT, zCancelledTimeRT, MINUTE)
			)
			
			-- Xác định ngưỡng thời gian theo loại giao hàng (thay đổi từ 24/06/2025)
			VAR zShopThreshold = 
			IF(
			    zCreatedDateRT >= DATE(2025, 6, 24),
			    SWITCH(
			        zType,
			        "Giao 2 giờ", 25,
			        "Giao 3 giờ", 30,
			        "Giao 4 giờ", 30,
			        BLANK()
			    ),
			    SWITCH(
			        zType,
			        "Giao 2 giờ", 15,
			        "Giao 3 giờ", 15,
			        "Giao 4 giờ", 15,
			        BLANK()
			    )
			)
			VAR zShipperThreshold = 
			IF(
			    zCreatedDateRT >= DATE(2025, 6, 24),
			    SWITCH(
			        zType,
			        "Giao 2 giờ", 95,
			        "Giao 3 giờ", 150,
			        "Giao 4 giờ", 210,
			        BLANK()
			    ),
			    SWITCH(
			        zType,
			        "Giao 2 giờ", 105,
			        "Giao 3 giờ", 165,
			        "Giao 4 giờ", 225,
			        BLANK()
			    )
			)
			
			-- Kiểm tra trạng thái trễ hạn Shop (thay đổi từ 24/06/2025)
			VAR zIsShopLate = 
			IF(
			    zCreatedDateRT >= DATE(2025, 6, 24),
			    zShopY > zShopThreshold,
			    zShopX > zShopThreshold
			)
			
			-- Kiểm tra trạng thái trễ hạn Shipper
			VAR zIsShipperLate = zShipper > zShipperThreshold
			
			RETURN
			SWITCH(
			    TRUE(),
			    -- Kiểm tra loại giao hàng trước
			    zShopThreshold = BLANK(), BLANK(),
			    
			    -- Kiểm tra trạng thái chưa hoàn tất
			    zStatus = "Chưa hoàn tất", BLANK(),
			    
			    -- Phân loại dựa trên trễ hạn
			    zIsShopLate && zIsShipperLate, "Shop và Shipper trễ hạn",
			    zIsShopLate, "Shop trễ hạn", 
			    zIsShipperLate, "Shipper trễ hạn",
			    "Shop và Shipper đúng hạn"
			)
			```
		lineageTag: 7ede6266-186b-4d7c-9c00-28370a92dc24
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Trạng thái phiếu' = ```
			
			        SWITCH (
			            TRUE (),
			            'F_Logistics'[Tình trạng đơn]
			                IN { 
			                    "Chờ lấy hàng", 
			                    "Đã lấy", 
			                    "Đang giao",
			                    "Mới tạo",
			                    "Thả hàng chưa xác nhận",
			                    "Thả hàng đã xác nhận",
			                    "Tài xế từ chối nhận hàng",
			                    "HTTC chưa xác nhận",
			                    BLANK()
			                }, "Chưa hoàn tất",
			            'F_Logistics'[Tình trạng đơn]
			                IN {
			                    "Lấy hàng thất bại",
			                    "Chờ trả hàng",
			                    "Đã trả hàng",
			                    "Hủy giao",
			                    "Hủy giao đã hoàn hàng",
			                    "Mất hàng",
			                    "Đã huỷ",
			                    "Hủy giao chưa hoàn hàng",
			                    "Hủy giao kho đã nhận hàng"
			                }, "Hủy giao",
			            'F_Logistics'[Tình trạng đơn] IN { "Giao thành công", "Hoàn tất", "HTTC đã xác nhận" }, "Hoàn tất",
			            BLANK ()
			        )
			
			```
		lineageTag: 56cdc6bd-7b0b-4267-adb4-281c50565f5f
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column B2B/B2C = IF(FIND("B2B", 'F_Logistics'[Cửa hàng], 1, 0) > 0, "B2B", "B2C")
