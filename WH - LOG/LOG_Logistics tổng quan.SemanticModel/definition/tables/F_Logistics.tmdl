	column 'Trễ hạn_RT' = ```
			
			VAR ChenhLechHoanTat =
			    MAX(0, 'F_Logistics'[Thời gian hoàn tất] - 'F_Logistics'[Giao hàng trước])
			VAR ChenhLechHuy =
			    MAX(0, 'F_Logistics'[Thời gian hủy] - 'F_Logistics'[Giao hàng trước])
			VAR zTG = 
			SWITCH(TRUE(),
			    'F_Logistics'[Giao hàng trước] = BLANK(), BLANK(),
			    'F_Logistics'[Thời gian hoàn tất] <> BLANK (), ChenhLechHoanTat,
			    'F_Logistics'[Thời gian hủy] <> BLANK (), ChenhLechHuy,
			    BLANK()
			)
			RETURN
			IF(
			    'F_Logistics'[Mã chuyến đi] = BLANK(),
			    BLANK(),
			            IF(
			                zTG > 0,
			                "Trễ hạn",
			                "Đúng hạn"
			                    )
			            )
			```
		lineageTag: ec8daa2e-d71c-42b9-8418-4e83475fa9ee
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Trễ hạn_DH' =
			
			VAR starts = 'F_Logistics'[Thời gian giao]
			VAR ends = 'F_Logistics'[Thời gian hoàn tất]
			VAR thoigiantaodon_taophieu = max( ends - starts, 0) -- Thời gian ngoài giờ làm việc (không ghi nhận)
			VAR zTG = IF (starts = BLANK () || ends = BLANK (), BLANK (), thoigiantaodon_taophieu )
			RETURN
			IF(
			    ISBLANK(zTG),
			    BLANK(),
			        IF(
			            zTG > 0,
			            "Trễ hạn",
			            "Đúng hạn"
			        )
			    )
		lineageTag: 55fcc054-0e24-42b9-8598-fd46d3cc2583
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

