	column 'Tính chất phiếu giao' =
			
			SWITCH (
			    TRUE (),
			    FIND ( "SP.", 'F_Logistics'[Số phiếu], 1, 0 ) > 0, "SP",
			    FIND ( "DC.", 'F_Logistics'[Số phiếu], 1, 0 ) > 0, "DC",
			    FIND ( "SO.", 'F_Logistics'[Số phiếu], 1, 0 ) > 0, "SO",
			    "Khác"
			)
		lineageTag: b33845c8-2e24-4ecb-ab48-d75fd53b5598
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Thời gian xử lý đơn' = ```
			
			VAR z1 = IF ([Tính chất phiếu giao] = "SP", MAX(DATEDIFF([Ngày đơn hàng], [Ngày lập phiếu], SECOND)/3600, 0))
			VAR z2 = IF ([Tính chất phiếu giao] = "SP", MAX(DATEDIFF([Ngày lập phiếu], [Ngày tạo chuyến đi], SECOND)/3600, 0))
			RETURN 
			    z1 + z2
			```
		lineageTag: cfdd97b0-e725-4ba5-af5e-968ff920cf7a
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Thời gian chờ lấy hàng' = IF ([Tính chất phiếu giao] = "SP", MAX(DATEDIFF([Ngày tạo chuyến đi], [Nhận lúc], SECOND)/3600, 0))
		lineageTag: 11e70f95-c9f5-4c90-8861-754212f03af8
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Thời gian giao cho khách' =
			
			--Ahamove web miền Bắc không ghi nhận cột Nhận lúc, nên tính leadtime bằng cách [Thời gian chờ lấy hàng] = 0 và dồn về [Thời gian giao cho khách]
			VAR z1 = COALESCE([Nhận lúc], [Ngày tạo chuyến đi])
			VAR z2 = COALESCE([Thời gian hoàn tất], [Thời gian hủy])
			RETURN
			    IF ([Tính chất phiếu giao] = "SP", MAX(DATEDIFF(z1, z2, SECOND)/3600, 0))
		lineageTag: 8db8895c-c1d7-41b8-839a-a09f34c0785b
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

