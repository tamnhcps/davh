	column 'Khung giờ' = ```
			
			VAR _Hour = HOUR ( F_Logistics[Ngày đơn hàng] )
			RETURN
			SWITCH (
			    TRUE(),
			    _Hour < 7,                "0 - <7h",
			    _Hour = 7,                "7h",
			    _Hour = 8,                "8h",
			    _Hour = 9,                "9h",
			    _Hour = 10,               "10h",
			    _Hour = 11,               "11h",
			    _Hour = 12,               "12h",
			    _Hour = 13,               "13h",
			    _Hour = 14,               "14h",
			    _Hour = 15,               "15h",
			    _Hour = 16,               "16h",
			    _Hour = 17,               "17h",
			    _Hour = 18,               "18h",
			    _Hour >= 19 && _Hour < 24,"19 - <24h",
			    BLANK()
			)
			
			```
