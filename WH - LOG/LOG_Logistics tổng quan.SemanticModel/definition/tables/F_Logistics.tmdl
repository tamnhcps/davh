	column 'Phí VC_All' = ```
			
			--Phí VC dự kiến theo K.Cách
			VAR zHTVC = 'F_Logistics'[Hình thức vận chuyển]
			VAR zKC = 'F_Logistics'[K.Cách từ CH theo bản đồ]
			VAR zTC = 'F_Logistics'[Tính chất phiếu giao]
			VAR zP = 
			IF(
			    zTC <> "SP",
			    BLANK(),
			    IF(
			        zHTVC = "NV SHOP",
			        SWITCH(
			            TRUE(),
			            zKC <= 0, 0,
			            zKC < 2, 8000,
			            zKC < 5, 16000,
			            zKC < 8, 20000,
			            zKC < 11, 28000,
			            zKC < 14, 32000,
			            zKC < 17, 36000,
			            40000
			        ),
			        IF(
			            zHTVC = "NV LOG",
			            SWITCH(
			                TRUE(),
			                zKC <= 0, 8000,
			                zKC < 10, 25000,
			                35000
			            ),
			            BLANK()
			        )
			    )
			)
			RETURN
			SWITCH (
			    TRUE (),
			    'F_Logistics'[Phí VC] > 0, 'F_Logistics'[Phí VC],
			    zP > 0, zP,
			    BLANK()
			)
			```
		formatString: #,0
		lineageTag: dfc052d7-4d2b-4f84-a56d-b6c6ef760718
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column MethodId =
			
			--Nội/Ngoại thành
			VAR zA =
			SWITCH(
			    TRUE(),
			    'F_Logistics'[Hình thức vận chuyển] = "AHAMOVE"
			        || 'F_Logistics'[Hình thức vận chuyển] = "XE MÁY LOG"
			            || 'F_Logistics'[Hình thức vận chuyển] = "Ô TÔ LOG"
			            || 'F_Logistics'[Hình thức vận chuyển] = "GRAB"
			            || 'F_Logistics'[Hình thức vận chuyển] = "NV SHOP", "NỘI THÀNH",
			    'F_Logistics'[Hình thức vận chuyển] = "LAZADA"
			        || 'F_Logistics'[Hình thức vận chuyển] = "NHẤT TÍN" || 'F_Logistics'[Hình thức vận chuyển] = "GHTK", "NGOẠI THÀNH",
			    "KHÁC"
			)
			VAR zB = 'F_Logistics'[Hình thức vận chuyển]
			RETURN
			    zA & "-" & zB
		lineageTag: 711b6cf2-c38d-4e24-b297-8fd2174ccc2c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

