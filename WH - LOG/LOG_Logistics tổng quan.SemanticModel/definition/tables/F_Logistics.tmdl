	column 'Hình thức vận chuyển' = ```
			
			-- User Bắc Nam đã thống nhất cách phân loại bên dưới
			IF(
			    'F_Logistics'[Miền] = "Miền Nam",
			    SWITCH(
			        TRUE(),
			        'F_Logistics'[Tên xe] IN {"Ô TÔ LOG"}, "Ô TÔ LOG", 
			        'F_Logistics'[Tên xe] IN {"XE MÁY LOG"} || CONTAINSSTRING('F_Logistics'[Tên xe], "XELOG"), "XE MÁY LOG",
			        'F_Logistics'[Tên xe] IN {"Nhân Viên Shop Giao", "NV shop giao", "Nội bộ liên tỉnh"}, "NV SHOP",
			        'F_Logistics'[Datasource] IN {"AHAMOVE-MN (SEP)", "AHAMOVE-MN"}, "AHAMOVE",
			        'F_Logistics'[Datasource] IN {"LAZADA-MN (SEP)"}, "LAZADA",
			        'F_Logistics'[Datasource] IN {"NHATTIN-MN", "NHATTIN-MN (SEP)"}, "NHẤT TÍN",
			        'F_Logistics'[Datasource] IN {"GHTK-MN (SEP)"}, "GHTK",
			        'F_Logistics'[Datasource] IN {"GRAB-MN (SEP)"}, "GRAB",
			        "KHÁC" //"Giao hàng cho khách B2B","XE KHO TRUNG TÂM" || CONTAINSSTRING('F_Logistics'[Tên xe], "XEKHO"),
			    ),
			    SWITCH(
			        TRUE(),
			        'F_Logistics'[Datasource] IN {"AHAMOVE-MB (SEP)", "AHAMOVE-MB"}, "AHAMOVE",
			        'F_Logistics'[Tên xe] IN {"XE MÁY LOG"}, "XE MÁY LOG",
			        'F_Logistics'[Tên xe] IN {"Ô TÔ LOG"}, "Ô TÔ LOG",
			        'F_Logistics'[Tên xe] IN {"NHÂN VIÊN SHOP GIAO", "XE KHO ĐI KHO TRUNG TÂM", "XE KHO TÔNG (KHO TÔNG CHON)", "XE KHO TRUNG CHUYỂN"} || ('F_Logistics'[Datasource] = "HTVRT-HN" && 'F_Logistics'[Tên xe] <> BLANK()), "NV SHOP",
			        'F_Logistics'[Datasource] IN {"LAZADA-MB (SEP)"}, "LAZADA",
			        'F_Logistics'[Datasource] IN {"NHATTIN-MB (SEP)"}, "NHẤT TÍN",
			        'F_Logistics'[Datasource] IN {"GHTK-MB (SEP)"}, "GHTK",
			        'F_Logistics'[Datasource] IN {"GRAB-MB (SEP)"}, "GRAB",
			        "KHÁC"
			    )
			)
			```
