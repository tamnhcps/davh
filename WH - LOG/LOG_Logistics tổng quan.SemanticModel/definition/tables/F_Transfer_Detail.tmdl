		lineageTag: 8a79e6b1-2d32-4b1f-9479-5ffad345a5cb
		summarizeBy: none
		sourceColumn: Kho cho hàng

		annotation SummarizationSetBy = Automatic

	column 'Kho nhận hàng'
		dataType: string
		lineageTag: d4a3baaf-e23d-4dd5-a61b-3208ebb10af5
		summarizeBy: none
		sourceColumn: Kho nhận hàng

