table F_Transfer_Detail
	lineageTag: 0665ae95-5879-4daa-a2e6-d6ae0fe69ed3

	column 'Thời gian hoàn tất phiếu' =
			
			IF(
			    'F_Transfer_Detail'[Lý do YCDC] <> "BHMR",
			    RELATED('F_Transfer'[Thời gian hoàn tất phiếu]),
			    BLANK()
			)
		lineageTag: 22e7ae9d-4340-4b1c-97a9-09c2d5602207
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Thời gian đi đường' =
			
			IF(
			    'F_Transfer_Detail'[Lý do YCDC] <> "BHMR",
			    RELATED('F_Transfer'[Thời gian đi đường]),
			    BLANK()
			)
		lineageTag: 40433066-e57b-40bb-a4e3-752e0b4ec10b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Số phiếu'
		dataType: string
		lineageTag: 893084c1-00c3-42f0-9dd6-c55318e6d7c8
