	partition F_Transfer_Detail = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=0c443b5c-c2db-4617-b273-e61ac25f9b66”#(lf)WITH TempTransfer AS (#(lf)SELECT UPPER(endS.Name) AS `Kho cho hàng`,#(lf)       UPPER(strS.Name) AS `Kho nhận hàng`,#(lf)       ag.AutoCode AS `Số phiếu`,#(lf)       DATE(ag.CreateDate) AS `Ngày lập phiếu`,#(lf)       UPPER(spg.Name) AS `Nhóm hàng`,#(lf)       CASE#(lf)           WHEN REGEXP_CONTAINS(UPPER(strS.Name), r'(KM|KHO MUON)') THEN 'Khác'#(lf)           WHEN ag.Description = 'Tự động từ cân hàng' THEN 'Cân hàng'#(lf)           WHEN ag.Description = 'Tự động từ chia hàng' THEN 'Chia hàng'#(lf)           WHEN REGEXP_CONTAINS(UPPER(strS.Name), r'(KHO)')#(lf)                AND UPPER(strS.Name) NOT IN ('KHO CCDC (HẬU CẦN)',#(lf)                                             'KHO CÔNG CỤ DỤNG CỤ',#(lf)                                             'KHO CÔNG NGHỆ',#(lf)                                             'KHO CXL HN',#(lf)                                             'KHO MƯỢN MÁY',#(lf)                                             'KHO MÁY LÊN ĐỜI') THEN 'Lỗi'#(lf)          WHEN NOT REGEXP_CONTAINS(UPPER(endS.Name), r'(KHO)')#(lf)                AND NOT REGEXP_CONTAINS(UPPER(strS.Name), r'(KHO)') THEN 'Xin hàng'#(lf)           ELSE 'Khác'#(lf)       END AS `Lý do YCDC`,#(lf)       'Miền Nam' AS `Miền`,#(lf)       SUM(asbd.Quantity) AS SL#(lf)FROM `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Store_TransferOrder` sto#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_General` ag ON sto.DeliveryNo = ag.Autocode#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_StoreBillDetail` asbd ON asbd.StoreBillId = ag.Id#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store` strS ON strS.Id = asbd.InputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store` endS ON endS.Id = asbd.OutputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product` sp ON sp.Id = asbd.ProductId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup` spg ON spg.Id = sp.ProductGroupId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` spe ON spe.id = sto.CreatedById#(lf)LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Employee` ee ON ee.id = spe.id#(lf)LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Department` sd ON sd.id = ee.DepartmentId#(lf)WHERE 1=1#(lf)  AND sto.StateId = 8#(lf)  AND ag.BillTypeId = 1#(lf)  AND ag.ReplaceById IS NULL#(lf)  AND DATE(ag.CreateDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  AND NOT UPPER(strS.Name) IN ('KHO BẢO HÀNH MỞ RỘNG')#(lf)GROUP BY 1,2,3,4,5,6,7#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT UPPER(endS.Name) AS `Kho cho hàng`,#(lf)       UPPER(strS.Name) AS `Kho nhận hàng`,#(lf)       ag.AutoCode AS `Số phiếu`,#(lf)       DATE(ag.CreateDate) AS `Ngày lập phiếu`,#(lf)       UPPER(spg.Name) AS `Nhóm hàng`,#(lf)       CASE#(lf)           WHEN REGEXP_CONTAINS(UPPER(strS.Name), r'(KM|KHO MUON)') THEN 'Khác'#(lf)           WHEN ag.Description = 'Tự động từ cân hàng' THEN 'Cân hàng'#(lf)           WHEN ag.Description = 'Tự động từ chia hàng' THEN 'Chia hàng'#(lf)           WHEN REGEXP_CONTAINS(UPPER(strS.Name), r'(KHO)')#(lf)                AND UPPER(strS.Name) NOT IN ('KHO CCDC (HẬU CẦN)',#(lf)                                             'KHO CÔNG CỤ DỤNG CỤ',#(lf)                                             'KHO CÔNG NGHỆ',#(lf)                                             'KHO CXL HN',#(lf)                                             'KHO MƯỢN MÁY',#(lf)                                             'KHO MÁY LÊN ĐỜI') THEN 'Lỗi'#(lf)           WHEN NOT REGEXP_CONTAINS(UPPER(endS.Name), r'(KHO)')#(lf)                AND NOT REGEXP_CONTAINS(UPPER(strS.Name), r'(KHO)') THEN 'Xin hàng'#(lf)           ELSE 'Khác'#(lf)       END AS `Lý do YCDC`,#(lf)       'Miền Bắc' AS `Miền`,#(lf)       SUM(asbd.Quantity) AS SL#(lf)FROM `cellphones-data-platform.cps_cdc_sep_hn_dbo.Store_TransferOrder` sto#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_General` ag ON sto.DeliveryNo = ag.Autocode#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_StoreBillDetail` asbd ON asbd.StoreBillId = ag.Id#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store` strS ON strS.Id = asbd.InputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store` endS ON endS.Id = asbd.OutputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product` sp ON sp.Id = asbd.ProductId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup` spg ON spg.Id = sp.ProductGroupId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` spe ON spe.id = sto.CreatedById#(lf)LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Employee` ee ON ee.id = spe.id#(lf)LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Department` sd ON sd.id = ee.DepartmentId#(lf)WHERE 1=1#(lf)  AND sto.StateId = 8#(lf)  AND ag.BillTypeId = 1#(lf)  AND ag.ReplaceById IS NULL#(lf)  AND DATE(ag.CreateDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  AND NOT UPPER(strS.Name) IN ('KHO BẢO HÀNH MỞ RỘNG')#(lf)GROUP BY 1,2,3,4,5,6#(lf)#(lf)UNION ALL#(lf)--BHMR cần tách luồng vì không tạo YCDC#(lf)SELECT#(lf)  UPPER(endS.Name) AS `Kho cho hàng`,#(lf)  UPPER(strS.Name) AS `Kho nhận hàng`,#(lf)  ag.AutoCode AS `Số phiếu`,#(lf)  DATE(ag.CreateDate) AS `Ngày lập phiếu`,#(lf)  UPPER(spg.Name) AS `Nhóm hàng`,#(lf)  'BHMR' AS `Lý do YCDC`,#(lf)  'Miền Nam' AS `Miền`,#(lf)  SUM(asbd.Quantity) AS SL#(lf)FROM#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_General` ag#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_StoreBillDetail` asbd ON asbd.StoreBillId = ag.Id#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store` strS ON strS.Id = asbd.InputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store` endS ON endS.Id = asbd.OutputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product` sp ON sp.Id = asbd.ProductId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup` spg ON spg.Id = sp.ProductGroupId#(lf)#(lf)WHERE#(lf)  ag.BillTypeId = 1#(lf)  AND ag.ReplaceById IS NULL#(lf)  AND DATE(ag.CreateDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  AND ag.Description = 'Tự động điều chuyển BHMR'#(lf)#(lf)GROUP BY 1,2,3,4,5,6#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT#(lf)  UPPER(endS.Name) AS `Kho cho hàng`,#(lf)  UPPER(strS.Name) AS `Kho nhận hàng`,#(lf)  ag.AutoCode AS `Số phiếu`,#(lf)  DATE(ag.CreateDate) AS `Ngày lập phiếu`,#(lf)  UPPER(spg.Name) AS `Nhóm hàng`,#(lf)  'BHMR' AS `Lý do YCDC`,#(lf)  'Miền Bắc' AS `Miền`,#(lf)  SUM(asbd.Quantity) AS SL#(lf)FROM#(lf)  `cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_General` ag#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_StoreBillDetail` asbd ON asbd.StoreBillId = ag.Id#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store` strS ON strS.Id = asbd.InputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store` endS ON endS.Id = asbd.OutputStoreId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product` sp ON sp.Id = asbd.ProductId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup` spg ON spg.Id = sp.ProductGroupId#(lf)WHERE#(lf)  ag.BillTypeId = 1#(lf)  AND ag.ReplaceById IS NULL#(lf)  AND DATE(ag.CreateDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  AND ag.Description = 'Tự động điều chuyển BHMR'#(lf)#(lf)GROUP BY 1,2,3,4,5,6#(lf))#(lf)SELECT * EXCEPT (`Kho cho hàng`, `Kho nhận hàng`),#(lf)CASE#(lf)  WHEN `Kho cho hàng` = 'HN 384XD' THEN 'HN 360XD'#(lf)  ELSE `Kho cho hàng`#(lf)END AS `Kho cho hàng`,#(lf)CASE#(lf)  WHEN `Kho nhận hàng` = 'HN 384XD' THEN 'HN 360XD'#(lf)  ELSE `Kho nhận hàng`#(lf)END AS `Kho nhận hàng`#(lf)FROM TempTransfer", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

