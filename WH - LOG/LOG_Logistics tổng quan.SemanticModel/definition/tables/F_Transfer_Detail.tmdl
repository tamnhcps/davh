		lineageTag: f94d48a4-58a5-44dd-ab09-91f6123d5876
		summarizeBy: none
		sourceColumn: Nhóm hàng

		annotation SummarizationSetBy = Automatic

	column 'Lý do YCDC'
		dataType: string
		lineageTag: 1fbc53f3-58e9-4616-b025-191ffa77f676
		summarizeBy: none
		sourceColumn: Lý do YCDC

		annotation SummarizationSetBy = Automatic

	column SL
		dataType: double
		lineageTag: 1e73eab6-0081-4ed7-a6ad-debf54340292
		summarizeBy: sum
		sourceColumn: SL

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Khu vực' =
			
			IF(
			    'F_Transfer_Detail'[Miền] = "Miền Nam",
			    SWITCH(
			        TRUE(),
			        LEFT('F_Transfer_Detail'[Kho cho hàng],3) IN {"HCM", "KHO"} && LEFT('F_Transfer_Detail'[Kho nhận hàng],3) IN {"HCM", "KHO"}, "HCM - HCM",
			        LEFT('F_Transfer_Detail'[Kho cho hàng],3) IN {"HCM", "KHO"} && NOT(LEFT('F_Transfer_Detail'[Kho nhận hàng],3) IN {"HCM", "KHO"}), "HCM - Tỉnh",
			        NOT(LEFT('F_Transfer_Detail'[Kho cho hàng],3) IN {"HCM", "KHO"}) && LEFT('F_Transfer_Detail'[Kho nhận hàng],3) IN {"HCM", "KHO"}, "Tỉnh - HCM",
			        "Liên tỉnh MN"
			    ),
			    SWITCH(
			        TRUE(),
			        LEFT('F_Transfer_Detail'[Kho cho hàng],3) IN {"HN ", "KHO"} && LEFT('F_Transfer_Detail'[Kho nhận hàng],3) IN {"HN ", "KHO"}, "HN - HN",
			        LEFT('F_Transfer_Detail'[Kho cho hàng],3) IN {"HN ", "KHO"} && NOT(LEFT('F_Transfer_Detail'[Kho nhận hàng],3) IN {"HN ", "KHO"}), "HN - Tỉnh",
			        NOT(LEFT('F_Transfer_Detail'[Kho cho hàng],3) IN {"HN ", "KHO"}) && LEFT('F_Transfer_Detail'[Kho nhận hàng],3) IN {"HN ", "KHO"}, "Tỉnh - HN",
			        "Liên tỉnh MB"
			    )
			)
		lineageTag: 24a6ff73-7e70-4cc7-9179-bad4d5985aec
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Miền
		dataType: string
		lineageTag: 253e491d-ddc8-4517-b031-1f79a2444bc1
		summarizeBy: none
		sourceColumn: Miền

		annotation SummarizationSetBy = Automatic

