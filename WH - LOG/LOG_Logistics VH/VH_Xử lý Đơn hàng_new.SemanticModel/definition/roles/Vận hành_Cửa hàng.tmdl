role 'Vận hành_Cửa hàng'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' = 'DIM_Danh mục_Ngày'[Date]>=LOOKUPVALUE('DIM_Phân quyền_User'[Startdate],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())

	tablePermission 'DIM_Phân quyền_Vận hành' = ```
			VAR zName = 
			    LOOKUPVALUE(
			        'DIM_Phân quyền_User'[Tên],
			        'DIM_Phân quyền_User'[Mail], 
			        USERPRINCIPALNAME()
			    )
			
			VAR zTable_AddColumns = 
			    ADDCOLUMNS(
			        'DIM_Phân quyền_Vận hành',
			        "zPath",
			        LOOKUPVALUE(
			            'DIM_Phân quyền_User'[Path],
			            'DIM_Phân quyền_User'[Tên], 
			            'DIM_Phân quyền_Vận hành'[Cửa hàng]
			        )
			    )
			
			VAR zFilteredTable = 
			    FILTER(
			        zTable_AddColumns,
			        PATHCONTAINS([zPath], zName)
			    )
			
			VAR zDistinctStores = 
			    DISTINCT(
			        SELECTCOLUMNS(
			            zFilteredTable,
			            "Cửa hàng", 'DIM_Phân quyền_Vận hành'[Cửa hàng]
			        )
			    )
			
			RETURN
			IF(
			    LOOKUPVALUE('DIM_Phân quyền_User'[Title], 'DIM_Phân quyền_User'[Mail], USERPRINCIPALNAME()) = "SHOP",
			    [Cửa hàng] IN zDistinctStores,
			    TRUE
			)
			```

	annotation PBI_Id = 854dcd1afee745d2a0a62f41ebe2d90f

