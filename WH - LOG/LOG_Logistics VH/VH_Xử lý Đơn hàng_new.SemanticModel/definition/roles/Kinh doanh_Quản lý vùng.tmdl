role 'Kinh doanh_Quản lý vùng'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' = 'DIM_Danh mục_Ngày'[Date]>=LOOKUPVALUE('DIM_Phân quyền_User'[Startdate],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())

	tablePermission 'Dim_Phân Quyền_Kinh doanh' = ```
			IF( 
			LOOKUPVALUE('DIM_Phân quyền_User'[Title],'DIM_Phân quyền_User'[Mail] ,USERPRINCIPALNAME()) = "QLNH", 
			[Quản lý vùng] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('DIM_Phân quyền_Kinh doanh','DIM_Phân quyền_Kinh doanh'[Quản lý vùng] = LOOKUPVALUE('DIM_Phân quyền_User'[Tên],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())),'DIM_Phân quyền_User'),
			                        "Path leader", PATHCONTAINS('DIM_Phân quyền_User'[Path],'DIM_Phân quyền_Kinh doanh'[Quản lý vùng])),[Path leader]),"Quản lý vùng",'DIM_Phân quyền_User'[Tên]))
			,True)
			```

	annotation PBI_Id = b571d08d86ff4572828633556fc8055a

