role 'Kinh doanh_PK_Ốp bao da'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' = 'DIM_Danh mục_Ngày'[Date]>=LOOKUPVALUE('DIM_Phân quyền_User'[Startdate],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())

	tablePermission 'Dim_Phân Quyền_Kinh doanh' = ```
			IF( 
			LOOKUPVALUE('DIM_Phân quyền_User'[Title],'DIM_Phân quyền_User'[Mail] ,USERPRINCIPALNAME()) = "QLNH", 
			[PK_Ốp bao da] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('DIM_Phân quyền_Kinh doanh','DIM_Phân quyền_Kinh doanh'[PK_Ốp bao da] = LOOKUPVALUE('DIM_Phân quyền_User'[Tên],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())),'DIM_Phân quyền_User'),
			                        "Path leader", PATHCONTAINS('DIM_Phân quyền_User'[Path],'DIM_Phân quyền_Kinh doanh'[PK_Ốp bao da])),[Path leader]),"PK",'DIM_Phân quyền_User'[Tên]))
			,True)
			```

	annotation PBI_Id = 2c7d0843593a4d59a26339876f075e21

