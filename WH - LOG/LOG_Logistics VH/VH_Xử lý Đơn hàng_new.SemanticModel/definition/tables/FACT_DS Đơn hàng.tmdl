	column 'Loại ca' = ```
			
			VAR giobatdau = TIME(8, 0, 0)
			VAR gioketthuc = TIME(21, 0, 0)
			VAR gio =  IF('FACT_DS Đơn hàng'[NgayDat]> 'FACT_DS Đơn hàng'[NgayDat], 'FACT_DS Đơn hàng'[NgayDat], 'FACT_DS Đơn hàng'[NgayDat])
			VAR giodat = TIME(HOUR(gio), MINUTE(gio), SECOND(gio))
			
			
			VAR duration =
			    IF(
			        AND(giodat >= giobatdau, giodat <= gioketthuc), 
			        "Trong giờ làm", 
			        "Ngoài giờ làm"
			    )
			
			RETURN
			    duration
			
			```
		lineageTag: 765b42a3-342d-41a0-9b75-13553a069051
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

