	column OrderSource =
			
			VAR department =
			    SWITCH (
			        TRUE (),
			        'FACT_DS Đơn hàng'[PhongBan]
			            IN {
			                "CSKH - Hotline",
			                "Nhóm Hotline CellphoneS",
			                "Phòng chăm sóc khách hàng"
			            }, "Hotline",
			        'FACT_DS Đơn hàng'[PhongBan]
			            IN {
			                "Nhóm chatline CellphoneS",
			                "Nhóm CTV Chatline CellphoneS",
			                "Nhóm Facebook CellphoneS"
			            }, "Chatline",
			        "Shop"
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        'FACT_DS Đơn hàng'[IsOnline]
			            && department = "Hotline", "Đơn Hotline xử lý",
			        'FACT_DS Đơn hàng'[IsOnline]
			            && department = "Chatline", "Đơn Chatline xử lý",
			        'FACT_DS Đơn hàng'[IsOnline]
			            && department = "Shop", "Đơn Shop xử lý",
			        'FACT_DS Đơn hàng'[IsOnline] = FALSE ()
			            && department = "Hotline", "Đơn KH gọi Hotline",
			        'FACT_DS Đơn hàng'[IsOnline] = FALSE ()
			            && department = "Chatline", "Đơn KH nhắn tin Chatline",
			        'FACT_DS Đơn hàng'[IsOnline] = FALSE ()
			            && department = "Shop", "Đơn Offline",
			        BLANK ()
			    )
		lineageTag: 0a2765a8-5a49-4fac-88b6-872c387b1639
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column StatusPayment =
			
			IF('FACT_DS Đơn hàng'[TrangThaiThanhToan] = "Đã thanh toán", "Đã thanh toán", "Chưa thanh toán")
		lineageTag: b90ab7e1-c9bd-492b-8aa4-4fef80fefd6a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column OrderState =
			
			SWITCH(TRUE(),
			'FACT_DS Đơn hàng'[TrangThaiDon] = "Đã xuất kho", "Thành công",
			'FACT_DS Đơn hàng'[TrangThaiDon] = "Hủy đơn", "Thất bại",
			"Chờ xử lý")
		lineageTag: 901679e6-2df3-44e7-b860-4b652d72021b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Product_HighestPrice = ```
			
			VAR maxprice = 
			    CALCULATE(
			        MAX('FACT_DS Đơn hàng'[TongDon]),
			        ALLEXCEPT('FACT_DS Đơn hàng', 'FACT_DS Đơn hàng'[SoDonHang])
			    )
			RETURN
			IF('FACT_DS Đơn hàng'[TongDon] = maxprice, 1, 0)
			```
		formatString: 0
		lineageTag: 73362ceb-c398-46fd-814d-dc0ab2177db7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column ChasedState =
			
			VAR count_active =
			    CALCULATE (
			        SUM ( 'FACT_DS Đơn hàng'[IsChased] ),
			        FILTER (
			            'FACT_DS Đơn hàng',
			            'FACT_DS Đơn hàng'[OrderState] = "Thất bại"
			                && 'FACT_DS Đơn hàng'[SoDonHang]
			                    = EARLIER ( 'FACT_DS Đơn hàng'[SoDonHang] )
			        )
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        ISBLANK ( 'FACT_DS Đơn hàng'[IsChased] ), 'FACT_DS Đơn hàng'[OrderState],
			        count_active > 0, "Đã chuyển đổi",
			        "Hủy đơn"
			    )
		lineageTag: cfcd5a88-4c4f-41c2-87d0-042481547184
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

