	measure 'Avg_SLA_DH_LM g%' = ```
			
			
			VAR SelectedPeriod = SELECTEDVALUE(Parameter_ThoiGian[Parameter_NgayTuanThang Order])
			VAR SelectedWeekIndex = MAX('DIM_Danh mục_Ngày'[Năm/Tuần_Index])
			
			VAR AvgSLA_LM =
			SWITCH(
			    TRUE(),
			    SelectedPeriod = 0, 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH]), DATEADD('DIM_Danh mục_Ngày'[Date], -1, DAY)),
			
			    SelectedPeriod = 2, 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH]),  PARALLELPERIOD('DIM_Danh mục_Ngày'[Date], -1, MONTH)),
			
			    SelectedPeriod = 1, 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH]),
			        FILTER(
			                ALL('DIM_Danh mục_Ngày'),
			                'DIM_Danh mục_Ngày'[Năm/Tuần_Index] = SelectedWeekIndex + 1))
			)
			
			VAR AvgSLA = 
			    CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH])
			    )
			    
			RETURN
			IF (
			        AvgSLA_LM <> 0,
			        DIVIDE ( AvgSLA, AvgSLA_LM, BLANK () ) - 1,
			        BLANK()
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 3. XLDH
		lineageTag: fd0d46f1-56ca-4416-8f5b-7c1ef0b86a05

	measure 'Avg_SLA_SP_LM g%' = ```
			
			
			VAR SelectedPeriod = SELECTEDVALUE(Parameter_ThoiGian[Parameter_NgayTuanThang Order])
			VAR SelectedWeekIndex = MAX('DIM_Danh mục_Ngày'[Năm/Tuần_Index])
			
			VAR AvgSLA_LM =
			SWITCH(
			    TRUE(),
			    SelectedPeriod = 0, 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra SP]), DATEADD('DIM_Danh mục_Ngày'[Date], -1, DAY)),
			
			    SelectedPeriod = 2, 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra SP]), PARALLELPERIOD('DIM_Danh mục_Ngày'[Date], -1, MONTH)),
			
			    SelectedPeriod = 1, 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra SP]),
			        FILTER(
			                ALL('DIM_Danh mục_Ngày'),
			                'DIM_Danh mục_Ngày'[Năm/Tuần_Index] = SelectedWeekIndex + 1))
			        )
			VAR AvgSLA = 
			    CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra SP])
			        --FILTER('FACT_DS Online_SLA', 'FACT_DS Online_SLA'[SLA ra SP] <> BLANK()) 
			    )
			
			VAR Z = 
			IF (
			        AvgSLA_LM <> 0,
			        DIVIDE ( AvgSLA, AvgSLA_LM, BLANK () ) - 1,
			        BLANK()
			    )
			RETURN Z     
			// FORMAT(AvgSLA_LM, "hh:mm:ss")
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 3. XLDH
		lineageTag: 717111d7-2815-45a0-8693-e8b76dc1af26

	measure Avg_SLA_DH_LM = ```
			
			
			VAR SelectedPeriod = SELECTEDVALUE(Parameter_ThoiGian[Parameter_NgayTuanThang Fields])
			VAR SelectedWeekIndex = SELECTEDVALUE('DIM_Danh mục_Ngày'[Năm/Tuần_Index])
			
			VAR _result =
			SWITCH(
			    TRUE(),
			    SelectedPeriod = "Ngày", 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH]), DATEADD('DIM_Danh mục_Ngày'[Date], -1, DAY)),
			
			    SelectedPeriod = "Năm/tháng", 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH]),  PARALLELPERIOD('DIM_Danh mục_Ngày'[Date], -1, MONTH)),
			
			    SelectedPeriod = "Năm/tuần", 
			        CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH]), DATEADD('DIM_Danh mục_Ngày'[WeekStartDate], -7, DAY)
			))
			VAR TotalSeconds = _result * 3600
			VAR Hours = INT(TotalSeconds / 3600)
			VAR Minutes = INT(MOD(TotalSeconds, 3600) / 60)
			VAR Seconds = MOD(TotalSeconds, 60)
			
			RETURN
			    FORMAT(TIME(Hours, Minutes, Seconds), "hh:mm:ss")
			
			
			```
		displayFolder: 3. XLDH
		lineageTag: 85822683-abde-406d-9841-3adfc3ea249f

	measure 'Med_SLA_DH_LM g%' = ```
			
			
			VAR SelectedPeriod = SELECTEDVALUE(Parameter_ThoiGian[Parameter_NgayTuanThang Order])
			VAR SelectedWeekIndex = MAX('DIM_Danh mục_Ngày'[Năm/Tuần_Index])
			
			VAR MedSLA_LM =
			SWITCH(
			    TRUE(),
			    SelectedPeriod = 0, 
			    CALCULATE(
			    MEDIANX(
			        'FACT_DS Online_SLA',
			        'FACT_DS Online_SLA'[SLA ra DH]), DATEADD('DIM_Danh mục_Ngày'[Date], -1, DAY)),
			
			    SelectedPeriod = 2, 
			    CALCULATE(
			    MEDIANX(
			        'FACT_DS Online_SLA',
			        'FACT_DS Online_SLA'[SLA ra DH]),  PARALLELPERIOD('DIM_Danh mục_Ngày'[Date], -1, MONTH)),
			
			    SelectedPeriod = 1, 
			    CALCULATE(
			    MEDIANX(
			        'FACT_DS Online_SLA',
			        'FACT_DS Online_SLA'[SLA ra DH]),
			        FILTER(
			                ALL('DIM_Danh mục_Ngày'),
			                'DIM_Danh mục_Ngày'[Năm/Tuần_Index] = SelectedWeekIndex + 1))
			)
			VAR MedSLA = 
			CALCULATE(
			    MEDIANX(
			        'FACT_DS Online_SLA',
			        'FACT_DS Online_SLA'[SLA ra DH])) 
			RETURN
			IF (
			        MedSLA_LM <> 0,
			        DIVIDE ( MedSLA, MedSLA_LM, BLANK () ) - 1,
			        BLANK()
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 3. XLDH
		lineageTag: 9ad2942c-e152-42d1-9480-b67fb062aadd

