	measure __Dso_DH_tiem_nang = ```
			
			VAR Grain =
			SUMMARIZECOLUMNS(
			        'DIM_Danh mục_Phòng ban'[Miền],
			        'DIM_Danh mục_Phòng ban'[Province],
			        'DIM_Danh mục_Phòng ban'[District],
			        'DIM_Danh mục_Phòng ban'[RSM],
			        'DIM_Danh mục_Phòng ban'[AM],
			        'DIM_Danh mục_Phòng ban'[Cửa hàng],
			        'DIM_Danh mục_Nhóm hàng'[Nhóm hàng],
			        'DIM_Danh mục_Sản phẩm'[Model],
			        'DIM_Danh mục_Sản phẩm'[Tên hàng],
			        "slgDH",
			            CALCULATE (
			                SUM ( 'FACT_DS Đơn hàng'[Slg] ),
			                'FACT_DS Đơn hàng'[is_PhieuBanLe_blank] = 1,
			                'FACT_DS Đơn hàng'[ChasedState] = "Chờ xử lý"
			            ),
			        "slgTon",
			            CALCULATE (
			                SUM ( 'FACT_Warehouse_Current Inventory'[Quantity] ),
			               'DIM_Danh mục_Sản phẩm'[ton_ao] <> 1 
			            ),
			        "avg_price",
			        CALCULATE (
			            AVERAGE( 'FACT_DS Đơn hàng'[Đơn_giá] ),
			            'FACT_DS Đơn hàng'[is_PhieuBanLe_blank] = 1,
			            'FACT_DS Đơn hàng'[ChasedState] = "Chờ xử lý"
			        )
			)
			var _addColumn = 
			ADDCOLUMNS(
			    Grain,
			    "dso",IF ( [slgDH] <> BLANK() && [slgTon] <> BLANK(), MIN ( [slgDH], [slgTon] ), BLANK() )*[avg_price]
			)
			RETURN SUMX(_addColumn, [dso])
			```
		displayFolder: TỒN
		lineageTag: c74d694d-fd3c-44da-971f-e12b11cd8179

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Avg_SLA_SSHH = ```
			
			VAR AvgSLA = 
			    CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra SSHH])
			    )
			VAR TotalSeconds = AvgSLA * 3600
			VAR Hours = INT(TotalSeconds / 3600)
			VAR Minutes = INT(MOD(TotalSeconds, 3600) / 60)
			VAR Seconds = MOD(TotalSeconds, 60)
			
			RETURN
			    FORMAT(TIME(Hours, Minutes, Seconds), "hh:mm:ss")
			```
		displayFolder: 3. XLDH
		lineageTag: 0bbb49cf-9300-4b88-9681-5ae22f5f0fb3

	measure Avg_SLA_SSHH_Comt = ```
			
			VAR AvgSLA = 
			    CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra SSHH]))
			VAR TotalSeconds = AvgSLA * 3600
			VAR Hours = INT(TotalSeconds / 3600)
			VAR Minutes = INT(MOD(TotalSeconds, 3600) / 60)
			VAR Seconds = MOD(TotalSeconds, 60)
			
			VAR z = TIME(Hours, Minutes, Seconds)
			
			RETURN
			SWITCH(
			    TRUE(),
			    z <= TIME(0,15,0), "Nhanh",
			    z <= TIME(0,30,0), "Chậm",
			    z > TIME(0,30,0), "Trễ",
			    "Trễ")
			
			```
		displayFolder: 3. XLDH
		lineageTag: 8959a450-5036-41c1-b403-7fc6fd60f022

	measure Med_SLA_SSHH = ```
			
			VAR MedianTimeNum = 
			MEDIANX(
			    'FACT_DS Online_SLA',
			    'FACT_DS Online_SLA'[SLA ra SSHH]
			)
			VAR TotalSeconds = MedianTimeNum * 3600
			VAR Hours = INT(TotalSeconds / 3600)
			VAR Minutes = INT(MOD(TotalSeconds, 3600) / 60)
			VAR Seconds = MOD(TotalSeconds, 60)
			
			RETURN
			    FORMAT(TIME(Hours, Minutes, Seconds), "hh:mm:ss")
			
			```
		lineageTag: 32220aef-1a4c-4f06-bd75-c6869c6f5dbe

