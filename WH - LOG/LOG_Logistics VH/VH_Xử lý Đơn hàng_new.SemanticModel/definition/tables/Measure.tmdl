	measure Title_ChiTietDSDH = ```
			
			VAR _SelectedValues = SELECTCOLUMNS( 
			    ALLSELECTED(Parameter_DanhMucChiTiet), 
			    "PhongBan", Parameter_DanhMucChiTiet[Parameter_Phongban]
			)
			VAR _RowCount = COUNTROWS(_SelectedValues)
			VAR _Result = 
			    SWITCH(
			        TRUE(),
			        _RowCount = 1, CONCATENATEX(_SelectedValues, [PhongBan], ", "),
			        _RowCount > 1, 
			            VAR FirstValue = TOPN(_RowCount - 1, _SelectedValues, [PhongBan], ASC)
			            VAR LastValue = LASTNONBLANK(_SelectedValues, [PhongBan])
			            RETURN CONCATENATEX(FirstValue, [PhongBan], UNICHAR(44)&UNICHAR(32)) & " và " & LastValue,
			        BLANK()
			    )
			RETURN 
			"Chi tiết và Trạng thái DH theo " & _Result
			```
		displayFolder: 1. DS Đơn hàng
		lineageTag: 6fa2b195-5a42-428e-b00a-412890bbc6a3

