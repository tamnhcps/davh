	measure Dso_DH_tiềm_năng = ```
			
			VAR Grain =
			SUMMARIZECOLUMNS(
			        'DIM_Danh mục_Phòng ban'[Miền],
			        'DIM_Danh mục_Phòng ban'[Province],
			        'DIM_Danh mục_Phòng ban'[District],
			        'DIM_Danh mục_Phòng ban'[RSM],
			        'DIM_Danh mục_Phòng ban'[AM],
			        'DIM_Danh mục_Phòng ban'[Cửa hàng],
			        'DIM_Danh mục_Nhóm hàng'[Nhóm hàng],
			        'DIM_Danh mục_Sản phẩm'[Model],
			        'DIM_Danh mục_Sản phẩm'[Tên hàng],
			        "slgDH",
			            CALCULATE (
			                SUM ( 'FACT_DS Đơn hàng'[Slg] ),
			                'FACT_DS Đơn hàng'[is_PhieuBanLe_blank] = 1,
			                'FACT_DS Đơn hàng'[ChasedState] = "Chờ xử lý"
			            ),
			        "slgTon",
			            CALCULATE (
			                SUM ( 'FACT_Warehouse_Current Inventory'[Quantity] ),
			               'DIM_Danh mục_Sản phẩm'[ton_ao] <> 1 
			            ),
			        "avg_price",
			        CALCULATE (
			            AVERAGE( 'FACT_DS Đơn hàng'[Đơn_giá] ),
			            'FACT_DS Đơn hàng'[is_PhieuBanLe_blank] = 1,
			            'FACT_DS Đơn hàng'[ChasedState] = "Chờ xử lý"
			        )
			)
			var _addColumn = 
			ADDCOLUMNS(
			    Grain,
			    "dso",IF ( [slgDH] <> BLANK() && [slgTon] <> BLANK(), MIN ( [slgDH], [slgTon] ), BLANK() )*[avg_price]
			)
			RETURN SUMX(_addColumn, [dso])
			```
		formatString: #,0
		displayFolder: TỒN
		lineageTag: 2f050819-03ed-4d3b-bcb3-8cc876ecdccf

		annotation PBI_FormatHint = {"isDecimal":true}

