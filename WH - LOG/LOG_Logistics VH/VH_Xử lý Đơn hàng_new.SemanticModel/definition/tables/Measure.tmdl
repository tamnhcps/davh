	measure 'g% LM' =
			
			VAR slg =
			    IF (
			        [Slg DH_LM] <> 0,
			        DIVIDE ( [Slg DH], [Slg DH_LM], BLANK () ) - 1,
			        BLANK()
			    )
			VAR tytrong =
			    IF (
			        [TyTrong DH_Huy LM] <> 0,
			        DIVIDE ( [TyTrong DH_Huy], [TyTrong DH_Huy LM], BLANK () ) - 1,
			        BLANK()
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        ISINSCOPE ( 'DIM_Danh mục_Trạng thái Đơn hàng'[ChasedState] ), tytrong,
			        ISINSCOPE ( 'DIM_Danh mục_Lý do Hủy đơn'[CancelReason] ), tytrong,
			        slg
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 1. DS Đơn hàng
		lineageTag: 860cb53b-9189-4ed5-a0b6-4081653882f6

