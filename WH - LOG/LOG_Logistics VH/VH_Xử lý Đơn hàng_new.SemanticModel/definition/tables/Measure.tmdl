	measure Avg_SLA_DH = ```
			
			// VAR AvgSLA = 
			//     CALCULATE(
			//         AVERAGE('FACT_DS Online_SLA'[SLA ra DH])
			//     )
			// VAR TotalSeconds = AvgSLA * 3600
			// VAR Hours = INT(TotalSeconds / 3600)
			// VAR Minutes = INT(MOD(TotalSeconds, 3600) / 60)
			// VAR Seconds = MOD(TotalSeconds, 60)
			
			// RETURN
			//     FORMAT(TIME(Hours, Minutes, Seconds), "hh:mm:ss")
			
			VAR AvgSLA = 
			    CALCULATE(
			        AVERAGE('FACT_DS Online_SLA'[SLA ra DH])
			    )
			
			-- 1. Tính tổng giây và lấy giá trị tuyệt đối để tránh lỗi số âm
			VAR TotalSeconds_Raw = AvgSLA * 3600
			VAR TotalSeconds = ABS(TotalSeconds_Raw) 
			
			-- 2. Tách Giờ, Phút, Giây từ số dương
			VAR Hours = INT(TotalSeconds / 3600)
			VAR Minutes = INT(MOD(TotalSeconds, 3600) / 60)
			VAR Seconds = INT(MOD(TotalSeconds, 60))
			
			-- 3. Xác định dấu (nếu âm thì thêm dấu - phía trước)
			VAR Sign = IF(TotalSeconds_Raw < 0, "-", "")
			
			-- 4. Ghép chuỗi thủ công để hiển thị đúng format hh:mm:ss
			RETURN
			    Sign & 
			    FORMAT(Hours, "00") & ":" & 
			    FORMAT(Minutes, "00") & ":" & 
			    FORMAT(Seconds, "00")
			```
		displayFolder: 3. XLDH
		lineageTag: 47ddd75f-ec36-44a0-9542-2956159ca2f4

	measure Med_SLA_DH = ```
			
			VAR MedianTimeNum = MEDIANX( 
			    'FACT_DS Online_SLA',
			    'FACT_DS Online_SLA'[SLA ra DH]
			)
			
			VAR TotalSeconds = MedianTimeNum * 3600
			VAR Hours = INT(TotalSeconds / 3600)
			VAR Minutes = INT(MOD(TotalSeconds, 3600) / 60)
			VAR Seconds = MOD(TotalSeconds, 60)
			
			RETURN
			    FORMAT(TIME(Hours, Minutes, Seconds), "hh:mm:ss")
			
			```
		displayFolder: 3. XLDH
		lineageTag: a9d89961-e750-4ba7-8f80-1cec779977ac

