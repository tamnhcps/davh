	measure 'TyTrong DH huy' =
			
			var total = CALCULATE([Slg Online])
			--, ALL('DIM_Danh mục_Nguồn đơn hàng'), ALL('DIM_Danh mục_Trạng thái Đơn hàng'))
			var part = [Slg DH_Huy]
