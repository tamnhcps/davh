	column CancelByDepartment =
			
			VAR department =
			    SWITCH (
			        TRUE (),
			        'FACT_DS Online'[Phòng ban người từ chối]
			            IN {
			                "CSKH - Hotline",
			                "Nhóm Hotline CellphoneS",
			                "Phòng chăm sóc khách hàng"
			            }, "Đơn Hotline từ chối",
			        'FACT_DS Online'[Phòng ban người từ chối]
			            IN {
			                "Nhóm chatline CellphoneS",
			                "Nhóm CTV Chatline CellphoneS",
			                "Nhóm Facebook CellphoneS"
			            }, "Đơn Chatline từ chối",
			        "Đơn Shop từ chối"
			    )
			RETURN IF('FACT_DS Online'[Trạng thái đơn] = "Hủy đơn", department, BLANK())
		lineageTag: d5d0b8a3-afb0-4398-8faa-28ccb1e32db5
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

