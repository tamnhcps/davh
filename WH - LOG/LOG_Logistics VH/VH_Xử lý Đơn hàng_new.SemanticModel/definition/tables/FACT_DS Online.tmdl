			    SWITCH(TRUE(),
			    'FACT_DS Online'[TrangThaiDon] = "Đã xuất kho", "Thành công",
			    'FACT_DS Online'[TrangThaiDon] = "Hủy đơn","Thất bại",
			    "Chờ xử lý"))
