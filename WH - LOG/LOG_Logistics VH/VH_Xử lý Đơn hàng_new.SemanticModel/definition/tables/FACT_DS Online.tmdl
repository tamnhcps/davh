		annotation SummarizationSetBy = Automatic

	column 'SLA ra SP' = ```
			
			VAR NgayDat =  IF('FACT_DS Online'[Đồng bộ lúc]> 'FACT_DS Online'[Ngày xử lý], 'FACT_DS Online'[Ngày đặt], 'FACT_DS Online'[Đồng bộ lúc])
			VAR NgayXuLy = 'FACT_DS Online'[NgayBanLe]
			
			VAR IsValid =
			    NOT ISBLANK(NgayDat) &&
			    NOT ISBLANK(NgayXuLy) && 
			    NOT 'FACT_DS Online'[OrderState] <> "Thành công"
			
			// VAR Duration =
			//     IF(
			//         IsValid,
			//         NgayXuLy - NgayDat,
			//         BLANK()
			//     )
			
			VAR DurationInHours =
			    IF(
			        IsValid,
			        DATEDIFF(NgayDat, NgayXuLy, SECOND) / 3600, -- đổi giây thành giờ
			        BLANK()
			    )
			
			RETURN
			    DurationInHours
			
			```
		formatString: 0.00
		lineageTag: 1d4b5c2b-b2f6-48bb-9f6b-5ce5e9905738
