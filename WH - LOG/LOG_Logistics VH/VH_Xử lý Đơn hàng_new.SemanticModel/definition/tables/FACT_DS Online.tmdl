	column Product_HighestPrice = ```
			
			VAR maxprice = 
			    CALCULATE(
			        MAX('FACT_DS Online'[Tổng đơn hàng]),
			        ALLEXCEPT('FACT_DS Online', 'FACT_DS Online'[Số online])
			    )
			RETURN
			IF('FACT_DS Online'[Tổng đơn hàng] = maxprice, 1, 0)
			```
		formatString: 0
