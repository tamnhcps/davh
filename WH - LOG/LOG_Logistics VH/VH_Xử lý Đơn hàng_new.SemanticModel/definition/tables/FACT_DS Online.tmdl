	column Cheating_check =
			
			IF(
			    'FACT_DS Online'[Số điện thoại liên hệ] <> "",
			    "Normal",
			
			    IF(
			        'FACT_DS Online'[OnlineState] = "Thành công"
			        &&
			        (
			            (
			                NOT ISBLANK('FACT_DS Online'[SDT_WN])
			                && NOT ISBLANK('FACT_DS Online'[SDT_DH])
			                && 'FACT_DS Online'[SDT_WN] <> 'FACT_DS Online'[SDT_DH]
			            )
			            ||
			            (
			                NOT ISBLANK('FACT_DS Online'[SDT_WN])
			                && NOT ISBLANK('FACT_DS Online'[SDT_SP])
			                && 'FACT_DS Online'[SDT_WN] <> 'FACT_DS Online'[SDT_SP]
			            )
			            ||
			            (
			                NOT ISBLANK('FACT_DS Online'[SDT_DH])
			                && NOT ISBLANK('FACT_DS Online'[SDT_SP])
			                && 'FACT_DS Online'[SDT_DH] <> 'FACT_DS Online'[SDT_SP]
			            )
			        ),
			        "Cheating",
			        "Normal"
			    )
			)
		lineageTag: 37ee5742-2de0-476b-a65a-bbbd30dc3823
		summarizeBy: none

