	column 'Mã kho' =
			
			VAR minindex_kho =
			    CALCULATE (
			        MIN ( 'DIM_Danh mục_Kho'[Index] ),
			        FILTER (
			            'DIM_Danh mục_Kho',
			            'DIM_Danh mục_Kho'[Tên kho] = EARLIER ( 'FACT_DS Online'[Cửa hàng] )
			        )
			    )
			VAR minindex_cuahang =
			    CALCULATE (
			        MIN ( 'DIM_Danh mục_Kho'[Index] ),
			        FILTER (
			            'DIM_Danh mục_Kho',
			            'DIM_Danh mục_Kho'[Cửa hàng] = EARLIER ( 'FACT_DS Online'[Cửa hàng] )
			        )
			    )
			VAR minindex =
			    IF ( minindex_cuahang <> BLANK (), minindex_cuahang, minindex_kho )
			RETURN
			    LOOKUPVALUE ( 'DIM_Danh mục_Kho'[Mã kho], 'DIM_Danh mục_Kho'[Index], minindex )
		lineageTag: f7d62642-4892-4201-a287-ce89278925d7
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

