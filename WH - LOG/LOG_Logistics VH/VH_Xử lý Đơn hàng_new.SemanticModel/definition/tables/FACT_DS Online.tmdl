	column IsChased =
			
			var check_DH =
			COUNTROWS (
			    FILTER (
			        'FACT_DS Đơn hàng',
			        'FACT_DS Đơn hàng'[OrderState] <> "Thất bại"
			            && 'FACT_DS Đơn hàng'[NhomHang] = EARLIER ( 'FACT_DS Online'[NhomHang] )
			            && 'FACT_DS Đơn hàng'[DiDong] = EARLIER ( 'FACT_DS Online'[SDT_WN] )
			            && 'FACT_DS Đơn hàng'[NgayDat] > EARLIER ( 'FACT_DS Online'[Ngày đặt] )
			            && 'FACT_DS Đơn hàng'[NgayDat] <= EARLIER ( 'FACT_DS Online'[Ngày đặt]) + 3
			            --&& 'FACT_DS Đơn hàng'[MaDatHang] <> EARLIER ( 'FACT_DS Online'[Số online] )
			    )
			)
			var check_Online =
			COUNTROWS (
			    FILTER (
			        'FACT_DS Online',
			        'FACT_DS Online'[OnlineState] <> "Thất bại"
			            && 'FACT_DS Online'[NhomHang] = EARLIER ( 'FACT_DS Online'[NhomHang] )
			            && 'FACT_DS Online'[SDT_WN]  = EARLIER ( 'FACT_DS Online'[SDT_WN] )
			            && 'FACT_DS Online'[Ngày đặt] > EARLIER ( 'FACT_DS Online'[Ngày đặt] )
			            && 'FACT_DS Online'[Ngày đặt] <= EARLIER ( 'FACT_DS Online'[Ngày đặt]) + 3
			            && 'FACT_DS Online'[Số online] <> EARLIER ( 'FACT_DS Online'[Số online])
			    )
			)
			return IF('FACT_DS Online'[OnlineState] = "Thất bại", COALESCE(check_DH + check_Online, 0), BLANK())
		lineageTag: de05329a-ce0a-4e82-86e2-6fea713b6bba
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column NhomHang = RELATED('DIM_Danh mục_Sản phẩm'[Nhóm hàng])
		lineageTag: 1bf3c2b6-221c-4213-a887-6c67e3bf271b
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column ChasedState =
			
			VAR count_active =
			    CALCULATE (
			        SUM ( 'FACT_DS Online'[IsChased] ),
			        FILTER (
			            'FACT_DS Online',
			            'FACT_DS Online'[OnlineState] = "Thất bại"
			                && 'FACT_DS Online'[Số online]
			                    = EARLIER ( 'FACT_DS Online'[Số online] )
			        )
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        ISBLANK ( 'FACT_DS Online'[IsChased] ), 'FACT_DS Online'[OnlineState],
			        count_active > 0, "Đã chuyển đổi",
			        "Hủy đơn"
			    )
		lineageTag: 29d47f67-cf2a-4735-b5db-55bf62de9b2f
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'SLA ra DH' = ```
			
			VAR GioBatDau = TIME(8, 0, 0)
			VAR GioKetThuc = TIME(21, 0, 0)
			
			VAR NgayDat =
			    IF('FACT_DS Online'[Đồng bộ lúc] > 'FACT_DS Online'[Ngày xử lý],
			        'FACT_DS Online'[Ngày đặt],
			        'FACT_DS Online'[Đồng bộ lúc]
			    )
			
			VAR NgayXuly = 'FACT_DS Online'[Ngày xử lý]
			
			VAR NgayDatOnly = INT(NgayDat)
			VAR NgayXuLyOnly = INT(NgayXuly)
			
			VAR GioDat = TIME(HOUR(NgayDat), MINUTE(NgayDat), SECOND(NgayDat))
			VAR GioXuLy = TIME(HOUR(NgayXuly), MINUTE(NgayXuly), SECOND(NgayXuly))
			
			-- Nếu xử lý trước 8h → đẩy lên 8h
			VAR GioXuLyGioiHan = IF(GioXuLy < GioBatDau, GioBatDau, GioXuLy)
			VAR NgayXuLyNew = NgayXuLyOnly + GioXuLyGioiHan
			
			VAR CungNgay = NgayDatOnly = NgayXuLyOnly
			VAR TruocGio = GioDat < GioBatDau
			VAR TrongGio = GioDat >= GioBatDau && GioDat <= GioKetThuc
			VAR SauGio = GioDat > GioKetThuc
			
			VAR ThoiGianSLA_Days =
			    SWITCH(
			        TRUE(),
			        ISBLANK(NgayXuly), BLANK(),
			        NgayDat > NgayXuly, 0,
			        -- --- Cùng ngày ---
			        CungNgay && TrongGio, NgayXuLyNew - NgayDat,
			        CungNgay && TruocGio, NgayXuLyNew - (NgayDatOnly + GioBatDau),
			        CungNgay && SauGio, NgayXuLyNew - NgayDat,
			
			        -- --- Khác ngày ---
			        NOT CungNgay && TrongGio, NgayXuLyNew - NgayDat,
			        NOT CungNgay && TruocGio, NgayXuLyNew - (NgayDatOnly + GioBatDau),
			        NOT CungNgay && SauGio, NgayXuLyNew - (NgayDatOnly + 1 + GioBatDau),
			
			        BLANK()
			    )
			
			RETURN
			    ThoiGianSLA_Days * 24  -- chuyển từ ngày sang giờ
			
			```
		dataType: double
		formatString: 0.00
		lineageTag: 957a44ae-b261-4a20-bcda-2c10a89485bf
		summarizeBy: sum

		changedProperty = DataType

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column OrderSource = ```
			
			VAR department =
			    SWITCH (
			        TRUE (),
			        AND('FACT_DS Online'[Phòng ban người xử lý] = "Admin", 'FACT_DS Online'[LoaiDon] = "Đơn tự động"), "admin",
			        'FACT_DS Online'[Phòng ban người xử lý]
			            IN {
			                "CSKH - Hotline",
			                "Nhóm Hotline CellphoneS",
			                "Phòng chăm sóc khách hàng"
			            }, "Hotline",
			        'FACT_DS Online'[Phòng ban người xử lý]
			            IN {
			                "Nhóm chatline CellphoneS",
			                "Nhóm CTV Chatline CellphoneS",
			                "Nhóm Facebook CellphoneS"
			            }, "Chatline",
			        'FACT_DS Online'[Phòng ban người từ chối]
			            IN {
			                "CSKH - Hotline",
			                "Nhóm Hotline CellphoneS",
			                "Phòng chăm sóc khách hàng"
			            }, "Hotline",
			        'FACT_DS Online'[Phòng ban người từ chối]
			            IN {
			                "Nhóm chatline CellphoneS",
			                "Nhóm CTV Chatline CellphoneS",
			                "Nhóm Facebook CellphoneS"
			            }, "Chatline",
			        "Shop"
			    )
			VAR Z = 
			    SWITCH (
			        TRUE (),
			        department = "admin", "Đơn tự động",
			        department = "Hotline", "Đơn Hotline xử lý",
			        department = "Chatline", "Đơn Chatline xử lý",
			        department = "Shop", "Đơn Shop xử lý",
			        BLANK ()
			    )
			RETURN z
			```
		lineageTag: 594b6508-d45a-4d04-aa1f-00d38981f3d3
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'Loại ca' = ```
			
			VAR giobatdau = TIME(8, 0, 0)
			VAR gioketthuc = TIME(21, 0, 0)
			VAR gio =  IF('FACT_DS Online'[Đồng bộ lúc]> 'FACT_DS Online'[Ngày xử lý], 'FACT_DS Online'[Ngày đặt], 'FACT_DS Online'[Đồng bộ lúc])
			VAR giodat = TIME(HOUR(gio), MINUTE(gio), SECOND(gio))
			
			
			VAR duration =
			    IF(
			        AND(giodat >= giobatdau, giodat <= gioketthuc), 
			        "Trong giờ làm", 
			        "Ngoài giờ làm"
			    )
			
			RETURN
			    duration
			
			```
		lineageTag: 462595a4-d1a8-45ae-aed2-b1ce1008a79d
		summarizeBy: none

