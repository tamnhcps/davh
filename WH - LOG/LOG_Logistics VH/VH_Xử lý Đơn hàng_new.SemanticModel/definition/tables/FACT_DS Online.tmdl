	column SSHH_Date
		dataType: dateTime
		formatString: General Date
		lineageTag: eac6639c-e12a-4ea8-81af-d298bfae56dc
		summarizeBy: none
		sourceColumn: SSHH_Date

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 'SLA ra SSDH' = ```
			
			VAR GioBatDau = TIME(8, 0, 0)
			VAR GioKetThuc = TIME(21, 0, 0)
			
			VAR NgayDat =
			    // IF('FACT_DS Online'[Đồng bộ lúc] > 'FACT_DS Online'[Ngày xử lý],
			    //     'FACT_DS Online'[Ngày đặt],
			    //     'FACT_DS Online'[Đồng bộ lúc]
			    // )
			    // 'FACT_DS Online'[Ngày đặt]
			    'FACT_DS Online'[Ngày xử lý]
			
			VAR NgayXuly = 'FACT_DS Online'[SSHH_Date]
			
			VAR NgayDatOnly = INT(NgayDat)
			VAR NgayXuLyOnly = INT(NgayXuly)
			
			VAR GioDat = TIME(HOUR(NgayDat), MINUTE(NgayDat), SECOND(NgayDat))
			VAR GioXuLy = TIME(HOUR(NgayXuly), MINUTE(NgayXuly), SECOND(NgayXuly))
			
			-- Nếu xử lý trước 8h → đẩy lên 8h
			VAR GioXuLyGioiHan = IF(GioXuLy < GioBatDau, GioBatDau, GioXuLy)
			VAR NgayXuLyNew = NgayXuLyOnly + GioXuLyGioiHan
			
			VAR CungNgay = NgayDatOnly = NgayXuLyOnly
			VAR TruocGio = GioDat < GioBatDau
			VAR TrongGio = GioDat >= GioBatDau && GioDat <= GioKetThuc
			VAR SauGio = GioDat > GioKetThuc
			
			VAR ThoiGianSLA_Days =
			    SWITCH(
			        TRUE(),
			        ISBLANK(NgayXuly), BLANK(),
			        NgayDat > NgayXuly, 0,
			        CungNgay && TrongGio, NgayXuLyNew - NgayDat,
			        CungNgay && TruocGio, NgayXuLyNew - (NgayDatOnly + GioBatDau),
			        CungNgay && SauGio, NgayXuLyNew - NgayDat,
			
			        -- --- Khác ngày ---
			        NOT CungNgay && TrongGio, NgayXuLyNew - NgayDat,
			        NOT CungNgay && TruocGio, NgayXuLyNew - (NgayDatOnly + GioBatDau),
			        NOT CungNgay && SauGio, NgayXuLyNew - (NgayDatOnly + 1 + GioBatDau),
			
			        BLANK()
			    )
			
			RETURN
			    ThoiGianSLA_Days * 24  -- chuyển từ ngày sang giờ
			
			```
		lineageTag: 3df71a5f-8499-4bf5-9087-3d9e6d654a5c
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'SLA ra SSHH_format' = ```
			
			VAR AvgSLA = 'FACT_DS Online'[SLA ra SSDH]
			VAR TotalSeconds = AvgSLA * 3600
			
			VAR Days = INT(TotalSeconds / 86400)
			VAR RemainderSeconds = MOD(TotalSeconds, 86400)
			
			VAR Hours = INT(RemainderSeconds / 3600)
			VAR Minutes = INT(MOD(RemainderSeconds, 3600) / 60)
			VAR Seconds = MOD(RemainderSeconds, 60)
			
			RETURN
			IF(AvgSLA = BLANK(),"",
			    FORMAT(Days, "0") & "d " &
			    FORMAT(Hours, "00") & ":" &
			    FORMAT(Minutes, "00") & ":" &
			    FORMAT(Seconds, "00"))
			
			```
		lineageTag: 4a34f658-8b5d-4737-9347-f6232c3882ef
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

