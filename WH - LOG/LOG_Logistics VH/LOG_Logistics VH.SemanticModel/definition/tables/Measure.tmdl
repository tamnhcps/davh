	/// 
	measure 'TG hoàn thành phiếu_TB' =
			
			CALCULATE (
			    AVERAGE ( 'F_Transfer_Detail'[Thời gian hoàn tất phiếu] ),
			    FILTER (
			        'F_Transfer_Detail',
			        'F_Transfer_Detail'[Thời gian hoàn tất phiếu]
