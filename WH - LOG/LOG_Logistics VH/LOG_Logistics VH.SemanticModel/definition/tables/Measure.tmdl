	measure 'Slg_Hoàn tất' =
			
			CALCULATE (
			    [Số phiếu_Tình trạng đơn],
			    FILTER (
			        'F_Logistics_Status',
			        'F_Logistics_Status'[Tính chất phiếu giao] = "SP"
			            && 'F_Logistics_Status'[Tình trạng đơn] = "Hoàn tất"
			    )
			)
		formatString: #,0
		displayFolder: Tài xế
		lineageTag: c22a7cbf-9f7e-499d-9177-679380dfe027

	measure 'Slg_Chưa hoàn tất' = ```
			
			CALCULATE (
			    [Số phiếu_Tình trạng đơn],
			    FILTER (
			        'F_Logistics_Status',
			        'F_Logistics_Status'[Tính chất phiếu giao] = "SP"
			            && 'F_Logistics_Status'[Tình trạng đơn] IN {"Đang giao", "Mới tạo", "Thả hàng chưa xác nhận", "Thả hàng đã xác nhận"} 
			    )
			)
			// [Đang giao] + [Mới tạo] + [Thả hàng chưa xác nhận] + [Thả hàng đã xác nhận]
			```
		formatString: #,0
		displayFolder: Tài xế
		lineageTag: b4529ad6-f8cc-42b4-acf9-c869990e91fc

	measure 'Slg_Hủy giao' =
			
			CALCULATE (
			    [Số phiếu_Tình trạng đơn],
			    FILTER (
			        'F_Logistics_Status',
			        'F_Logistics_Status'[Tính chất phiếu giao] = "SP"
			            && 'F_Logistics_Status'[Tình trạng đơn] IN {"Hủy giao chưa hoàn hàng", "Hủy giao đã hoàn hàng", "Hủy giao kho đã nhận hàng", "Tài xế từ chối nhận hàng"}
			    )
			)
			// [Hủy giao chưa hoàn hàng] + [Hủy giao đã hoàn hàng] + [Hủy giao kho đã nhận hàng] + [Tài xế từ chối nhận hàng]
		formatString: #,0
		displayFolder: Tài xế
		lineageTag: ba6b5b3f-c02d-4436-9ff4-9be3183fd877

	measure 'Số phiếu SP' =
			
			[Slg_Hoàn tất] + [Slg_Chưa hoàn tất] + [Slg_Hủy giao]
		formatString: #,0
		displayFolder: Tài xế
		lineageTag: a550ae50-a002-4a55-b814-41a4fe75f4eb

	/// Khoảng cách từ CH theo bản đồ trung bình ngày (DVT: m)
	measure 'Khoảng cách TB/Ngày' =
			
			DIVIDE(
			    [Khoảng cách],
			    DISTINCTCOUNT('F_Logistics'[Date])
