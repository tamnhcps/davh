			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trạng thái xử lý đơn] IN {"Shop trễ hạn", "Shipper trễ hạn", "Shop và Shipper trễ hạn", "Shop và Shipper đúng hạn"}
			    )
			)
		formatString: 0
		displayFolder: Giao hàng combined\Phân loại trễ hạn
		lineageTag: bb22013c-b0ab-4989-9235-9c0122533899

	measure '% Trễ hạn_Shop' =
			
