	/// (Thời gian hoàn tất - Nhận lần đầu lúc) trung bình (DVT: ngày)
	measure 'TG đi đường_TB' =
			
			CALCULATE (
			    AVERAGE ( 'F_Transfer_Detail'[Thời gian đi đường] ),
			    FILTER (
			        'F_Transfer_Detail',
			        'F_Transfer_Detail'[Thời gian đi đường]
