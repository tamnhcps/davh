	measure '% Trễ hạn_DH_LM' =
			
			-- Min date in current filter
			VAR x = MIN('D_Date'[Date])
			-- First date with f_table
			VAR y = EOMONTH([Date_LogsFrom], 0)
			RETURN
			-- Show LM only if previous month exists
			    IF(
			        x > y,
			        CALCULATE(
			            [% Trễ hạn_DH],
			            DATEADD('D_Date'[Date], -1, MONTH)
			        ),
			        BLANK()
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Giao hàng combined\Phân loại trễ hạn
		lineageTag: 5e20720e-ed9b-4497-b5e3-76e43168e319

