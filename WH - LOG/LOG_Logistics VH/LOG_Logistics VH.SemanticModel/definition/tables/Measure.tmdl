	measure 'Số phiếu_Tình trạng đơn' = COUNT('F_Logistics_Status'[Số phiếu])
		formatString: #,0
		displayFolder: Tài xế
		lineageTag: 69ca7083-1167-4d0c-b72c-5f988a82a328

	measure 'Số phiếu_LM' =
			
			-- Min date in current filter
			VAR x = MIN('D_Date'[Date])
			-- First date with f_table
			VAR y = EOMONTH([Date_LogsFrom], 0)
			RETURN
			-- Show LM only if previous month exists
			    IF(
			        x > y,
			        CALCULATE(
			            [Số phiếu],
			            DATEADD('D_Date'[Date], -1, MONTH)
			        ),
			        BLANK()
			    )
		formatString: #,0
		displayFolder: Giao hàng combined\Số phiếu
		lineageTag: 52eaf3f3-efe1-40da-a09f-5719ed5bc37c

	/// Số phiếu so với tháng trước (DVT: %)
	/// 
	measure 'g% Số phiếu' =
			
			VAR dso_lm_g =
			    DIVIDE (
			        [Số phiếu],
			        [Số phiếu_LM],
			        BLANK ()
			    ) - 1
			RETURN
			    IF (
			        [Số phiếu_LM] <> 0
			            && [Số phiếu] <> 0,
			        dso_lm_g,
			        BLANK()
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Giao hàng combined\Số phiếu
		lineageTag: c4095ef6-71ea-414c-8ea0-712b9d31b798

	measure 'Slg Nhập_LM' =
			
			CALCULATE(
			    [Slg Nhập],
			    DATEADD('D_Date'[Date], -1, MONTH)
			)
		formatString: #,0
		displayFolder: So sánh nhập chuyển
		lineageTag: 00add612-0ece-4d29-b823-5e76279ba322

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Slg Chuyển_LM' =
			
			CALCULATE(
			    [Slg Chuyển],
			    DATEADD('D_Date'[Date], -1, MONTH)
			)
		formatString: #,0
		displayFolder: So sánh nhập chuyển
		lineageTag: c015a11e-44ad-4840-8f8b-57f0eb142251

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Tổng phí vận chuyển bảo hành, lấy từ phiếu SP giao vận chuyển bảo hành và phiếu SO (gồm cả B2B và B2C)
	measure 'Phí VC_Bảo hành' =
			
			CALCULATE (
			    SUM('F_Logistics'[Phí VC]),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[IsCareService] = 1
			    )
			)
		formatString: #,0
		displayFolder: Phí VC_Nội ngoại thành
		lineageTag: 68991ea3-5804-4d96-9788-7e73401821e7

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Tổng phí vận chuyển từ phiếu SP có trạng thái Hoàn tất (Chỉ gồm B2C)
	measure 'Phí VC' =
			
			CALCULATE (
			    SUM ( 'F_Logistics'[Phí VC] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Tính chất phiếu giao] = "SP"
			        && NOT CONTAINSSTRING('F_Logistics'[Cửa hàng], "B2B")
			        && 'F_Logistics'[Tên xe] <> "Giao hàng cho khách B2B"
			        && 'F_Logistics'[IsSentDocument] = BLANK()
			        && 'F_Logistics'[Tình trạng đơn] IN {"Hoàn tất", "Giao thành công"}
			    )
			)
		displayFolder: Phí VC_Nội ngoại thành
		lineageTag: 244b6a1b-e04a-404b-bf37-39da82ba7c38

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Số phiếu_Nội thành' =
			
			CALCULATE(
			    [Số phiếu],
			    FILTER(
			        'F_Logistics',
