	/// 
	/// 
	measure 'Trễ hạn_DH' =
			
			CALCULATE (
			    COUNT('F_Logistics'[Trễ hạn theo DH] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trễ hạn theo DH]= "Trễ hạn"
