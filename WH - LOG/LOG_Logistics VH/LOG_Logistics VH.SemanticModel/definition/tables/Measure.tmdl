	measure 'Chi phí dự báo_Nội thành' =
			
			VAR z1 = CALCULATE([Phí VC_Nội thành], PARALLELPERIOD('D_Date'[Date], -1, MONTH))
			VAR z2 = CALCULATE([Phí VC_Nội thành], PARALLELPERIOD('D_Date'[Date], -2, MONTH))
			VAR z3 = CALCULATE([Phí VC_Nội thành], PARALLELPERIOD('D_Date'[Date], -3, MONTH))
			VAR zDaysInMonth = COUNTROWS(FILTER(ALL('D_Date'), 'D_Date'[Năm/Tháng] = MAX('D_Date'[Năm/Tháng])))
			VAR zAvgCost =
			IF(
			    z1 <> BLANK()
			        && z2 <> BLANK()
			            && z3 <> BLANK(),
			            AVERAGEX(
			                {
			                    z1,
			                    z2,
			                    z3
			                },
			                [Value]
			            )
			)
			RETURN
			IF(
			    ISINSCOPE('D_Date'[Date]),
			        zAvgCost / zDaysInMonth,
			        zAvgCost
			)
		formatString: #,0
		displayFolder: Chi phí dự báo_Nội ngoại thành
		lineageTag: c9a37ea9-c754-4176-b151-5eb23e3e9f5a

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Chi phí dự báo_Ngoại thành' =
			
