		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Update-Filtered = ```
			
			--Update
			VAR zFmt_HeaderStart = 
				"<a> <span style='color:#17283c'> <b> "
			VAR zFmt_HeaderEnd = 
				": </b> </a>"
			VAR zUpdate_time =
			    [Maxdate_Nội bộ]
			VAR zUpdate = 
				"<font_update> <span style='color:#17283c'>
			        <u> Cập nhật đến </u>: " & zUpdate_time & 
			    "</font_update>" 
			
			--Thời gian
			VAR zFil_Ngay =
			    ISFILTERED( 'D_Date'[date] )
			VAR zNgay =
			    zFmt_HeaderStart & "Ngày" & zFmt_HeaderEnd
			        & "Từ " & MIN('D_Date'[date])
			        & " đến " & MAX('D_Date'[date]) & "."
			VAR zFil_Thang =
			    ISFILTERED('D_Date'[Năm/Tháng])
			VAR zThang =
			    zFmt_HeaderStart & "Năm/Tháng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Date'[Năm/Tháng] ), 'D_Date'[Năm/Tháng] , ", " ) & "."
			
			VAR zFil_ThoiGian = 
				zFil_Ngay + zFil_Thang + 0
			
			--Chủ thể
			VAR zFil_B2BB2C =
			    ISFILTERED( 'D_B2B/B2C'[B2B/B2C] )
			VAR zB2BB2C =
			    zFmt_HeaderStart & "B2B/B2C" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES('D_B2B/B2C'[B2B/B2C] ), 'D_B2B/B2C'[B2B/B2C], ", " ) & "."
			
			VAR zFil_Mien =
			    ISFILTERED( 'D_Department'[mien] )
			VAR zMien =
			    zFmt_HeaderStart & "Miền" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Department'[mien] ), 'D_Department'[mien], ", " ) & "."
			
			VAR zFil_TrangThai =
			    ISFILTERED( 'D_Status'[Trạng thái phiếu] )
			VAR zTrangThai =
			    zFmt_HeaderStart & "Trạng thái phiếu" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES('D_Status'[Trạng thái phiếu] ), 'D_Status'[Trạng thái phiếu], ", " ) & "."
			
			VAR zFil_TCPG =
			    ISFILTERED( 'D_TicketType'[Tính chất phiếu giao] )
			VAR zTCPG =
			    zFmt_HeaderStart & "Nguồn phát sinh" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES('D_TicketType'[Tính chất phiếu giao] ), 'D_TicketType'[Tính chất phiếu giao], ", " ) & "."
			
			VAR zFil_NNT =
			    ISFILTERED( 'D_DeliveryMethod'[Phân loại khu vực vận chuyển] )
			VAR zNNT =
			    zFmt_HeaderStart & "Nội/Ngoại thành" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES('D_DeliveryMethod'[Phân loại khu vực vận chuyển] ), 'D_DeliveryMethod'[Phân loại khu vực vận chuyển], ", " ) & "."
			
			VAR zFil_HTVC =
			    ISFILTERED( 'D_DeliveryMethod'[Hình thức vận chuyển])
			VAR zHTVC =
			    zFmt_HeaderStart & "Hình thức vận chuyển" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES('D_DeliveryMethod'[Hình thức vận chuyển] ), 'D_DeliveryMethod'[Hình thức vận chuyển], ", " ) & "."
			
			VAR zFil_AM =
			    ISFILTERED( 'D_Department'[am_visual] )
			VAR zAM =
			    zFmt_HeaderStart & "AM" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Department'[am_visual] ), 'D_Department'[am_visual], ", " ) & "."
			
			VAR zFil_CH =
			    ISFILTERED( 'D_Department'[bo_phan] )
			VAR zCH =
			    zFmt_HeaderStart & "Cửa hàng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Department'[bo_phan] ), 'D_Department'[bo_phan], ", " ) & "."
			
			VAR zFil_NLGH =
			    ISFILTERED( 'D_DeliveryType'[Loại giao hàng] )
			VAR zNLGH =
			    zFmt_HeaderStart & "Loại giao hàng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_DeliveryType'[Loại giao hàng] ), 'D_DeliveryType'[Loại giao hàng], ", " ) & "."
			
			VAR zFil_NV =
			    ISFILTERED( 'D_Employee'[Nhân viên] )
			VAR zNV =
			    zFmt_HeaderStart & "Tài xế" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Employee'[Nhân viên] ), 'D_Employee'[Nhân viên], ", " ) & "."
			
			VAR zFil_MienII =
			    ISFILTERED( 'D_Region'[Miền] )
			VAR zMienII =
			    zFmt_HeaderStart & "Miền" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Region'[Miền] ), 'D_Region'[Miền], ", " ) & "."
			
			VAR zFil_KV =
			    ISFILTERED( 'D_Area'[Khu vực] )
			VAR zKV =
			    zFmt_HeaderStart & "Khu vực" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Area'[Khu vực] ), 'D_Area'[Khu vực], ", " ) & "."
			
			VAR zFil_NH =
			    ISFILTERED( 'D_ProductGroup'[Nhóm hàng] )
			VAR zNH =
			    zFmt_HeaderStart & "Nhóm hàng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_ProductGroup'[Nhóm hàng] ), 'D_ProductGroup'[Nhóm hàng], ", " ) & "."
			
			VAR zFil_LD =
			    ISFILTERED( 'D_YcdcReason'[Lý do YCDC] )
			VAR zLD =
			    zFmt_HeaderStart & "Lý do YCDC" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_YcdcReason'[Lý do YCDC] ), 'D_YcdcReason'[Lý do YCDC], ", " ) & "."
			
			VAR zFil_TX =
			    ISFILTERED( 'D_Car'[Tên xe] )
			VAR zTX =
			    zFmt_HeaderStart & "Tên xe" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Car'[Tên xe] ), 'D_Car'[Tên xe], ", " ) & "."
			
			VAR zFil_TrangThaiIII =
			    ISFILTERED( 'D_Status_Driver'[Trạng thái phiếu SP] )
			VAR zTrangThaiIII =
			    zFmt_HeaderStart & "Nhóm trạng thái" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Status_Driver'[Trạng thái phiếu SP] ), 'D_Status_Driver'[Trạng thái phiếu SP], ", " ) & "."
			
			VAR zFil_TTD =
			    ISFILTERED( 'D_Status_Driver'[Tình trạng đơn] )
			VAR zTTD =
			    zFmt_HeaderStart & "Trạng thái" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Status_Driver'[Tình trạng đơn] ), 'D_Status_Driver'[Tình trạng đơn], ", " ) & "."
			
			VAR zFil_TinhThanh =
			    ISFILTERED( 'D_Province'[Tỉnh thành] )
			VAR zTinhThanh =
			    zFmt_HeaderStart & "Tỉnh thành" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Province'[Tỉnh thành]), 'D_Province'[Tỉnh thành], ", " ) & "."
			
			VAR zFil_RT =
			    ISFILTERED( 'F_Logistics'[Mã chuyến đi] )
			VAR zRT =
			    zFmt_HeaderStart & "Mã chuyến đi" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'F_Logistics'[Mã chuyến đi] ), 'F_Logistics'[Mã chuyến đi], ", " ) & "."
			
			VAR zFil_SP =
			    ISFILTERED( 'F_Logistics'[Số phiếu] )
			VAR zSP =
			    zFmt_HeaderStart & "Số phiếu" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'F_Logistics'[Số phiếu]), 'F_Logistics'[Số phiếu], ", " ) & "."
			
			VAR zFil_ChuThe = 
			    zFil_B2BB2C + zFil_Mien + zFil_TrangThai + zFil_TCPG + zFil_NNT + zFil_HTVC + zFil_AM + zFil_CH + zFil_NLGH + zFil_NV +
			    zFil_MienII + zFil_KV + zFil_NH + zFil_LD + zFil_TX + zFil_TrangThaiIII + zFil_TTD + zFil_TinhThanh + zFil_RT + zFil_SP + 0
				
			--Final
			VAR zFilter =
			    IF(
			        zFil_ThoiGian + 
			        zFil_ChuThe = 0,
			        BLANK(),
			        "<br> <u> <span style='color:#17283c'> Bộ lọc áp dụng:</u> "
			            & IF( zFil_Ngay = TRUE, zNgay, BLANK() )
			            & IF( zFil_Thang = TRUE, zThang, BLANK() )
			            & IF( zFil_B2BB2C = TRUE, zB2BB2C, BLANK() )
			            & IF( zFil_Mien = TRUE, zMien, BLANK() )
			            & IF( zFil_TrangThai = TRUE, zTrangThai, BLANK() )
			            & IF( zFil_TCPG = TRUE, zTCPG, BLANK() )
			            & IF( zFil_NNT = TRUE, zNNT, BLANK() )
			            & IF( zFil_HTVC = TRUE, zHTVC, BLANK() )
			            & IF( zFil_AM = TRUE, zAM, BLANK() )
			            & IF( zFil_CH = TRUE, zCH, BLANK() )
			            & IF( zFil_NLGH = TRUE, zNLGH, BLANK() )
			            & IF( zFil_NV = TRUE, zNV, BLANK() )
			            & IF( zFil_MienII = TRUE, zMienII, BLANK() )
			            & IF( zFil_KV = TRUE, zKV, BLANK() )
			            & IF( zFil_NH = TRUE, zNH, BLANK() )
			            & IF( zFil_LD = TRUE, zLD, BLANK() )
			            & IF( zFil_TX = TRUE, zTX, BLANK() )
			            & IF( zFil_TrangThaiIII = TRUE, zTrangThaiIII, BLANK() )
			            & IF( zFil_TTD = TRUE, zTTD, BLANK() )
			            & IF( zFil_TinhThanh = TRUE, zTinhThanh, BLANK() )
			            & IF( zFil_RT = TRUE, zRT, BLANK() )
			            & IF( zFil_SP = TRUE, zSP, BLANK() )
			    )
			RETURN
			    "<font_all> <i> <span style='color:#df062d'>" & zUpdate & zFilter & "</font_all>"
			```
		displayFolder: Other
		lineageTag: 2f6dd29a-199d-4bd4-b98a-7ad898954ce6

