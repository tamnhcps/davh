table Measure
	lineageTag: dc78e311-43d8-4a2f-be23-c7f4a9a468b5

	/// Số phiếu SP/DC
	/// 
	measure 'Số phiếu' = ```
			
			CALCULATE(
			    DISTINCTCOUNT ( 'F_Logistics'[Số phiếu]),
			    FILTER(
			        'F_Logistics',
			        'F_Logistics'[Tính chất phiếu giao] IN {"SP", "DC"}
			            && 'F_Logistics'[IsUnique] = 1
			    )
			)
			--Lưu trữ
			// CALCULATE(
			//     DISTINCTCOUNT ( 'FACT_Logistics_Appended'[Số phiếu]),
			//     FILTER(
			//         'FACT_Logistics_Appended',
			//         'FACT_Logistics_Appended'[Tính chất phiếu giao] IN {"SP", "DC"}
			//     )
			// )
			
			
			```
		formatString: #,0
		displayFolder: Giao hàng combined\Số phiếu
		lineageTag: ef6a5b1e-dc2e-4a1e-a4f2-009a19bed672

		changedProperty = FormatString

	measure 'Hoàn tất %' = ```
			
			DIVIDE(
			   [Hoàn tất],
			   [Số phiếu],
			   blank()
			   )
			
			```
		formatString: 0%;-0%;0%
		displayFolder: Giao hàng combined\Số phiếu
		lineageTag: d6f026ad-af89-4330-a05d-937e99f302f5

		changedProperty = FormatString

	/// Số phiếu SP/DC có trạng thái hoàn tất
	/// 
	measure 'Hoàn tất' =
			
			CALCULATE (
			    [Số phiếu],
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trạng thái phiếu] = "Hoàn tất"
			    )
			)
		formatString: #,0
		displayFolder: Giao hàng combined\Số phiếu
		lineageTag: dce4f497-f354-4f63-b7a3-038cdecdb01b

		changedProperty = FormatString

	measure 'Maxdate_Nội bộ' =
			CALCULATE(MAX ( 'F_Logistics'[Ngày tạo chuyến đi] ), ALL())
			// // CALCULATE(
			//     MAX ( 'FACT_Logistics_Appended'[Ngày tạo chuyến đi] )
			// //     FILTER(FACT_Logistics_Appended, FACT_Logistics_Appended[Mã chuyến đi] <> BLANK())
			// // )
		formatString: General Date
		displayFolder: Other
		lineageTag: 4132cb1a-4646-4b90-96f1-01768c2ebf2f

		changedProperty = FormatString

	/// Tổng khoảng cách từ CH theo bản đồ (DVT: m)
	/// 
	measure 'Khoảng cách' =
			
			SUM ( 'F_Logistics'[K.Cách từ CH theo bản đồ] )
		formatString: #,0
		displayFolder: Giao hàng combined\Khoảng cách
		lineageTag: d40ca420-b938-41c1-984e-f259763b69c6

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Số giờ trong ngày' = 24
		formatString: 0
		displayFolder: Other
		lineageTag: 5c918d6e-9326-4810-8224-34a4199395d8

	/// Khoảng cách từ CH theo bản đồ trung bình (DVT: m)
	measure 'Khoảng cách_TB' =
			
			CALCULATE(
			    AVERAGE ( 'F_Logistics'[K.Cách từ CH theo bản đồ] ),
			    FILTER(
			        'F_Logistics',
			        'F_Logistics'[K.Cách từ CH theo bản đồ] > 0
			    )
			)
		formatString: #,0.00
		displayFolder: Giao hàng combined\Khoảng cách
		lineageTag: ce69d39d-b2a7-44fa-b58d-cd4f49d9fe35

		changedProperty = FormatString

	/// (Ngày tạo chuyến đi - Ngày đơn hàng) trung bình (DVT: giờ)
	/// *Không bao gồm phiếu có tổng thời gian giao hàng vượt quá 1 tuần
	measure 'TG xử lý đơn_TB' =
			
			CALCULATE (
			    AVERAGE ( 'F_Logistics'[Thời gian xử lý đơn] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Thời gian xử lý đơn] <> BLANK ()
			            && 'F_Logistics'[IsOutlier] = 0
			    )
			)
		formatString: #,0.00
		displayFolder: Giao hàng combined\Thời gian giao hàng
		lineageTag: 5e312014-e026-45d2-b32d-5d9a89afd1a7

		changedProperty = FormatString

	/// Nội bộ: (Thời gian kết thúc đơn hàng - Thời gian nhận lúc) trung bình (DVT: giờ)
	/// Đối tác: (Thời gian giao thành công - Thời gian đang giao) trung bình (DVT: giờ)
	/// *Không bao gồm phiếu có tổng thời gian giao hàng vượt quá 1 tuần
	measure 'TG giao cho khách_TB' =
			
			CALCULATE (
			    AVERAGE ( 'F_Logistics'[Thời gian giao cho khách] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Thời gian giao cho khách] <> BLANK ()
			            && 'F_Logistics'[IsOutlier] = 0
			    )
			)
		formatString: #,0.00
		displayFolder: Giao hàng combined\Thời gian giao hàng
		lineageTag: d8b1500f-642d-413b-b193-41c131790fcb

		changedProperty = FormatString

	/// Nội bộ: (Thời gian nhận lúc lần đầu - Thời gian tạo số tuyến) trung bình (DVT: giờ)
	/// Đối tác: (Thời gian đã lấy hàng - Thời gian tạo vận đơn) trung bình (DVT: giờ)
	/// *Không bao gồm phiếu có tổng thời gian giao hàng vượt quá 1 tuần
	/// 
	measure 'TG chờ lấy hàng_TB' =
			
			CALCULATE (
			    AVERAGE ( 'F_Logistics'[Thời gian chờ lấy hàng] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Thời gian chờ lấy hàng] <> BLANK ()
			            && 'F_Logistics'[IsOutlier] = 0
			    )
			)
		formatString: 0.00
		displayFolder: Giao hàng combined\Thời gian giao hàng
		lineageTag: f0ccad06-bb5f-4cbf-b6c7-2ed2441151af

		changedProperty = FormatString

	measure 'Giá trị đơn' = ```
			
			SUMX(
			    SUMMARIZE(
			        FILTER(
			            F_Logistics, 
			            F_Logistics[Tính chất phiếu giao old] = "SP"
			                && F_Logistics[IsUnique] = 1
			        ),
			        F_Logistics[Số phiếu],
			        F_Logistics[Giá trị đơn]
			    ),
			    F_Logistics[Giá trị đơn]
			   )
			```
		formatString: #,0
		displayFolder: Giao hàng combined\Doanh thu
		lineageTag: d67200b6-0b54-4119-a1ff-19f6099e5c39

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Khoảng cách từ CH theo bản đồ trung bình đơn (DVT: m)
	measure 'Khoảng cách TB/đơn' = [Khoảng cách]/[Số phiếu]
		displayFolder: Giao hàng combined\Khoảng cách
		lineageTag: 4213304a-e95f-48e1-939b-e06fc9e1091e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Giá trị đơn_LM' =
			
			CALCULATE (
			    [Giá trị đơn],
			    PREVIOUSMONTH ( 'D_Date'[Date] )
			)
		formatString: 0
		displayFolder: Giao hàng combined\Doanh thu
		lineageTag: f91928b6-eac8-4fa9-971a-c253a5048f97

		annotation PBI_FormatHint = {"isDecimal":true}

	/// Giá trị đơn so với tháng trước (DVT: %)
	measure 'g% Giá trị đơn' =
			
			VAR dso_lm_g =
			    DIVIDE (
			        [Giá trị đơn],
			        [Giá trị đơn_LM],
			        BLANK ()
			    ) - 1
			RETURN
			    IF (
			        [Giá trị đơn_LM] <> 0
			            && [Giá trị đơn] <> 0,
			        dso_lm_g,
			        BLANK()
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Giao hàng combined\Doanh thu
		lineageTag: 12cbb744-5c83-4d49-9553-56029bd074dc

	/// (Ngày tạo chuyến đi - ngày đơn hàng) quá 15 phút
	/// 
	measure 'Trễ hạn_Shop' =
			
			CALCULATE (
			    count ( 'F_Logistics'[Trạng thái xử lý đơn] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trạng thái xử lý đơn] IN {"Shop trễ hạn", "Shop và Shipper trễ hạn"}
			    )
			)
		formatString: 0
		displayFolder: Giao hàng combined\Phân loại trễ hạn
		lineageTag: 2d035713-71e9-4893-9607-f89ff914789b

	/// (Thời gian hoàn tất - Ngày tạo chuyến đi) quá 105 phút đối với loại đơn giao 2h, tương tự cho loại đơn giao 3h và 4h
	/// 
	measure 'Trễ hạn_Shipper' =
			
			CALCULATE (
			    COUNT('F_Logistics'[Trạng thái xử lý đơn] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trạng thái xử lý đơn] IN {"Shipper trễ hạn", "Shop và Shipper trễ hạn"}
			    )
			)
		formatString: 0
		displayFolder: Giao hàng combined\Phân loại trễ hạn
		lineageTag: c34ff185-590c-4db4-8907-07ab748ad511

	/// Thoả đồng thời điều kiện [% Late by shop] và [% Late by shipper]
	/// 
	measure 'Trễ hạn_Shop & Shipper' =
			
			CALCULATE (
			    count ( 'F_Logistics'[Trạng thái xử lý đơn] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trạng thái xử lý đơn]= "Shop và Shipper trễ hạn"
