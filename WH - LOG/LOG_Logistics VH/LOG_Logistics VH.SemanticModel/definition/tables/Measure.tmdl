	/// Số lượng sản phẩm theo phương thức nhập mua trong nước và trạng thái đã hoàn thành so với tháng trước (DVT: %)
	/// 
	/// 
	measure '% Slg Nhập LM' =
			
			DIVIDE(
			    [Slg Nhập] - [Slg Nhập_LM],
			    [Slg Nhập_LM],
			    BLANK()
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: So sánh nhập chuyển
