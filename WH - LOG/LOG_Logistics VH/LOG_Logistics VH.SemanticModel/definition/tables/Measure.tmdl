	/// Trễ hạn theo thời gian hẹn trên RT = (Thời gian hoàn tất/Thời gian huỷ - Giao hàng trước) > 0
	measure 'Trễ hạn_RT' =
			
			CALCULATE (
			    COUNT('F_Logistics'[Trễ hạn theo RT] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Trễ hạn theo RT] = "Trễ hạn"
