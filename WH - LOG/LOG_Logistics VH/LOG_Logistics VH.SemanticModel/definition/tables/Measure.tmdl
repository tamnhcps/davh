	/// (Ngày lập phiếu SP   - Ngày đơn hàng) ) trung bình (DVT: giờ)
	/// *Không bao gồm phiếu có tổng thời gian giao hàng vượt quá 1 tuần
	measure 'TG xử lý DH ra SP' =
			
			CALCULATE (
			    AVERAGE ( 'F_Logistics'[Thời gian DH ra SP] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Thời gian DH ra SP] <> BLANK ()
			            && 'F_Logistics'[IsOutlier] = 0
			    )
			)
		formatString: #,0.00
		displayFolder: Giao hàng combined\Thời gian giao hàng
		lineageTag: 1afd19ba-99aa-482f-8b47-896a440f8117

	/// (Ngày tạo chuyến đi - Ngày lập phiếu SP) trung bình (DVT: giờ)
	/// *Không bao gồm phiếu có tổng thời gian giao hàng vượt quá 1 tuần
	measure 'TG xử lý SP ra RT' =
			
			CALCULATE (
			    AVERAGE ( 'F_Logistics'[Thời gian SP ra RT] ),
			    FILTER (
			        'F_Logistics',
			        'F_Logistics'[Thời gian SP ra RT] <> BLANK ()
			            && 'F_Logistics'[IsOutlier] = 0
			    )
			)
		displayFolder: Giao hàng combined\Thời gian giao hàng
		lineageTag: df3b6cef-d7f2-49f8-a4f5-b3a808d5ca95

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Phí VC_LM' =
			
			-- Min date in current filter
			VAR x = MIN('D_Date'[Date])
			-- First date with f_table
			VAR y = EOMONTH([Date_LogsFrom], 0)
			RETURN
			-- Show LM only if previous month exists
			    IF(
			        x > y,
			        CALCULATE(
			            [Phí VC],
			            DATEADD('D_Date'[Date], -1, MONTH)
			        ),
			        BLANK()
			    )
		displayFolder: Phí VC_Nội ngoại thành
		lineageTag: 3d519abb-e2ca-449c-b44d-a419db1dab97

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Phí VC_MoM%' =
			
			DIVIDE(
			    [Phí VC] - [Phí VC_LM],
			    [Phí VC_LM],
			    BLANK()
			)
		displayFolder: Phí VC_Nội ngoại thành
		lineageTag: 6c72ccaa-6e96-4d67-b26e-e8dc298dcb47

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Measure = ```
			
			CALCULATE(
			    DISTINCTCOUNT('F_Logistics'[Mã tài xế])
			    ,FILTER(
			        'D_Employee'
			        , 'D_Employee'[DepartmentName] = "Nhóm Giao nhận Xe máy_KV2"
			        ||'D_Employee'[DepartmentName] =  "Nhóm Giao nhận Xe máy_KV1"))
			
			```
		formatString: 0
		lineageTag: 6c3d05ca-6ff5-4a89-ab82-de31f1306b6e

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'NS tài xế' = ```
			
			VAR total_edays = 
			    CALCULATE(
			    DISTINCTCOUNT('F_Logistics'[Mã tài xế])
			    ,FILTER(
			        'D_Employee'
			        , 'D_Employee'[DepartmentName] = "Nhóm Giao nhận Xe máy_KV2"
			        ||'D_Employee'[DepartmentName] =  "Nhóm Giao nhận Xe máy_KV1"))
			VAR total_phieu = 'Measure'[Số phiếu]
			RETURN
			DIVIDE(total_phieu,total_edays,BLANK())
			```
		lineageTag: af42f5e4-0056-4a82-b3f6-bfdd89d69e07

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Khoảng cách MIN' =
			
			CALCULATE(
			    MIN('F_Logistics'[K.Cách từ CH theo bản đồ])
			    ,'F_Logistics'[Trạng thái phiếu] = "Hoàn tất"
			    , F_Logistics[K.Cách từ CH theo bản đồ] > 0
			    , F_Logistics[K.Cách từ CH theo bản đồ] <> BLANK()
			)
		displayFolder: Giao hàng combined\Khoảng cách
		lineageTag: 8fc88d18-0011-48fb-9702-0094391b1ddd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Khoảng cách MAX' =
			
			CALCULATE(
			    MAX('F_Logistics'[K.Cách từ CH theo bản đồ])
			    ,'F_Logistics'[Trạng thái phiếu] = "Hoàn tất"
			    , F_Logistics[K.Cách từ CH theo bản đồ] >0
			)
		displayFolder: Giao hàng combined\Khoảng cách
		lineageTag: c9775acb-1072-4a51-9b91-af0b57e600ee

		annotation PBI_FormatHint = {"isGeneralNumber":true}

