	measure 'Giá trị đơn_nội bộ' = ```
			
			   SUMX(
			    SUMMARIZE(
			        FILTER(
			            F_Logistics, 
			            'F_Logistics'[Tính chất phiếu giao] = "SP"
			            && 'F_Logistics'[Hình thức vận chuyển] IN {"NV LOG", "NV SHOP", "AHAMOVE"}
			            && NOT CONTAINSSTRING('F_Logistics'[Cửa hàng], "B2B")
			            && 'F_Logistics'[Tên xe] <> "Giao hàng cho khách B2B"
			            && 'F_Logistics'[Tình trạng đơn] IN {"Hoàn tất", "Giao thành công"}
			        ),
			        F_Logistics[Số phiếu],
			        F_Logistics[Giá trị đơn]
			    ),
			    F_Logistics[Giá trị đơn]
			   )
			```
		displayFolder: Dso_Nội ngoại thành
		lineageTag: 1b06c030-d22c-4c2e-941e-e37ecdaf85ec

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Giá trị đơn_đối tác' = ```
			
			   SUMX(
			    SUMMARIZE(
			        FILTER(
			            F_Logistics, 
			            'F_Logistics'[Tính chất phiếu giao] = "SP"
			            && 'F_Logistics'[Hình thức vận chuyển] IN {"LAZADA", "NHẤT TÍN", "GHTK"}
			            && NOT CONTAINSSTRING('F_Logistics'[Cửa hàng], "B2B")
			            && 'F_Logistics'[IsSentDocument] = BLANK()
			            && 'F_Logistics'[Tình trạng đơn] IN {"Hoàn tất", "Giao thành công"}
			        ),
			        F_Logistics[Số phiếu],
			        F_Logistics[Giá trị đơn]
			    ),
			    F_Logistics[Giá trị đơn]
			   )
			```
		formatString: #,0
