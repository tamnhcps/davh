	/// Số lượng sản phẩm điều chuyển có trạng thái hoàn tất so với tháng trước (DVT: %)
	/// 
	measure '% Slg Chuyển LM' =
			
			DIVIDE(
			    [Slg Chuyển] - [Slg Chuyển_LM],
			    [Slg Chuyển_LM],
			    BLANK()
			)
		formatString: 0.00%;-0.00%;0.00%
