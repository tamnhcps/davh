	column MethodId =
			
			--Nội/Ngoại thành
			VAR zA =
			SWITCH(
			    TRUE(),
			    'F_Logistics'[Hình thức vận chuyển] = "AHAMOVE"
			        || 'F_Logistics'[Hình thức vận chuyển] = "XE MÁY LOG"
			            || 'F_Logistics'[Hình thức vận chuyển] = "Ô TÔ LOG"
			            || 'F_Logistics'[Hình thức vận chuyển] = "GRAB"
			            || 'F_Logistics'[Hình thức vận chuyển] = "NV SHOP", "NỘI THÀNH",
			    'F_Logistics'[Hình thức vận chuyển] = "LAZADA"
			        || 'F_Logistics'[Hình thức vận chuyển] = "NHẤT TÍN" || 'F_Logistics'[Hình thức vận chuyển] = "GHTK", "NGOẠI THÀNH",
			    "KHÁC"
			)
			VAR zB = 'F_Logistics'[Hình thức vận chuyển]
			RETURN
			    zA & "-" & zB
		lineageTag: 711b6cf2-c38d-4e24-b297-8fd2174ccc2c
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

