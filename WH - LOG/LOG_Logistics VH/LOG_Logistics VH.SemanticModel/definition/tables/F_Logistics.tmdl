	column 'Slg phiếu' = ```
			
			CALCULATE(
			    COUNT('F_Logistics'[Số phiếu]),
			    FILTER(
			        'F_Logistics',
			        'F_Logistics'[số phiếu] = EARLIER('F_Logistics'[số phiếu])
			    )
			)
			
			```
		formatString: 0
		lineageTag: 9a85c867-1aa8-4509-b23b-6229da3d10a2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column IsUnique = ```
			
			// VAR zD =
			// CALCULATE(
			//     MAX('FACT_Logistics_Appended'[Ngày tạo chuyến đi]),
			//     FILTER(
			//         ALL('FACT_Logistics_Appended'),
			//         'FACT_Logistics_Appended'[Số phiếu] = EARLIER('FACT_Logistics_Appended'[Số phiếu])
			//     )
			// )
			// RETURN
			// SWITCH(
			//     TRUE(),
			//     'FACT_Logistics_Appended'[Slg phiếu] = 1, 1,
			//     'FACT_Logistics_Appended'[Slg phiếu] > 1 && 'FACT_Logistics_Appended'[Ngày tạo chuyến đi] = zD, 1,
			//     0
			// )
			// IsUnique = 
			VAR zD =
			CALCULATE(
			    MAX('F_Logistics'[Ngày tạo chuyến đi]),
			    FILTER(
			        ALL('F_Logistics'),
			        'F_Logistics'[Số phiếu] = EARLIER('F_Logistics'[Số phiếu])
			            && 'F_Logistics'[Trạng thái phiếu] = "Hoàn tất"
			    )
			)
			VAR zRT =
			CALCULATE(
			    MAX('F_Logistics'[Thời gian hoàn tất]),
			    FILTER(
			        ALL('F_Logistics'),
			        'F_Logistics'[Số phiếu] = EARLIER('F_Logistics'[Số phiếu])
			    )
			)
			RETURN
			SWITCH(
			    TRUE(),
			    'F_Logistics'[Slg phiếu] = 1, 1,
			    'F_Logistics'[Slg phiếu] > 1 && 'F_Logistics'[Ngày tạo chuyến đi] = zD, 1,
			    0
			)
			```
		formatString: 0
		lineageTag: 47bdd758-af56-4f64-9fc3-f1e9d09dc4dc
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

