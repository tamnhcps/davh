	partition F_Logistics = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=0c443b5c-c2db-4617-b273-e61ac25f9b66”#(lf)WITH F_LOG AS(#(lf)  SELECT#(lf)  cua_hang AS `Cửa hàng`,#(lf)  ngay_don_hang  AS `Ngày đơn hàng`,#(lf)  tinh_trang_don AS `Tình trạng đơn`,#(lf)  so_phieu AS `Số phiếu`,#(lf)  ngay_lap_phieu AS `Ngày lập phiếu`,#(lf)  gia_tri_don AS `Giá trị đơn`,#(lf)  phi_van_chuyen AS `Phí VC`,#(lf)  loai_giao_hang AS `Loại giao hàng`,#(lf)  giao_hang_truoc AS `Giao hàng trước`,#(lf)  nhan_luc AS `Nhận lúc`,#(lf)  ngay_tao_chuyen_di AS `Ngày tạo chuyến đi`,#(lf)  ma_chuyen_di AS `Mã chuyến đi`,#(lf)  ten_xe AS `Tên xe`,#(lf)  ma_tai_xe AS `Mã tài xế`,#(lf)  thoi_gian_hoan_tat AS `Thời gian hoàn tất`,#(lf)  khoang_cach_tu_cua_hang_theo_ban_do AS `K_Cách từ CH theo bản đồ`,#(lf)  thoi_gian_huy AS `Thời gian hủy`,#(lf)  thoi_gian_giao AS `Thời gian giao`,#(lf)  is_sent_document AS IsSentDocument,#(lf)  is_care_service AS IsCareService,#(lf)  tinh_thanh AS `Tỉnh thành`,#(lf)  quan_huyen AS `Quận huyện`,#(lf)  data_source AS Datasource,#(lf)  CASE#(lf)    WHEN LEFT(so_phieu, 3) = 'SP.' THEN 'SP'#(lf)    WHEN LEFT(so_phieu, 3) = 'DC.' THEN 'DC'#(lf)    WHEN LEFT(so_phieu, 3) = 'SO.' THEN 'SO'#(lf)    ELSE 'Khác'#(lf)  END AS `Tính chất phiếu giao`#(lf)  --,#(lf)  --GREATEST(DATETIME_DIFF(ngay_don_hang, giao_hang_truoc, MINUTE),0) AS BonusTime#(lf)FROM cellphones-data-platform.datamart_cps_logistics.rpt_logistics#(lf)WHERE DATE(ngay_tao_chuyen_di) >= DATE_SUB(DATE_TRUNC(CURRENT_DATE(), MONTH), INTERVAL 6 MONTH)#(lf)), P_LOG AS (#(lf)SELECT *,#(lf)#(lf)  ----- TRẠNG THÁI PHIẾU -----#(lf)  CASE #(lf)    WHEN `Tình trạng đơn` IN (""Chờ lấy hàng"", ""Đã lấy"", ""Đang giao"",""Mới tạo"",""Thả hàng chưa xác nhận"",#(lf)                              ""Thả hàng đã   xác nhận"",""Tài xế từ chối nhận hàng"",""HTTC chưa xác nhận"")#(lf)    OR `Tình trạng đơn` IS NULL #(lf)    THEN 'Chưa hoàn tất'#(lf)    WHEN `Tình trạng đơn` IN (""Lấy hàng thất bại"",""Chờ trả hàng"",""Đã trả hàng"",""Hủy giao"",""Hủy giao đã hoàn hàng"",#(lf)                              ""Mất hàng"",""Đã huỷ"",""Hủy giao chưa hoàn hàng"",""Hủy giao kho đã nhận hàng"")#(lf)    THEN 'Hủy giao'#(lf)    WHEN `Tình trạng đơn` IN (""Giao thành công"", ""Hoàn tất"", ""HTTC đã xác nhận"" )#(lf)    THEN 'Hoàn tất'#(lf)    ELSE NULL#(lf)  END AS `Trạng thái phiếu`,  #(lf)#(lf)  ----- THỜI GIAN XỬ LÝ ĐƠN -----              #(lf)  CASE#(lf)    WHEN `Tính chất phiếu giao` <> 'SP' THEN NULL#(lf)    ELSE#(lf)        GREATEST(DATETIME_DIFF(`Ngày lập phiếu`, `Ngày đơn hàng`, MINUTE) / 60.00 ,0)#(lf)        +#(lf)        GREATEST(DATETIME_DIFF(`Ngày tạo chuyến đi`, `Ngày lập phiếu`, MINUTE) / 60.00 ,0)#(lf)  END AS `Thời gian xử lý đơn`,#(lf)#(lf)  ----- THỜI GIAN CHỜ LẤY HÀNG -----#(lf)  CASE#(lf)    WHEN `Tính chất phiếu giao` <> 'SP' THEN NULL#(lf)    ELSE #(lf)        GREATEST(DATETIME_DIFF(COALESCE(`Nhận lúc`,`Thời gian hủy`),`Ngày tạo chuyến đi`, MINUTE) / 60.00 ,0)#(lf)    END AS `Thời gian chờ lấy hàng`,#(lf)#(lf)  ----- THỜI GIAN GIAO CHO KHÁCH -----       #(lf)  CASE#(lf)    WHEN `Tính chất phiếu giao` <> 'SP' THEN NULL#(lf)    WHEN COALESCE(`Thời gian hoàn tất`, `Thời gian hủy`) IS NULL#(lf)    THEN NULL#(lf)    ELSE  GREATEST(#(lf)      DATETIME_DIFF(#(lf)                    COALESCE(`Thời gian hoàn tất`,`Thời gian hủy`),#(lf)                    COALESCE(`Nhận lúc`,`Ngày tạo chuyến đi`), MINUTE)/ 60.00,0)#(lf)  END AS `Thời gian giao cho khách`,#(lf)#(lf)  ----- HÌNH THỨC VẬN CHUYỂN -----#(lf)#(lf)  CASE#(lf)    -- 1. Ưu tiên các điều kiện mới bổ sung#(lf)    WHEN `Tên xe` LIKE '%Giao hàng cho khách B2B%' THEN 'B2B'#(lf)    #(lf)    WHEN `Tên xe` = '51B-22272' THEN 'Ô TÔ LOG'#(lf)    #(lf)    WHEN `Tên xe` IN (#(lf)        '51M -85324', 'XE KHO NOI BO', 'XE KHO TRUNG TÂM', #(lf)        'XEKHO1 (51D - 73244)', 'XEKHO2 (51D - 73444)', 'XEKHO3 (51D - 74350)', #(lf)        'XEKHO4 (51D - 74291)', 'XEKHO5 (51M - 85324)', 'XEKHO6 (51E - 20963)', #(lf)        'XEKHO7 (51E - 20802)', 'XEKHO9 (51D - 62003)'#(lf)    ) THEN 'XE KHO TRUNG TÂM'#(lf)    #(lf)    WHEN `Tên xe` IN (#(lf)        'XEKHO8 (51B - 51090)', 'XELOG1 (51B - 19761)', #(lf)        'XELOG2 (51B - 20168)', 'XELOG5 (51B - 22272)'#(lf)    ) THEN 'XE LOG'#(lf)#(lf)    -- 2. Các nhóm xe LOG cố định#(lf)    WHEN `Tên xe` = 'Ô TÔ LOG' THEN 'Ô TÔ LOG'#(lf)    WHEN `Tên xe` = 'XE MÁY LOG' THEN 'XE MÁY LOG'#(lf)#(lf)    -- 3. Phân loại theo Datasource (Đối tác ngoài)#(lf)    WHEN `Datasource` IN ('AHAMOVE-MN (SEP)', 'AHAMOVE-MN', 'AHAMOVE-MB (SEP)', 'AHAMOVE-MB') THEN 'AHAMOVE'#(lf)    WHEN `Datasource` IN ('LAZADA-MN (SEP)', 'LAZADA-MB (SEP)') THEN 'LAZADA'#(lf)    WHEN `Datasource` IN ('NHATTIN-MN', 'NHATTIN-MN (SEP)', 'NHATTIN-MB (SEP)')   OR `Tên xe` = ""GIAO HÀNG NHẤT TÍN"" THEN 'NHẤT TÍN'#(lf)    WHEN `Datasource` IN ('GHTK-MN (SEP)', 'GHTK-MB (SEP)') THEN 'GHTK'#(lf)    WHEN `Datasource` IN ('GRAB-MN (SEP)', 'GRAB-MB (SEP)') THEN 'GRAB'#(lf)#(lf)    -- 4. Nhóm Nhân viên Shop / Nội bộ#(lf)    WHEN `Tên xe` IN (#(lf)        'Nhân Viên Shop Giao', 'NV shop giao', 'Nội bộ liên tỉnh', #(lf)        'NHÂN VIÊN SHOP GIAO', 'XE KHO ĐI KHO TRUNG TÂM', #(lf)        'XE KHO TÔNG (KHO TÔNG CHON)', 'XE KHO TRUNG CHUYỂN'#(lf)    ) THEN 'NV SHOP'#(lf)    #(lf)    WHEN `Datasource` = 'HTVRT-HN' AND `Tên xe` IS NOT NULL THEN 'NV SHOP'#(lf)#(lf)    ELSE 'KHÁC'#(lf)END AS `Hình thức vận chuyển`#(lf)FROM F_LOG fl#(lf)) #(lf)SELECT * EXCEPT (`Phí VC`),#(lf)#(lf)  ----- B2B/B2C------#(lf)  CASE#(lf)    WHEN `Cửa hàng` LIKE '%B2B%' THEN 'B2B'#(lf)    ELSE 'B2C'#(lf)    END AS `B2B_B2C`,#(lf) #(lf)  ----- PHÍ VC ALL -----#(lf)  CASE#(lf)    WHEN `Phí VC` > 0#(lf)    THEN `Phí VC`#(lf)    WHEN `Tính chất phiếu giao` <> 'SP'#(lf)    THEN NULL#(lf)    WHEN `Hình thức vận chuyển` = 'NV SHOP'#(lf)    THEN#(lf)        CASE#(lf)            WHEN `K_Cách từ CH theo bản đồ` <= 0 THEN 0#(lf)            WHEN `K_Cách từ CH theo bản đồ` < 2 THEN 8000#(lf)            WHEN `K_Cách từ CH theo bản đồ` < 5 THEN 16000#(lf)            WHEN `K_Cách từ CH theo bản đồ` < 8 THEN 20000#(lf)            WHEN `K_Cách từ CH theo bản đồ` < 11 THEN 28000#(lf)            WHEN `K_Cách từ CH theo bản đồ` < 14 THEN 32000#(lf)            WHEN `K_Cách từ CH theo bản đồ` < 17 THEN 36000#(lf)            ELSE 40000#(lf)        END#(lf)    WHEN `Hình thức vận chuyển` = 'NV LOG'#(lf)    THEN#(lf)        CASE#(lf)            WHEN `K_Cách từ CH theo bản đồ` <= 0 THEN 8000#(lf)            WHEN `K_Cách từ CH theo bản đồ` < 10 THEN 25000#(lf)            ELSE 35000#(lf)        END#(lf)    ELSE NULL#(lf)#(lf)END AS `Phí VC`,#(lf)#(lf)  ----- TRẠNG THÁI XỬ LÝ ĐƠN -----#(lf)    CASE #(lf)      WHEN `Loại giao hàng` IS NULL THEN NULL#(lf)      WHEN `Trạng thái phiếu` = 'Chưa hoàn tất' THEN NULL#(lf)      WHEN `Loại giao hàng` IN ('Giao 2 giờ', 'Giao 3 giờ', 'Giao 4 giờ') #(lf)      AND `Thời gian xử lý đơn` > 25/60 THEN 'Shop xử lý trễ'#(lf)    ELSE 'Shop xử lý đúng hạn'#(lf)  END AS `Trạng thái xử lý đơn`,#(lf)#(lf)  ----- TRẠNG THÁI GIAO HÀNG SHIPPER -----#(lf)  CASE #(lf)    WHEN `Loại giao hàng` IS NULL THEN NULL#(lf)    WHEN `Trạng thái phiếu` = 'Chưa hoàn tất' THEN NULL#(lf)    WHEN `Loại giao hàng` IN ('Giao 2 giờ', 'Giao 3 giờ', 'Giao 4 giờ')#(lf)    AND `Thời gian giao cho khách` > 95/60 THEN 'Shipper giao trễ'#(lf)    ELSE 'Shipper giao đúng hạn'#(lf)  END AS `Trạng thái giao hàng shipper`,#(lf)#(lf)  ----- TRỄ HẠN THEO RT -----#(lf) CASE#(lf)    WHEN `Mã chuyến đi` IS NULL#(lf)    THEN NULL#(lf)    WHEN `Giao hàng trước` IS NULL#(lf)    THEN NULL#(lf)    WHEN `Thời gian hoàn tất` IS NOT NULL#(lf)    THEN#(lf)        CASE#(lf)            WHEN GREATEST(#(lf)                    DATETIME_DIFF(#(lf)                        `Thời gian hoàn tất`,#(lf)                        `Giao hàng trước`,#(lf)                        SECOND#(lf)                    ) / 3600.0,#(lf)                    0#(lf)                 ) > 0#(lf)            THEN 'Trễ hạn'#(lf)#(lf)            ELSE 'Đúng hạn'#(lf)        END#(lf)    WHEN `Thời gian hủy` IS NOT NULL#(lf)    THEN#(lf)        CASE#(lf)            WHEN GREATEST(#(lf)                    DATETIME_DIFF(#(lf)                        `Thời gian hủy`,#(lf)                        `Giao hàng trước`,#(lf)                        SECOND#(lf)                    ) / 3600.0,#(lf)                    0#(lf)                 ) > 0#(lf)            THEN 'Trễ hạn'#(lf)#(lf)            ELSE 'Đúng hạn'#(lf)        END#(lf)    ELSE 'Đúng hạn'#(lf)  END AS `Trễ hạn theo RT`,#(lf)#(lf)  ----- TRỄ HẠN THEO DH -----#(lf)  CASE#(lf)   WHEN `Thời gian giao` IS NULL#(lf)         OR `Thời gian hoàn tất` IS NULL#(lf)    THEN NULL#(lf)    WHEN GREATEST(#(lf)            DATETIME_DIFF(#(lf)                `Thời gian hoàn tất`,#(lf)                `Thời gian giao`,#(lf)                SECOND#(lf)            ) / 3600.0,#(lf)            0#(lf)         ) > 0#(lf)    THEN 'Trễ hạn'#(lf)    ELSE 'Đúng hạn' #(lf)  END AS `Trễ hạn theo DH`,#(lf)#(lf)  ---- KHUNG KHOẢNG CÁCH -----#(lf)  CASE #(lf)    WHEN `K_Cách từ CH theo bản đồ` IS NULL THEN NULL#(lf)    WHEN `K_Cách từ CH theo bản đồ` <= 2 THEN '0 - 2 km'#(lf)    WHEN `K_Cách từ CH theo bản đồ` <= 3 THEN '> 2 - 3 km'#(lf)    WHEN `K_Cách từ CH theo bản đồ` <= 5 THEN '> 3 - 5 km'#(lf)    WHEN `K_Cách từ CH theo bản đồ` <= 10 THEN '> 5 - 10 km'#(lf)    WHEN `K_Cách từ CH theo bản đồ` <= 20 THEN '> 10 - 20 km'#(lf)    WHEN `K_Cách từ CH theo bản đồ` <= 20 THEN '> 20 - 30 km'#(lf)    ELSE '>= 30 km'  #(lf)  END AS `Khung khoảng cách`,#(lf)  CASE #(lf)    WHEN `Ngày tạo chuyến đi` IS NULL THEN NULL#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 6 THEN '0-6h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 8 THEN '6-8h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 10 THEN '8-10h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 12 THEN '10-12h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 14 THEN '12-14h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 16 THEN '14-16h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 18 THEN '16-18h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 20 THEN '18-20h'#(lf)    WHEN EXTRACT(HOUR FROM `Ngày tạo chuyến đi`) < 22 THEN '20-22h'#(lf)    ELSE '22-24h'#(lf)  END AS `Khung giờ giao`,#(lf)  CASE #(lf)    WHEN `Hình thức vận chuyển` IN (""AHAMOVE"", ""XE MÁY LOG"", ""Ô TÔ LOG"", ""GRAB"",""NV SHOP"" ) THEN ""NỘI THÀNH""#(lf)    WHEN `Hình thức vận chuyển` IN (""NHẤT TÍN"", ""GHTK"") THEN  ""NGOẠI THÀNH""#(lf)    ELSE ""KHÁC""#(lf)  END AS `Phân loại khu vực vận chuyển`,#(lf)  COALESCE(#(lf)                DATETIME_DIFF(`Thời gian hoàn tất`,`Ngày lập phiếu`,HOUR)/24,#(lf)                DATETIME_DIFF(`Thời gian hủy`,`Ngày lập phiếu`,HOUR)/24#(lf)                      ) AS Check,#(lf)#(lf)  ----- THỜI GIAN DH RA SP -----#(lf)  CASE #(lf)    WHEN `Tính chất phiếu giao` = 'SP'#(lf)    THEN GREATEST(DATETIME_DIFF (`Ngày lập phiếu`,`Ngày đơn hàng`, MINUTE)/60.00,0)#(lf)    ELSE 0#(lf)  END AS `Thời gian DH ra SP`,#(lf)#(lf)  ---- THỜI GIAN SP RA RT -----#(lf)  CASE #(lf)    WHEN `Tính chất phiếu giao` = 'SP'#(lf)    THEN GREATEST(DATETIME_DIFF (`Ngày tạo chuyến đi`,`Ngày lập phiếu`, MINUTE)/60.00,0)#(lf)    ELSE 0 #(lf)  END AS `Thời gian SP ra RT`#(lf)FROM P_LOG", null, [EnableFolding=true]),
