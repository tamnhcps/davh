	partition F_PO = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=0c443b5c-c2db-4617-b273-e61ac25f9b66”#(lf)SELECT #(lf)  DATE(p.CreatedDate) AS `Ngày lập phiếu`,#(lf)  UPPER(spg.Name) AS `Nhóm hàng`,#(lf)  SUM(pd.Quantity) AS Slg,#(lf)  'Miền Nam' AS `Miền`#(lf)FROM#(lf)  cellphones-data-platform.cps_cdc_sep_hcm_dbo.PO_Order p#(lf)INNER JOIN#(lf)  cellphones-data-platform.cps_cdc_sep_hcm_dbo.PO_OrderDetail pd ON p.Id = pd.OrderId#(lf)INNER JOIN#(lf)  cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product sp ON sp.Id = pd.ProductId#(lf)INNER JOIN #(lf)  cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup spg ON spg.id = sp.ProductGroupId#(lf)WHERE #(lf)  p.MethodId = 2#(lf)  AND p.StateId = 16#(lf)  AND DATE(p.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)GROUP BY#(lf)  p.CreatedDate,#(lf)  spg.Name#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT #(lf)  DATE(p.CreatedDate) AS `Ngày lập phiếu`,#(lf)  UPPER(spg.Name) AS `Nhóm hàng`,#(lf)  SUM(pd.Quantity) AS Slg,#(lf)  'Miền Bắc' AS `Miền`#(lf)FROM#(lf)  cellphones-data-platform.cps_cdc_sep_hn_dbo.PO_Order p#(lf)INNER JOIN#(lf)  cellphones-data-platform.cps_cdc_sep_hn_dbo.PO_OrderDetail pd ON p.Id = pd.OrderId#(lf)INNER JOIN#(lf)  cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product sp ON sp.Id = pd.ProductId#(lf)INNER JOIN #(lf)  cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup spg ON spg.id = sp.ProductGroupId#(lf)WHERE #(lf)  p.MethodId = 2#(lf)  AND p.StateId = 16#(lf)  AND DATE(p.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)GROUP BY#(lf)  p.CreatedDate,#(lf)  spg.Name", null, [EnableFolding=true])
				in
				    Source

