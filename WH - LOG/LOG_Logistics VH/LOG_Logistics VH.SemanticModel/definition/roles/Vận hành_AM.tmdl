role 'Vận hành_AM'
	modelPermission: read

	tablePermission D_Date = 'D_Date'[Date]>=LOOKUPVALUE('D_User'[Startdate],'D_User'[Mail],USERPRINCIPALNAME())

	tablePermission D_User_Operations = ```
			VAR zName = 
			    LOOKUPVALUE(
			        'D_User'[Tên],
			        'D_User'[Mail], 
			        USERPRINCIPALNAME()
			    )
			
			VAR zTable_AddColumns = 
			    ADDCOLUMNS(
			        'D_User_Operations',
			        "zPath",
			        LOOKUPVALUE(
			            'D_User'[Path],
			            'D_User'[Tên], 
			            'D_User_Operations'[Leader]
			        )
			    )
			
			VAR zFilteredTable = 
			    FILTER(
			        zTable_AddColumns,
			        PATHCONTAINS([zPath], zName)
			    )
			
			VAR zDistinctStores = 
			    DISTINCT(
			        SELECTCOLUMNS(
			            zFilteredTable,
			            "Cửa hàng", 'D_User_Operations'[Bộ phận]
			        )
			    )
			
			RETURN
			IF(
			    LOOKUPVALUE('D_User'[Title], 'D_User'[Mail], USERPRINCIPALNAME()) = "AM",
			    [Bộ phận] IN zDistinctStores,
			    TRUE
			)
			```

	annotation PBI_Id = 0cfe8532b0cd4c03a7523d6b626dbe78

