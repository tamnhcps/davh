role 'Vận hành_AM'
	modelPermission: read

	tablePermission D_Date = 'D_Date'[Date]>=LOOKUPVALUE('D_Phân quyền_User'[Startdate],'D_Phân quyền_User'[Mail],USERPRINCIPALNAME())

	tablePermission 'D_Phân quyền_Vận hành' = ```
			IF( 
			LOOKUPVALUE('D_Phân quyền_User'[Title],'D_Phân quyền_User'[Mail] ,USERPRINCIPALNAME()) = "AM", 
			[Cửa hàng] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('D_Phân quyền_Vận hành','D_Phân quyền_Vận hành'[Leader] = LOOKUPVALUE('D_Phân quyền_User'[Tên],'D_Phân quyền_User'[Mail],USERPRINCIPALNAME())),'D_Phân quyền_User'),
			                        "Path leader", PATHCONTAINS('D_Phân quyền_User'[Path],'D_Phân quyền_Vận hành'[Leader])),[Path leader]),"Cửa hàng",'D_Phân quyền_User'[Tên]))
			,True)
			```

	annotation PBI_Id = 23bd102648ad4cbca1bf4210c0c2ba8e

