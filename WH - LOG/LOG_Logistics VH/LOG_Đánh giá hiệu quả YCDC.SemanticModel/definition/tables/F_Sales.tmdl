	partition F_Sales = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=84704b94-290f-44a3-a451-50c034ea8c35”#(lf)-- SO#(lf)select#(lf)  s.CreateDate#(lf)  ,s.Date#(lf)  ,if( s.Region = 'HCM', 'Miền Nam', 'Miền Bắc') `Miền`#(lf)  ,s.StoreCode#(lf)  ,CONCAT(UPPER(s.DMC3), ""-"", if( s.Region = 'HCM', 'Miền Nam', 'Miền Bắc')) `Phân quyền_Kinh doanh`#(lf)  ,s.StoreCode `Phân quyền_Vận hành`#(lf)  ,s.ProductCode#(lf)  ,sum( s.quantity ) `SL`#(lf)from#(lf)  `cellphones-data-platform.cps_sales_datamart.cps_cdc_sep_union_dbo_sales_transaction` s#(lf)#(lf)where#(lf)  1 = 1#(lf)  and s.IsSales = 1#(lf)  and DATE(s.CreateDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 7 MONTH), MONTH) --DATE_SUB(CURRENT_DATE(), INTERVAL 70 DAY)#(lf)  and date( s.CreateDate ) < date( current_date(""Asia/Ho_Chi_Minh"") )#(lf)  and NOT s.MethodId IN (27, 3, 91) -- ('Nhập đổi', 'Nhập trả', 'Nhập trả dịch vụ')#(lf)#(lf)group by#(lf)  s.CreateDate#(lf)  ,s.Date#(lf)  ,s.Region#(lf)  ,s.DMC3#(lf)  ,s.StoreCode#(lf)  ,s.ProductCode", null, [EnableFolding=true])
				in
				    Source

