	column 'TG xác nhận tại shop' = MAX( DATEDIFF([Thời gian RT2_HT], [Ngày xác nhận], SECOND)/ 86400, 0)
		lineageTag: a2852498-8ed5-4d17-a54f-18af45f24961
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column DC_Type = ```
			
			VAR IsKho_From =
			    CONTAINSSTRING ( F_Ycdc[Kho cho hàng], "KHO" )
			        || F_Ycdc[Kho cho hàng] = "HCM.HC"
			
			VAR IsKho_To =
			    CONTAINSSTRING ( F_Ycdc[Kho nhận hàng], "KHO" )
			        || F_Ycdc[Kho nhận hàng] = "HCM.HC"
			
			VAR IsShop_From =
			    NOT IsKho_From
			VAR IsShop_To =
			    NOT IsKho_To
			
			VAR HasDC =
			    NOT ISBLANK ( F_Ycdc[TransitStoreId] )
			
			RETURN
			SWITCH (
			    TRUE(),
			
			    -- KHO - KHO
			    IsKho_From && IsKho_To && NOT HasDC,
			    "KHO - KHO",
			
			    -- KHO - SHOP
			    IsKho_From && IsShop_To && NOT HasDC,
			    "KHO - SHOP",
			
			    -- SHOP - KHO
			    IsShop_From && IsKho_To && NOT HasDC,
			    "SHOP - KHO",
			
			    -- SHOP - SHOP
			    IsShop_From && IsShop_To && NOT HasDC,
			    "SHOP - SHOP",
			
			    -- SHOP - DC - SHOP
			    IsShop_From && IsShop_To && HasDC,
			    "SHOP - DC - SHOP",
			
			    -- KHO - DC - SHOP
			    IsKho_From && IsShop_To && HasDC,
			    "KHO - DC - SHOP",
			
			    -- SHOP - DC - KHO
			    IsShop_From && IsKho_To && HasDC,
			    "SHOP - DC - KHO",
			
			    BLANK()
			)
			
			```
		lineageTag: b0175d3e-6981-4ed4-9ac4-f5190c0fcafe
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

