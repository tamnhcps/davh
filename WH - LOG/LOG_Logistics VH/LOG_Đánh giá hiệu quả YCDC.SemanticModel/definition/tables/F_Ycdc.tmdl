	column 'Ngày xác nhận chuyển kho' = ```
			
			VAR _KNH = F_Ycdc[Kho nhận hàng]
			VAR _Product = F_Ycdc[Mã hàng]
			
			// VAR CurrentRank = 
			//     RANKX(
			//         FILTER(
			//             ALL(F_Ycdc),
			//             F_Ycdc[Mã hàng] = EARLIER(F_Ycdc[Mã hàng]) &&
			//             F_Ycdc[Kho nhận hàng] = EARLIER(F_Ycdc[Kho nhận hàng])
			//         ),
			//         F_Ycdc[Ngày xác nhận],
			//         ,
			//         ASC,
			//         DENSE
			//     )
			VAR CurrentRank = 
			    RANKX(
			        FILTER(
			            ALL(F_Ycdc),
			            F_Ycdc[Mã hàng] = _Product &&
			            F_Ycdc[Kho nhận hàng] = _KNH
			        ),
			        F_Ycdc[Ngày xác nhận],
			        ,
			        ASC,
			        DENSE
			    )
			// VAR NextDate = 
			//     CALCULATE(
			//         MIN(F_Ycdc[Ngày xác nhận]),
			//         FILTER(
			//             ALL(F_Ycdc),
			//             F_Ycdc[Mã hàng] = EARLIER(F_Ycdc[Mã hàng]) &&
			//             F_Ycdc[Kho nhận hàng] = EARLIER(F_Ycdc[Kho nhận hàng]) &&
			//             RANKX(
			//                 FILTER(
			//                     ALL(F_Ycdc),
			//                     F_Ycdc[Mã hàng] = EARLIER(F_Ycdc[Mã hàng]) &&
			//                     F_Ycdc[Kho nhận hàng] = EARLIER(F_Ycdc[Kho nhận hàng])
			//                 ),
			//                 F_Ycdc[Ngày xác nhận],
			//                 ,
			//                 ASC,
			//                 DENSE
			//             ) = CurrentRank + 1
			//         )
			//     )
			VAR NextDate = 
			    CALCULATE(
			        MIN(F_Ycdc[Ngày xác nhận]),
			        FILTER(
			            ALL(F_Ycdc),
			            F_Ycdc[Mã hàng] = _Product &&
			            F_Ycdc[Kho nhận hàng] = _KNH &&
			            RANKX(
			                FILTER(
			                    ALL(F_Ycdc),
			                    F_Ycdc[Mã hàng] = _Product &&
			                    F_Ycdc[Kho nhận hàng] = _KNH
			                ),
			                F_Ycdc[Ngày xác nhận],
			                ,
			                ASC,
			                DENSE
			            ) = CurrentRank + 1
			        )
			    )
			
			RETURN
			    NextDate
			```
		formatString: General Date
		lineageTag: 0fb652fe-d8fa-4bff-b17f-01c4207453cc
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 0b462ae1-9f5a-49a6-8d15-9f0c519a39a2
			defaultHierarchy: LocalDateTable_de488614-ea36-4f52-81c4-7c3ca25159d1.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'Ngày lập SP' = ```
			
			VAR _KNH = F_Ycdc[Kho nhận hàng]
			VAR _Product = F_Ycdc[Mã hàng]
			VAR _Date_XN = F_Ycdc[Ngày xác nhận]
			VAR _Date_XNC = F_Ycdc[Ngày xác nhận chuyển kho]
			
			RETURN 
			IF('F_Ycdc'[Ngày xác nhận chuyển kho] <> BLANK(),
			CALCULATE(
			    MIN('F_Sales'[CreateDate]),
			    FILTER(
			        'F_Sales',
			        'F_Sales'[StoreCode] = _KNH &&
			        'F_Sales'[ProductCode] = _Product &&
			        'F_Sales'[CreateDate] >= _Date_XN &&
			        'F_Sales'[CreateDate] <= _Date_XNC --&&
			        // NOT 'FACT_Sale'[MethodName] IN {"Nhập đổi", "Nhập trả", "Nhập trả dịch vụ"}
			    )
			),
			CALCULATE(
			    MIN('F_Sales'[CreateDate]),
			    FILTER(
			        'F_Sales',
			        'F_Sales'[StoreCode] = _KNH &&
			        'F_Sales'[ProductCode] = _Product &&
			        'F_Sales'[CreateDate] >= _Date_XN --&&
			        // NOT 'FACT_Sale'[MethodName] IN {"Nhập đổi", "Nhập trả", "Nhập trả dịch vụ"}
			    )
			)
			)
			// IF('F_Ycdc'[Ngày xác nhận chuyển kho] <> BLANK(),
			// CALCULATE(
			//     MIN('F_Sales'[CreateDate]),
			//     FILTER(
			//         'F_Sales',
			//         'F_Sales'[StoreCode] = EARLIER('F_Ycdc'[Kho nhận hàng]) &&
			//         'F_Sales'[ProductCode] = EARLIER('F_Ycdc'[Mã hàng]) &&
			//         'F_Sales'[CreateDate] >= EARLIER('F_Ycdc'[Ngày xác nhận]) &&
			//         'F_Sales'[CreateDate] <= EARLIER('F_Ycdc'[Ngày xác nhận chuyển kho]) --&&
			//         // NOT 'FACT_Sale'[MethodName] IN {"Nhập đổi", "Nhập trả", "Nhập trả dịch vụ"}
			//     )
			// ),
			// CALCULATE(
			//     MIN('F_Sales'[CreateDate]),
			//     FILTER(
			//         'F_Sales',
			//         'F_Sales'[StoreCode] = EARLIER('F_Ycdc'[Kho nhận hàng]) &&
			//         'F_Sales'[ProductCode] = EARLIER('F_Ycdc'[Mã hàng]) &&
			//         'F_Sales'[CreateDate] >= EARLIER('F_Ycdc'[Ngày xác nhận]) --&&
			//         // NOT 'FACT_Sale'[MethodName] IN {"Nhập đổi", "Nhập trả", "Nhập trả dịch vụ"}
			//     )
			// )
			// )
			
			```
		formatString: General Date
		lineageTag: 614eb7f6-8964-47ad-b060-1441f292cb5d
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 967fafb8-8d20-4818-b6a4-db146b2a61db
