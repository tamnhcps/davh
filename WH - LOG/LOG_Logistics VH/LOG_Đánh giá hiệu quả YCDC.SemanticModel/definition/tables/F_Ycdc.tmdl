	column 'TG tồn CH đến lúc bán' =
			
			VAR zSP = DATEDIFF([Ngày xác nhận], [Ngày lập SP], SECOND)/ 86400
			VAR zDC = DATEDIFF([Ngày xác nhận], [Ngày lập phiếu chuyển kho], SECOND)/ 86400
			RETURN
			SWITCH(
			    TRUE(),
			    zDC = BLANK(), zSP,
			    zSP <= zDC, zSP
			)
		lineageTag: 476852e1-7649-4ee2-8ad9-236cdf736508
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'TG tồn CH đến lúc chuyển kho' =
			
			VAR zSP = DATEDIFF([Ngày xác nhận], [Ngày lập SP], SECOND)/ 86400
			VAR zDC = DATEDIFF([Ngày xác nhận], [Ngày lập phiếu chuyển kho], SECOND)/ 86400
			RETURN
			SWITCH(
			    TRUE(),
			    zSP = BLANK(), zDC,
			    zDC <= zSP,  zDC
			)
		lineageTag: b77f736c-cbdd-45d1-be5a-f5a8d39f0330
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column PriceTag =
			
			VAR _KNH = F_Ycdc[Kho nhận hàng]
			VAR _Product = F_Ycdc[Mã hàng]
			RETURN
			 CALCULATE(
			    FIRSTNONBLANK('F_PriceTag'[barcode], 1),
			    FILTER(
			        'F_PriceTag',
			        'F_PriceTag'[productcode] = _Product
			            && 'F_PriceTag'[Mã kho] = _KNH
			    )
			)
			// CALCULATE(
			//     FIRSTNONBLANK('F_PriceTag'[barcode], 1),
			//     FILTER(
			//         'F_PriceTag',
			//         'F_PriceTag'[productcode] = EARLIER('F_Ycdc'[Mã hàng])
			//             && 'F_PriceTag'[Mã kho] = EARLIER('F_Ycdc'[Kho nhận hàng])
			//     )
			// )
		lineageTag: 3dbc9b42-9092-4095-89bd-270ff764e18d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Khu vực' =
			
			IF(
			    'F_Ycdc'[Miền] = "Miền Nam",
			    SWITCH(
			        TRUE(),
			        LEFT('F_Ycdc'[Kho cho hàng],3) = "HCM" && LEFT('F_Ycdc'[Kho nhận hàng],3) = "HCM", "HCM - HCM",
			        LEFT('F_Ycdc'[Kho cho hàng],3) = "HCM" && LEFT('F_Ycdc'[Kho nhận hàng],3) <> "HCM", "HCM - Tỉnh",
			        LEFT('F_Ycdc'[Kho cho hàng],3) <> "HCM" && LEFT('F_Ycdc'[Kho nhận hàng],3) = "HCM", "Tỉnh - HCM",
			        "Tỉnh - Tỉnh"
			    ),
			    SWITCH(
			        TRUE(),
			        LEFT('F_Ycdc'[Kho cho hàng],2) = "HN" && LEFT('F_Ycdc'[Kho nhận hàng],2) = "HN", "HN - HN",
			        LEFT('F_Ycdc'[Kho cho hàng],2) = "HN" && LEFT('F_Ycdc'[Kho nhận hàng],2) <> "HN", "HN - Tỉnh",
			        LEFT('F_Ycdc'[Kho cho hàng],2) <> "HN" && LEFT('F_Ycdc'[Kho nhận hàng],2) = "HN", "Tỉnh - HN",
			        "Tỉnh - Tỉnh"
			    )
			)
		lineageTag: 71113020-b84c-42b2-882a-8ff5467e96de
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Hình thức vận chuyển' = ```
			
			VAR _DC = F_Ycdc[Phiếu chuyển]
			RETURN 
			CALCULATE(
			    FIRSTNONBLANK('F_Logistics'[Hình thức vận chuyển], 1),
			    FILTER(
			        'F_Logistics',
			        'F_Logistics'[Số phiếu] = _DC
			    )
			)
			// CALCULATE(
			//     FIRSTNONBLANK('F_Logistics'[Hình thức vận chuyển], 1),
