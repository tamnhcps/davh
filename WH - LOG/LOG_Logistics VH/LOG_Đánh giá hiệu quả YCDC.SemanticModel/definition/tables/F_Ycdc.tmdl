	column ma_tai_xe_RT2
		dataType: string
		lineageTag: 3a581d27-4ddf-4881-9bd4-f3526ed3955d
		summarizeBy: none
		sourceColumn: ma_tai_xe_RT2

		annotation SummarizationSetBy = Automatic

	partition F_Ycdc = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=84704b94-290f-44a3-a451-50c034ea8c35”#(lf)with#(lf)-------------Miền Nam----------------------#(lf)SO_RouteLog_MN as (#(lf)  select *,#(lf)        rank() over( partition by RouterDetailId order by PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S',StartDate) desc) as rank1#(lf)  from `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_RouteLog` #(lf)  where#(lf)    IsFinal = TRUE#(lf)    AND IsTransit IS NULL#(lf)),#(lf)#(lf)SO_RouteLog_MN_Final as (#(lf)  select *#(lf)  from SO_RouteLog_MN#(lf)  where#(lf)    rank1 = 1#(lf))#(lf)#(lf), RT1_MN as (#(lf)  select #(lf)    srd.StoreBillCode,#(lf)    sr.Code as ma_RT,#(lf)    sr.CreateByName as `ma_nv_tao_rt`,#(lf)    srd.CreateDate as  `Thời gian tạo RT1`,#(lf)    if(srd.TransitStoreId is null, null, PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.TakeDate)) as `Thời gian RT1 chuyển trạng thái sang HTTC Đã xác nhận`,#(lf)    srd.FinishDate as `Thời gian RT1_HT`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.StartDate) as `Tài xế nhận giao`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.EndDate) as `Tài xế bấm giao hàng thành công`,#(lf)    srd.StartDate as `Nhận lúc`,#(lf)    srd.TransitStoreId,#(lf)    CASE srd.StateId#(lf)        WHEN 1 THEN 'Mới tạo'#(lf)        WHEN 2 THEN 'Đang giao'#(lf)        WHEN 3 THEN 'Hoàn tất'#(lf)        WHEN 4 THEN 'Hủy giao chưa hoàn hàng'#(lf)        WHEN 5 THEN 'Hủy giao đã hoàn hàng'#(lf)        WHEN 7 THEN 'Đã giao đơn vị vận chuyển'#(lf)        WHEN 8 THEN 'HTTC chưa xác nhận'#(lf)        WHEN 9 THEN 'Tài xế từ chối nhận hàng'#(lf)        WHEN 10 THEN 'Hủy giao kho đã nhận hàng'#(lf)        WHEN 11 THEN 'Thả hàng chưa xác nhận'#(lf)        WHEN 12 THEN IF(srd.TransitStoreId IS NULL, 'Thả hàng đã xác nhận', 'HTTC đã xác nhận')#(lf)        ELSE NULL#(lf)      END AS tinh_trang_don,#(lf)      IFNULL(driverLog.Code, driver.Code) AS ma_tai_xe,#(lf)      rank() over( partition by srd.StoreBillCode order by srd.CreateDate asc) as rank1,#(lf)  from `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_Route` sr#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_RouteDetail` srd on srd.RouteId = sr.id#(lf)  -- left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_RouteLog`  srl on srl.RouterDetailID = srd.id#(lf)  left join SO_RouteLog_MN_Final as srl on srl.RouterDetailID = srd.id#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driver ON driver.Id = srd.DriverStaffId#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driverLog ON driverLog.Id = srl.DriverStaffId#(lf)#(lf)  where #(lf)    srd.DeleteDate is null #(lf)    -- and srl.TakeDate IS NOT NULL #(lf)    -- and  srd.StoreBillCode = 'DC.04NVC.25.11.000139'#(lf)    and date(_airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)#(lf))#(lf)#(lf), RT1_MN_Final as (#(lf)  select * from RT1_MN#(lf)  where #(lf)    rank1 = 1 #(lf)    and `Tài xế bấm giao hàng thành công` is not null#(lf))#(lf)#(lf), RT2_MN as (#(lf)  select #(lf)    srd.StoreBillCode,#(lf)    sr.Code as ma_RT,#(lf)    sr.CreateByName as `ma_nv_tao_rt`,#(lf)    srd.CreateDate as  `Thời gian tạo RT2`,#(lf)    srd.FinishDate as `Thời gian RT2_HT`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.StartDate) as `Tài xế nhận giao`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.EndDate) as `Tài xế bấm giao hàng thành công`,#(lf)    srd.StartDate as `Nhận lúc`,#(lf)    srd.TransitStoreId,#(lf)    CASE srd.StateId#(lf)        WHEN 1 THEN 'Mới tạo'#(lf)        WHEN 2 THEN 'Đang giao'#(lf)        WHEN 3 THEN 'Hoàn tất'#(lf)        WHEN 4 THEN 'Hủy giao chưa hoàn hàng'#(lf)        WHEN 5 THEN 'Hủy giao đã hoàn hàng'#(lf)        WHEN 7 THEN 'Đã giao đơn vị vận chuyển'#(lf)        WHEN 8 THEN 'HTTC chưa xác nhận'#(lf)        WHEN 9 THEN 'Tài xế từ chối nhận hàng'#(lf)        WHEN 10 THEN 'Hủy giao kho đã nhận hàng'#(lf)        WHEN 11 THEN 'Thả hàng chưa xác nhận' #(lf)        WHEN 12 THEN IF(srd.TransitStoreId IS NULL, 'Thả hàng đã xác nhận', 'HTTC đã xác nhận')#(lf)        ELSE NULL#(lf)      END AS tinh_trang_don,#(lf)    IFNULL(driverLog.Code, driver.Code) AS ma_tai_xe,#(lf)    rank() over( partition by srd.StoreBillCode order by srd.CreateDate desc) as rank1#(lf)  from `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_Route` sr#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_RouteDetail` srd on srd.RouteId = sr.id#(lf)  -- left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_RouteLog` srl on srl.RouterDetailID = srd.id#(lf)  left join SO_RouteLog_MN_Final as srl on srl.RouterDetailID = srd.id#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driver ON driver.Id = srd.DriverStaffId#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driverLog ON driverLog.Id = srl.DriverStaffId#(lf)  where#(lf)    srd.DeleteDate is null --and srl.TakeDate IS NOT NULL #(lf)    AND date(_airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH) #(lf))#(lf)#(lf), RT2_MN_final as (#(lf)  select * #(lf)  from RT2_MN#(lf)  where #(lf)    rank1 = 1 #(lf)    and `Tài xế bấm giao hàng thành công` is not null#(lf))#(lf)-------------Miền Bắc----------------------#(lf), SO_RouteLog_MB as (#(lf)  select *,#(lf)        rank() over( partition by RouterDetailId order by PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S',StartDate) desc) as rank1#(lf)  from `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_RouteLog`#(lf)  where#(lf)    IsFinal = TRUE#(lf)    AND IsTransit IS NULL#(lf)),#(lf)#(lf)SO_RouteLog_MB_Final as (#(lf)  select *#(lf)  from SO_RouteLog_MB#(lf)  where#(lf)    rank1 = 1#(lf))#(lf)#(lf)#(lf), RT1_MB as (#(lf)  select #(lf)    srd.StoreBillCode,#(lf)    sr.Code as ma_RT,#(lf)    sr.CreateByName as `ma_nv_tao_rt`,#(lf)    srd.CreateDate as  `Thời gian tạo RT1`,#(lf)    -- sr.CreateDate as `Thời gian RT1 chuyển trạng thái sang HTTC Chưa Xác nhận`,#(lf)    if(srd.TransitStoreId is null, null, PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.TakeDate)) as `Thời gian RT1 chuyển trạng thái sang HTTC Đã xác nhận`,#(lf)    srd.FinishDate as `Thời gian RT1_HT`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.StartDate) as `Tài xế nhận giao`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.EndDate) as `Tài xế bấm giao hàng thành công`,#(lf)    srd.StartDate as `Nhận lúc`,#(lf)    srd.TransitStoreId,#(lf)    CASE srd.StateId#(lf)        WHEN 1 THEN 'Mới tạo'#(lf)        WHEN 2 THEN 'Đang giao'#(lf)        WHEN 3 THEN 'Hoàn tất'#(lf)        WHEN 4 THEN 'Hủy giao chưa hoàn hàng'#(lf)        WHEN 5 THEN 'Hủy giao đã hoàn hàng'#(lf)        WHEN 7 THEN 'Đã giao đơn vị vận chuyển'#(lf)        WHEN 8 THEN 'HTTC chưa xác nhận'#(lf)        WHEN 9 THEN 'Tài xế từ chối nhận hàng'#(lf)        WHEN 10 THEN 'Hủy giao kho đã nhận hàng'#(lf)        WHEN 11 THEN 'Thả hàng chưa xác nhận'#(lf)        WHEN 12 THEN IF(srd.TransitStoreId IS NULL, 'Thả hàng đã xác nhận', 'HTTC đã xác nhận')#(lf)        ELSE NULL#(lf)      END AS tinh_trang_don,#(lf)    IFNULL(driverLog.Code, driver.Code) AS ma_tai_xe,#(lf)    rank() over( partition by srd.StoreBillCode order by srd.CreateDate asc) as rank1,#(lf)  from `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_Route` sr#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_RouteDetail` srd on srd.RouteId = sr.id#(lf)  -- left join `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_RouteLog` srl on srl.RouterDetailID = srd.id#(lf)  left join SO_RouteLog_MB_Final as srl on srl.RouterDetailID = srd.id#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driver ON driver.Id = srd.DriverStaffId#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driverLog ON driverLog.Id = srl.DriverStaffId#(lf)  where #(lf)    srd.DeleteDate is null #(lf)    AND date(_airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf))#(lf)#(lf), RT1_MB_Final as (#(lf)  select * #(lf)  from RT1_MB#(lf)  where #(lf)    rank1 = 1 #(lf)    and `Tài xế bấm giao hàng thành công` is not null#(lf))#(lf)#(lf), RT2_MB as (#(lf)  select #(lf)    srd.StoreBillCode,#(lf)    sr.Code as ma_RT,#(lf)    sr.CreateByName as `ma_nv_tao_rt`,#(lf)    srd.CreateDate as  `Thời gian tạo RT2`,#(lf)    srd.FinishDate as `Thời gian RT2_HT`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.StartDate) as `Tài xế nhận giao`,#(lf)    PARSE_TIMESTAMP('%Y-%m-%dT%H:%M:%E*S', srl.EndDate) as `Tài xế bấm giao hàng thành công`,#(lf)    srd.StartDate as `Nhận lúc`,#(lf)    srd.TransitStoreId,#(lf)    CASE srd.StateId#(lf)        WHEN 1 THEN 'Mới tạo'#(lf)        WHEN 2 THEN 'Đang giao'#(lf)        WHEN 3 THEN 'Hoàn tất'#(lf)        WHEN 4 THEN 'Hủy giao chưa hoàn hàng'#(lf)        WHEN 5 THEN 'Hủy giao đã hoàn hàng'#(lf)        WHEN 7 THEN 'Đã giao đơn vị vận chuyển'#(lf)        WHEN 8 THEN 'HTTC chưa xác nhận'#(lf)        WHEN 9 THEN 'Tài xế từ chối nhận hàng'#(lf)        WHEN 10 THEN 'Hủy giao kho đã nhận hàng'#(lf)        WHEN 11 THEN 'Thả hàng chưa xác nhận' #(lf)        WHEN 12 THEN IF(srd.TransitStoreId IS NULL, 'Thả hàng đã xác nhận', 'HTTC đã xác nhận')#(lf)        ELSE NULL#(lf)      END AS tinh_trang_don,#(lf)    IFNULL(driverLog.Code, driver.Code) AS ma_tai_xe,#(lf)    rank() over( partition by srd.StoreBillCode order by srd.CreateDate desc) as rank1#(lf)  from `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_Route` sr#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_RouteDetail` srd on srd.RouteId = sr.id#(lf)  -- left join `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_RouteLog` srl on srl.RouterDetailID = srd.id#(lf)  left join SO_RouteLog_MB_Final as srl on srl.RouterDetailID = srd.id#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driver ON driver.Id = srd.DriverStaffId#(lf)  left join `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` driverLog ON driverLog.Id = srl.DriverStaffId#(lf)  where#(lf)    srd.DeleteDate is null #(lf)    and date(_airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf))#(lf)#(lf), RT2_MB_final as (#(lf)  select * #(lf)  from RT2_MB#(lf)  where #(lf)    rank1 = 1 #(lf)    and `Tài xế bấm giao hàng thành công` is not null#(lf))#(lf)-------------Yêu cầu điều chuyển----------------#(lf)#(lf)-- Miền Nam --#(lf), YCDC_MN as (#(lf)  SELECT #(lf)      UPPER(endS.Code) AS `Kho cho hàng`,#(lf)      UPPER(strS.Code) AS `Kho nhận hàng`,#(lf)      sto.AutoCode AS `Số phiếu`,#(lf)      sto.CreatedDate AS `Ngày lập`,#(lf)      ag.Autocode AS `Phiếu chuyển`,#(lf)      ag.CreateDate AS `Ngày lập phiếu chuyển`,#(lf)      asb.ConfirmByDate AS `Ngày xác nhận`,#(lf)      sto.CreatedById AS `Mã người lập`,#(lf)      p.ma_hang AS `Mã hàng`,#(lf)      Shared_Product.IsOversize,#(lf)      CASE#(lf)        WHEN REGEXP_CONTAINS(UPPER(strS.Name), r'(KM|KHO MUON)') THEN 'Khác'#(lf)        WHEN ag.Description = 'Tự động từ cân hàng' THEN 'Cân hàng'#(lf)        WHEN ag.Description = 'Tự động từ chia hàng' THEN 'Chia hàng'#(lf)        WHEN NOT REGEXP_CONTAINS(UPPER(endS.Name), r'(KHO)')#(lf)          AND NOT REGEXP_CONTAINS(UPPER(strS.Name), r'(KHO)') THEN 'Xin hàng'#(lf)        ELSE 'Khác'#(lf)      END AS `Lý do YCDC`,#(lf)      rt1.ma_RT as RT1,#(lf)      rt1.TransitStoreId,#(lf)      rt1.`Thời gian tạo RT1`,#(lf)      rt1.`Thời gian RT1 chuyển trạng thái sang HTTC Đã xác nhận`,#(lf)      rt1.`Thời gian RT1_HT`,#(lf)      rt1.ma_tai_xe as ma_tai_xe_RT1,#(lf)      rt1.`Tài xế nhận giao` as `Tài xế nhận giao RT1`,#(lf)      rt1.`Tài xế bấm giao hàng thành công` as `Tài xế bấm giao hàng thành công RT1`,#(lf)      rt1.`Nhận lúc` as `Nhận lúc RT1`,#(lf)      rt2.ma_RT as RT2,#(lf)      rt2.`Thời gian tạo RT2`,#(lf)      rt2.`Thời gian RT2_HT`,#(lf)      rt2.ma_tai_xe as ma_tai_xe_RT2,#(lf)      rt2.`Tài xế nhận giao` as `Tài xế nhận giao RT2`,#(lf)      rt2.`Tài