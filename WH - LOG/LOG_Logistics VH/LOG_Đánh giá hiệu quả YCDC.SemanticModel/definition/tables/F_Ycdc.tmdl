firmByDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH) #(lf)      --AND DATE(asbd._airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)      --AND DATE(ag._airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)      AND DATE(stod._airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)      AND DATE(sto.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  GROUP BY #(lf)      endS.Code,#(lf)      strS.Code,#(lf)      sto.AutoCode,#(lf)      sto.CreatedDate,#(lf)      ag.Autocode,#(lf)      ag.CreateDate,#(lf)      asb.ConfirmByDate,#(lf)      sto.CreatedById,#(lf)      p.ma_hang,#(lf)      strS.Name,#(lf)      ag.Description,#(lf)      endS.Name,#(lf)      RT1,#(lf)      TransitStoreId,#(lf)      `Thời gian tạo RT1`,#(lf)      `Thời gian RT1 chuyển trạng thái sang HTTC Đã xác nhận`,#(lf)      `Thời gian RT1_HT`,#(lf)      `Tài xế nhận giao RT1`,#(lf)      `Tài xế bấm giao hàng thành công RT1`,#(lf)      `Nhận lúc RT1`,#(lf)      RT2,#(lf)      `Thời gian tạo RT2`,#(lf)      `Thời gian RT2_HT`,#(lf)      `Tài xế nhận giao Rt2`,#(lf)      `Tài xế bấm giao hàng thành công Rt2`,#(lf)      `Nhận lúc RT2`,#(lf)      Shared_Product.IsOversize,#(lf)      ma_tai_xe_RT1,#(lf)      ma_tai_xe_RT2#(lf))#(lf)#(lf)-- Miền Bắc --#(lf), YCDC_MB as (#(lf)    SELECT #(lf)      UPPER(endS.Code) AS `Kho cho hàng`,#(lf)      UPPER(strS.Code) AS `Kho nhận hàng`,#(lf)      sto.AutoCode AS `Số phiếu`,#(lf)      sto.CreatedDate AS `Ngày lập`,#(lf)      ag.Autocode AS `Phiếu chuyển`,#(lf)      ag.CreateDate AS `Ngày lập phiếu chuyển`,#(lf)      asb.ConfirmByDate AS `Ngày xác nhận`,#(lf)      sto.CreatedById AS `Mã người lập`,#(lf)      p.ma_hang AS `Mã hàng`,#(lf)      Shared_Product.IsOversize,#(lf)      CASE#(lf)        WHEN REGEXP_CONTAINS(UPPER(strS.Name), r'(KM|KHO MUON)') THEN 'Khác'#(lf)        WHEN ag.Description = 'Tự động từ cân hàng' THEN 'Cân hàng'#(lf)        WHEN ag.Description = 'Tự động từ chia hàng' THEN 'Chia hàng'#(lf)        WHEN NOT REGEXP_CONTAINS(UPPER(endS.Name), r'(KHO)')#(lf)          AND NOT REGEXP_CONTAINS(UPPER(strS.Name), r'(KHO)') THEN 'Xin hàng'#(lf)        ELSE 'Khác'#(lf)      END AS `Lý do YCDC`,#(lf)      rt1.ma_RT as RT1,#(lf)      rt1.TransitStoreId,#(lf)      rt1.`Thời gian tạo RT1`,#(lf)      rt1.`Thời gian RT1 chuyển trạng thái sang HTTC Đã xác nhận`,#(lf)      rt1.`Thời gian RT1_HT`,#(lf)      rt1.ma_tai_xe as ma_tai_xe_RT1,#(lf)      rt1.`Tài xế nhận giao` as `Tài xế nhận giao RT1`,#(lf)      rt1.`Tài xế bấm giao hàng thành công` as `Tài xế bấm giao hàng thành công RT1`,#(lf)      rt1.`Nhận lúc` as `Nhận lúc RT1`,#(lf)      rt2.ma_RT as RT2,#(lf)      rt2.`Thời gian tạo RT2`,#(lf)      rt2.`Thời gian RT2_HT`,#(lf)      rt1.ma_tai_xe as ma_tai_xe_RT2,#(lf)      rt2.`Tài xế nhận giao` as `Tài xế nhận giao RT2`,#(lf)      rt2.`Tài xế bấm giao hàng thành công` as `Tài xế bấm giao hàng thành công RT2`,#(lf)      rt2.`Nhận lúc` as `Nhận lúc RT2`,#(lf)      -- rpt.data_source,#(lf)      'Miền Bắc' AS `Miền`,#(lf)      SUM(asbd.Quantity) AS Quantity#(lf)  FROM `cellphones-data-platform.cps_cdc_sep_hn_dbo.Store_TransferOrder` sto#(lf)  INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.Store_TransferOrderDetail` stod ON stod.OrderId = sto.Id#(lf)  INNER JOIN `cellphones-data-platform.sqlserver_htv_hn_dbo.vw_Acc_General` ag ON sto.DeliveryNo = ag.Autocode#(lf)  INNER JOIN `cellphones-data-platform.sqlserver_htv_hn_dbo.vw_Acc_StoreBill` asb ON asb.Id = ag.Id#(lf)  INNER JOIN `cellphones-data-platform.sqlserver_htv_hn_dbo.vw_Acc_StoreBillDetail` asbd ON asbd.StoreBillId = ag.Id AND stod.ProductId = asbd.ProductId#(lf)  INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store` strS ON strS.Id = asbd.InputStoreId#(lf)  INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store` endS ON endS.Id = asbd.OutputStoreId#(lf)  INNER JOIN `cellphones-data-platform.cps_DA_General_Transform.dim_product` p ON p.product_id = asbd.ProductId#(lf)    LEFT JOIN  (#(lf)              select *#(lf)              from `cellphones-data-platform.cps_cdc_sep_hn_dbo.Shared_Product`#(lf)              where#(lf)                  IsOversize = true#(lf)             ) as  Shared_Product on Shared_Product.id = p.product_id#(lf)  INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` sp ON sp.id = sto.CreatedById#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Employee` ee ON ee.id = sp.id#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Department` sd ON sd.id = ee.DepartmentId#(lf)  LEFT JOIN RT1_MB_Final as rt1 on rt1.StoreBillCode = ag.Autocode#(lf)  LEFT JOIN RT2_MB_Final as rt2 on rt2.StoreBillCode = ag.Autocode#(lf)  WHERE #(lf)    1=1#(lf)    AND sto.StateId = 8#(lf)    AND ag.BillTypeId = 1#(lf)    AND ag.ReplaceById IS NULL#(lf)    AND DATE(asb.ConfirmByDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)    --AND DATE(asbd._airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)    --AND DATE(ag._airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)    AND DATE(stod._airbyte_emitted_at) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)    AND DATE(sto.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  GROUP BY#(lf)      endS.Code,#(lf)      strS.Code,#(lf)      sto.AutoCode,#(lf)      sto.CreatedDate,#(lf)      ag.Autocode,#(lf)      ag.CreateDate,#(lf)      asb.ConfirmByDate,#(lf)      sto.CreatedById,#(lf)      p.ma_hang,#(lf)      strS.Name,#(lf)      ag.Description,#(lf)      endS.Name,#(lf)      RT1,#(lf)      TransitStoreId,#(lf)      `Thời gian tạo RT1`,#(lf)      `Thời gian RT1 chuyển trạng thái sang HTTC Đã xác nhận`,#(lf)      `Thời gian RT1_HT`,#(lf)      `Tài xế nhận giao RT1`,#(lf)      `Tài xế bấm giao hàng thành công RT1`,#(lf)      `Nhận lúc RT1`,#(lf)      RT2,#(lf)      `Thời gian tạo RT2`,#(lf)      `Thời gian RT2_HT`,#(lf)      `Tài xế nhận giao Rt2`,#(lf)      `Tài xế bấm giao hàng thành công Rt2`,#(lf)      `Nhận lúc RT2`,#(lf)      Shared_Product.IsOversize,#(lf)      ma_tai_xe_RT1,#(lf)      ma_tai_xe_RT2#(lf))#(lf)#(lf)  select #(lf)      `Kho cho hàng`,#(lf)      `Kho nhận hàng`,#(lf)      `Số phiếu`,#(lf)      `Ngày lập`,#(lf)      `Phiếu chuyển`,#(lf)      `Ngày lập phiếu chuyển`,#(lf)      `Ngày xác nhận`,#(lf)      `Mã người lập`,#(lf)      `Mã hàng`,#(lf)      IsOversize,#(lf)      `Lý do YCDC`,#(lf)      RT1,#(lf)      TransitStoreId,#(lf)      `Thời gian tạo RT1`,#(lf)      `Thời gian RT1 chuyển trạng thái sang HTTC Đã xác nhận`,#(lf)      `Thời gian RT1_HT`,#(lf)      ma_tai_xe_RT1,#(lf)      `Tài xế nhận giao RT1`,#(lf)      `Tài xế bấm giao hàng thành công RT1`,#(lf)      `Nhận lúc RT1`,#(lf)      if(TransitStoreId is null, null, RT2) as RT2,#(lf)      if(TransitStoreId is null, null, `Thời gian tạo RT2`) as `Thời gian tạo RT2`,#(lf)      if(TransitStoreId is null, null, `Thời gian RT2_HT`) as `Thời gian RT2_HT`,#(lf)      if(TransitStoreId is null, null, ma_tai_xe_RT2) as ma_tai_xe_RT2,#(lf)      if(TransitStoreId is null, null, `Tài xế nhận giao RT2`) as `Tài xế nhận giao RT2`,#(lf)      if(TransitStoreId is null, null, `Tài xế bấm giao hàng thành công RT2`) as `Tài xế bấm giao hàng thành công RT2`,#(lf)      if(TransitStoreId is null, null, `Nhận lúc RT2`) as `Nhận lúc RT2`,#(lf)      -- rpt.data_source,#(lf)      `Miền`,#(lf)      Quantity#(lf)  from YCDC_MB#(lf)  where `Lý do YCDC` IN ('Cân hàng', 'Xin hàng', 'Chia hàng') #(lf)union all#(lf)    select #(lf)      `Kho cho hàng`,#(lf)      `Kho nhận hàng`,#(lf)      `Số phiếu`,#(lf)      `Ngày lập`,#(lf)      `Phiếu chuyển`,#(lf)      `Ngày lập phiếu chuyển`,#(lf)      `Ngày xác nhận`,#(lf)      `Mã người lập`,#(lf)      `Mã hàng`,#(lf)      IsOversize,#(lf)      `Lý do YCDC`,#(lf)      RT1,#(lf)      Tran