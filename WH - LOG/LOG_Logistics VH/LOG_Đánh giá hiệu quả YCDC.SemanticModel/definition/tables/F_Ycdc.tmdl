	column 'Ngày lập phiếu chuyển kho' = ```
			
			VAR _KNH = F_Ycdc[Kho nhận hàng]
			VAR _Product = F_Ycdc[Mã hàng]
			VAR _Date_XN = F_Ycdc[Ngày xác nhận]
			VAR _Date_XNC = F_Ycdc[Ngày xác nhận chuyển kho]
			RETURN
			 IF('F_Ycdc'[Ngày xác nhận chuyển kho] <> BLANK(),
			CALCULATE(
			    MIN('F_Dc'[Ngày lập phiếu chuyển]),
			    FILTER(
			        'F_Dc',
			        'F_Dc'[Kho cho hàng] = _KNH &&
			        'F_Dc'[Mã hàng] = _Product &&
			        'F_Dc'[Ngày lập phiếu chuyển] >= _Date_XN &&
			        'F_Dc'[Ngày lập phiếu chuyển] <= _Date_XNC
			    )
			),
			CALCULATE(
			    MIN('F_Dc'[Ngày lập phiếu chuyển]),
			    FILTER(
			        'F_Dc',
			        'F_Dc'[Kho cho hàng] = _KNH &&
			        'F_Dc'[Mã hàng] = _Product &&
			        'F_Dc'[Ngày lập phiếu chuyển] >= _Date_XN
			    )
			)
			)
			// IF('F_Ycdc'[Ngày xác nhận chuyển kho] <> BLANK(),
			// CALCULATE(
			//     MIN('F_Dc'[Ngày lập phiếu chuyển]),
			//     FILTER(
			//         'F_Dc',
			//         'F_Dc'[Kho cho hàng] = EARLIER('F_Ycdc'[Kho nhận hàng]) &&
			//         'F_Dc'[Mã hàng] = EARLIER('F_Ycdc'[Mã hàng]) &&
			//         'F_Dc'[Ngày lập phiếu chuyển] >= EARLIER('F_Ycdc'[Ngày xác nhận]) &&
			//         'F_Dc'[Ngày lập phiếu chuyển] <= EARLIER('F_Ycdc'[Ngày xác nhận chuyển kho])
			//     )
			// ),
			// CALCULATE(
			//     MIN('F_Dc'[Ngày lập phiếu chuyển]),
			//     FILTER(
			//         'F_Dc',
			//         'F_Dc'[Kho cho hàng] = EARLIER('F_Ycdc'[Kho nhận hàng]) &&
			//         'F_Dc'[Mã hàng] = EARLIER('F_Ycdc'[Mã hàng]) &&
			//         'F_Dc'[Ngày lập phiếu chuyển] >= EARLIER('F_Ycdc'[Ngày xác nhận])
			//     )
			// )
			// )
			
			```
		formatString: General Date
		lineageTag: 51321bb0-b9fd-489f-9d64-4579b9270f64
		summarizeBy: none

