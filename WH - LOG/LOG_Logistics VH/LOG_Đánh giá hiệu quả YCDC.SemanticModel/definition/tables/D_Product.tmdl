	partition D_Product = m
		mode: import
		queryGroup: DIM
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=84704b94-290f-44a3-a451-50c034ea8c35”#(lf)select #(lf)  UPPER(nhom_hang) #(lf)  nhom_hang, #(lf)  loai_hang, #(lf)  ma_hang, #(lf)  ten_hang, #(lf)  p.inactive, #(lf)  ngay_tao_ma, #(lf)  ten_hang_loai_mau, #(lf)  p.VAT, #(lf)  url, #(lf)  thuong_hieu, #(lf)  `model`, #(lf)  nhom_chuc_nang, #(lf)  nhom_chuc_nang_nho, #(lf)  Android_exp, #(lf)  s_star_exp, #(lf)  ten_chuong_trinh,#(lf)  s.IsOversize#(lf)from `cellphones-data-platform.cps_DA_General_Transform.dim_product` p#(lf)left join ( select *#(lf)            from `cps_cdc_sep_hcm_dbo.Shared_Product` s #(lf)            where IsOversize = true#(lf)  ) as s  on s.Id = p.product_id#(lf)--where inactive = false", null, [EnableFolding=true])
				in
				    Source

