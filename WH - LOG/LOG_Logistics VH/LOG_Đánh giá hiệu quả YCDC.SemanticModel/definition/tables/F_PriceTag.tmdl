	column branchname
		dataType: string
		lineageTag: 1131ba85-6cfe-4910-a415-2881d87a3fda
		summarizeBy: none
		sourceColumn: branchname

		annotation SummarizationSetBy = Automatic

	column 'Mã kho' = ```
			
			VAR _branchname = F_PriceTag[branchname] 
			VAR minindex_kho =
			    CALCULATE (
			        MIN ( 'D_Storage'[Index] ),
			        FILTER (
			            'D_Storage',
			            'D_Storage'[Tên kho] = _branchname
			        )
			    )
			VAR minindex_cuahang =
			    CALCULATE (
			        MIN ( 'D_Storage'[Index] ),
			        FILTER (
			            'D_Storage',
			            'D_Storage'[Phân loại kho] = "Kho cửa hàng"
			            && 'D_Storage'[Kho phân tích] = "Kho bình thường"            
			            && 'D_Storage'[Cửa hàng] = _branchname
			        )
			    )
			VAR minindex =
			    IF ( minindex_cuahang <> BLANK (), minindex_cuahang, minindex_kho )
			RETURN
			    LOOKUPVALUE ( 'D_Storage'[Mã kho], 'D_Storage'[Index], minindex )
			```
		lineageTag: b5df5205-d5d9-4391-9060-c68478142780
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition F_PriceTag = m
		mode: import
