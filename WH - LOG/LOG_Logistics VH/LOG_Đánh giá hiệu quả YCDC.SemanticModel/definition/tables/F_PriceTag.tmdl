		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=84704b94-290f-44a3-a451-50c034ea8c35”#(lf)with cte as   #(lf)(#(lf)  select *#(lf)  from cellphones-data-platform.cps_postgre_data_report_dwh.product_price_tags_hcm#(lf)  union all#(lf)  select *#(lf)  from cellphones-data-platform.cps_postgre_data_report_dwh.product_price_tags_hn#(lf))#(lf)Select #(lf) barcode,#(lf) productcode,#(lf) y.name as branchname#(lf)from cte x#(lf)left join cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_SubBranch y#(lf)  on x.branchid = y.id", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

