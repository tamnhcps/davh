	column 'Lý do YCDC' = ```
			
			VAR _Date_DC = F_Dc[Ngày lập phiếu chuyển]
			VAR _KCH = F_Dc[Kho cho hàng]
			VAR _Product = F_Dc[Mã hàng]
			RETURN 
			CALCULATE(
			    FIRSTNONBLANK(
			        'F_Ycdc'[Lý do YCDC],
			        1
			    ),
			    FILTER(
			        'F_Ycdc',
			        'F_Ycdc'[Ngày lập phiếu chuyển] = _Date_DC &&
			        'F_Ycdc'[Kho cho hàng] = _KCH &&
			        'F_Ycdc'[Mã hàng] = _Product
			    )
			)
			```
		lineageTag: 647eb55c-e81d-40eb-aa8c-b2d4673209f3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition F_Dc = calculated
		mode: import
		source = ```
				
				SUMMARIZE(
				    FILTER(
				        'F_Ycdc',
				        'F_Ycdc'[Lý do YCDC] <> "Khác"
				    ),
				    'F_Ycdc'[Kho cho hàng],
				    'F_Ycdc'[Mã hàng],
				    'F_Ycdc'[Phiếu chuyển],
				    'F_Ycdc'[Ngày lập phiếu chuyển]
				)
				
				```

