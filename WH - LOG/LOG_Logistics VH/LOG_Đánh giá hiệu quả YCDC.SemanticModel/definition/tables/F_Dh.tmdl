	partition F_Dh = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "--“dataset_id=84704b94-290f-44a3-a451-50c034ea8c35”#(lf)with#(lf)inv as (#(lf)SELECT#(lf)  DATE_ADD(run_date, INTERVAL 1 DAY) AS start_date,#(lf)  StoreCode, #(lf)  ProductCode,#(lf)  SUM(Quantity) AS Quantity#(lf)FROM `cellphones-data-platform.cps_exported_dataset.cps_snap_inventory_level_daily`#(lf)WHERE#(lf)  DATE(run_date) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH) --DATE_SUB(CURRENT_DATE(), INTERVAL 71 DAY)#(lf)GROUP BY 1, 2, 3#(lf)),#(lf)#(lf)Order_DH as (#(lf)--HCM#(lf)SELECT#(lf)  so.AutoCode AS SoDonHang,#(lf)  TempBill.AutoCode AS PhieuBanLe,#(lf)  es.code AS StoreCode,#(lf)  DATETIME(so.CreatedDate) AS CreatedDate,#(lf)  DATE(so.CreatedDate) AS NgayDat,#(lf)  od.Price,#(lf)  SUM(od.Quantity) AS Quantity,#(lf)  sp.code AS ProductCode,#(lf)  'Miền Nam' AS `Miền`#(lf)FROM `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_Order` so#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_OrderDetail` od ON od.OrderId = so.Id#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product` sp ON sp.Id = OD.ProductId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store` es ON es.Id = od.OutputStoreId#(lf)LEFT JOIN (#(lf)      SELECT#(lf)        sbd.SOOrderDetailId,#(lf)        ag.AutoCode,#(lf)      FROM `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_StoreBillDetail` sbd#(lf)      JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Acc_General` ag ON ag.Id = sbd.StoreBillId#(lf)      JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_OrderDetail` sd ON sbd.SOOrderDetailId = sd.Id#(lf)      JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.SO_Order` so ON sd.OrderId = so.Id#(lf)      WHERE#(lf)        DATE(so.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)        AND ag.ReplaceById IS NULL#(lf)        AND ag.Autocode NOT LIKE '%#%'#(lf)      GROUP BY sbd.SOOrderDetailId,  ag.AutoCode#(lf)    ) TempBill ON TempBill.SOOrderDetailId = od.Id#(lf)WHERE#(lf)  1=1#(lf)  AND DATE(SO.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  AND so.MethodId IN (14, 56, 57, 58, 59)#(lf)  AND so.ReplaceById IS NULL#(lf)  AND NOT REGEXP_CONTAINS(UPPER(es.code), r'(B2B)') #(lf)GROUP BY#(lf)  so.AutoCode,#(lf)  TempBill.AutoCode,#(lf)  es.code,#(lf)  so.CreatedDate,#(lf)  od.Price,#(lf)  sp.code#(lf)#(lf)UNION ALL#(lf)#(lf)--HN#(lf)SELECT #(lf)  so.AutoCode AS SoDonHang,#(lf)  TempBill.AutoCode AS PhieuBanLe,#(lf)  es.code AS StoreCode,#(lf)  DATETIME(so.CreatedDate) AS CreatedDate,#(lf)  DATE(so.CreatedDate) AS NgayDat,#(lf)  od.Price,#(lf)  SUM(od.Quantity) AS Quantity,#(lf)  sp.code AS ProductCode,#(lf)  'Miền Bắc' AS `Miền`#(lf)FROM#(lf)  `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_Order` so#(lf)INNER JOIN#(lf)  `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_OrderDetail` od#(lf)ON#(lf)  od.OrderId = so.Id#(lf)INNER JOIN#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product` sp#(lf)ON#(lf)  sp.Id = OD.ProductId#(lf)INNER JOIN#(lf)  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store` es#(lf)ON#(lf)  es.Id = od.OutputStoreId#(lf)LEFT JOIN (#(lf)  SELECT#(lf)    sbd.SOOrderDetailId,#(lf)    ag.AutoCode,#(lf)  FROM#(lf)    `cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_StoreBillDetail` sbd#(lf)  JOIN#(lf)    `cellphones-data-platform.cps_cdc_sep_hn_dbo.Acc_General` ag#(lf)  ON#(lf)    ag.Id = sbd.StoreBillId#(lf)  JOIN#(lf)    `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_OrderDetail` sd#(lf)  ON#(lf)    sbd.SOOrderDetailId = sd.Id#(lf)  JOIN#(lf)    `cellphones-data-platform.cps_cdc_sep_hn_dbo.SO_Order` so#(lf)  ON#(lf)    sd.OrderId = so.Id#(lf)  WHERE#(lf)    DATE(so.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)    AND ag.ReplaceById IS NULL#(lf)    AND ag.Autocode NOT LIKE '%#%'#(lf)  GROUP BY#(lf)    sbd.SOOrderDetailId,#(lf)    ag.AutoCode#(lf)    ) TempBill#(lf)ON#(lf)  TempBill.SOOrderDetailId = od.Id#(lf)WHERE#(lf)  1=1#(lf)  AND DATE(SO.CreatedDate) >= DATE_TRUNC(DATE_SUB(CURRENT_DATE(), INTERVAL 6 MONTH), MONTH)#(lf)  AND so.MethodId IN (14, 56, 57, 58, 59)#(lf)  AND so.ReplaceById IS NULL#(lf)  AND NOT REGEXP_CONTAINS(UPPER(es.code), r'(B2B)') #(lf)GROUP BY#(lf)  so.AutoCode,#(lf)  TempBill.AutoCode,#(lf)  es.code,#(lf)  so.CreatedDate,#(lf)  od.Price,#(lf)  sp.code#(lf))#(lf)#(lf)select #(lf)  od.*,#(lf)  i.Quantity as `Tồn đầu ngày`#(lf)from Order_DH as od#(lf)left join inv as i on i.start_date = od.NgayDat and i.ProductCode = od.ProductCode  and i.StoreCode = od.StoreCode", null, [EnableFolding=true]),
