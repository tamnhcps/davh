	column 'Tồn bổ sung' = ```
			
			--Trường hợp lập điều chuyển và xác nhận hàng trong ngày. Ta cần cộng vào (chỉ xét theo date) vì
			--1.Bảng snapshot cập nhật duy nhất 1 lần vào 0h30
			--2.Báo cáo cập nhật 1 lần/ngày, nên không dùng SO_CurrentInventory
			--Ghi chú: Kết quả cột Tồn bổ sung => Tồn chỉ dùng để tính tại thời điểm lập DH có tồn hay không
			VAR _NgayDat = F_Dh[NgayDat]
			VAR _StoreCode = F_Dh[StoreCode]
			VAR _ProductCode = F_Dh[ProductCode] 
			
			RETURN
			CALCULATE(
			    SUM('F_Ycdc'[Quantity]),
			    FILTER(
			        'F_Ycdc',
			        'F_Ycdc'[Ngày xác nhận_date] = _NgayDat &&
			        'F_Ycdc'[Kho nhận hàng] = _StoreCode &&
			        'F_Ycdc'[Mã hàng] = _ProductCode &&
			        'F_Ycdc'[Ngày lập phiếu chuyển].[Date] = 'F_Ycdc'[Ngày xác nhận_date]
			    )
			)
			
			--Lưu trữ
			// Ngày lập phiếu chuyển = 
			// VAR CurrentStoreCode = 'FACT_DS đơn hàng'[StoreCode]
			// VAR CurrentProductCode = 'FACT_DS đơn hàng'[ProductCode]
			// VAR CurrentNgayDat = 'FACT_DS đơn hàng'[NgayDat]
			// VAR NgayLapPhieuChuyen = 
			//     CALCULATE(
			//         MAXX(
			//             FILTER(
			//                 'FACT_DC',
			//                 'FACT_DC'[Kho cho hàng] = CurrentStoreCode &&
			//                 'FACT_DC'[Mã hàng] = CurrentProductCode &&
			//                 'FACT_DC'[Ngày lập phiếu chuyển] <= CurrentNgayDat
			//             ),
			//             'FACT_DC'[Ngày lập phiếu chuyển]
			//         )
			//     )
			
			// RETURN
			//     IF(
			//         DATEDIFF(NgayLapPhieuChuyen, CurrentNgayDat, DAY) <= 14,
			//         NgayLapPhieuChuyen,
			//         BLANK()
			//     )
			
			// Lý do YCDC = 
			// CALCULATE(
			//     FIRSTNONBLANK(
			//         'FACT_DC'[Lý do YCDC],
			//         1
			//     ),
			//     FILTER(
			//         'FACT_DC',
			//         'FACT_DC'[Ngày lập phiếu chuyển] = EARLIER('FACT_DS đơn hàng'[Ngày lập phiếu chuyển]) &&
			//         'FACT_DC'[Kho cho hàng] = EARLIER('FACT_DS đơn hàng'[StoreCode]) &&
			//         'FACT_DC'[Mã hàng] = EARLIER('FACT_DS đơn hàng'[ProductCode])
			//     )
			// )
			```
		lineageTag: 3a78b5f1-42ef-4381-96e1-b1985daf8fcf
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

