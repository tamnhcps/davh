	/// Thời gian tính từ ngày xác nhận YCDC đến ngày lập SP (DVT: Ngày)
	measure 'TG bán hàng' = ```
			
			VAR TG =
			    CALCULATE(
			        AVERAGE('F_Ycdc'[TG_Xác nhận_Lập phiếu bán]),
			        KEEPFILTERS('F_Ycdc'[Lý do YCDC] <> "Khác")
			    )
			RETURN
			    SWITCH(
			        TRUE(),
			        ISINSCOPE('D_Employee'[Nhân viên]), BLANK(),
			        TG
			    )
			
			```
		formatString: #,0.00
		displayFolder: TG
		lineageTag: 122611df-adaa-4d1e-ae3d-1c988a62d5cd

