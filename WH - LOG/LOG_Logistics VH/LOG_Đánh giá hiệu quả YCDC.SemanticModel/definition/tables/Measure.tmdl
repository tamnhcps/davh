		formatString: 0.00%;-0.00%;0.00%
		displayFolder: YCDC
		lineageTag: 46bf5d0c-800d-4839-8ab5-e472ac1b740e

	/// Thời gian tính từ ngày lập YCDC đến ngày lập DC (DVT: Ngày)
	measure 'TG lập DC' = ```
			
			AVERAGEX(
			    SUMMARIZE(
			        FILTER(
			            'F_Ycdc',
			            'F_Ycdc'[TG_Lập YCDC_Lập DC] <> BLANK() && 
			            'F_Ycdc'[TG_Lập YCDC_Lập DC] <> 0
			        ),
			        'F_Ycdc'[Phiếu chuyển],
			        "Avg_TG lập YCDC_lập DC", AVERAGE('F_Ycdc'[TG_Lập YCDC_Lập DC])
			    ),
			    [Avg_TG lập YCDC_lập DC]
			)
			```
		displayFolder: TG
		lineageTag: a182ba74-f70e-4314-8dcb-f69848c6c544

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Thời gian tính từ ngày lập DC đến ngày xác nhận (DVT: Ngày)
