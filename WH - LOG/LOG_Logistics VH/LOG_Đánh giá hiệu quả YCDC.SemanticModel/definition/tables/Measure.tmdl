	measure 'Tổng DC' =
			
			CALCULATE(
			    [DC],
			    FILTER(
			        'F_Ycdc',
			        'F_Ycdc'[TG_Xác nhận_Lập phiếu chuyển] <> BLANK()
			            || ('F_Ycdc'[TG_Xác nhận_Lập phiếu chuyển] = BLANK() && 'F_Ycdc'[Ngày xác nhận_date] <= AVERAGE('LastUpdated'[update]) - 7)
