	measure 'Thời gian cập nhật' =
			
			CALCULATE(
			    MAX('F_Ycdc'[Ngày xác nhận]),
			    ALL()
			)
		formatString: General Date
		displayFolder: FILTER
		lineageTag: ba75d0e0-095e-481d-8633-9f2accda4664

	measure Update-Filtered = ```
			
			--Update
			VAR zFmt_HeaderStart = 
				"<a> <span style='color:#FFDA78'> <b> "
			VAR zFmt_HeaderEnd = 
				": </b> </a>"
			VAR zUpdate_time =
			    [Thời gian cập nhật]
			VAR zUpdate = 
				"<font_update> <span style='color:LightYellow'>
			        <u> Cập nhật đến </u>: " & zUpdate_time & 
			    "</font_update>" 
			
			--Thời gian
			VAR zFil_Ngay =
			    ISFILTERED( 'D_Date'[date] )
			VAR zNgay =
			    zFmt_HeaderStart & "Ngày" & zFmt_HeaderEnd
			        & "Từ " & MIN('D_Date'[date])
			        & " đến " & MAX('D_Date'[date]) & "."
			
			VAR zFil_NamThang =
			    ISFILTERED( 'D_Date'[yearMonth])
			VAR zNamThang =
			    zFmt_HeaderStart & "Năm tháng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Date'[yearMonth] ), 'D_Date'[yearMonth] , ", " ) & "."
			
			VAR zFil_ThoiGian = 
				zFil_Ngay + zFil_NamThang + 0
			
			--Chủ thể
			VAR zFil_Mien =
			    ISFILTERED( 'D_Region'[Miền] )
			VAR zMien =
			    zFmt_HeaderStart & "Miền" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Region'[Miền] ), 'D_Region'[Miền], ", " ) & "."
			
			VAR zFil_LyDoYCDC =
			    ISFILTERED( 'D_YcdcReason'[Lý do YCDC] )
			VAR zLyDoYCDC =
			    zFmt_HeaderStart & "Lý do YCDC" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_YcdcReason'[Lý do YCDC] ), 'D_YcdcReason'[Lý do YCDC] , ", " ) & "."
			
			VAR zFil_VanPhongCongTy =
			    ISFILTERED( 'D_Department'[hara_workplace_name] )
			VAR zVanPhongCongTy =
			    zFmt_HeaderStart & "Văn phòng/Công ty" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Department'[hara_workplace_name] ), 'D_Department'[hara_workplace_name], ", " ) & "."
			
			VAR zFil_TinhThanh =
			    ISFILTERED( 'D_Department'[tinh_thanh_pho] )
			VAR zTinhThanh =
			    zFmt_HeaderStart & "Tỉnh thành" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Department'[tinh_thanh_pho] ), 'D_Department'[tinh_thanh_pho], ", " ) & "."
			
			VAR zFil_DonVi =
			    ISFILTERED( 'D_Department'[bo_phan] )
			VAR zDonVi =
			    zFmt_HeaderStart & "Đơn vị" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Department'[bo_phan] ), 'D_Department'[bo_phan] , ", " ) & "."
			
			VAR zFil_NhanVien =
			    ISFILTERED( 'D_Employee'[Nhân viên])
			VAR zNhanVien =
			    zFmt_HeaderStart & "Nhân viên" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Employee'[Nhân viên] ), 'D_Employee'[Nhân viên], ", " ) & "."
			
			VAR zFil_NhomHang =
			    ISFILTERED( 'D_ProductGroup'[nhom_hang] )
			VAR zNhomHang =
			    zFmt_HeaderStart & "Nhóm hàng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_ProductGroup'[nhom_hang] ), 'D_ProductGroup'[nhom_hang], ", " ) & "."
			
			VAR zFil_Model =
			    ISFILTERED( 'D_Product'[Model] )
			VAR zModel =
			    zFmt_HeaderStart & "Model" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Product'[Model] ), 'D_Product'[Model], ", " ) & "."
			
			VAR zFil_TenHang =
			    ISFILTERED( 'D_Product'[ten_hang] )
			VAR zTenHang =
			    zFmt_HeaderStart & "Tên hàng" & zFmt_HeaderEnd
			        & CONCATENATEX( VALUES( 'D_Product'[ten_hang] ), 'D_Product'[ten_hang], ", " ) & "."
			
			VAR zFil_ChuThe = 
			    zFil_Mien + zFil_LyDoYCDC + zFil_VanPhongCongTy + zFil_TinhThanh + zFil_DonVi + zFil_NhanVien + zFil_NhomHang + zFil_Model + zFil_TenHang + 0
				
			--Final
			VAR zFilter =
			    IF(
			        zFil_ThoiGian + 
			        zFil_ChuThe = 0,
			        BLANK(),
			        "<br> <u> <span style='color:LightYellow'> Bộ lọc áp dụng:</u> "
			            & IF( zFil_Ngay = TRUE, zNgay, BLANK() )
			            & IF( zFil_NamThang = TRUE, zNamThang, BLANK() )
			            & IF( zFil_Mien = TRUE, zMien, BLANK() )
			            & IF( zFil_LyDoYCDC = TRUE, zLyDoYCDC, BLANK() )
			            & IF( zFil_VanPhongCongTy = TRUE, zVanPhongCongTy, BLANK() )
			            & IF( zFil_TinhThanh = TRUE, zTinhThanh, BLANK() )
			            & IF( zFil_DonVi = TRUE, zDonVi, BLANK() )
			            & IF( zFil_NhanVien = TRUE, zNhanVien, BLANK() )
			            & IF( zFil_NhomHang = TRUE, zNhomHang, BLANK() )
			            & IF( zFil_Model = TRUE, zModel, BLANK() )
			            & IF( zFil_TenHang = TRUE, zTenHang, BLANK() )
			    )
			RETURN
			    "<font_all> <i> <span style='color:#F5F5F5'>" & zUpdate & zFilter & "</font_all>"
			```
		displayFolder: FILTER
		lineageTag: 10c632f6-58a7-4146-b68b-984b60517c69

