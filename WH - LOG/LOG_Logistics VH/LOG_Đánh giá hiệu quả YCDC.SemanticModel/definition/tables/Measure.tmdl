			        'F_Ycdc'[Phiếu chuyển],
			        "Avg_TG_lập DC_xác nhận", AVERAGE('F_Ycdc'[TG_Lập DC_Xác nhận])
			    ),
			    [Avg_TG_lập DC_xác nhận]
			)
			
			
			
			```
		displayFolder: TG
		lineageTag: 48f8358a-af54-462b-a1bb-137639482ffd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

