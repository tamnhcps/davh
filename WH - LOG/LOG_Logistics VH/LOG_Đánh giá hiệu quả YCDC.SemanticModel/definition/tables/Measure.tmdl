	measure 'Số lần chuyển kho đến khi bán' =
			
			VAR zSP = DISTINCTCOUNT('F_Dc_Imei'[imei])
			VAR zDC = COUNTROWS('F_Dc_Imei')
			RETURN
			DIVIDE(
			    zDC,
			    zSP
			)
		displayFolder: YCDC
		lineageTag: f58b8c8f-bab0-4318-bee6-6da6d1864e5f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure YCDC1 =
			
			VAR _updateDate = SELECTEDVALUE('LastUpdated'[update])
			RETURN
			CALCULATE(
			    [YCDC],
			    KEEPFILTERS(
			        NOT ISBLANK('F_Ycdc'[Ngày lập SP]) &&
			        'F_Ycdc'[TG_Xác nhận_Lập phiếu bán] <= 1 &&
			        'F_Ycdc'[Ngày xác nhận_date] <= _updateDate - 1
			    )
			)
			
			// CALCULATE(
			//     [YCDC],
			//     FILTER(
			//         'F_Ycdc',
			//         'F_Ycdc'[Ngày lập SP] <> BLANK()
			//             && 'F_Ycdc'[TG_Xác nhận_Lập phiếu bán] <= 1
			//             && 'F_Ycdc'[Ngày xác nhận_date] <= AVERAGE('LastUpdated'[update]) - 1
			//     )
			// )
		formatString: 0
		displayFolder: YCDC
		lineageTag: f2c4d571-4bb5-47e8-a347-0a42b093cfb2

	measure 'Tổng YCDC1' =
			
			VAR _updateDate = AVERAGE('LastUpdated'[update])
			RETURN
			CALCULATE(
			    [YCDC],
			    KEEPFILTERS('F_Ycdc'[Ngày xác nhận_date] <= _updateDate - 1),
			    ALLSELECTED('D_Date'[date])
			)
			
			// CALCULATE(
			//     [YCDC],
			//     FILTER(
			//         'F_Ycdc',
			//         'F_Ycdc'[Ngày xác nhận_date] <= AVERAGE('LastUpdated'[update]) - 1
			//     ),
			//     ALLSELECTED('D_Date'[date])
			// )
		formatString: 0
		displayFolder: YCDC
		lineageTag: 58b1a65f-b012-4d58-9d66-365cbf1faae4

	measure '% YCDC1 theo SKU' =
			
			DIVIDE(
			    [YCDC1],
			    [Tổng YCDC1],
			    0
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: YCDC
		lineageTag: 91b62806-94a2-4814-9ff0-440add439b5c

	measure 'Selected_YCDC7 | YCDC14 theo SKU' =
			
			VAR Selection =
			    SELECTEDVALUE ( 'D_SelectedMeasure'[Measure] )
			RETURN
			    SWITCH (
			        TRUE (),
			        Selection = "% YCDC7", [YCDC7],
			        [YCDC14]
			    )
		formatString: 0
		displayFolder: Selected Measure
		lineageTag: 05c65b4d-8769-4dc7-a078-bdbb321f4ed7

