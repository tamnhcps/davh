	/// [YCDC] có [TG bán hàng] trong 7 ngày
	measure YCDC7 =
			
			VAR _updateDate = SELECTEDVALUE('LastUpdated'[update])
			RETURN
			CALCULATE(
			    [YCDC],
			    KEEPFILTERS(
			        NOT ISBLANK('F_Ycdc'[Ngày lập SP]) &&
			        'F_Ycdc'[TG_Xác nhận_Lập phiếu bán] <= 7 &&
			        'F_Ycdc'[Ngày xác nhận_date] <= _updateDate - 7
			    )
			)
			// CALCULATE(
			//     [YCDC],
			//     FILTER(
			//         'F_Ycdc',
			//         'F_Ycdc'[Ngày lập SP] <> BLANK()
			//             && 'F_Ycdc'[TG_Xác nhận_Lập phiếu bán] <= 7
			//             && 'F_Ycdc'[Ngày xác nhận_date] <= AVERAGE('LastUpdated'[update]) - 7
			//     )
			// )
		formatString: #,0
		displayFolder: YCDC
		lineageTag: 5a6beb0e-ae3d-43a7-9ef6-73a95da4ba7d

	measure '% YCDC7 theo SKU' =
			
			DIVIDE(
			    [YCDC7],
