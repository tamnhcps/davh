	/// Số lượng sản phẩm YCDC đã xác nhận
	measure 'Số lượng' = ```
			
			CALCULATE(
			    SUM('F_Ycdc'[Quantity]),
			    KEEPFILTERS('F_Ycdc'[Lý do YCDC] <> "Khác")
			)
			
