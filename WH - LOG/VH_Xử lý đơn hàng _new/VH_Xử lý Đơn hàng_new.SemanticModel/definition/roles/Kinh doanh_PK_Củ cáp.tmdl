role 'Kinh doanh_PK_Củ cáp'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' = 'DIM_Danh mục_Ngày'[Date]>=LOOKUPVALUE('DIM_Phân quyền_User'[Startdate],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())

	tablePermission 'Dim_Phân Quyền_Kinh doanh' =
			IF(
			    LOOKUPVALUE(
			        'DIM_Phân quyền_User'[Title],
			        'DIM_Phân quyền_User'[Mail], USERPRINCIPALNAME()
			    ) = "QLNH",
			    [PK_Củ cáp]
			        IN DISTINCT(
			            SELECTCOLUMNS(
			                FILTER(
			                    ADDCOLUMNS(
			                        CROSSJOIN(
			                            FILTER(
			                                'DIM_Phân quyền_Kinh doanh',
			                                'DIM_Phân quyền_Kinh doanh'[PK_Củ cáp]
			                                    = LOOKUPVALUE(
			                                        'DIM_Phân quyền_User'[Tên],
			                                        'DIM_Phân quyền_User'[Mail], USERPRINCIPALNAME()
			                                    )
			                            ),
			                            'DIM_Phân quyền_User'
			                        ),
			                        "Path leader", PATHCONTAINS( 'DIM_Phân quyền_User'[Path], 'DIM_Phân quyền_Kinh doanh'[PK_Củ cáp] )
			                    ),
			                    [Path leader]
			                ),
			                "PK", 'DIM_Phân quyền_User'[Tên]
			            )
			        ),
			    TRUE
			)

	annotation PBI_Id = 9c1843463b1747129d90f03cb7390d5d

