	partition 'FACT_Warehouse_Current Inventory' = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=8cc95609-f041-4368-a7a2-25617b22271a""#(lf)--Tồn đi đường#(lf)WITH on_street_inventory_staging AS (#(lf)SELECT#(lf)  Acc_StoreBillDetail.ProductId#(lf)  , ERP_Store.Code AS StoreCode#(lf)  , COALESCE(Acc_StoreBillDetail.Quantity,0) AS quantity#(lf)  , ""HCM"" AS region#(lf)  , ""Tồn đi đường"" AS Type#(lf)FROM `cellphones-data-platform.sqlserver_dprt_hcm_dbo.vw_Acc_StoreBillDetail` AS Acc_StoreBillDetail#(lf)INNER JOIN `cellphones-data-platform.sqlserver_dprt_hcm_dbo.vw_Acc_StoreBill` AS Acc_StoreBill#(lf)  ON Acc_StoreBillDetail.StoreBillId = Acc_StoreBill.Id#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Store_ImportExportMethod` AS Store_ImportExportMethod#(lf)  ON Acc_StoreBill.MethodId = Store_ImportExportMethod.Id#(lf)INNER JOIN `cellphones-data-platform.sqlserver_dprt_hcm_dbo.vw_Acc_General` AS Acc_General#(lf)  ON Acc_StoreBill.Id = Acc_General.Id#(lf)INNER JOIN  `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Product` AS ERP_Product#(lf)  ON ERP_Product.Id = Acc_StoreBillDetail.ProductId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store` AS ERP_Store#(lf)  ON ERP_Store.id = Acc_StoreBillDetail.InputStoreId#(lf)WHERE 1=1#(lf)AND Store_ImportExportMethod.MethodType = 3 -- Phiếu điều chuyển#(lf)AND Acc_General.ReplaceById is null#(lf)AND Acc_StoreBill.ConfirmByDate is NULL#(lf)AND ERP_Product.IsStock IS TRUE#(lf)AND Acc_General.BillTypeId=1#(lf)#(lf)UNION ALL#(lf)SELECT#(lf)  Acc_StoreBillDetail.ProductId#(lf)  , ERP_Store.code AS StoreCode#(lf)  , COALESCE(Acc_StoreBillDetail.Quantity,0) AS quantity#(lf)  , ""HN"" AS region#(lf)  , ""Tồn đi đường"" AS Type#(lf)FROM `cellphones-data-platform.sqlserver_htv_hn_dbo.vw_Acc_StoreBillDetail` AS Acc_StoreBillDetail#(lf)INNER JOIN `cellphones-data-platform.sqlserver_htv_hn_dbo.vw_Acc_StoreBill` AS Acc_StoreBill#(lf)  ON Acc_StoreBillDetail.StoreBillId = Acc_StoreBill.Id#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Store_ImportExportMethod` AS Store_ImportExportMethod#(lf)  ON Acc_StoreBill.MethodId = Store_ImportExportMethod.Id#(lf)INNER JOIN `cellphones-data-platform.sqlserver_htv_hn_dbo.vw_Acc_General` AS Acc_General#(lf)  ON Acc_StoreBill.Id = Acc_General.Id#(lf)INNER JOIN  `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Product` AS ERP_Product#(lf)  ON ERP_Product.Id = Acc_StoreBillDetail.ProductId#(lf)INNER JOIN `cellphones-data-platform.cps_cdc_sep_hn_dbo.ERP_Store` AS ERP_Store#(lf)  ON ERP_Store.id = Acc_StoreBillDetail.InputStoreId#(lf)WHERE 1=1#(lf)AND Store_ImportExportMethod.MethodType = 3 -- Phiếu điều chuyển#(lf)AND Acc_General.ReplaceById is null#(lf)AND Acc_StoreBill.ConfirmByDate is NULL#(lf)AND ERP_Product.IsStock IS TRUE#(lf)AND Acc_General.BillTypeId=1#(lf))#(lf)#(lf), on_street_inventory AS (#(lf)SELECT#(lf)s.ProductId, #(lf)s.StoreCode,#(lf)dp.ma_hang,#(lf)dp.ten_hang,#(lf)SUM(quantity) AS quantity,#(lf)Type#(lf)FROM on_street_inventory_staging as s#(lf)LEFT JOIN `cellphones-data-platform.cps_DA_General_Transform.dim_product` dp on dp.product_id = s.ProductId#(lf)WHERE quantity <> 0 AND quantity IS NOT NULL#(lf)GROUP BY s.ProductId, s.StoreCode, dp.ma_hang, dp.ten_hang , s.Type#(lf))#(lf)#(lf)--Tồn ngày#(lf), ton_ngay as (#(lf)select#(lf)st.id,#(lf)st.StoreTypeId,#(lf)st.code StoreCode,#(lf)st.name as StoreName,#(lf)p.Code as ProductCode,#(lf)CI.Quantity,#(lf)st.IsMain,#(lf)'DPRT-HCM' Datasource#(lf)from cellphones-data-platform.cps_cdc_sep_hcm_dbo.Store_CurrentInventory CI#(lf)INNER join cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store st on st.Id = ci.StoreId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_SubBranch sb on sb.id = st.BranchId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product p on p.Id = Ci.ProductId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup pg on pg.id = p.ProductGroupId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductType pt on pt.id = p.ProductTypeId#(lf)where #(lf)--sb.CenterId in (1,3759) and #(lf)CI.Quantity > 0 #(lf)#(lf)UNION ALL#(lf)#(lf)select#(lf)st.id,#(lf)st.StoreTypeId,#(lf)st.code StoreCode,#(lf)st.name as StoreName,#(lf)p.Code as ProductCode,#(lf)CI.Quantity,#(lf)st.IsMain,#(lf)'DPRT-HN' Datasource#(lf)from cellphones-data-platform.cps_cdc_sep_hn_dbo.Store_CurrentInventory CI#(lf)INNER join cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Store st on st.Id = ci.StoreId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_SubBranch sb on sb.id = st.BranchId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Product p on p.Id = Ci.ProductId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductGroup pg on pg.id = p.ProductGroupId#(lf)inner join cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_ProductType pt on pt.id = p.ProductTypeId#(lf)where #(lf)--sb.CenterId in (1,3759) and #(lf)CI.Quantity > 0 #(lf))#(lf)#(lf)select #(lf)ton_ngay.*,#(lf)on_street_inventory.quantity as ton_di_duong#(lf)from ton_ngay #(lf)left join on_street_inventory on ton_ngay.StoreCode = on_street_inventory.StoreCode and ton_ngay.ProductCode = on_street_inventory.ma_hang", null, [EnableFolding=true])
				in
				    Source

