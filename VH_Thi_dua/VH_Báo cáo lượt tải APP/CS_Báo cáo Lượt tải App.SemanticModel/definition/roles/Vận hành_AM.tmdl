role 'Vận hành_AM'
	modelPermission: read

	tablePermission 'DIM_Phân quyền_Vận hành' = ```
			SWITCH(
			    TRUE(),
			    'DIM_Phân quyền_Vận hành'[Leader]=LOOKUPVALUE('DIM_Phân quyền_Nhập tay'[Tên],'DIM_Phân quyền_Nhập tay'[Mail],USERPRINCIPALNAME()),
			    LOOKUPVALUE('DIM_Phân quyền_User'[Title],'DIM_Phân quyền_User'[Mail] ,USERPRINCIPALNAME()) = "AM", 
			    [Cửa hàng] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('DIM_Phân quyền_Vận hành','DIM_Phân quyền_Vận hành'[AM] = LOOKUPVALUE('DIM_Phân quyền_User'[Tên],'DIM_Phân quyền_User'[Mail],USERPRINCIPALNAME())),'DIM_Phân quyền_User'),
			                        "Path leader", PATHCONTAINS('DIM_Phân quyền_User'[Path],'DIM_Phân quyền_Vận hành'[AM])),[Path leader]),"Cửa hàng",'DIM_Phân quyền_User'[Tên]))
			)
			```

	annotation PBI_Id = 488f32dd76674445b866873fd7068263

