	partition 'FACT_App_Cài đặt app' = m
		mode: import
		queryGroup: FACT
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=d126f45f-e72b-4ccf-a839-992dea1815aa""#(lf)with dim_storage as (#(lf)  select#(lf)    ma_kho as store_code,#(lf)    cua_hang as store_name#(lf)  from `cellphones-data-platform.cps_DA_General_Transform.dim_storage`#(lf)  where phan_loai_kho = ""Kho cửa hàng""#(lf)  and muc_dich_quan_ly = ""Kho bình thường""#(lf)  and is_inactive is false#(lf)  and BranchID is not null#(lf))#(lf)#(lf)select#(lf)  c.phone as customer_phone,#(lf)  a.shop_code,#(lf)  b.store_code,#(lf)  a.is_first_login,#(lf)  timestamp_add(a.updated_at, interval 7 hour) as updated_time,#(lf)  extract(hour from timestamp_add(a.updated_at, interval 7 hour)) as hour#(lf)from `cellphones-data-platform.cps_web_authentication_dwh.app_referrals ` as a#(lf)left join dim_storage as b#(lf)  --on a.shop_code = b.store_name#(lf)  on (#(lf)    case#(lf)      when a.shop_code = ""CPS-HCM-Q12-938CNAT"" then ""CPS-HCM-Q12-93/8CNAT""#(lf)      when a.shop_code = ""CPS-HCM-HMO-439QT"" then ""CPS-HCM-HMO-4/39QT""#(lf)      when a.shop_code = ""CPS-HNO-CGI-306CG"" then ""CPS-HNO-CGI-310CG""#(lf)      else a.shop_code#(lf)    end#(lf)  ) = b.store_name#(lf)left join `cellphones-data-platform.cps_web_authentication_dwh.members` as c#(lf)  on a.member_id = c.id#(lf)order by 3", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

