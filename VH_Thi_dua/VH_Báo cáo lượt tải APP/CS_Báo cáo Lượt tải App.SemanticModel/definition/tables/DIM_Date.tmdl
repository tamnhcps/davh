table DIM_Date
	lineageTag: 4a9ed876-ff60-4023-9e62-e5e941ab6270

	column Ngay_isActive =
			
			VAR zMax =
			    CALCULATE(
			        MAX( 'FACT_Sale_Cài đặt app_New'[Date] ),
			        FILTER( 'FACT_Sale_Cài đặt app_New', 'FACT_Sale_Cài đặt app_New'[phone] <> BLANK() )
			    )
			RETURN
			    IF(
			        Dim_Date[Date] <= zMax,
			        1,
			        0
			    )
		formatString: 0
		lineageTag: ececa943-c66c-4c6d-b265-126eb318ecf2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

