role 'Kinh doanh_PK_Ốp bao da'
	modelPermission: read

	tablePermission 'D_Danh mục_Ngày' = 'D_Danh mục_Ngày'[Date]>=LOOKUPVALUE('D_Phân quyền_User'[Startdate],'D_Phân quyền_User'[Mail],USERPRINCIPALNAME())

	tablePermission 'D_Phân Quyền_Kinh doanh' = ```
			IF( 
			LOOKUPVALUE('D_Phân quyền_User'[Title],'D_Phân quyền_User'[Mail] ,USERPRINCIPALNAME()) = "QLNH", 
			[PK_Ốp bao da] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('D_Phân Quyền_Kinh doanh','D_Phân Quyền_Kinh doanh'[PK_Ốp bao da] = LOOKUPVALUE('D_Phân quyền_User'[Tên],'D_Phân quyền_User'[Mail],USERPRINCIPALNAME())),'D_Phân quyền_User'),
			                        "Path leader", PATHCONTAINS('D_Phân quyền_User'[Path],'D_Phân Quyền_Kinh doanh'[PK_Ốp bao da])),[Path leader]),"PK",'D_Phân quyền_User'[Tên]))
			,True)
			```

	annotation PBI_Id = 2c7d0843593a4d59a26339876f075e21

