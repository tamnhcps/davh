role 'Kinh doanh_Quản lý vùng'
	modelPermission: read

	tablePermission 'D_Danh mục_Ngày' = 'D_Danh mục_Ngày'[Date]>=LOOKUPVALUE('D_Phân quyền_User'[Startdate],'D_Phân quyền_User'[Mail],USERPRINCIPALNAME())

	tablePermission 'D_Phân Quyền_Kinh doanh' = ```
			IF( 
			LOOKUPVALUE('D_Phân quyền_User'[Title],'D_Phân quyền_User'[Mail] ,USERPRINCIPALNAME()) = "QLNH", 
			[Quản lý vùng] IN DISTINCT(
			    SELECTCOLUMNS(
			        FILTER(
			            ADDCOLUMNS(
			                CROSSJOIN(
			                    FILTER('D_Phân Quyền_Kinh doanh','D_Phân Quyền_Kinh doanh'[Quản lý vùng] = LOOKUPVALUE('D_Phân quyền_User'[Tên],'D_Phân quyền_User'[Mail],USERPRINCIPALNAME())),'D_Phân quyền_User'),
			                        "Path leader", PATHCONTAINS('D_Phân quyền_User'[Path],'D_Phân Quyền_Kinh doanh'[Quản lý vùng])),[Path leader]),"Quản lý vùng",'D_Phân quyền_User'[Tên]))
			,True)
			```

	annotation PBI_Id = b571d08d86ff4572828633556fc8055a

