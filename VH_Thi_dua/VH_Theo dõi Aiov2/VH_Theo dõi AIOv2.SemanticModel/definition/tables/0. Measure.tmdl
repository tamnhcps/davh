	measure 'Thời gian cập nhật' =
			
			CALCULATE(MAX( 'F_StoreBills'[Date] ), ALL())
		formatString: General Date
		lineageTag: de3cc149-94fb-414f-b2b5-1d287e9566a7

	measure 'Slg SP g%' = ```
			
			VAR SelectedPeriod =
			    SELECTEDVALUE(Parameter_ThoiGian[Parameter_NgayTuanThang Order])
			
			VAR SelectedWeekIndex =
			    MAX('D_Danh mục_Ngày'[Năm/Tuần_Index])
			
			VAR SP =
			    [Slg SP]
			
			VAR SP_LM =
			    SWITCH(
			        TRUE(),
			
			        -- Ngày hoặc Theo khung giờ: so với ngày trước
			        SelectedPeriod IN { 0, 3 },
			            CALCULATE(
			                [Slg SP],
			                DATEADD('D_Danh mục_Ngày'[Date], -1, DAY)
			            ),
			
			        -- Năm/Tháng: so với tháng trước
			        SelectedPeriod = 2,
			            CALCULATE(
			                [Slg SP],
			                PARALLELPERIOD('D_Danh mục_Ngày'[Date], -1, MONTH)
			            ),
			
			        -- Năm/Tuần: so với tuần trước theo logic index hiện tại
			        SelectedPeriod = 1,
			            CALCULATE(
			                [Slg SP],
			                FILTER(
			                    ALL('D_Danh mục_Ngày'),
			                    'D_Danh mục_Ngày'[Năm/Tuần_Index] = SelectedWeekIndex + 1
			                )
			            )
			    )
			
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(SP), BLANK(),
			        SP_LM <> 0, DIVIDE(SP, SP_LM, BLANK()) - 1,
			        BLANK()
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 25c71bef-29f4-46b6-9d53-62358a38821b

