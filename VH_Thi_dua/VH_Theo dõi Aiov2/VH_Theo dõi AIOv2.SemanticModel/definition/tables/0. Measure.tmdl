	measure Avg_CompletionTime = ```
			
			VAR _avg = 
			    CALCULATE(
			        AVERAGE(F_StoreBills[completion_time_minutes]),
			        SUMMARIZE(F_StoreBills,F_StoreBills[client_session_id]))
			VAR _second = _avg*60
			VAR _day = INT(_second / 86400)
			VAR _hour = INT(MOD(_second, 86400) / 3600)
			VAR _min = INT(MOD(_second, 3600) / 60)
			VAR _sec = MOD(_second, 60)
			VAR _final_result = 
			IF(_day = BLANK() || _day = 0, BLANK(), FORMAT(_day, "0") & " ngày ") &
			FORMAT(_hour, "00") & ":" &
			FORMAT(_min, "00") & ":" &
			FORMAT(_sec, "00")
			RETURN
			IF(
			    _avg > 0,
			    _final_result,
			    BLANK()
			)
			```
		lineageTag: 7b908e60-4ea8-42c5-9261-a3a7bc86bc8d

	measure Avg_CompletionTime_ = ```
			
			VAR _avg = 
			    CALCULATE(
			        AVERAGE(F_StoreBills[completion_time_minutes]),
			        SUMMARIZE(F_StoreBills,F_StoreBills[client_session_id]))
			VAR _second = _avg*60
			VAR _day = INT(_second / 86400)
			VAR _hour = INT(MOD(_second, 86400) / 3600)
			VAR _min = INT(MOD(_second, 3600) / 60)
			VAR _sec = MOD(_second, 60)
			VAR _final_result = 
			IF(_day = BLANK() || _day = 0, BLANK(), FORMAT(_day, "0") & " ngày ") &
			FORMAT(_hour, "00") & ":" &
			FORMAT(_min, "00") & ":" &
			FORMAT(_sec, "00")
			RETURN
			_avg
			```
		formatString: #,0.00
		lineageTag: da18e467-e9e5-418a-b5b6-d0f004ee26ad

