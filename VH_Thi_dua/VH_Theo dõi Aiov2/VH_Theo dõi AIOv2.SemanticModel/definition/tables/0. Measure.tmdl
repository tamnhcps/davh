	measure 'Slg SP_AioV2 g%' = ```
			
			VAR SelectedPeriod =
			    SELECTEDVALUE(Parameter_ThoiGian[Parameter_NgayTuanThang Order])
			
			VAR SelectedWeekIndex =
			    MAX('D_Danh mục_Ngày'[Năm/Tuần_Index])
			
			VAR SP_AioV2 =
			    [Slg SP_AioV2]
			
			VAR SP_AioV2_LM =
			    SWITCH(
			        TRUE(),
			        SelectedPeriod IN { 0, 3 },
			            CALCULATE(
			                [Slg SP_AioV2],
			                DATEADD('D_Danh mục_Ngày'[Date], -1, DAY)
			            ),
			
			        SelectedPeriod = 2,
			            CALCULATE(
			                [Slg SP_AioV2],
			                PARALLELPERIOD('D_Danh mục_Ngày'[Date], -1, MONTH)
			            ),
			
			        SelectedPeriod = 1,
			            CALCULATE(
			                [Slg SP_AioV2],
			                FILTER(
			                    ALL('D_Danh mục_Ngày'),
			                    'D_Danh mục_Ngày'[Năm/Tuần_Index] = SelectedWeekIndex + 1
			                )
			            )
			    )
			
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(SP_AioV2), BLANK(),
			        SP_AioV2_LM <> 0, DIVIDE(SP_AioV2, SP_AioV2_LM, BLANK()) - 1,
			        BLANK()
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3a5e577a-b1ea-4946-b429-2a513b1d454f

