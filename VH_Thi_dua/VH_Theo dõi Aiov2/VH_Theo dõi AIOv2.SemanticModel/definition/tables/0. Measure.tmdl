	measure _Update = ```
			
			-- Cập nhật
			VAR zFmt_HeaderStart = "<a> <span style='color: LightBlack; font-size:12px'> <b> "
			VAR zFmt_HeaderEnd = ": </b> </span></a>"
			VAR zUpdate_time = [Thời gian cập nhật]
			VAR zUpdate = "<font_update> <span style='color: LightBlack; font-size:12px'> <u> Thời gian cập nhật </u>: " & zUpdate_time & "</span></font_update>"
			
			-- Thời gian
			VAR zFil_NamThang = ISFILTERED('D_Danh mục_Ngày'[Năm/Tháng])
			VAR zNamThang = zFmt_HeaderStart & "Năm - Tháng" & zFmt_HeaderEnd & CONCATENATEX(VALUES('D_Danh mục_Ngày'[Năm/Tháng]), 'D_Danh mục_Ngày'[Năm/Tháng], ", ") & "."
			
			VAR zFil_Date = ISFILTERED('D_Danh Mục_Ngày'[date])
			VAR zDate = zFmt_HeaderStart & "Ngày" & zFmt_HeaderEnd & CONCATENATEX(VALUES('D_Danh Mục_Ngày'[date]), 'D_Danh Mục_Ngày'[date], ", ") & "."
			
			VAR zFil_ThoiGian = zFil_NamThang
			
			-- Địa lý
			VAR zFil_Mien = ISFILTERED('D_Danh mục_Phòng ban'[Miền])
			VAR zMien = zFmt_HeaderStart & "Miền" & zFmt_HeaderEnd & CONCATENATEX(VALUES('D_Danh mục_Phòng ban'[Miền]), 'D_Danh mục_Phòng ban'[Miền], ", ") & "."
			
			-- Cửa hàng
			VAR zFil_AM = ISFILTERED('D_Danh mục_Phòng ban'[AM])
			VAR zAM = zFmt_HeaderStart & "AM" & zFmt_HeaderEnd & CONCATENATEX(VALUES('D_Danh mục_Phòng ban'[AM]), 'D_Danh mục_Phòng ban'[AM], ", ") & "."
			
			VAR zFil_Shop = ISFILTERED('D_Danh mục_Phòng ban'[Cửa hàng])
			VAR zShop = zFmt_HeaderStart & "Size" & zFmt_HeaderEnd & CONCATENATEX(VALUES('D_Danh Mục_Phòng Ban'[Cửa hàng]), 'D_Danh Mục_Phòng Ban'[Cửa hàng], ", ") & "."
			
			VAR zFil_ChuThe = zFil_Mien + zFil_AM + zFil_Shop
			
			-- Phân loại & DMC3
			VAR zFil_HTTT = ISFILTERED(F_StoreBills[PaymentName])
			VAR zHTTT = zFmt_HeaderStart & "HTTT" & zFmt_HeaderEnd & CONCATENATEX(VALUES(F_StoreBills[PaymentName]), F_StoreBills[PaymentName], ", ") & "."
			
			VAR zFil_PhuongThuc = ISFILTERED(F_StoreBills[Name])
			VAR zPhuongThuc = zFmt_HeaderStart & "Phương thức" & zFmt_HeaderEnd & CONCATENATEX(VALUES(F_StoreBills[Name]), F_StoreBills[Name], ", ") & "."
			
			VAR zFil_Nguon = ISFILTERED(F_StoreBills[OrderSource])
			VAR zNguon = zFmt_HeaderStart & "Nguồn" & zFmt_HeaderEnd & CONCATENATEX(VALUES(F_StoreBills[OrderSource]), F_StoreBills[OrderSource], ", ") & "."
			
			VAR zFil_Lendoi = ISFILTERED(F_StoreBills[is_PG])
			VAR zLendoi_ = zFmt_HeaderStart & "Người tạo đơn" & zFmt_HeaderEnd & CONCATENATEX(VALUES(F_StoreBills[is_PG]), F_StoreBills[is_PG], ", ") & "."
			
			VAR zFil_para = ISFILTERED(Parameter_CR[Parameter_CR Fields])
			VAR zpara = zFmt_HeaderStart & "Parameter" & zFmt_HeaderEnd & CONCATENATEX(VALUES(Parameter_CR[Parameter_CR Fields]), Parameter_CR[Parameter_CR Fields], ", ") & "."
			
			VAR zFil_measure = zFil_HTTT + zFil_PhuongThuc + zFil_para + zFil_Nguon
			
			-- Kết quả cuối cùng
			VAR zFilter =
			    IF(
			        zFil_ThoiGian + zFil_ChuThe + zFil_measure = 0,
			        BLANK(),
			        "<br> <u> <span style='color: LightBlack; font-size:12px'> Bộ lọc áp dụng:</u> "
			            & IF(zFil_NamThang, zNamThang, BLANK())
			            & IF(zFil_Mien, zMien, BLANK())
			            & IF(zFil_AM, zAM, BLANK())
			            & IF(zFil_Shop, zShop, BLANK())
			            & IF(zFil_HTTT, zHTTT, BLANK())
			            & IF(zFil_PhuongThuc, zPhuongThuc, BLANK())
			            & IF(zFil_Nguon, zNguon, BLANK())
			            & IF(zFil_Lendoi, zLendoi_, BLANK())
			            & IF(zFil_para, zpara, BLANK())
			    )
			
			RETURN
			    "<font_all> <i> <span style='color: #000000; font-size:12px'>" 
			        & zUpdate & zFilter 
			    & "</span></i></font_all>"
			
			```
		lineageTag: 6a383aa2-df3b-4c00-ae69-5a6fc7c08563

	measure 'Slg SP_SepDesktop_PG' =
			
			CALCULATE(
			    DISTINCTCOUNT(F_StoreBills[AutoCode]),
			    F_StoreBills[is_aio] = 0,
			    F_StoreBills[is_PG] = 1)
		formatString: 0
		lineageTag: 422008c7-f2d0-4929-9d7f-7ea1d1c8b0df

	measure 'TyTrong SP_SepDesktop_PG' =
			
			DIVIDE([Slg SP_SepDesktop_PG], [Slg SP],BLANK())
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c3bc4f4e-801c-4328-bc3e-0accc262b61c

	measure 'TyTrong SP_SepDesktop_PG g%' = ```
			
			VAR SelectedPeriod =
			    SELECTEDVALUE(Parameter_ThoiGian[Parameter_NgayTuanThang Order])
			
			VAR SelectedWeekIndex =
			    MAX('D_Danh mục_Ngày'[Năm/Tuần_Index])
			
			VAR SP =
			    [TyTrong SP_SepDesktop_PG]
			
			VAR SP_LM =
			    SWITCH(
			        TRUE(),
			        SelectedPeriod IN { 0, 3 },
			            CALCULATE(
			                [TyTrong SP_SepDesktop_PG],
			                DATEADD('D_Danh mục_Ngày'[Date], -1, DAY)
			            ),
			
			        SelectedPeriod = 2,
			            CALCULATE(
			                [TyTrong SP_SepDesktop_PG],
			                PARALLELPERIOD('D_Danh mục_Ngày'[Date], -1, MONTH)
			            ),
			
			        SelectedPeriod = 1,
			            CALCULATE(
			                [TyTrong SP_SepDesktop_PG],
			                FILTER(
			                    ALL('D_Danh mục_Ngày'),
			                    'D_Danh mục_Ngày'[Năm/Tuần_Index] = SelectedWeekIndex + 1
			                )
			            )
			    )
			
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(SP), BLANK(),
			        SP_LM <> 0, DIVIDE(SP, SP_LM, BLANK()) - 1,
			        BLANK()
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 13198b5f-750b-444a-98a7-10ba6e082630

	measure 'Target TyTrong SP_AioV2' = ```
			
			VAR size = SELECTEDVALUE('D_Danh mục_Phòng ban'[Size])
			RETURN
			SWITCH(
			    TRUE(),
			    size in {"A", "S"}, 0.6,
			    0.7)
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 68268f8a-6366-4212-ae01-d1d34004402b

