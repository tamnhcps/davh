	column 'Khung giờ Order'
		dataType: int64
		formatString: 0
		lineageTag: 44a5b41a-3d2c-4d79-8b02-01985bec380f
		summarizeBy: sum
		sourceColumn: Khung giờ Order

		annotation SummarizationSetBy = Automatic

	partition F_StoreBills = m
		mode: import
		source =
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([Implementation="2.0"]){[Name="cellphones-data-platform"]}[Data], "-- BigQuery: Tổng hợp AIO V2 vs SepDesktop + PaymentType theo schema HCM và HN#(lf)WITH#(lf)#(lf)-- HCM: Tỷ lệ AIOV2 theo branch#(lf)hcm_branch_stats AS (#(lf)  SELECT#(lf)    DATE(a.CreatedDate) Date,#(lf)#(lf)    CASE#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 8#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 10 THEN '8h - 10h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 10#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 12 THEN '10h - 12h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 12#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 14 THEN '12h - 14h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 14#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 16 THEN '14h - 16h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 16#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 18 THEN '16h - 18h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 18#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 20 THEN '18h - 20h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 20#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 22 THEN '20h - 22h'#(lf)      ELSE '22h - 8h'#(lf)    END AS `Khung giờ`,#(lf)#(lf)    CASE#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 8#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 10 THEN 1#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 10#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 12 THEN 2#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 12#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 14 THEN 3#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 14#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 16 THEN 4#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 16#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 18 THEN 5#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 18#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 20 THEN 6#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 20#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 22 THEN 7#(lf)      ELSE 8#(lf)    END AS `Khung giờ Order`,#(lf)#(lf)    a.BranchId,#(lf)    s.BranchName,#(lf)    ie.Name,#(lf)    empTitle.Name AS title_emp,#(lf)    departmentEmp.Name AS department_emp,#(lf)    UPPER(sper.Code) AS msnv,#(lf)    sper.FullName AS full_name,#(lf)    a.AutoCode,#(lf)    a.RefAutoCode,#(lf)    a.OrderIdentifier,#(lf)    CASE#(lf)      WHEN a.OrderIdentifier <> ""None"" THEN 1#(lf)      ELSE 0#(lf)    END AS is_aio,#(lf)    ep.Name PaymentType,#(lf)    CASE#(lf)      WHEN p.PaymentType LIKE '%SUBD%' THEN 'Cấn trừ cọc'#(lf)      ELSE p.PaymentName#(lf)    END AS PaymentName,#(lf)#(lf)    MIN(#(lf)      CASE#(lf)        WHEN PaymentType LIKE ""%FEE%"" THEN 1#(lf)        WHEN PaymentType = ""SUBDE"" THEN 1#(lf)        WHEN PaymentType IN (""CARD"", ""CASH"", ""PAYPOS"", ""TRANSFER"") THEN 1#(lf)        WHEN PaymentType = ""ELWA"" AND paymentName IN ('MOMO', 'VNPAY', 'MOMO - Ví thông thường') THEN 1#(lf)        WHEN Paymenttype = ""PAYDEPT""#(lf)          AND LOWER(PaymentName) IN (#(lf)            'khách hàng thu sau giao nhận',#(lf)            'khách lẻ giao hàng lazada',#(lf)            'khách lẻ giao hàng ahamove',#(lf)            'khách lẻ nhất tín express',#(lf)            'khách lẻ giao hàng tiết kiệm',#(lf)            'cod - giao hàng ahamove',#(lf)            'cod - giao hàng lazada',#(lf)            'cod - giao hàng nhất tín express',#(lf)            'cod - giao hàng nội bộ',#(lf)            'cod - giao hàng tiết kiệm'#(lf)          ) THEN 1#(lf)        ELSE 0#(lf)      END#(lf)    ) OVER (PARTITION BY a.AutoCode) AS is_aio_support,#(lf)#(lf)    o.OnlineNo,#(lf)    CASE#(lf)      WHEN o.OnlineNo LIKE 'W%' THEN TRUE#(lf)      ELSE FALSE#(lf)    END AS is_online#(lf)#(lf)  FROM `cellphones-data-platform.postgres_data_sale_s12869_dwh.StoreBills` a#(lf)  JOIN `cellphones-data-platform.postgres_data_sale_s12869_dwh.PaymentDetails` AS p#(lf)    ON p.StoreBillId = a.Id#(lf)  JOIN `cellphones-data-platform.cps_DA_General_Transform.dim_storage` s#(lf)    ON a.BranchId = s.BranchID#(lf)  JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Store_ImportExportMethod` ie#(lf)    ON a.MethodId = ie.Id#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_PaymentType` ep#(lf)    ON ep.Code = p.PaymentType#(lf)  LEFT JOIN `cellphones-data-platform.postgres_data_sale_s12869_dwh.Orders` o#(lf)    ON a.OrderCode = o.OrderCode#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` sper#(lf)    ON sper.Id = COALESCE(o.CreatedBy, a.CreatedBy)#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Employee` eeCreate#(lf)    ON eeCreate.Id = sper.Id#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_EmployeeTitle` empTitle#(lf)    ON empTitle.Id = eeCreate.TitleId#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Department` departmentEmp#(lf)    ON departmentEmp.Id = eeCreate.DepartmentId#(lf)  WHERE#(lf)    a.MethodId IN (14, 57, 58)#(lf)    AND DATE(a.CreatedDate) >= '2025-07-01'#(lf)    AND DATE(p.CreatedDate) >= '2025-07-01'#(lf)    AND p.PaymentType NOT LIKE '%FEE%'#(lf)),#(lf)#(lf)-- HN: Tỷ lệ AIOV2 theo branch#(lf)hn_branch_stats AS (#(lf)  SELECT#(lf)    DATE(a.CreatedDate) Date,#(lf)#(lf)    CASE#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 8#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 10 THEN '8h - 10h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 10#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 12 THEN '10h - 12h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 12#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 14 THEN '12h - 14h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 14#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 16 THEN '14h - 16h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 16#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 18 THEN '16h - 18h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 18#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 20 THEN '18h - 20h'#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 20#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 22 THEN '20h - 22h'#(lf)      ELSE '22h - 8h'#(lf)    END AS `Khung giờ`,#(lf)#(lf)    CASE#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 8#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 10 THEN 1#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 10#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 12 THEN 2#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 12#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 14 THEN 3#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 14#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 16 THEN 4#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 16#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 18 THEN 5#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 18#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 20 THEN 6#(lf)      WHEN EXTRACT(HOUR FROM a.CreatedDate) >= 20#(lf)       AND EXTRACT(HOUR FROM a.CreatedDate) < 22 THEN 7#(lf)      ELSE 8#(lf)    END AS `Khung giờ Order`,#(lf)#(lf)    a.BranchId,#(lf)    s.BranchName,#(lf)    ie.Name,#(lf)    empTitle.Name AS title_emp,#(lf)    departmentEmp.Name AS department_emp,#(lf)    UPPER(sper.Code) AS msnv,#(lf)    sper.FullName AS full_name,#(lf)    a.AutoCode,#(lf)    a.RefAutoCode,#(lf)    a.OrderIdentifier,#(lf)    CASE#(lf)      WHEN a.OrderIdentifier <> ""None"" THEN 1#(lf)      ELSE 0#(lf)    END AS is_aio,#(lf)    ep.Name PaymentType,#(lf)    CASE#(lf)      WHEN p.PaymentType LIKE '%SUBD%' THEN 'Cấn trừ cọc'#(lf)      ELSE p.PaymentName#(lf)    END AS PaymentName,#(lf)#(lf)    MIN(#(lf)      CASE#(lf)        WHEN PaymentType LIKE ""%FEE%"" THEN 1#(lf)        WHEN PaymentType = ""SUBDE"" THEN 1#(lf)        WHEN PaymentType IN (""CARD"", ""CASH"", ""PAYPOS"", ""TRANSFER"") THEN 1#(lf)        WHEN PaymentType = ""ELWA"" AND paymentName IN ('MOMO', 'VNPAY', 'MOMO - Ví thông thường') THEN 1#(lf)        WHEN Paymenttype = ""PAYDEPT""#(lf)          AND LOWER(PaymentName) IN (#(lf)            'khách hàng thu sau giao nhận',#(lf)            'khách lẻ giao hàng lazada',#(lf)            'khách lẻ giao hàng ahamove',#(lf)            'khách lẻ nhất tín express',#(lf)            'khách lẻ giao hàng tiết kiệm',#(lf)            'cod - giao hàng ahamove',#(lf)            'cod - giao hàng lazada',#(lf)            'cod - giao hàng nhất tín express',#(lf)            'cod - giao hàng nội bộ',#(lf)            'cod - giao hàng tiết kiệm'#(lf)          ) THEN 1#(lf)        ELSE 0#(lf)      END#(lf)    ) OVER (PARTITION BY a.AutoCode) AS is_aio_support,#(lf)#(lf)    o.OnlineNo,#(lf)    CASE#(lf)      WHEN o.OnlineNo LIKE 'W%' THEN TRUE#(lf)      ELSE FALSE#(lf)    END AS is_online#(lf)#(lf)  FROM `cellphones-data-platform.postgres_data_sale_s3759_dwh.StoreBills` a#(lf)  JOIN `cellphones-data-platform.postgres_data_sale_s3759_dwh.PaymentDetails` AS p#(lf)    ON p.StoreBillId = a.Id#(lf)  JOIN `cellphones-data-platform.cps_DA_General_Transform.dim_storage` s#(lf)    ON a.BranchId = s.BranchID#(lf)  JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Store_ImportExportMethod` ie#(lf)    ON a.MethodId = ie.Id#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_PaymentType` ep#(lf)    ON ep.Code = p.PaymentType#(lf)  LEFT JOIN `cellphones-data-platform.postgres_data_sale_s3759_dwh.Orders` o#(lf)    ON a.OrderCode = o.OrderCode#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Person` sper#(lf)    ON sper.Id = COALESCE(o.CreatedBy, a.CreatedBy)#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_Employee` eeCreate#(lf)    ON eeCreate.Id = sper.Id#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.ERP_EmployeeTitle` empTitle#(lf)    ON empTitle.Id = eeCreate.TitleId#(lf)  LEFT JOIN `cellphones-data-platform.cps_cdc_sep_hcm_dbo.Shared_Department` departmentEmp#(lf)    ON departmentEmp.Id = eeCreate.DepartmentId#(lf)  WHERE#(lf)    a.MethodId IN (14, 57, 58)#(lf)    AND DATE(a.CreatedDate) >= '2025-07-01'#(lf)    AND DATE(p.CreatedDate) >= '2025-07-01'#(lf)    AND p.PaymentType NOT LIKE '%FEE%'#(lf)),#(lf)#(lf)-- Lấy dữ liệu event trên app AIOv2#(lf)filtered AS (#(lf)  SELECT#(lf)    client_session_id,#(lf)    event_name,#(lf)    event_time,#(lf)    branch_id,#(lf)    current_key#(lf)  FROM `cellphones-data-platform.cps_erp_prod_tracking_mongodb.Collects`#(lf)  WHERE#(lf)    DATE(event_time) >= DATE('2025-07-01')#(lf)    AND current_key <> ""None""#(lf)),#(lf)#(lf)-- Lấy thời gian xảy ra event đầu tiên trên app AIOv2#(lf)session_first AS (#(lf)  SELECT#(lf)    client_session_id,#(lf)    branch_id,#(lf)    current_key,#(lf)    MIN(TIMESTAMP(event_time)) AS first_event_time#(lf)  FROM filtered#(lf)  GROUP BY#(lf)    client_session_id,#(lf)    branch_id,#(lf)    current_key#(lf)),#(lf)#(lf)-- Lấy thời gian xảy ra event lưu đơn trên app AIOv2#(lf)save_events AS (#(lf)  SELECT#(lf)    f.client_session_id,#(lf)    f.branch_id,#(lf)    f.event_name,#(lf)    f.current_key,#(lf)    TIMESTAMP(f.event_time) AS save_event_time,#(lf)    sf.first_event_time,#(lf)    TIMESTAMP_DIFF(TIMESTAMP(f.event_time), sf.first_event_time, SECOND) / 60.0 AS completion_time_minutes#(lf)  FROM filtered f#(lf)  JOIN session_first sf#(lf)    ON f.client_session_id = sf.client_session_id#(lf)  WHERE#(lf)    f.event_name IN (#(lf)      'SaveStoreBillWithComboPromotion',#(lf)      'SaveStoreBillWithPromotion',#(lf)      'SaveStoreBillWithOutPromotion'#(lf)    )#(lf)),#(lf)#(lf)-- Nhóm theo thời gian được tính#(lf)completion_time_minutes AS (#(lf)  SELECT#(lf)    *,#(lf)    CASE#(lf)      WHEN completion_time_minutes < 3 THEN '0-3 phút'#(lf)      WHEN completion_time_minutes < 5 THEN '3-5 phút'#(lf)      WHEN completion_time_minutes < 10 THEN '5-10 phút'#(lf)      WHEN completion_time_minutes < 15 THEN '10-15 phút'#(lf)      WHEN completion_time_minutes < 30 THEN '15-30 phút'#(lf)      ELSE '30+ phút'#(lf)    END AS minuteRange,#(lf)    CASE#(lf)      WHEN completion_time_minutes < 3 THEN 1#(lf)      WHEN completion_time_minutes < 5 THEN 2#(lf)      WHEN completion_time_minutes < 10 THEN 3#(lf)      WHEN completion_time_minutes < 15 THEN 4#(lf)      WHEN completion_time_minutes < 30 THEN 5#(lf)      ELSE 6#(lf)    END AS minuteRangeOrder#(lf)  FROM save_events#(lf))#(lf)#(lf)-- Xem thống kê theo chi nhánh#(lf)SELECT DISTINCT * EXCEPT(OrderIdentifier)#(lf)FROM (#(lf)  SELECT * FROM hcm_branch_stats#(lf)  UNION ALL#(lf)  SELECT * FROM hn_branch_stats#(lf)) a#(lf)LEFT JOIN completion_time_minutes b#(lf)  ON a.OrderIdentifier = b.current_key#(lf) AND a.BranchId = b.branch_id#(lf)WHERE msnv <> 'ADMIN'", null, [EnableFolding=true])
