	column OrderSource =
			
			VAR department =
			    SWITCH (
			        TRUE (),
			        'F_StoreBills'[department_emp]
			            IN {
			                "CSKH - Hotline",
			                "Nhóm Hotline CellphoneS",
			                "Phòng chăm sóc khách hàng"
			            }, "Hotline",
			        'F_StoreBills'[department_emp]
			            IN {
			                "Nhóm chatline CellphoneS",
			                "Nhóm CTV Chatline CellphoneS",
			                "Nhóm Facebook CellphoneS"
			            }, "Chatline",
			        "Shop"
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        F_StoreBills[is_online] = TRUE()
			            && department = "Hotline", "Đơn Hotline xử lý",
			        F_StoreBills[is_online] = TRUE()
			            && department = "Chatline", "Đơn Chatline xử lý",
			        F_StoreBills[is_online] = TRUE()
			            && department = "Shop", "Đơn Shop xử lý",
			        F_StoreBills[is_online] = FALSE ()
			            && department = "Hotline", "Đơn KH gọi Hotline",
			        F_StoreBills[is_online] = FALSE ()
			            && department = "Chatline", "Đơn KH nhắn tin Chatline",
			        F_StoreBills[is_online] = FALSE ()
			            && department = "Shop", "Đơn Offline",
			        BLANK ()
			    )
		lineageTag: bd4f3160-dc69-4237-b591-2e241bf0c459
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column is_PG = ```
			IF(CONTAINSSTRING(F_StoreBills[title_emp], "PG"),1,0) 
			```
