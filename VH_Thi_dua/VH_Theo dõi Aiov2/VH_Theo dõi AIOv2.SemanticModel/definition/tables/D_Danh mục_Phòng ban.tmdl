	column 'Isnot B2B_ONL' =
			
			IF(
			    'D_Danh mục_Phòng ban'[Cửa hàng] <> "CPS-HCM-SHOPONLINE"
			        && 'D_Danh mục_Phòng ban'[Cửa hàng] <> "CPS-HNO-SHOPONLINE"
			        && 'D_Danh mục_Phòng ban'[Cửa hàng] <> "CPS-HNO-DDA-B2B"
			        && 'D_Danh mục_Phòng ban'[Cửa hàng] <> "Phòng B2B"
			        && 'D_Danh mục_Phòng ban'[Cửa hàng] <> "Phòng bảo hành CellphoneS",
			    1,
			    0
			)
		formatString: 0
		lineageTag: 76bce8a9-7bbc-4dc7-9a52-d1dfa6e6446c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Shop_size = 'D_Danh mục_Phòng ban'[Cửa hàng]&" ("&'D_Danh mục_Phòng ban'[Size]&")"
		lineageTag: 5df8134e-8797-4539-8d27-8c129a200ecb
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Target_AIOv2 = IF('D_Danh mục_Phòng ban'[Size] in {"A", "S"}, 0.6, 0.7)
		lineageTag: ce17e85d-9d69-42f2-b0ef-4b60e6c54a96
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

