		annotation SummarizationSetBy = Automatic

	column Leader = LOOKUPVALUE('D_Phân quyền_User'[Leader],'D_Phân quyền_User'[Tên],'DIM_Phân quyền_Vận hành'[Cửa hàng],BLANK())
