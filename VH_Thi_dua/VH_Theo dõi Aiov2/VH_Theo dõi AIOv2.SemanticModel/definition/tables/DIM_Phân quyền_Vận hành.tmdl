	column OP =
			
			VAR Mien =
			    LOOKUPVALUE(
			        'D_Danh mục_Kho'[Miền],
			        'D_Danh mục_Kho'[Mã kho], 'DIM_Phân quyền_Vận hành'[Mã kho]
			    )
			RETURN
			    LOOKUPVALUE( 'D_Phân quyền_Vận hành_Vùng'[Tên],'D_Phân quyền_Vận hành_Vùng'[Miền],Mien)
		lineageTag: 040b6d0c-6da6-40be-b48d-03bf2f9c02ea
