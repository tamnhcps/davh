role 'Vận hành_AM'
	modelPermission: read

	tablePermission 'DIM_Danh mục_Ngày' =
			'DIM_Danh mục_Ngày'[Date]
			    >= LOOKUPVALUE(
			        'DIM_Phân quyền_User'[Startdate],
			        'DIM_Phân quyền_User'[Mail], USERPRINCIPALNAME()
			    )

	tablePermission 'DIM_Phân quyền_Vận hành' = ```
			VAR zName = 
			    LOOKUPVALUE(
			        'DIM_Phân quyền_User'[Tên],
			        'DIM_Phân quyền_User'[Mail], 
			        USERPRINCIPALNAME()
			    )
			
			VAR zTable_AddColumns = 
			    ADDCOLUMNS(
			        'DIM_Phân quyền_Vận hành',
			        "zPath",
			        LOOKUPVALUE(
			            'DIM_Phân quyền_User'[Path],
			            'DIM_Phân quyền_User'[Tên], 
			            'DIM_Phân quyền_Vận hành'[Leader]
			        )
			    )
			
			VAR zFilteredTable = 
			    FILTER(
			        zTable_AddColumns,
			        PATHCONTAINS([zPath], zName)
			    )
			
			VAR zDistinctStores = 
			    DISTINCT(
			        SELECTCOLUMNS(
			            zFilteredTable,
			            "Cửa hàng", 'DIM_Phân quyền_Vận hành'[Cửa hàng]
			        )
			    )
			
			RETURN
			IF(
			    LOOKUPVALUE('DIM_Phân quyền_User'[Title], 'DIM_Phân quyền_User'[Mail], USERPRINCIPALNAME()) = "AM",
			    [Cửa hàng] IN zDistinctStores,
			    TRUE
			)
			```

	annotation PBI_Id = 538ebc965ebd43f2a979f618b9bbcd3c

