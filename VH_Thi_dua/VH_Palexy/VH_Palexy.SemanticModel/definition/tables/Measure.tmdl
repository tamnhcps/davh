	measure Time_refresh = CALCULATE(max(FACT_Palexy_Store[day]),all(FACT_Palexy_Store))
		formatString: Short Date
		lineageTag: e6d03976-9cd4-4347-826c-159ce31213f5

	measure 'Store_Total opportunities' =
			
			var _z = SUM ( FACT_Palexy_Store[total_opportunities] ) - SUM ( FACT_Palexy_Store[visit_asp] ) - SUM ( FACT_Palexy_Store[visit_SO_TH] ) - SUM ( FACT_Palexy_Store[visit_thecao] ) - SUM ( FACT_Palexy_Store[visit_loai_tru] )
			
			RETURN IF(_z < 0, [Store_Sales transaction], _z)
		displayFolder: Store\Customer
		lineageTag: 10029af6-ec6d-49a9-9b1a-f35b31ad2c96

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Store_Conversion by Opportunities' =
			
			VAR _y = [Store_Conversion by Opportunities_plx] * 100
			VAR _x = (_y - TRUNC(_y)) / 100
			VAR _z =
			    DIVIDE ( [Store_Sales transaction], [Store_Total opportunities], BLANK () )
			RETURN
			    IF (
			        _z > 0.95,
			        0.95 + _x,
			        _z
			    )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Store\Sale
		lineageTag: 445ba377-41d3-4cbe-9d8f-69c42c819742

	measure 'Store_Total visit_asp' =
			
			CALCULATE (
			    SUM ( FACT_Palexy_Store[visit_asp] ),
			    ALL ( 'DIM_Danh mục_Section'[section_metadata_value_label] )
			)
		formatString: 0
		displayFolder: Store\Traffic
		lineageTag: f923cf8c-fd87-498c-9473-ff3a759c2c0e

	measure 'Store_Sales transaction by phone' =
			
