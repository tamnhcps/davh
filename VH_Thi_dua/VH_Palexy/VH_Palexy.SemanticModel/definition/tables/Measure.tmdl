	measure 'Số ngày liên tiếp không đạt CR' = ```
			
			VAR _today_raw = CALCULATE(FIRSTNONBLANK('DIM_Danh mục_Ngày'[refresh_time],0))
			VAR _today = DATE(YEAR([Date_MaxDate]),MONTH([Date_MaxDate]),DAY([Date_MaxDate]))
			VAR _startmonth = DATE(YEAR([Date_MaxDate]),MONTH([Date_MaxDate]),1)
			VAR _condition = 
			IF ( [Run-rate]  = 1, [Date_MaxDate],_today)
			VAR _minDate = 
			CALCULATE(
			    MIN('DIM_Danh mục_Ngày'[Date])
			)
			VAR _mien = SELECTEDVALUE('DIM_Danh mục_Phòng ban'[Miền])
			VAR _tbl_shop = 
			ADDCOLUMNS(
			    FILTER(
			        SUMMARIZECOLUMNS(
			            'DIM_Danh mục_Ngày'[Date],
			            'DIM_Danh mục_Phòng ban'[am],
			            'DIM_Danh mục_Phòng ban'[Bộ phận],
			            "target", CALCULATE ([Store_Evaluation])
			        ),
			        'DIM_Danh mục_Ngày'[Date] >= _minDate -30
			    ),
			    "notAchieved", IF([target] = "Không đạt" , 1, 0)
			)
			VAR _mien_target = IF(_mien = "Miền Nam", 0.85,0.82)
			VAR _tbl_am = 
			ADDCOLUMNS(
			    FILTER(
			        SUMMARIZECOLUMNS(
			            'DIM_Danh mục_Ngày'[Date],
			            'DIM_Danh mục_Phòng ban'[am],
			            "target", 
			            CALCULATE (
			                DIVIDE(
			                    [Store_Conversion by Opportunities],
			                    _mien_target))
			        ),
			        'DIM_Danh mục_Ngày'[Date] >= _minDate -30
			    ),
			    "notAchieved", IF([target] < 1 , 1, 0)
			)
			VAR _tbl_mien = 
			ADDCOLUMNS(
			    FILTER(
			        SUMMARIZECOLUMNS(
			            'DIM_Danh mục_Ngày'[Date],
			            'DIM_Danh mục_Phòng ban'[Miền],
			            "target", 
			            CALCULATE (
			                DIVIDE(
			                    [Store_Conversion by Opportunities],
			                    _mien_target))
			        ),
			        'DIM_Danh mục_Ngày'[Date] >= _minDate -30
			    ),
			    "notAchieved", IF([target] < 1 , 1, 0)
			)
			VAR _last_achieved_date_shop = 
			CALCULATE(
			    MAX('DIM_Danh mục_Ngày'[Date]),
			    FILTER(
			        _tbl_shop,
			        'DIM_Danh mục_Ngày'[Date] <= _today && [notAchieved] = 0
			    )
			)
			VAR _last_achieved_date_am = 
			CALCULATE(
			    MAX('DIM_Danh mục_Ngày'[Date]),
			    FILTER(
			        _tbl_am,
			        'DIM_Danh mục_Ngày'[Date] <= _today && [notAchieved] = 0
			    )
			)
			VAR _last_achieved_date_mien = 
			CALCULATE(
			    MAX('DIM_Danh mục_Ngày'[Date]),
			    FILTER(
			        _tbl_mien,
			        'DIM_Danh mục_Ngày'[Date] <= _today && [notAchieved] = 0
			    )
			)
			VAR _result = 
			IF( _startmonth <= _today,
			
			SWITCH(
			    TRUE(),
			    SELECTEDVALUE(Parameter_OP[Parameter_OP Order]) = 0, 
			        DATEDIFF(MAX(_last_achieved_date_mien,_startmonth - 1),_condition,DAY),
			    SELECTEDVALUE(Parameter_OP[Parameter_OP Order]) = 2,
			        DATEDIFF(MAX(_last_achieved_date_shop,_startmonth - 1),_condition,DAY),
			        DATEDIFF(MAX(_last_achieved_date_am,_startmonth - 1),_condition,DAY)
			),
			SWITCH(
			    TRUE(),
			    SELECTEDVALUE(Parameter_OP[Parameter_OP Order]) = 0, 
			        DATEDIFF(MAX(_last_achieved_date_mien,_startmonth),_condition,DAY),
			    SELECTEDVALUE(Parameter_OP[Parameter_OP Order]) = 2,
			        DATEDIFF(MAX(_last_achieved_date_shop,_startmonth),_condition,DAY),
			        DATEDIFF(MAX(_last_achieved_date_am,_startmonth),_condition,DAY)
			))
			RETURN 
			_result
			```
		formatString: 0
		lineageTag: d8d5b3cb-e236-4451-8a8a-261b7ccf0b09

	measure Run-rate = ```
			
			--Chỉ số Runrate chỉ tính tới ngày hôm qua---
			VAR _max_date_1 = 
			CALCULATE(MAX( 'DIM_Danh mục_Ngày'[date]), FILTER('DIM_Danh mục_Ngày','DIM_Danh mục_Ngày'[Ngày_isActive] = 1))
			VAR _max_date_2 = DAY(TODAY() -1)
			VAR _condition = IF( EOMONTH(_max_date_1,0) = EOMONTH(TODAY() - 1,0),1,0)
			RETURN 
			IF(
			    _condition = 1, 
			    DIVIDE(DAY(EOMONTH(_max_date_1,0)),DAY(_max_date_1), 1),
			    1
			) 
			```
		lineageTag: 1667ac30-db78-44d4-80b9-a1e69f04cf1d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Date_MaxDate =
			
			CALCULATE(MAX( 'DIM_Danh mục_Ngày'[date]), FILTER('DIM_Danh mục_Ngày','DIM_Danh mục_Ngày'[Ngày_isActive] = 1))
		formatString: General Date
		lineageTag: 57f576bc-2eab-41da-b2b7-67bea7cdddf3

	measure 'Kết quả final' = ```
			
			VAR _selection = SELECTEDVALUE('DIM_Danh mục_Selection'[Metric])
			VAR _condition = SELECTEDVALUE('DIM_Danh mục_Báo cáo'[Date])
			VAR _max_date = MAX('DIM_Danh mục_Ngày'[Date])
			VAR _min_date = MIN('DIM_Danh mục_Ngày'[Date])
			VAR _date_filter = SELECTEDVALUE('DIM_Danh mục_Báo cáo'[Date_Real])
			VAR _date =
			    DATEVALUE(
			        SUMMARIZE(
			            FILTER(
			                'DIM_Danh mục_Báo cáo',
			                NOT('DIM_Danh mục_Báo cáo'[Date] IN {"CR tháng", "Số ngày không đạt liên tiếp", "Traffic tháng"})
			            ),
			            'DIM_Danh mục_Báo cáo'[Date]
			        )
			    )
			VAR _crbo_plx = [CRbO_PLX]
			VAR _total_opps_plx = [Total Opps_PLX]
			RETURN
			SWITCH(
			    TRUE(),
			
			    _selection = "CR" && _condition = "CR tháng",
			        FORMAT(CALCULATE([Store_Conversion by Opportunities], ALL('DIM_Danh mục_Ngày'[Date])), "0.00%"),
			
			    _selection = "CR" && _condition = "Số ngày không đạt liên tiếp",
			        FORMAT(CALCULATE([Số ngày liên tiếp không đạt CR], ALL('DIM_Danh mục_Ngày'[Date])), "0"),
			
			    _selection = "CR" && _date <= _max_date && _date >= _min_date,
			        FORMAT(CALCULATE([Store_Conversion by Opportunities], FILTER('DIM_Danh mục_Ngày', 'DIM_Danh mục_Ngày'[Date] = _date_filter)), "0.00%"),
			
			    _selection = "Visits final" && _condition = "Traffic tháng",
			        FORMAT(CALCULATE([Store_Total visit final], ALL('DIM_Danh mục_Ngày'[Date])), "###,###"),
			
			    _selection = "Visits final" && _date <= _max_date && _date >= _min_date,
			        FORMAT(CALCULATE([Store_Total visit final], FILTER('DIM_Danh mục_Ngày', 'DIM_Danh mục_Ngày'[Date] = _date_filter)), "###,###"),
			
			    _selection = "CRbO_PLX",
			        IF(NOT ISBLANK(_crbo_plx), FORMAT(_crbo_plx, "0.00%")),
			
			    _selection = "Total Opps_PLX",
			        IF(NOT ISBLANK(_total_opps_plx), FORMAT(_total_opps_plx, "#,0"))
