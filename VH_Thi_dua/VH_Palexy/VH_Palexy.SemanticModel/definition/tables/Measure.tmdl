	measure Format = ```
			
			VAR _selection = SELECTEDVALUE('DIM_Danh mục_Selection'[Metric])
			VAR _condition = SELECTEDVALUE('DIM_Danh mục_Báo cáo'[Date])
			VAR _max_date = MAX( 'DIM_Danh mục_Ngày'[Date] )
			VAR _min_date = MIN( 'DIM_Danh mục_Ngày'[Date] )
			VAR _date_filter = SELECTEDVALUE('DIM_Danh mục_Báo cáo'[Date_Real])
			VAR _date = DATEVALUE(SUMMARIZE(FILTER('DIM_Danh mục_Báo cáo',NOT('DIM_Danh mục_Báo cáo'[Date] IN {"CR tháng","Số ngày không đạt liên tiếp","Traffic tháng"})),'DIM_Danh mục_Báo cáo'[Date]))
			VAR _mien = SELECTEDVALUE('DIM_Danh mục_Phòng ban'[Miền])
			VAR _target = 
			IF(
			    SELECTEDVALUE(Parameter_OP[Parameter_OP Order]) <= 1,
			        IF(_mien = "Miền Nam", 0.85,0.82),
			        [Store_Target_CR])
			RETURN
			SWITCH( TRUE(),
			    _selection = "CR" && _condition = "CR tháng" && CALCULATE([Store_Conversion by Opportunities],ALL('DIM_Danh mục_Ngày'[Date])) >= _target, "#b7e1cd",
			    _selection = "CR" && _condition = "CR tháng" && CALCULATE([Store_Conversion by Opportunities],ALL('DIM_Danh mục_Ngày'[Date])) < _target, "#f4cccc",
			    _selection = "CR" && _date <= _max_date && _date >= _min_date && CALCULATE([Store_Conversion by Opportunities],FILTER('DIM_Danh mục_Ngày', 'DIM_Danh mục_Ngày'[Date] = _date_filter)) >= _target, "#b7e1cd",
			    _selection = "CR" && _date <= _max_date && _date >= _min_date && CALCULATE([Store_Conversion by Opportunities],FILTER('DIM_Danh mục_Ngày', 'DIM_Danh mục_Ngày'[Date] = _date_filter)) < _target, "#f4cccc",
			
			    _selection = "CR" && _condition = "Số ngày không đạt liên tiếp" && CALCULATE([Số ngày liên tiếp không đạt CR],ALL('DIM_Danh mục_Ngày'[Date])) = 0, "#b7e1cd",
			    _selection = "CR" && _condition = "Số ngày không đạt liên tiếp" && CALCULATE([Số ngày liên tiếp không đạt CR],ALL('DIM_Danh mục_Ngày'[Date])) >= 1, "#f4cccc"
			)
			
			```
		lineageTag: b783eb98-4666-4e5f-8c4a-56b723a47f77

	measure 'Số ngày không đạt' = CALCULATE([Số ngày liên tiếp không đạt CR],ALL('DIM_Danh mục_Ngày'[Date]))
		formatString: 0
		lineageTag: 5ff86a5c-7588-4106-88e2-01c2e2924f2e

	measure 'Số ngày liên tiếp không đạt CR_v2' = ```
			
			VAR _today      = [Date_MaxDate]
			VAR _startMonth = DATE(YEAR(_today), MONTH(_today), 1)
			VAR _mien       = SELECTEDVALUE('DIM_Danh mục_Phòng ban'[Miền])
			VAR _mienTarget = IF(_mien = "Miền Nam", 0.85, 0.82)
			VAR _condition  = IF([Run-rate] = 1, _today, _today)
			
			VAR _minDate = CALCULATE(MIN('DIM_Danh mục_Ngày'[Date]))
			
			-- Tạo bảng shop
			VAR _tblShop = 
			    ADDCOLUMNS(
			        FILTER(
			            SUMMARIZECOLUMNS(
			                'DIM_Danh mục_Ngày'[Date],
			                'DIM_Danh mục_Phòng ban'[am],
			                'DIM_Danh mục_Phòng ban'[Bộ phận],
			                "target", [Store_Evaluation]
			            ),
			            'DIM_Danh mục_Ngày'[Date] >= _minDate - 30
			        ),
			        "notAchieved", IF([target] = "Không đạt", 1, 0)
			    )
			
			-- Tạo bảng AM
			VAR _tblAM = 
			    ADDCOLUMNS(
			        FILTER(
			            SUMMARIZECOLUMNS(
			                'DIM_Danh mục_Ngày'[Date],
			                'DIM_Danh mục_Phòng ban'[am],
			                "target", DIVIDE([Store_Conversion by Opportunities], _mienTarget)
			            ),
			            'DIM_Danh mục_Ngày'[Date] >= _minDate - 30
			        ),
			        "notAchieved", IF([target] < 1, 1, 0)
			    )
			
			-- Tìm ngày gần nhất đạt target
			VAR _lastAchievedShop = CALCULATE(
			    MAX('DIM_Danh mục_Ngày'[Date]),
			    FILTER(_tblShop, [notAchieved] = 0 && 'DIM_Danh mục_Ngày'[Date] <= _today)
			)
			
			VAR _lastAchievedAM = CALCULATE(
			    MAX('DIM_Danh mục_Ngày'[Date]),
			    FILTER(_tblAM, [notAchieved] = 0 && 'DIM_Danh mục_Ngày'[Date] <= _today)
			)
			
			-- Dựa trên loại đánh giá: AM hay shop
			VAR _lastAchieved = 
			    IF(SELECTEDVALUE(Parameter_OP[Parameter_OP Order]) <= 1, _lastAchievedAM, _lastAchievedShop)
			
			-- Nếu không có ngày nào đạt → dùng đầu tháng -1
			VAR _fallbackDate = IF(ISBLANK(_lastAchieved), _startMonth - 1, _lastAchieved)
			
			-- Tính số ngày liên tiếp không đạt
			VAR _result = DATEDIFF(_fallbackDate, _condition, DAY)
			
			RETURN _result
			
			```
		formatString: 0
		lineageTag: bf6924f2-ed68-4d1a-897c-2b4f4abbd59e

