	measure 'Format_PLX - Theo dõi CR' = ```
			
			VAR _condition =
			    SELECTEDVALUE ( 'DIM_Danh mục_Báo cáo'[Date] )
			
			VAR _date_filter =
			    SELECTEDVALUE ( 'DIM_Danh mục_Báo cáo'[Date_Real] )
			
			VAR _mien =
			    SELECTEDVALUE ( 'DIM_Danh mục_Phòng ban'[Miền] )
			
			VAR _target =
			    IF (
			        SELECTEDVALUE ( Parameter_OP[Parameter_OP Order] ) <= 1,
			        IF ( _mien = "Miền Nam", 0.85, 0.82 ),
			        [Store_Target_CR]
			    )
			
			VAR _cr_plx_month =
			    CALCULATE (
			        [Store_Conversion by Opportunities_plx],
			        REMOVEFILTERS ( 'DIM_Danh mục_Ngày'[Date] )
			    )
			
			VAR _cr_plx_day =
			    CALCULATE (
			        [Store_Conversion by Opportunities_plx],
			        REMOVEFILTERS ( 'DIM_Danh mục_Ngày'[Date] ),
			        TREATAS ( { _date_filter }, 'DIM_Danh mục_Ngày'[Date] )
			    )
			
			RETURN
			    SWITCH (
			        TRUE (),
			
			        _condition IN { "CR Tháng", "CR tháng" }
			            && _cr_plx_month >= _target,
			            "#b7e1cd",
			
			        _condition IN { "CR Tháng", "CR tháng" }
			            && _cr_plx_month < _target,
			            "#f4cccc",
			
			        NOT ISBLANK ( _date_filter )
			            && _cr_plx_day >= _target,
			            "#b7e1cd",
			
			        NOT ISBLANK ( _date_filter )
			            && _cr_plx_day < _target,
			            "#f4cccc",
			
			        BLANK ()
			    )
			
			```
