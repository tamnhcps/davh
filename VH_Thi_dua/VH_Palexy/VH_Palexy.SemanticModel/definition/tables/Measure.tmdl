table Measure
	lineageTag: f4c1ec4f-73cb-4609-93bb-e16623a957b0

	measure 'Store_Total visit' =
			
			CALCULATE (
			    SUM ( FACT_Palexy_Store[visits] ),
			    ALL ( 'DIM_Danh mục_Section'[section_metadata_value_label] )
			)
		formatString: #,0
		displayFolder: Store\Traffic
		lineageTag: 9b7d7057-069b-4b07-af43-cb7bcb8ab054

		changedProperty = FormatString

	measure 'Store_Avg dwell time' =
			
			VAR _x =
			    SUM ( FACT_Palexy_Store[visit * avg dwell time] )
			VAR _visit = [Store_Total visit]
			VAR _z =
			    DIVIDE (
			        _x,
			        _visit,
			        BLANK ()
			    )
			RETURN
			    IF (
			        _z > 0,
			        TIME ( 0, 0, _z ),
			        BLANK ()
			    )
		formatString: hh:nn:ss
		displayFolder: Store\Traffic
		lineageTag: effafdea-baee-4c2c-858d-06849144c386

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	measure 'Store_Conversion rate' =
			
			DIVIDE (
			    [Store_Sales transaction],
			    [Store_Total visit],
			    BLANK ()
			)
		formatString: #,0.00%;-#,0.00%;#,0.00%
		displayFolder: Store\Sale
		lineageTag: 8714e0a8-a84f-47c0-a624-6be2741a1c12

		changedProperty = FormatString

	measure 'Store_Sale per visitor' =
			
