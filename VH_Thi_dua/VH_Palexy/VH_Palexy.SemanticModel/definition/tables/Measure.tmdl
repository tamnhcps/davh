	measure Store_Selection =
			
			VAR x_select =
			    SELECTEDVALUE ( 'DIM_Store_Measure selection'[Measure] )
			RETURN
			    SWITCH (
			        TRUE (),
			        x_select = "Total Visits", [Store_Total visit],
			        x_select = "Average dwell time (s)", [Store_Avg dwell time for visual],
			        x_select = "Average visitor per day", [Store_Avg visitors per store per day],
			        x_select = "Conversion Rate", [Store_Conversion rate],
			        x_select = "Sales per Visitor", [Store_Sale per visitor],
			        x_select = "Net Sales", [Store_Sales amount],
			        x_select = "Transaction", [Store_Sales transaction],
			        x_select = "ATV - Average Transaction Value", [Store_ATV (Average Transaction Value)],
			        x_select = "UPT - Units Per Transaction", [Store_UPT (Units Per Transaction)],
			        x_select = "ASP - Average Selling Price", [Store_ASP (Average Selling Price)],
			        x_select = "Interaction Rate", [Store_Interaction rate],
			        x_select = "Total Staff Hours", "",
			        x_select = "AVG Visitors per Staff", "",
			        x_select = "MAX Visitors per Staff", "",
			        x_select = "Sales per Staff Hour", "",
			        x_select = "Greeting Rate", [Store_Greeting rate],
			        x_select = "Avg Time to First Greeting", [Store_Avg Time To First Greeting],
			        x_select = "On Time Greeting Rate", [Store_On Time Greeting rate],
			        x_select = "Total Groups", [Store_Total group],
			        x_select = "Group Rate", [Store_Group rate],
			        x_select = "Avg Group Size", [Store_Avg group size],
			        x_select = "Total Groups With Kids", [Store_Total group with kids],
			        x_select = "Groups With Kids Rate", [Store_Group with kids rate],
			        x_select = "Total Opportunities", [Store_Total opportunities],
			        x_select = "Conversion by Opportunities", [Store_Conversion by Opportunities],
			        ""
			    )
		formatString: #,0.00
		displayFolder: Store\Selection
		lineageTag: 27693fc5-dd04-42ea-a4e8-26c672c9b630

	measure Date_Day =
			
			CALCULATE (
			    COUNTROWS ( 'DIM_Danh mục_Ngày' ),
			    FILTER (
			        'DIM_Danh mục_Ngày',
			        'DIM_Danh mục_Ngày'[Ngày_isActive] = 1
			    )
			)
		formatString: 0
		displayFolder: Date
		lineageTag: e102c418-8e00-431b-ab25-e5f51dfb469c

		changedProperty = FormatString

	measure 'Store_Avg visitors per store per day' =
			
			DIVIDE (
			    [Store_Total visit] / [Store_Qty store],
			    [Date_Day],
			    BLANK ()
			)
		formatString: #,0
		displayFolder: Store\Traffic
		lineageTag: b1f74280-4b69-4d9f-b363-551d09a52e74

