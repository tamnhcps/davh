		formatString: #,0
		displayFolder: Store\Sale
		lineageTag: be88c735-ef2c-4261-be78-7525c39f4ef4

	measure Store_Target_CR =
			
			AVERAGE ( Target_CR[Target_CR] )
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Store\Sale
		lineageTag: f06207c2-4383-4ccb-a965-b4aae2e06652

	measure Store_Evaluation = IF(ISBLANK([Store_Target_CR]), BLANK(), IF(DIVIDE([Store_Conversion by Opportunities], [Store_Target_CR], 0) > 1, "Đạt", "Không đạt"))
		displayFolder: Store\Sale
		lineageTag: 3379ffa5-1fed-4468-b3f3-bab6ba96abfb

	measure 'Store_Total visit_SOTH' = SUM ( FACT_Palexy_Store[visit_SO_TH] )
		formatString: #,0
		displayFolder: Store\Traffic
		lineageTag: 658c8cfa-adff-4056-9644-d74353b710e8

	measure 'Store_Total visit final' =
			
			[Store_Total visit] - [Store_Total visit_SOTH] - [Store_Total visit_asp]
		formatString: #,0
		displayFolder: Store\Traffic
		lineageTag: 828f5681-b5c8-4fa0-ba2c-2d6e9843b4d4

	measure 'Store_Conversion rate final' =
			
			DIVIDE (
			    [Store_Sales transaction],
			    [Store_Total visit final],
