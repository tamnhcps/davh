	measure 'Section_AvgDwellTime for visual' =
			
			VAR _x =
			    SUM ( FACT_Palexy_Section[visit * avg dwell time] )
			VAR _visit = [Section_Visits]
			VAR _z =
			    DIVIDE (
			        _x,
			        _visit,
			        BLANK ()
