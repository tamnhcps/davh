	partition 'DIM_Danh mục_Báo cáo' = calculated
		mode: import
		source = ```
				
				UNION(
				    SUMMARIZE(
				        'DIM_Danh mục_Ngày',
				        'DIM_Danh mục_Ngày'[Date],
				        'DIM_Danh mục_Ngày'[Index],
				        'DIM_Danh mục_Ngày'[yearMonth]
				    ),
				    CROSSJOIN(
				    DATATABLE(
				        "Metric",STRING,
				        "Index", INTEGER, 
				        {{"CR Tháng",1},{"Số ngày không đạt liên tiếp",2},{"Traffic Tháng",3}}
				    ),
				    DISTINCT('DIM_Danh mục_Ngày'[yearMonth])
				    )
				)
				```

