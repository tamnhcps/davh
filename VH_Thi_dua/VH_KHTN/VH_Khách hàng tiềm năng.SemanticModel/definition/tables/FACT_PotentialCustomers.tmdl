	column StoreCode =
			
			// CALCULATE(FIRSTNONBLANK(DIM_BQ_Store[ma_kho], TRUE()), FILTER(DIM_BQ_Store, DIM_BQ_Store[cua_hang] = EARLIER(FACT_PotentialCustomers[BranchName]) && DIM_BQ_Store[phan_loai_kho] = "Kho cửa hàng"))
			VAR minindex_kho =
			    CALCULATE (
			        MIN ( DIM_BQ_Store[Index] ),
			        FILTER (
			            DIM_BQ_Store,
			            DIM_BQ_Store[ten_kho] = EARLIER ( FACT_PotentialCustomers[BranchName] )
			            && DIM_BQ_Store[is_inactive] = FALSE()
			        )
			    )
			VAR minindex_cuahang =
			    CALCULATE (
			        MIN ( DIM_BQ_Store[Index] ),
			        FILTER (
			            DIM_BQ_Store,
			            DIM_BQ_Store[cua_hang] = EARLIER ( FACT_PotentialCustomers[BranchName] )
			            && DIM_BQ_Store[is_inactive] = FALSE()
			        )
			    )
			VAR minindex =
			    IF ( minindex_cuahang <> BLANK (), minindex_cuahang, minindex_kho )
			RETURN
			    LOOKUPVALUE ( DIM_BQ_Store[ma_kho], DIM_BQ_Store[Index], minindex )
		lineageTag: b22db211-745f-4eea-a24c-729e79886157
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column SĐT = SUBSTITUTE(FACT_PotentialCustomers[Phone], LEFT(FACT_PotentialCustomers[Phone], LEN(FACT_PotentialCustomers[Phone])-4), REPT("*", LEN(FACT_PotentialCustomers[Phone])-4))
		lineageTag: 6d93db0e-0182-413d-9276-edb92bbdcee1
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

