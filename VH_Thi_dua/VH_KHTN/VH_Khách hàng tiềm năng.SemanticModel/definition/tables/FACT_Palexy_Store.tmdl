		annotation SummarizationSetBy = Automatic

	column Target_daily = ```
			
			VAR visit_miss = 
			    IF( (1-FACT_Palexy_Store[net_sales_transactions]/(FACT_Palexy_Store[total_opportunities]-FACT_Palexy_Store[visit_asp]-FACT_Palexy_Store[visit_SO_TH]-FACT_Palexy_Store[visit_thecao])) <= 0, 0.1, 1-FACT_Palexy_Store[transaction_by_phone]/(FACT_Palexy_Store[total_opportunities]-FACT_Palexy_Store[visit_asp]-FACT_Palexy_Store[visit_SO_TH]-FACT_Palexy_Store[visit_thecao])) 
			VAR 
			    target = LOOKUPVALUE(FACT_Target[Target],FACT_Target[Month],FACT_Palexy_Store[month],FACT_Target[Miền],FACT_Palexy_Store[region])
			RETURN 
			    IFERROR(ROUND((FACT_Palexy_Store[total_opportunities]-FACT_Palexy_Store[visit_asp]-FACT_Palexy_Store[visit_SO_TH]-FACT_Palexy_Store[visit_thecao])*visit_miss*target, 0), BLANK())
			```
		lineageTag: a34ae228-5aa2-4144-aaca-b47cc7e5feef
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column visit_asp = CALCULATE(SUM(FACT_Palexy_Section[visits]),FILTER(FACT_Palexy_Section, (FACT_Palexy_Section[section_metadata_value_id] = 4519 || (FACT_Palexy_Section[section_metadata_value_id] = 8933 && FACT_Palexy_Section[region] = "Bắc"))  && FACT_Palexy_Section[store_name] = EARLIER(FACT_Palexy_Store[store_name]) && FACT_Palexy_Section[day] = EARLIER(FACT_Palexy_Store[day])))
		formatString: 0
		lineageTag: 673662b4-121a-4477-af81-ce7b9f0a0d02
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column transaction_by_phone
		dataType: double
		formatString: 0
		lineageTag: 3d5cbed7-1537-43be-aedd-de0964bf4261
		summarizeBy: sum
		sourceColumn: transaction_by_phone

		annotation SummarizationSetBy = Automatic

	column visit_SO_TH = CALCULATE(COUNT(FACT_SO_Thuho[AutoCode]),FILTER(FACT_SO_Thuho, FACT_SO_Thuho[Shop] = EARLIER(FACT_Palexy_Store[store_name]) && FACT_SO_Thuho[Date] = EARLIER(FACT_Palexy_Store[day])))
		formatString: 0
		lineageTag: 02c2255c-1662-4dbd-b93f-51fcaffbde1a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column visit_thecao = CALCULATE(SUM(FACT_TheCao[Transaction_Visit]),FILTER(FACT_TheCao, FACT_TheCao[StoreCode] = EARLIER(FACT_Palexy_Store[store_code]) && FACT_TheCao[Date] = EARLIER(FACT_Palexy_Store[day])))
		formatString: 0
		lineageTag: af9b5edd-5eb4-4bf5-a8c8-123224d8aeae
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

