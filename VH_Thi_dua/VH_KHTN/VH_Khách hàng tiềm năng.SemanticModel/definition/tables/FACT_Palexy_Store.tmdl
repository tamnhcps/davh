	column slg_pre
		dataType: double
		lineageTag: 6df073eb-26ca-4167-84b5-5ba57eee17e7
		summarizeBy: sum
		sourceColumn: slg_pre

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'total opportunities' = (FACT_Palexy_Store[total_opportunities]-FACT_Palexy_Store[visit_asp]-FACT_Palexy_Store[visit_SO_TH]-FACT_Palexy_Store[visit_thecao])
		lineageTag: d983c742-2402-49b5-8dce-005f908aae99
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column visit_loai_tru = ```
			
			CALCULATE(
			    SUM('Loại trừ CR'[Loại trừ]),
			    FILTER('Loại trừ CR', 
			        'Loại trừ CR'[Cửa hàng] = EARLIER(FACT_Palexy_Store[store_name]) 
			        && 'Loại trừ CR'[Ngày] = EARLIER(FACT_Palexy_Store[day]) 
			))
			```
		lineageTag: d012b34b-60c8-4728-9686-89533cc036fa
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition FACT_Palexy_Store = m
		mode: import
		queryGroup: FACT
		source = ```
				let
				    Source = Value.NativeQuery(GoogleBigQuery.Database([BillingProject="cellphones-data-platform"]){[Name="cellphones-data-platform"]}[Data], "---""dataset_id=2a26bbe0-48fb-47c2-99bf-d69f107e535c""#(lf)WITH CTE_NormalPhone AS(#(lf)SELECT#(lf)  StoreCode,#(lf)  Date, #(lf)  COUNT(DISTINCT ContactPhone) AS NoPhones  #(lf)FROM#(lf)  `cellphones-data-platform.cps_sales_datamart.cps_cdc_sep_union_dbo_sales_transaction`#(lf)WHERE#(lf)  IsSales = 1#(lf)  AND IsB2B = 0#(lf)  AND NOT MethodID IN (15, 56, 58, 59) #(lf)  AND DATE(CreateDate) BETWEEN '2024-01-01' AND '2024-07-01'#(lf)  AND NOT REGEXP_CONTAINS(ContactPhone, '[A-Za-z]')#(lf)  AND NOT (DMC3 = 'SIMTHE' AND DATE(CreateDate) >= '2024-06-01')#(lf)  AND AutoCode LIKE 'SP%'#(lf)GROUP BY 1, 2),#(lf)CTE_KhachLe AS(#(lf)SELECT#(lf)  StoreCode,#(lf)  Date, #(lf)  COUNT(ContactPhone) AS NoPhones  #(lf)FROM#(lf)  `cellphones-data-platform.cps_sales_datamart.cps_cdc_sep_union_dbo_sales_transaction`#(lf)WHERE#(lf)  IsSales = 1#(lf)  AND IsB2B = 0#(lf)  AND NOT MethodID IN (15, 56, 58, 59)#(lf)  AND DATE(CreateDate) BETWEEN '2024-01-01' AND '2024-07-01'#(lf)  AND REGEXP_CONTAINS(ContactPhone, '[A-Za-z]')#(lf)  AND NOT (DMC3 = 'SIMTHE' AND DATE(CreateDate) >= '2024-06-01')#(lf)  AND AutoCode LIKE 'SP%'#(lf)GROUP BY 1, 2)#(lf)#(lf), pre_order_camp17 as (#(lf)  SELECT #(lf)  StoreCode,#(lf)  Date,#(lf)  COUNT(DISTINCT ContactPhone) AS slg_pre#(lf)FROM `cellphones-data-platform.cps_sales_datamart.cps_cdc_sep_union_dbo_online_sales_transaction` #(lf)WHERE 1=1#(lf)  AND Date(CreatedDate) between '2025-09-12' and '2025-09-18'#(lf)  AND MethodId in (14, 57)#(lf)  AND OnlineNo IS NULL#(lf)  AND NOT OrderState in (""Hủy đơn"", ""Lưu thông tin"")#(lf)  AND (StatusPaymentId IS NULL OR StatusPaymentId = 2)#(lf)  AND ProductGroupName = 'IPHONE CTM'#(lf)  AND (ProductName LIKE 'APPLE IPHONE 17%' OR ProductName LIKE 'APPLE IPHONE AIR%')#(lf)GROUP BY 1, 2#(lf))#(lf)#(lf)Select p.*EXCEPT(region), case when p.region = 'Nam' then 'Miền Nam' when p.region = 'Bắc' then 'Miền Bắc' else null end as region, COALESCE(s.NoPhones, p.net_sales_transactions) as transaction_by_phone, pre.slg_pre#(lf)from `cellphones-data-platform.cps_mkt_source_dwh.palexy_store_report` p #(lf)left join pre_order_camp17 pre on p.store_code = pre.StoreCode and p.day = pre.Date#(lf)left join (#(lf)SELECT#(lf)  StoreCode,#(lf)  Date, #(lf)  SUM(NoPhones) AS NoPhones#(lf)FROM (SELECT * FROM CTE_NormalPhone UNION ALL SELECT * FROM CTE_KhachLe) phone#(lf)GROUP BY 1, 2) s on p.store_code = s.StoreCode and p.day = s.Date#(lf)WHERE #(lf)  (p.day >= '2024-01-01' AND p.visits > 0 AND p.day <> '2025-02-01') #(lf)  AND NOT (store_code = 'HCM.139TN' AND p.day > '2025-02-14' AND p.day < '2025-02-25')#(lf)  AND NOT (store_code = 'HCM.193TL8' AND p.day > '2025-07-26' AND p.day < '2025-07-31')", null, [EnableFolding=true]),
				    #"Replaced Value3" = Table.ReplaceValue(Source,null,0,Replacer.ReplaceValue,{"slg_pre"}),
				    #"Renamed Columns" = Table.RenameColumns(#"Replaced Value3",{{"total_opportunities", "total_opportunities_new"}}),
				    #"Replaced Value" = Table.ReplaceValue(#"Renamed Columns","CPS-HNO-CGI-306CG","CPS-HNO-CGI-310CG",Replacer.ReplaceText,{"store_name"}),
				    #"Replaced Value1" = Table.ReplaceValue(#"Replaced Value","HN.384XD","HN.360XD",Replacer.ReplaceText,{"store_code"}),
				    #"Replaced Value2" = Table.ReplaceValue(#"Replaced Value1","CPS-HNO-DDA-384XD","CPS-HNO-DDA-360XD",Replacer.ReplaceText,{"store_name"}),
				    #"Added Custom" = Table.AddColumn(
				    #"Replaced Value1",
				    "total_opportunities",
				    each
				        if [store_code] = "HN.51DCV" and [day] = #date(2025, 10, 15) then 111
				        else
				            (
				                if [conversion_by_opportunities] <> 0 then
				                    Number.Round([net_sales_transactions] / [conversion_by_opportunities], 0)
				                else
				                    0) * (
				                if
				                    ([day] >= #date(2025, 4, 7) and [day] < #date(2025, 8, 1))
				                    or ([day] >= #date(2025, 9, 19) and [day] <= #date(2025, 10, 14))
				                    or ([day] >= #date(2025, 10, 15) and [day] <= #date(2025, 11, 11) and [region] = "Miền Nam")
				                then
				                    if [tier] = "A" or [tier] = "B" then 0.93 else 0.95
				                else if
				                    ([day] >= #date(2025, 8, 1) and [day] < #date(2025, 9, 1))
				                    or ([day] >= #date(2025, 10, 15) and [region] = "Miền Bắc")
				                then
				                    0.97
				                else if
				                    ([day] >= #date(2025, 11, 12) and [day] < #date(2026, 1, 5) and [region] = "Miền Nam")
				                then
				                    if [tier] = "A" or [tier] = "B" then 0.95 else 0.97
				                else if
				                    ([day] >= #date(2026, 1, 5) and [region] = "Miền Nam")
				                then 
				                    0.97
				                else
				                    1
				            )
				            - [slg_pre]
				),
				    #"Changed Type" = Table.TransformColumnTypes(#"Added Custom",{{"total_opportunities", type number}})
				in
				    #"Changed Type"
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

